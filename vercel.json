{
  "trailingSlash": true,
  "routes": [
    {
      "src": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.granadaurban.com"
        }
      ],
      "status": 308,
      "headers": {
        "Location": "https://granadaurban.com/$1"
      }
    },
    {
      "src": "/eventos/conciertos-granada/?",
      "status": 308,
      "headers": {
        "Location": "/eventos/conciertos/"
      }
    },
    {
      "src": "/en/events/granada-concerts/?",
      "status": 308,
      "headers": {
        "Location": "/en/events/concerts/"
      }
    },
    {
      "src": "/artistas(?:/(.*))?",
      "status": 410,
      "headers": {
        "X-Robots-Tag": "noindex, follow"
      }
    },
    {
      "src": "/en/artists(?:/(.*))?",
      "status": 410,
      "headers": {
        "X-Robots-Tag": "noindex, follow"
      }
    },
    {
      "src": "/(eventos|en/events|rutas|en/routes|guias|en/guides)/?",
      "has": [
        {
          "type": "query",
          "key": "category"
        }
      ],
      "status": 308,
      "headers": {
        "Location": "/$1/"
      }
    },
    {
      "src": "/(eventos|en/events|rutas|en/routes|guias|en/guides)/?",
      "has": [
        {
          "type": "query",
          "key": "neighborhood"
        }
      ],
      "status": 308,
      "headers": {
        "Location": "/$1/"
      }
    },
    {
      "src": "/(eventos|en/events|rutas|en/routes|guias|en/guides)/?",
      "has": [
        {
          "type": "query",
          "key": "type"
        }
      ],
      "status": 308,
      "headers": {
        "Location": "/$1/"
      }
    },
    {
      "src": "/(eventos|en/events|rutas|en/routes|guias|en/guides)/?",
      "has": [
        {
          "type": "query",
          "key": "difficulty"
        }
      ],
      "status": 308,
      "headers": {
        "Location": "/$1/"
      }
    },
    {
      "src": "/(eventos|en/events|rutas|en/routes|guias|en/guides)/?",
      "has": [
        {
          "type": "query",
          "key": "duration"
        }
      ],
      "status": 308,
      "headers": {
        "Location": "/$1/"
      }
    },
    {
      "src": "/(eventos|en/events|rutas|en/routes|guias|en/guides)/?",
      "has": [
        {
          "type": "query",
          "key": "timeofday"
        }
      ],
      "status": 308,
      "headers": {
        "Location": "/$1/"
      }
    },
    {
      "src": "/(eventos|en/events|rutas|en/routes|guias|en/guides)/?",
      "has": [
        {
          "type": "query",
          "key": "date"
        }
      ],
      "status": 308,
      "headers": {
        "Location": "/$1/"
      }
    },
    {
      "src": "/(eventos|en/events|rutas|en/routes|guias|en/guides)/?",
      "has": [
        {
          "type": "query",
          "key": "price"
        }
      ],
      "status": 308,
      "headers": {
        "Location": "/$1/"
      }
    },
    {
      "src": "/(eventos|en/events|rutas|en/routes|guias|en/guides)/?",
      "has": [
        {
          "type": "query",
          "key": "q"
        }
      ],
      "status": 308,
      "headers": {
        "Location": "/$1/"
      }
    },
    {
      "src": "/_granada-assets/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "continue": true
    },
    {
      "src": "/(.*)\\.(?:avif|webp|jpg|jpeg|png|svg|ico|mp4|webm|woff2?)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "continue": true
    },
    {
      "src": "/ai/(.*)",
      "headers": {
        "X-Robots-Tag": "noindex, follow"
      },
      "continue": true
    },
    {
      "src": "/(.*)",
      "headers": {
        "Strict-Transport-Security": "max-age=63072000; includeSubDomains; preload",
        "X-Content-Type-Options": "nosniff",
        "Referrer-Policy": "strict-origin-when-cross-origin"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    }
  ]
}

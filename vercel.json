{
  "trailingSlash": true,
  "routes": [
    {
      "src": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.granadaurban.com"
        }
      ],
      "status": 308,
      "headers": {
        "Location": "https://granadaurban.com/$1"
      }
    },
    {
      "handle": "filesystem"
    }
  ]
}

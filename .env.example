EVENTBRITE_API_KEY=your_key_here

# Google Analytics 4
# Conseguir en: Analytics > Administrar > Flujos de datos > Web > ID de medición
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

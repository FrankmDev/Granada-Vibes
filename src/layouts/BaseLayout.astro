---
import type { Locale } from '@types';
import { SITE_CONFIG } from '@config/site';
import SEOHead from '@components/seo/SEOHead.astro';
import SchemaMarkup from '@components/seo/SchemaMarkup.astro';
import NavBar from '@components/layout/NavBar.astro';
import Footer from '@components/layout/Footer.astro';
import '../styles/global.css';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  canonical?: string;
  noindex?: boolean;
  schemaType?: 'website' | 'event' | 'route' | 'organization';
  schemaData?: Record<string, unknown>;
}

const {
  locale,
  title,
  description,
  ogImage,
  ogType,
  canonical,
  noindex,
  schemaType = 'website',
  schemaData,
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <script>if (history.scrollRestoration) history.scrollRestoration = 'manual';</script>

    <!-- SEO -->
    <SEOHead
      locale={locale}
      title={title ?? SITE_CONFIG.name}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      canonical={canonical}
      noindex={noindex}
    />

    <!-- Schema Markup -->
    <SchemaMarkup
      type={schemaType}
      locale={locale}
      data={schemaData}
      path={currentPath}
    />

    <!-- Fonts loaded via @fontsource in global.css (DM Sans + Fraunces) -->

    <!-- Resource Hints for Performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://images.unsplash.com" />
    <link rel="preconnect" href="https://images.unsplash.com" crossorigin />

    <!-- Preload Critical Fonts -->
    <link rel="preload" href="https://fonts.gstatic.com/s/dmsans/v15/rP2Yp2ywxg089UriI5-g4vlH9VoD8CmcqZG40F9JadbnoEwAopxRSW3zE_KB.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="https://fonts.gstatic.com/s/fraunces/v31/6NUh8FyLNQOQZAnv9bYEvDiIdE9Ea92uemAk_WBq8U_9v0c2Wa0K7iN7hzFUPJH58nib14c7qv8o.woff2" as="font" type="font/woff2" crossorigin />

    <slot name="head" />
  </head>

  <body class="min-h-screen flex flex-col bg-bg text-text-primary antialiased">
    <!-- Header: override via <Fragment slot="header"> -->
    <slot name="header">
      <NavBar locale={locale} currentPath={currentPath} />
    </slot>

    <!-- Main Content -->
    <main id="main-content" class="flex-1" role="main">
      <slot />
    </main>

    <!-- Footer: override via <Fragment slot="footer"> -->
    <slot name="footer">
      <Footer locale={locale} />
    </slot>

    <!-- Scroll reveal animation -->
    <script is:inline>
      (function () {
        if (!('IntersectionObserver' in window)) return;

        /* Generic scroll-animate elements */
        const revealObserver = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                revealObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
        );

        document.querySelectorAll('.scroll-animate').forEach(function (el) {
          revealObserver.observe(el);
        });

        /* Section-level in-view — adds .in-view to section when header enters viewport.
           Home section animations are paused until the section is in view. */
        var sectionObserver = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
                sectionObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.05, rootMargin: '0px 0px -80px 0px' }
        );

        document.querySelectorAll('.editorial-section, .seasonal, .routes-section, .cta-hero').forEach(function (el) {
          sectionObserver.observe(el);
        });
      })();
    </script>

    <!-- View Transitions support -->
    <script is:inline>
      // Check for reduced motion preference
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      
      if (!prefersReducedMotion) {
        // Add page load animation class
        document.addEventListener('DOMContentLoaded', () => {
          document.body.classList.add('page-loaded');
        });
      }
    </script>
  </body>
</html>

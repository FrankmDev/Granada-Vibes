---
import type { Locale } from '@types';
import { SITE_CONFIG } from '@config/site';
import SEOHead from '@components/seo/SEOHead.astro';
import SchemaMarkup from '@components/seo/SchemaMarkup.astro';
import NavBar from '@components/layout/NavBar.astro';
import Footer from '@components/layout/Footer.astro';
import '../styles/global.css';

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'article';
  canonical?: string;
  noindex?: boolean;
  schemaType?: 'website' | 'event' | 'route' | 'timePlan' | 'organization' | 'article';
  schemaData?: Record<string, unknown>;
  breadcrumb?: BreadcrumbItem[];
  faq?: FaqItem[];
  googleSiteVerification?: string;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleAuthor?: string;
  articleSection?: string;
  articleTags?: string[];
}

const {
  locale,
  title,
  description,
  ogImage,
  ogImageAlt,
  ogType,
  canonical,
  noindex,
  schemaType = 'website',
  schemaData,
  breadcrumb,
  faq,
  googleSiteVerification,
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor,
  articleSection,
  articleTags,
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start': new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0], j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src= 'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f); })(window,document,'script','dataLayer','GTM-NX8FRP5B');</script>
    <!-- End Google Tag Manager -->

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="msvalidate.01" content="6A19FE7E273FC514F82832219D058DDF" />

    {/* Resource hints — preconnect to critical third-party origins */}
    <link rel="preconnect" href="https://images.unsplash.com" />
    <link rel="dns-prefetch" href="https://images.unsplash.com" />
    <link rel="preconnect" href="https://upload.wikimedia.org" />
    <link rel="dns-prefetch" href="https://upload.wikimedia.org" />
    <link rel="preconnect" href="https://api.open-meteo.com" />
    <link rel="dns-prefetch" href="https://api.open-meteo.com" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    <script>if (history.scrollRestoration) history.scrollRestoration = 'manual';</script>

    <!-- SEO -->
    <SEOHead
      locale={locale}
      title={title ?? SITE_CONFIG.name}
      description={description}
      ogImage={ogImage}
      ogImageAlt={ogImageAlt}
      ogType={ogType}
      canonical={canonical}
      noindex={noindex}
      googleSiteVerification={googleSiteVerification}
      articlePublishedTime={articlePublishedTime}
      articleModifiedTime={articleModifiedTime}
      articleAuthor={articleAuthor}
      articleSection={articleSection}
      articleTags={articleTags}
    />

    <!-- Schema Markup -->
    <SchemaMarkup
      type={schemaType}
      locale={locale}
      data={schemaData}
      path={currentPath}
      breadcrumb={breadcrumb}
      faq={faq}
    />

    <!-- Fonts loaded via @fontsource in global.css (DM Sans + Fraunces) -->

    <slot name="head" />

    <!-- Force www subdomain -->
    <script is:inline>
      (function () {
        var host = window.location.hostname;
        if (host === 'granadaurban.com') {
          window.location.replace(
            window.location.href.replace('//granadaurban.com', '//www.granadaurban.com')
          );
        }
      })();
    </script>
  </head>

  <body class="min-h-screen flex flex-col bg-bg text-text-primary antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NX8FRP5B" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <a href="#main-content" class="skip-link">Skip to main content</a>

    <!-- Header: override via <Fragment slot="header"> -->
    <slot name="header">
      <NavBar locale={locale} currentPath={currentPath} />
    </slot>

    <!-- Main Content -->
    <main id="main-content" class="flex-1" role="main">
      <slot />
    </main>

    <!-- Footer: override via <Fragment slot="footer"> -->
    <slot name="footer">
      <Footer locale={locale} />
    </slot>

    <!-- Scroll reveal animation -->
    <script is:inline>
      (function () {
        if (!('IntersectionObserver' in window)) return;

        /* Generic scroll-animate elements */
        const revealObserver = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                revealObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
        );

        document.querySelectorAll('.scroll-animate, [data-reveal]').forEach(function (el) {
          revealObserver.observe(el);
        });

        /* Section-level in-view — adds .in-view to section when header enters viewport.
           Home section animations are paused until the section is in view. */
        var sectionObserver = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
                sectionObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.05, rootMargin: '0px 0px -80px 0px' }
        );

        document.querySelectorAll('.editorial-section, .seasonal, .routes-section, .journal-section, .cta-hero').forEach(function (el) {
          sectionObserver.observe(el);
        });
      })();
    </script>

    <!-- View Transitions support -->
    <script is:inline>
      // Check for reduced motion preference
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!prefersReducedMotion) {
        // Add page load animation class
        document.addEventListener('DOMContentLoaded', () => {
          document.body.classList.add('page-loaded');
        });
      }
    </script>
  </body>
</html>

---
import DirectoryDetailPage from '@components/pages/DirectoryDetailPage.astro';
import { getIndexableVenueEntries } from '@data/index.js';

export const getStaticPaths = () =>
  getIndexableVenueEntries().map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));

const { entry } = Astro.props;
---

<DirectoryDetailPage locale="es" entry={entry} />

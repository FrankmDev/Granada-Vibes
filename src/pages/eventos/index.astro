    }

    .empty-state.hidden { display: none; }

    .empty-content {
      text-align: center;
      max-width: 400px;
      margin: 0 auto;
    }

    .empty-icon {
      position: relative;
      width: 80px;
      height: 80px;
      margin: 0 auto 1.5rem;
    }

    .empty-icon::before {
      content: '';
      position: absolute;
      inset: -10px;
      background: var(--s-orange);
      border-radius: 1.25rem;
      filter: blur(30px);
      opacity: 0.15;
    }

    .empty-icon-inner {
      position: relative;
      width: 100%;
      height: 100%;
      background: rgba(255, 255, 255, 0.8);
      border: 1px solid var(--s-border);
      border-radius: 1rem;

---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/layout/PageHeader.astro';
import EventCard from '@components/events/EventCard.astro';
import Button from '@components/ui/Button.astro';
import { getAllEvents } from '@data';
import { useTranslations } from '@i18n/utils';
import type { EventCategory, Neighborhood } from '@types';

const locale = 'es';
const t = useTranslations(locale);
const events = getAllEvents();

const categories: EventCategory[] = ['concert', 'exhibition', 'festival', 'market', 'theater', 'workshop', 'guided-tour'];
const neighborhoods: Neighborhood[] = ['albaicin', 'sacromonte', 'centro', 'realejo', 'alhambra', 'cartuja', 'ronda'];

const ogImage = 'https://placehold.co/1200x630/0a0908/c9a84c?text=Granada+Vibes+Eventos';
---

<BaseLayout 
  locale={locale} 
  title={t('events.title')}
  description="Descubre los mejores eventos culturales en Granada. Conciertos, exposiciones, festivales y más. Filtra por categoría, barrio, fecha y precio."
  ogImage={ogImage}
>
  <!-- Page Header - Luxe Edition -->
  <PageHeader 
    title={t('events.title')}
    subtitle={t('events.subtitle')}
    accent="accent"
  />

  {/* Filters Bar - Enhanced Design */}
  <div class="relative border-y border-border/50 bg-bg-raised/50 backdrop-blur-sm">
    <div class="absolute inset-0 bg-gradient-to-r from-accent/[0.02] via-transparent to-accent/[0.02]"></div>
    
    <div class="container relative py-6 lg:py-8">
      {/* Fila 1 - Chips de categoría */}
      <div class="flex flex-wrap items-center gap-2 mb-6" role="group" aria-label={t('events.filters.title')}>
        <button 
          class="filter-category px-5 py-2.5 text-xs font-semibold uppercase tracking-wider bg-accent text-white rounded-full transition-all duration-300 hover:shadow-lg hover:shadow-accent/25"
          data-category="all"
          aria-pressed="true"
        >
          {t('categories.all')}
        </button>
        {categories.map((cat) => (
          <button 
            class="filter-category px-5 py-2.5 text-xs font-semibold uppercase tracking-wider text-text-secondary bg-bg-card border border-border rounded-full hover:border-accent/50 hover:text-text-primary transition-all duration-300"
            data-category={cat}
            aria-pressed="false"
          >
            {t(`categories.${cat}`)}
          </button>
        ))}
      </div>

      {/* Fila 2 - Filtros secundarios */}
      <div class="flex flex-wrap items-center gap-4 pt-6 border-t border-border/30">
        {/* Dropdown Barrio */}
        <div class="relative group">
          <select 
            id="filter-neighborhood"
            class="appearance-none px-5 py-2.5 pr-12 text-sm text-text-primary bg-bg-card border border-border rounded-xl focus:outline-none focus:border-accent cursor-pointer transition-all duration-300 hover:border-border-hover min-w-[160px]"
            aria-label="Filtrar por barrio"
          >
            <option value="all">Todos los barrios</option>
            {neighborhoods.map((n) => (
              <option value={n}>{t(`neighborhoods.${n}`)}</option>
            ))}
          </select>
          <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-text-muted pointer-events-none transition-colors group-hover:text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>

        {/* Dropdown Cuándo */}
        <div class="relative group">
          <select 
            id="filter-date"
            class="appearance-none px-5 py-2.5 pr-12 text-sm text-text-primary bg-bg-card border border-border rounded-xl focus:outline-none focus:border-accent cursor-pointer transition-all duration-300 hover:border-border-hover min-w-[160px]"
            aria-label="Filtrar por fecha"
          >
            <option value="all">Cualquier fecha</option>
            <option value="today">Hoy</option>
            <option value="week">Esta semana</option>
            <option value="weekend">Este fin de semana</option>
            <option value="month">Este mes</option>
          </select>
          <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-text-muted pointer-events-none transition-colors group-hover:text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>

        {/* Toggle Solo gratis */}
        <label class="flex items-center gap-3 px-5 py-2.5 bg-bg-card border border-border rounded-xl cursor-pointer hover:border-accent/50 transition-all duration-300 group">
          <input 
            type="checkbox" 
            id="filter-free"
            class="w-4 h-4 rounded border-border text-accent focus:ring-accent bg-bg-card cursor-pointer"
          />
          <span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Solo gratis</span>
        </label>

        <div class="flex-1" />

        {/* Botón Limpiar filtros (hidden by default) */}
        <button 
          id="clear-filters"
          class="hidden items-center gap-2 px-5 py-2.5 text-sm text-text-muted hover:text-accent transition-all duration-300 rounded-xl hover:bg-bg-card"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
          Limpiar filtros
        </button>
      </div>
    </div>
  </div>

  {/* Results counter */}
  <div class="container py-6">
    <div class="flex items-center gap-2 text-sm text-text-muted">
      <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
      Mostrando <span id="results-count" class="font-semibold text-text-primary">{events.length}</span> eventos
    </div>
  </div>

  {/* Events Grid */}
  <section class="container pb-20" aria-labelledby="events-heading">
    <h2 id="events-heading" class="sr-only">{t('events.title')}</h2>
    
    <div id="events-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
      {events.map((event) => (
        <div 
          class="event-card-wrapper reveal"
          data-category={event.category}
          data-neighborhood={event.neighborhood}
          data-price={event.price === null ? 'free' : 'paid'}
          data-date={event.date}
        >
          <EventCard event={event} locale={locale} t={t} />
        </div>
      ))}
    </div>
    
    {/* Empty state - Enhanced */}
    <div id="empty-state" class="hidden text-center py-24">
      <div class="relative w-24 h-24 mx-auto mb-8">
        <div class="absolute inset-0 bg-accent/10 rounded-3xl blur-xl"></div>
        <div class="relative w-full h-full bg-bg-card border border-border rounded-3xl flex items-center justify-center">
          <svg class="w-12 h-12 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
      </div>
      <h3 class="font-display text-2xl font-semibold text-text-primary mb-3">
        Sin resultados para estos filtros
      </h3>
      <p class="text-text-secondary mb-8 max-w-md mx-auto">Prueba a cambiar los filtros o ver todos los eventos disponibles en Granada</p>
      <Button variant="accent" size="md" id="empty-clear-filters">
        Limpiar filtros
      </Button>
    </div>
  </section>

  <script is:inline>
    (function() {
      // Get filter elements
      const categoryButtons = document.querySelectorAll('.filter-category');
      const neighborhoodSelect = document.getElementById('filter-neighborhood');
      const dateSelect = document.getElementById('filter-date');
      const freeCheckbox = document.getElementById('filter-free');
      const clearFiltersBtn = document.getElementById('clear-filters');
      const emptyClearFiltersBtn = document.getElementById('empty-clear-filters');
      const resultsCount = document.getElementById('results-count');
      const emptyState = document.getElementById('empty-state');
      const eventsGrid = document.getElementById('events-grid');
      const eventCards = document.querySelectorAll('.event-card-wrapper');

      // Current filter state
      let filters = {
        category: 'all',
        neighborhood: 'all',
        date: 'all',
        free: false
      };

      // Helper: Check if date matches filter
      function matchesDateFilter(eventDate, filter) {
        if (filter === 'all') return true;
        
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        const event = new Date(eventDate);
        event.setHours(0, 0, 0, 0);
        
        const diffTime = event - today;
        const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
        
        switch (filter) {
          case 'today':
            return diffDays === 0;
          case 'week':
            return diffDays >= 0 && diffDays <= 7;
          case 'weekend': {
            const dayOfWeek = today.getDay();
            const daysUntilSaturday = dayOfWeek === 0 ? 6 : 6 - dayOfWeek;
            const saturday = new Date(today);
            saturday.setDate(today.getDate() + daysUntilSaturday);
            const sunday = new Date(saturday);
            sunday.setDate(saturday.getDate() + 1);
            return event >= saturday && event <= sunday;
          }
          case 'month':
            return event.getMonth() === today.getMonth() && event.getFullYear() === today.getFullYear();
          default:
            return true;
        }
      }

      // Apply filters
      function applyFilters() {
        let visibleCount = 0;
        
        eventCards.forEach(card => {
          const category = card.dataset.category;
          const neighborhood = card.dataset.neighborhood;
          const price = card.dataset.price;
          const date = card.dataset.date;
          
          const matchesCategory = filters.category === 'all' || category === filters.category;
          const matchesNeighborhood = filters.neighborhood === 'all' || neighborhood === filters.neighborhood;
          const matchesPrice = !filters.free || price === 'free';
          const matchesDate = matchesDateFilter(date, filters.date);
          
          const isVisible = matchesCategory && matchesNeighborhood && matchesPrice && matchesDate;
          
          if (isVisible) {
            card.style.display = '';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });
        
        // Update results count
        resultsCount.textContent = visibleCount;
        
        // Show/hide empty state
        if (visibleCount === 0) {
          eventsGrid.classList.add('hidden');
          emptyState.classList.remove('hidden');
        } else {
          eventsGrid.classList.remove('hidden');
          emptyState.classList.add('hidden');
        }
        
        // Show/hide clear filters button
        const hasActiveFilters = filters.category !== 'all' || 
                                 filters.neighborhood !== 'all' || 
                                 filters.date !== 'all' || 
                                 filters.free;
        
        if (hasActiveFilters) {
          clearFiltersBtn.classList.remove('hidden');
          clearFiltersBtn.classList.add('inline-flex');
        } else {
          clearFiltersBtn.classList.add('hidden');
          clearFiltersBtn.classList.remove('inline-flex');
        }
      }

      // Category buttons
      categoryButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          // Update visual state
          categoryButtons.forEach(b => {
            b.classList.remove('bg-accent', 'text-white', 'shadow-lg', 'shadow-accent/25');
            b.classList.add('text-text-secondary', 'bg-bg-card', 'border', 'border-border');
            b.setAttribute('aria-pressed', 'false');
          });
          btn.classList.remove('text-text-secondary', 'bg-bg-card', 'border', 'border-border');
          btn.classList.add('bg-accent', 'text-white', 'shadow-lg', 'shadow-accent/25');
          btn.setAttribute('aria-pressed', 'true');
          
          // Update filter state
          filters.category = btn.dataset.category;
          applyFilters();
        });
      });

      // Neighborhood select
      neighborhoodSelect?.addEventListener('change', (e) => {
        filters.neighborhood = e.target.value;
        applyFilters();
      });

      // Date select
      dateSelect?.addEventListener('change', (e) => {
        filters.date = e.target.value;
        applyFilters();
      });

      // Free checkbox
      freeCheckbox?.addEventListener('change', (e) => {
        filters.free = e.target.checked;
        applyFilters();
      });

      // Clear filters
      function clearFilters() {
        filters = {
          category: 'all',
          neighborhood: 'all',
          date: 'all',
          free: false
        };
        
        // Reset UI
        categoryButtons.forEach(b => {
          if (b.dataset.category === 'all') {
            b.classList.remove('text-text-secondary', 'bg-bg-card', 'border', 'border-border');
            b.classList.add('bg-accent', 'text-white', 'shadow-lg', 'shadow-accent/25');
            b.setAttribute('aria-pressed', 'true');
          } else {
            b.classList.remove('bg-accent', 'text-white', 'shadow-lg', 'shadow-accent/25');
            b.classList.add('text-text-secondary', 'bg-bg-card', 'border', 'border-border');
            b.setAttribute('aria-pressed', 'false');
          }
        });
        
        neighborhoodSelect.value = 'all';
        dateSelect.value = 'all';
        freeCheckbox.checked = false;
        
        applyFilters();
        
        // Scroll to top
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }

      clearFiltersBtn?.addEventListener('click', clearFilters);
      emptyClearFiltersBtn?.addEventListener('click', clearFilters);
    })();
  </script>
</BaseLayout>

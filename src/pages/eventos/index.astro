---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/layout/PageHeader.astro';
import EventCard from '@components/events/EventCard.astro';
import { getAllEvents } from '@data/index';
import { useTranslations } from '@i18n/utils';
import type { EventCategory, Neighborhood } from '@types';

const locale = 'es';
const t = useTranslations(locale);
const events = getAllEvents();

const categories: EventCategory[] = ['concert', 'exhibition', 'festival', 'market', 'theater', 'workshop', 'guided-tour', 'cinema', 'other'];
const neighborhoods: Neighborhood[] = ['albaicin', 'sacromonte', 'centro', 'realejo', 'alhambra', 'cartuja', 'zaidin', 'otro'];

const ogImage = 'https://placehold.co/1200x630/D4704A/FFFFFF?text=Granada+Vibes+Eventos';
---

<BaseLayout 
  locale={locale} 
  title={t('events.title')}
  description="Agenda cultural de Granada 2025: conciertos en el Generalife, exposiciones, festivales de flamenco, teatro y más. Descubre eventos gratis y de pago en el Albaicín, Centro y Sacromonte."
  ogImage={ogImage}
>
  <!-- Page Header -->
  <PageHeader 
    title={t('events.title')}
    subtitle={t('events.subtitle')}
    accent="primary"
  />

  {/* Filters Bar */}
  <div class="relative border-y border-white/[0.06] bg-[#0a0a0a]">
    <div class="absolute inset-0 bg-gradient-to-r from-[#E84D27]/[0.03] via-transparent to-[#E84D27]/[0.03]" aria-hidden="true"></div>
    
    <div class="container relative py-8 lg:py-10">
      {/* Fila 1 - Chips de categoría */}
      <div class="flex flex-wrap items-center gap-3 mb-6" role="group" aria-label={t('events.filters.title')}>
        <button 
          class="filter-category px-6 py-3 text-xs font-bold uppercase tracking-[0.1em] bg-[#E84D27] text-white rounded-full transition-all duration-300 hover:shadow-lg hover:shadow-[#E84D27]/20"
          data-category="all"
          aria-pressed="true"
        >
          {t('categories.all')}
        </button>
        {categories.map((cat) => (
          <button 
            class="filter-category px-6 py-3 text-xs font-bold uppercase tracking-[0.1em] text-white/70 bg-white/[0.05] border border-white/[0.08] rounded-full hover:border-[#E84D27]/30 hover:text-[#E84D27] transition-all duration-300"
            data-category={cat}
            aria-pressed="false"
          >
            {t(`categories.${cat}`)}
          </button>
        ))}
      </div>

      {/* Fila 2 - Filtros secundarios */}
      <div class="flex flex-wrap items-center gap-4 pt-6 border-t border-white/[0.06]">
        {/* Dropdown Barrio */}
        <div class="relative group">
          <select 
            id="filter-neighborhood"
            class="appearance-none px-5 py-3 pr-12 text-sm text-white bg-white/[0.05] border border-white/[0.08] rounded-xl focus:outline-none focus:border-[#E84D27] cursor-pointer transition-all duration-300 hover:border-white/[0.15] min-w-[180px]"
            aria-label="Filtrar por barrio"
          >
            <option value="all">Todos los barrios</option>
            {neighborhoods.map((n) => (
              <option value={n}>{t(`neighborhoods.${n}`)}</option>
            ))}
          </select>
          <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-white/40 pointer-events-none transition-colors group-hover:text-[#E84D27]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>

        {/* Dropdown Cuándo */}
        <div class="relative group">
          <select 
            id="filter-date"
            class="appearance-none px-5 py-3 pr-12 text-sm text-white bg-white/[0.05] border border-white/[0.08] rounded-xl focus:outline-none focus:border-[#E84D27] cursor-pointer transition-all duration-300 hover:border-white/[0.15] min-w-[180px]"
            aria-label="Filtrar por fecha"
          >
            <option value="all">Cualquier fecha</option>
            <option value="today">Hoy</option>
            <option value="week">Esta semana</option>
            <option value="weekend">Este fin de semana</option>
            <option value="month">Este mes</option>
          </select>
          <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-white/40 pointer-events-none transition-colors group-hover:text-[#E84D27]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>

        {/* Toggle Solo gratis */}
        <label class="flex items-center gap-3 px-5 py-3 bg-white/[0.05] border border-white/[0.08] rounded-xl cursor-pointer hover:border-[#E84D27]/30 transition-all duration-300 group">
          <input 
            type="checkbox" 
            id="filter-free"
            class="w-4 h-4 rounded border-white/[0.15] bg-white/[0.05] text-[#E84D27] focus:ring-[#E84D27] cursor-pointer"
          />
          <span class="text-sm text-white/50 group-hover:text-white transition-colors font-medium">Solo gratis</span>
        </label>

        <div class="flex-1"></div>

        {/* Botón Limpiar filtros */}
        <button 
          id="clear-filters"
          class="hidden items-center gap-2 px-5 py-3 text-sm text-white/50 hover:text-[#E84D27] transition-all duration-300 rounded-xl hover:bg-[#E84D27]/10 font-medium"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
          Limpiar filtros
        </button>
      </div>
    </div>
  </div>

  {/* Results counter */}
  <div class="container py-8">
    <div class="flex items-center gap-3 text-sm text-white/50">
      <span class="w-2 h-2 rounded-full bg-[#E84D27] animate-pulse"></span>
      Mostrando <span id="results-count" class="font-bold text-white">{events.length}</span> eventos
    </div>
  </div>

  {/* Events Grid */}
  <section class="container pb-24" aria-labelledby="events-heading">
    <h2 id="events-heading" class="sr-only">{t('events.title')}</h2>
    
    <div id="events-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {events.map((event) => (
        <div 
          class="event-card-wrapper scroll-animate"
          data-category={event.category}
          data-neighborhood={event.neighborhood}
          data-price={event.price === null ? 'free' : 'paid'}
          data-date={event.date}
        >
          <EventCard event={event} locale={locale} t={t} />
        </div>
      ))}
    </div>
    
    {/* Empty state */}
    <div id="empty-state" class="hidden text-center py-24">
      <div class="relative w-24 h-24 mx-auto mb-8">
        <div class="absolute inset-0 bg-[#E84D27]/20 rounded-2xl blur-xl"></div>
        <div class="relative w-full h-full bg-[#0a0a0a] border border-[#E84D27]/20 rounded-2xl flex items-center justify-center">
          <svg class="w-12 h-12 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
      </div>
      <h3 class="text-2xl font-bold text-white mb-3">
        Sin resultados para estos filtros
      </h3>
      <p class="text-white/50 mb-8 max-w-md mx-auto">Prueba a cambiar los filtros o ver todos los eventos disponibles en Granada</p>
      <button 
        id="empty-clear-filters"
        class="inline-flex items-center gap-2 px-6 py-3 bg-[#E84D27] text-white font-semibold rounded-full hover:bg-[#F06040] transition-all duration-300 hover:shadow-lg hover:shadow-[#E84D27]/25"
      >
        Limpiar filtros
      </button>
    </div>
  </section>

  <script is:inline>
    (function() {
      const categoryButtons = document.querySelectorAll('.filter-category');
      const neighborhoodSelect = document.getElementById('filter-neighborhood');
      const dateSelect = document.getElementById('filter-date');
      const freeCheckbox = document.getElementById('filter-free');
      const clearFiltersBtn = document.getElementById('clear-filters');
      const emptyClearFiltersBtn = document.getElementById('empty-clear-filters');
      const resultsCount = document.getElementById('results-count');
      const emptyState = document.getElementById('empty-state');
      const eventsGrid = document.getElementById('events-grid');
      const eventCards = document.querySelectorAll('.event-card-wrapper');

      let filters = {
        category: 'all',
        neighborhood: 'all',
        date: 'all',
        free: false
      };

      function matchesDateFilter(eventDate, filter) {
        if (filter === 'all') return true;
        
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        const event = new Date(eventDate);
        event.setHours(0, 0, 0, 0);
        
        const diffTime = event - today;
        const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
        
        switch (filter) {
          case 'today':
            return diffDays === 0;
          case 'week':
            return diffDays >= 0 && diffDays <= 7;
          case 'weekend': {
            const dayOfWeek = today.getDay();
            const daysUntilSaturday = dayOfWeek === 0 ? 6 : 6 - dayOfWeek;
            const saturday = new Date(today);
            saturday.setDate(today.getDate() + daysUntilSaturday);
            const sunday = new Date(saturday);
            sunday.setDate(saturday.getDate() + 1);
            return event >= saturday && event <= sunday;
          }
          case 'month':
            return event.getMonth() === today.getMonth() && event.getFullYear() === today.getFullYear();
          default:
            return true;
        }
      }

      function applyFilters() {
        let visibleCount = 0;
        
        eventCards.forEach(card => {
          const category = card.dataset.category;
          const neighborhood = card.dataset.neighborhood;
          const price = card.dataset.price;
          const date = card.dataset.date;
          
          const matchesCategory = filters.category === 'all' || category === filters.category;
          const matchesNeighborhood = filters.neighborhood === 'all' || neighborhood === filters.neighborhood;
          const matchesPrice = !filters.free || price === 'free';
          const matchesDate = matchesDateFilter(date, filters.date);
          
          const isVisible = matchesCategory && matchesNeighborhood && matchesPrice && matchesDate;
          
          if (isVisible) {
            card.style.display = '';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });
        
        resultsCount.textContent = visibleCount;
        
        if (visibleCount === 0) {
          eventsGrid.classList.add('hidden');
          emptyState.classList.remove('hidden');
        } else {
          eventsGrid.classList.remove('hidden');
          emptyState.classList.add('hidden');
        }
        
        const hasActiveFilters = filters.category !== 'all' || 
                                 filters.neighborhood !== 'all' || 
                                 filters.date !== 'all' || 
                                 filters.free;
        
        if (hasActiveFilters) {
          clearFiltersBtn.classList.remove('hidden');
          clearFiltersBtn.classList.add('inline-flex');
        } else {
          clearFiltersBtn.classList.add('hidden');
          clearFiltersBtn.classList.remove('inline-flex');
        }
      }

      categoryButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          categoryButtons.forEach(b => {
            b.classList.remove('bg-[#E84D27]', 'text-white');
            b.classList.add('text-white/70', 'bg-white/[0.05]', 'border', 'border-white/[0.08]');
            b.setAttribute('aria-pressed', 'false');
          });
          btn.classList.remove('text-white/70', 'bg-white/[0.05]', 'border', 'border-white/[0.08]');
          btn.classList.add('bg-[#E84D27]', 'text-white');
          btn.setAttribute('aria-pressed', 'true');
          
          filters.category = btn.dataset.category;
          applyFilters();
        });
      });

      neighborhoodSelect?.addEventListener('change', (e) => {
        filters.neighborhood = e.target.value;
        applyFilters();
      });

      dateSelect?.addEventListener('change', (e) => {
        filters.date = e.target.value;
        applyFilters();
      });

      freeCheckbox?.addEventListener('change', (e) => {
        filters.free = e.target.checked;
        applyFilters();
      });

      function clearFilters() {
        filters = {
          category: 'all',
          neighborhood: 'all',
          date: 'all',
          free: false
        };
        
        categoryButtons.forEach(b => {
          if (b.dataset.category === 'all') {
            b.classList.remove('text-[var(--color-text-primary)]', 'bg-white', 'border', 'border-[var(--color-border)]');
            b.classList.add('bg-[var(--color-primary)]', 'text-white');
            b.setAttribute('aria-pressed', 'true');
          } else {
            b.classList.remove('bg-[var(--color-primary)]', 'text-white');
            b.classList.add('text-[var(--color-text-primary)]', 'bg-white', 'border', 'border-[var(--color-border)]');
            b.setAttribute('aria-pressed', 'false');
          }
        });
        
        neighborhoodSelect.value = 'all';
        dateSelect.value = 'all';
        freeCheckbox.checked = false;
        
        applyFilters();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }

      clearFiltersBtn?.addEventListener('click', clearFilters);
      emptyClearFiltersBtn?.addEventListener('click', clearFilters);
    })();
  </script>
</BaseLayout>

    /* Mobile CTA */
    .mobile-cta-wrapper {
      display: none;
      padding: 2rem 1.5rem;
      border-top: 1px solid var(--s-border);
      background: var(--s-bg);
    }

    .mobile-cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      width: 100%;
      padding: 1rem 1.75rem;
      font-family: var(--font-display);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--s-ink);
      background: transparent;
      border: 1.5px solid var(--s-ink);
      border-radius: 100px;
      text-decoration: none;
      transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .mobile-cta:hover {
      background: var(--s-orange);
      border-color: var(--s-orange);
      color: var(--s-bg);
    }

    .mobile-cta svg { transition: transform 0.25s ease; }

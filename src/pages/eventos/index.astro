    /* ═══════════════════════════════════════════════════════════════
       CARD CONTENT - Editorial Typography
       ═══════════════════════════════════════════════════════════════ */
    .item-content {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;

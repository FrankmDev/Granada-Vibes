    .item-title {
      font-family: var(--font-body);
      font-size: clamp(1.15rem, 1.8vw, 1.65rem);
      font-weight: 400;
      letter-spacing: -0.02em;
      line-height: 1.15;
      margin: 0;
      color: white;

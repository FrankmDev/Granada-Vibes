      transform: translateY(-2px);
    }

    /* ═══════════════════════════════════════════════════════════════
       DATE BADGE - Floating Glass Pill
       ═══════════════════════════════════════════════════════════════ */
    .date-badge {
      position: absolute;
      top: 1.5rem;
      right: 1.5rem;
      z-index: 5;
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.97) 0%, rgba(250, 248, 245, 0.97) 100%);
      backdrop-filter: blur(20px) saturate(160%);
      -webkit-backdrop-filter: blur(20px) saturate(160%);
      border: 1px solid rgba(255, 255, 255, 0.6);

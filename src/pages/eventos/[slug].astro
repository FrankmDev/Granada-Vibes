---
import BaseLayout from '@layouts/BaseLayout.astro';
import NavBar from '@components/layout/NavBar.astro';
import Footer from '@components/layout/Footer.astro';
import VenueMap from '@components/ui/VenueMap.astro';
import EventDetailHero from '@components/events/EventDetailHero.astro';
import EventDetailContent from '@components/events/EventDetailContent.astro';
import { getAllEvents } from '@data/index.js';
import { getVenueCoordinates } from '@data/venues/coordinates.js';
import { useTranslations } from '@i18n/utils';
import { formatFullDate, formatTime } from '@utils/dates';

export function getStaticPaths() {
  const events = getAllEvents();
  return events.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
const locale = 'es';
const t = useTranslations(locale);

const venueCoords = getVenueCoordinates(event.venue, event.neighborhood);
const relatedEvents = getAllEvents()
  .filter(e => e.category === event.category && e.id !== event.id)
  .slice(0, 3);

const eventImage = event.imageUrl || event.image;
const ogImage = eventImage || 'https://placehold.co/1200x630/0a0a0a/f0ede8?text=Granada+Vibes';

const priceText = event.price === null ? 'Entrada libre.' : `Desde ${event.price}€.`;
const seoDescription = `${event.title[locale]} en Granada — ${formatFullDate(event.date, locale)}, ${formatTime(event.time, locale)}. ${t(`categories.${event.category}`)} en ${event.venue}, barrio ${t(`neighborhoods.${event.neighborhood}`)}. ${priceText} Descubre todos los detalles en Granada Vibes.`;
---

<BaseLayout
  locale={locale}
  title={event.title[locale]}
  description={seoDescription}
  ogImage={ogImage}
  schemaType="event"
  schemaData={event}
>
  <NavBar slot="header" locale={locale} currentPath={Astro.url.pathname} />

  <!-- DARK CINEMATIC HERO -->
  <EventDetailHero event={event} locale={locale} />

  <!-- CREAM EDITORIAL CONTENT -->
  <EventDetailContent>
  <div class="det-page">

    <div class="det-content-wrap">
      <div class="det-layout">

        <!-- MAIN COLUMN (70%) -->
        <main id="main-content" class="det-main">

          <!-- Description block -->
          <article class="det-block det-block-premium" data-reveal>
            <header class="det-block-head">
              <span class="det-block-num">01</span>
              <div class="det-block-divider"></div>
              <span class="det-block-eyebrow">[ Sobre el evento ]</span>
            </header>
            <h2 class="det-block-title">Descripción</h2>
            <div class="det-block-body">
              <p class="det-lead">{event.description[locale]}</p>
            </div>
            <div class="det-block-footer">
              <span class="det-block-accent-line"></span>
            </div>
            <div class="det-hover-corners" aria-hidden="true">
              <span class="hc tl"></span><span class="hc tr"></span>
              <span class="hc bl"></span><span class="hc br"></span>
            </div>
          </article>

          <!-- Venue block -->
          <article class="det-block det-block-premium" data-reveal>
            <header class="det-block-head">
              <span class="det-block-num">02</span>
              <div class="det-block-divider"></div>
              <span class="det-block-eyebrow">[ Ubicación ]</span>
            </header>
            <h2 class="det-block-title">{event.venue}</h2>
            <div class="det-block-body">
              <div class="evt-venue-meta">
                <span class="evt-neighborhood-tag">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  {t(`neighborhoods.${event.neighborhood}`)}
                </span>
                {event.address && (
                  <span class="evt-address">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                    </svg>
                    {event.address}
                  </span>
                )}
              </div>
              {event.venueDescription && (
                <p class="evt-venue-desc">{event.venueDescription[locale]}</p>
              )}
            </div>
            <div class="evt-map-frame">
              <div class="evt-map-label" aria-hidden="true">
                <span class="evt-map-label-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.447-.894L15 7m0 13V7"/>
                  </svg>
                </span>
                [ {locale === 'es' ? 'MAPA DEL VENUE' : 'VENUE MAP'} ]
              </div>
              {venueCoords ? (
                <VenueMap lat={venueCoords.lat} lng={venueCoords.lng} venueName={event.venue} theme="light" />
              ) : (
                <div class="evt-map-placeholder">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  <p>{t('detail.mapComingSoon')}</p>
                </div>
              )}
            </div>
            <div class="det-block-footer">
              <span class="det-block-accent-line"></span>
            </div>
            <div class="det-hover-corners" aria-hidden="true">
              <span class="hc tl"></span><span class="hc tr"></span>
              <span class="hc bl"></span><span class="hc br"></span>
            </div>
          </article>

          <!-- Highlights block -->
          {event.highlights && event.highlights[locale] && event.highlights[locale]!.length > 0 && (
            <article class="det-block det-block-premium" data-reveal>
              <header class="det-block-head">
                <span class="det-block-num">03</span>
                <div class="det-block-divider"></div>
                <span class="det-block-eyebrow">[ Experiencia ]</span>
              </header>
              <h2 class="det-block-title">Qué esperar</h2>
              <div class="det-block-body">
                <ul class="evt-highlights" role="list">
                  {event.highlights[locale]!.map((item, i) => (
                    <li class="evt-highlight-item" style={`--stagger: ${i * 0.08}s`}>
                      <span class="evt-hl-marker" aria-hidden="true">
                        <span class="evt-hl-num">{(i + 1).toString().padStart(2, '0')}</span>
                        <span class="evt-hl-bar"></span>
                      </span>
                      <span class="evt-hl-text">{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
              <div class="det-block-footer">
                <span class="det-block-accent-line"></span>
              </div>
              <div class="det-hover-corners" aria-hidden="true">
                <span class="hc tl"></span><span class="hc tr"></span>
                <span class="hc bl"></span><span class="hc br"></span>
              </div>
            </article>
          )}

          <!-- Tips block -->
          {event.tips && (
            <article class="det-block det-block-premium evt-tips-block" data-reveal>
              <header class="det-block-head">
                <span class="det-block-num">04</span>
                <div class="det-block-divider"></div>
                <span class="det-block-eyebrow">[ Recomendación ]</span>
              </header>
              <h2 class="det-block-title">Consejos prácticos</h2>
              <div class="det-block-body">
                <div class="evt-tips-inner">
                  <div class="evt-tips-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                  </div>
                  <div class="evt-tips-content">
                    <p class="evt-tips-text">{event.tips[locale]}</p>
                    <div class="evt-tips-decoration">
                      <span class="evt-tips-quote">"</span>
                    </div>
                  </div>
                </div>
              </div>
              <div class="det-block-footer">
                <span class="det-block-accent-line"></span>
              </div>
            </article>
          )}

          <!-- Tags -->
          {event.tags.length > 0 && (
            <div class="det-tags det-tags-premium" data-reveal>
              <span class="det-tags-eyebrow">[ Etiquetas ]</span>
              <div class="det-tags-flow">
                {event.tags.map((tag, i) => (
                  <span class="det-tag-pill" style={`--ti: ${i}`}>#{tag}</span>
                ))}
              </div>
            </div>
          )}

        </main>

        <!-- SIDEBAR (30%) -->
        <aside>
          <div class="det-sidebar-sticky">

            <!-- Info card -->
            <div class="det-sidebar-card det-info-card det-card-premium" data-reveal>
              <div class="det-sc-head">
                <span class="det-sc-eyebrow">[ Información ]</span>
                <div class="det-sc-line"></div>
              </div>

              <div class="det-info-section">
                <div class="det-info-row">
                  <span class="det-info-label">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    {t('detail.date')}
                  </span>
                  <span class="det-info-val evt-info-date">{formatFullDate(event.date, locale)}</span>
                </div>
                <div class="det-info-sep"></div>
                <div class="det-info-row">
                  <span class="det-info-label">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    {t('detail.time')}
                  </span>
                  <span class="det-info-val">{formatTime(event.time, locale)}</span>
                </div>
              </div>

              <div class="det-info-section">
                <div class="det-info-sep"></div>
                <div class="det-info-row">
                  <span class="det-info-label">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                    </svg>
                    {t('detail.category')}
                  </span>
                  <span class="det-info-val">{t(`categories.${event.category}`)}</span>
                </div>
                <div class="det-info-sep"></div>
                <div class="det-info-row">
                  <span class="det-info-label">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    {t('events.filters.neighborhood')}
                  </span>
                  <span class="det-info-val">{t(`neighborhoods.${event.neighborhood}`)}</span>
                </div>
              </div>

              <div class="det-info-section det-info-price-section">
                <div class="det-info-sep"></div>
                <div class="det-info-row">
                  <span class="det-info-label">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    {t('detail.price')}
                  </span>
                  <span class:list={['det-info-val', 'evt-info-price', event.price === null && 'is-free']}>
                    {event.price === null ? t('detail.free') : `${event.price}€`}
                  </span>
                </div>
              </div>

              <div class="evt-info-actions">
                {(event.ticketsUrl || event.sourceUrl) ? (
                  <a
                    href={event.ticketsUrl || event.sourceUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="evt-btn-primary"
                  >
                    <span>{t('detail.getTickets')}</span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                ) : (
                  <div class="evt-btn-primary">
                    <span>{event.price === null ? t('detail.free') : t('detail.bookPlace')}</span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                )}
                <button id="share-btn" class="evt-btn-secondary"
                  data-title={event.title[locale]}
                  data-url={Astro.url.href}
                >
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
                  </svg>
                  <span class="share-label" aria-live="polite">Compartir evento</span>
                </button>
              </div>
            </div>

            <!-- Related events -->
            {relatedEvents.length > 0 && (
              <div class="det-sidebar-card det-related-card det-card-premium" data-reveal>
                <div class="det-sc-head">
                  <span class="det-sc-eyebrow">[ {locale === 'es' ? 'Próximos eventos' : 'Upcoming events'} ]</span>
                  <div class="det-sc-line"></div>
                </div>
                <div class="det-related-list">
                  {relatedEvents.map((rel, i) => (
                    <a
                      href={`/eventos/${rel.slug}`}
                      class="det-related-item"
                      style={`--ri: ${i}`}
                      aria-label={rel.title[locale]}
                    >
                      <div class="det-rel-thumb">
                        {(rel.imageUrl || rel.image) ? (
                          <img src={rel.imageUrl || rel.image} alt="" loading="lazy" />
                        ) : (
                          <div class="det-rel-thumb-fallback">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                              <rect x="3" y="3" width="18" height="18" rx="2"/>
                              <circle cx="8.5" cy="8.5" r="1.5"/>
                              <path d="M21 15l-5-5L5 21"/>
                            </svg>
                          </div>
                        )}
                        <div class="det-rel-thumb-overlay"></div>
                      </div>
                      <div class="det-rel-info">
                        <span class="det-rel-title">{rel.title[locale]}</span>
                        <span class="det-rel-meta">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                          </svg>
                          {formatFullDate(rel.date, locale)} · {rel.price === null ? t('detail.free') : `${rel.price}€`}
                        </span>
                      </div>
                      <svg class="det-rel-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  ))}
                </div>
                <a href="/eventos" class="det-all-link">
                  {t('detail.allEvents')}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </div>
            )}

          </div>
        </aside>
      </div>
    </div>

    <!-- Footer ornament -->
    <div class="det-footer-orn" aria-hidden="true">
      <span class="det-orn-line"></span>
      <span class="det-orn-diamond"></span>
      <span class="det-orn-star">
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17.2l-6.2 4.1 2.4-7.4L2 9.4h7.6z"/>
        </svg>
      </span>
      <span class="det-orn-diamond"></span>
      <span class="det-orn-line"></span>
    </div>

  </div>
  </EventDetailContent>

  <Footer slot="footer" locale={locale} />
</BaseLayout>

<script is:inline>
  (function () {
    const btn = document.getElementById('share-btn');
    if (!btn) return;
    btn.addEventListener('click', async function () {
      const title = btn.dataset.title;
      const url   = btn.dataset.url;
      const label = btn.querySelector('.share-label');
      if (navigator.share) {
        try { await navigator.share({ title, text: 'Descubre "' + title + '" en Granada Vibes', url }); return; }
        catch (_) {}
      }
      try {
        await navigator.clipboard.writeText(url ?? '');
        if (label) {
          const orig = label.textContent;
          label.textContent = '¡Copiado!';
          setTimeout(() => { label.textContent = orig; }, 2000);
        }
      } catch (_) {}
    });
  })();
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const io = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } }),
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('[data-reveal]').forEach(el => io.observe(el));
  });
</script>

<!-- Reading progress bar -->
<script>
  (function () {
    const bar = document.createElement('div');
    bar.id = 'read-progress';
    bar.setAttribute('aria-hidden', 'true');
    document.body.appendChild(bar);

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
          bar.style.setProperty('--scroll-progress', `${progress}%`);
          ticking = false;
        });
        ticking = true;
      }
    });
  })();
</script>

<style is:global>
  #read-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: var(--scroll-progress, 0%);
    height: 3px;
    background: linear-gradient(90deg, #c9a84c, #e6c587, #c9a84c);
    background-size: 200% 100%;
    animation: shimmer 2s linear infinite;
    z-index: 9999;
    transition: width 0.1s linear;
    pointer-events: none;
    box-shadow: 0 2px 10px rgba(201, 168, 76, 0.4);
  }

  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* Premium block styling */
  .det-block-premium {
    position: relative;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
  }

  .det-block-premium:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.06), 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .det-block-body {
    position: relative;
  }

  .det-block-footer {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(26, 22, 25, 0.06);
  }

  .det-block-accent-line {
    display: block;
    width: 40px;
    height: 2px;
    background: linear-gradient(90deg, #c9a84c, transparent);
    transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .det-block-premium:hover .det-block-accent-line {
    width: 80px;
  }

  /* Enhanced venue meta */
  .evt-venue-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .evt-neighborhood-tag,
  .evt-address {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.8rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    border-radius: 4px;
    transition: all 0.3s ease;
  }

  .evt-neighborhood-tag {
    background: rgba(201, 168, 76, 0.12);
    border: 1px solid rgba(201, 168, 76, 0.25);
    color: #8a6d3b;
  }

  .evt-neighborhood-tag:hover {
    background: rgba(201, 168, 76, 0.2);
    border-color: rgba(201, 168, 76, 0.4);
    transform: translateY(-1px);
  }

  .evt-address {
    background: rgba(26, 22, 25, 0.04);
    border: 1px solid rgba(26, 22, 25, 0.08);
    color: var(--s-ink-2, #5a5550);
  }

  .evt-neighborhood-tag svg,
  .evt-address svg {
    width: 14px;
    height: 14px;
    opacity: 0.7;
  }

  /* Enhanced map label */
  .evt-map-label {
    font-family: var(--font-display, 'DM Sans', sans-serif);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--s-ink-3, #8a7f77);
    padding: 0.75rem 1rem 0.4rem;
    border-bottom: 1px solid var(--s-border, rgba(26,22,25,0.10));
    background: var(--s-bg-hi, #faf8f5);
    display: flex;

---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/layout/Breadcrumbs.astro';
import Icon from '@components/ui/Icon.astro';
import VenueMap from '@components/ui/VenueMap.astro';
import { getAllEvents, getEventBySlug } from '@data/index.js';
import { getVenueCoordinates } from '@data/venues/coordinates.js';
import { useTranslations } from '@i18n/utils';
import { formatDate, formatFullDate, formatTime, getTemporalProximity } from '@utils/dates';

export function getStaticPaths() {
  const events = getAllEvents();
  return events.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
const locale = 'es';
const t = useTranslations(locale);

const breadcrumbs = [
  { label: t('nav.home'), href: '/' },
  { label: t('nav.events'), href: '/eventos' },
  { label: event.title[locale] },
];

// Get temporal proximity for badge
const temporalProximity = getTemporalProximity(event.date);
const proximityLabels = {
  'today': 'HOY',
  'tomorrow': 'MAÑANA',
  'this-week': 'ESTA SEMANA',
  'future': null,
};

// Get venue coordinates for map
const venueCoords = getVenueCoordinates(event.venue, event.neighborhood);

// Get related events (same category, different event)
const relatedEvents = getAllEvents()
  .filter(e => e.category === event.category && e.id !== event.id)
  .slice(0, 3);

// Event image (from scraper or mock)
const eventImage = event.imageUrl || event.image;

// OG Image
const ogImage = eventImage || 'https://placehold.co/1200x630/0a0a0a/f0ede8?text=Granada+Vibes';
---

<BaseLayout 
  locale={locale}
  title={event.title[locale]}
  description={`${event.title[locale]} en Granada — ${formatDate(event.date, locale)}. ${event.venue}, ${t(`neighborhoods.${event.neighborhood}`)}. Precio: ${event.price === null ? 'Gratis' : event.price + '€'}. Compra entradas y descubre más en Granada Vibes.`}
  ogImage={ogImage}
  schemaType="event"
  schemaData={event}
>
  {/* Background decorations */}
  <div class="absolute top-0 left-1/4 w-[800px] h-[800px] bg-[#E84D27]/5 rounded-full blur-[180px] pointer-events-none -z-10"></div>
  <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-[#F59E0B]/5 rounded-full blur-[150px] pointer-events-none -z-10"></div>

  <article class="container pt-28 pb-20 lg:pt-32 relative z-10">
    <Breadcrumbs items={breadcrumbs} />

    {/* Hero image */}
    {eventImage && (
      <div class="relative w-full aspect-[21/9] rounded-2xl overflow-hidden mt-6 mb-10 border border-white/[0.06]">
        <img
          src={eventImage}
          alt={event.title[locale]}
          class="absolute inset-0 w-full h-full object-cover"
          loading="eager"
          decoding="async"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent" />
      </div>
    )}

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-12 lg:gap-16 mt-8">
      <!-- Columna Principal (70%) -->
      <div class="order-2 lg:order-1">
        <!-- Hero del evento -->
        <header class="mb-10">
          <!-- Badges -->
          <div class="flex flex-wrap items-center gap-3 mb-5">
            <span class="px-3 py-1.5 text-[11px] font-bold uppercase tracking-wider bg-[#E84D27]/10 text-[#E84D27] rounded-full border border-[#E84D27]/30">
              {t(`categories.${event.category}`)}
            </span>
            {temporalProximity && proximityLabels[temporalProximity] && (
              <span class:list={[
                'px-3 py-1.5 text-[11px] font-bold uppercase tracking-wider rounded-full border animate-pulse',
                temporalProximity === 'today' 
                  ? 'bg-[#E84D27] text-white border-[#E84D27]' 
                  : temporalProximity === 'tomorrow'
                    ? 'bg-[#F59E0B]/20 text-[#F59E0B] border-[#F59E0B]/30'
                    : 'bg-white/[0.05] text-white/60 border-white/[0.1]'
              ]}>
                {proximityLabels[temporalProximity]}
              </span>
            )}
            {event.featured && (
              <span class="px-3 py-1.5 text-[11px] font-bold uppercase tracking-wider bg-[#E84D27]/10 text-[#E84D27] rounded-full border border-[#E84D27]/30">
                Destacado
              </span>
            )}
          </div>

          <!-- Headline -->
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-[-0.02em] text-white mb-6 leading-[1.1]">
            {event.title[locale]}
          </h1>

          <!-- Descripción -->
          <p class="text-lg lg:text-xl text-white/50 leading-relaxed max-w-2xl">
            {event.description[locale]}
          </p>
        </header>

        <!-- Línea separadora -->
        <div class="h-px bg-gradient-to-r from-[#E84D27]/30 via-white/[0.06] to-transparent mb-10" />

        <!-- Sección "El lugar" -->
        <section class="mb-12" aria-labelledby="venue-heading">
          <h2 id="venue-heading" class="text-2xl lg:text-3xl font-bold text-white mb-5">
            {event.venue}
          </h2>
          
          <div class="flex items-center gap-2 mb-5">
            <span class="px-3 py-1 text-xs font-medium bg-white/[0.05] text-white/60 rounded-full border border-white/[0.08]">
              {t(`neighborhoods.${event.neighborhood}`)}
            </span>
            {event.address && (
              <span class="text-sm text-white/40">{event.address}</span>
            )}
          </div>

          {event.venueDescription && (
            <p class="text-white/50 leading-relaxed mb-8">
              {event.venueDescription[locale]}
            </p>
          )}

          {venueCoords ? (
            <VenueMap lat={venueCoords.lat} lng={venueCoords.lng} venueName={event.venue} />
          ) : (
            <div class="aspect-video bg-white/[0.03] rounded-2xl border border-white/[0.06] flex items-center justify-center">
              <div class="text-center">
                <div class="w-16 h-16 bg-white/[0.05] rounded-2xl flex items-center justify-center mx-auto mb-4">
                  <svg class="w-8 h-8 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <p class="text-white/30 text-sm">Ubicación no disponible</p>
              </div>
            </div>
          )}
        </section>

        <!-- Sección "Qué esperar" -->
        {event.highlights && event.highlights[locale]?.length > 0 && (
          <section class="mb-12" aria-labelledby="highlights-heading">
            <h2 id="highlights-heading" class="text-2xl lg:text-3xl font-bold text-white mb-6">
              Qué esperar
            </h2>
            <ul class="space-y-4">
              {event.highlights[locale]?.map((highlight) => (
                <li class="flex items-start gap-4">
                  <span class="w-2 h-2 rounded-full bg-[#E84D27] mt-2.5 flex-shrink-0" />
                  <span class="text-white/50 leading-relaxed">{highlight}</span>
                </li>
              ))}
            </ul>
          </section>
        )}

        <!-- Sección "Consejos prácticos" -->
        {event.tips && (
          <section class="mb-12" aria-labelledby="tips-heading">
            <div class="p-6 bg-white/[0.03] rounded-2xl border border-white/[0.06]">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-[#E84D27]/10 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-[#E84D27]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <h3 class="text-lg font-bold text-white mb-2">Consejos prácticos</h3>
                  <p class="text-white/50 leading-relaxed">{event.tips[locale]}</p>
                </div>
              </div>
            </div>
          </section>
        )}

        <!-- Tags -->
        {event.tags.length > 0 && (
          <section aria-labelledby="tags-heading">
            <h2 id="tags-heading" class="sr-only">Etiquetas</h2>
            <div class="flex flex-wrap gap-2">
              {event.tags.map((tag) => (
                <span class="px-4 py-2 text-sm text-white/50 bg-white/[0.04] rounded-full border border-white/[0.06]">
                  #{tag}
                </span>
              ))}
            </div>
          </section>
        )}
      </div>

      <!-- Sidebar (30%) -->
      <aside class="order-1 lg:order-2">
        <div class="lg:sticky lg:top-28 space-y-6">
          <!-- Card de info principal -->
          <div class="p-6 lg:p-8 bg-white/[0.04] backdrop-blur-xl border border-white/[0.06] rounded-2xl">
            <!-- Fecha completa -->
            <div class="mb-6">
              <p class="text-sm text-white/40 mb-1">Fecha</p>
              <p class="text-2xl font-black text-white">
                {formatFullDate(event.date, locale)}
              </p>
              {event.endDate && event.endDate !== event.date && (
                <p class="text-sm text-white/40 mt-1">
                  Hasta {formatDate(event.endDate, locale)}
                </p>
              )}
            </div>

            <!-- Hora -->
            <div class="mb-6">
              <p class="text-sm text-white/40 mb-1">Hora</p>
              <div class="flex items-center gap-2">
                <svg class="w-5 h-5 text-[#E84D27]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <p class="text-xl font-black text-white">
                  {formatTime(event.time, locale)}
                </p>
              </div>
            </div>

            <!-- Precio -->
            <div class="mb-6">
              <p class="text-sm text-white/40 mb-1">Precio</p>
              <p class:list={[
                'text-3xl font-black',
                event.price === null ? 'text-emerald-400' : 'text-white'
              ]}>
                {event.price === null ? 'Gratis' : `${event.price}€`}
              </p>
            </div>

            <!-- CTA -->
            {(event.ticketsUrl || event.sourceUrl) ? (
              <a
                href={event.ticketsUrl || event.sourceUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center gap-2 w-full px-6 py-4 bg-[#E84D27] text-white font-bold text-sm uppercase tracking-wider rounded-xl transition-all duration-300 hover:shadow-[0_8px_30px_rgba(232,77,39,0.3)] hover:scale-[1.02]"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
                </svg>
                Comprar entradas
              </a>
            ) : (
              <button 
                class="flex items-center justify-center gap-2 w-full px-6 py-4 bg-[#E84D27] text-white font-bold text-sm uppercase tracking-wider rounded-xl transition-all duration-300 hover:shadow-[0_8px_30px_rgba(232,77,39,0.3)] hover:scale-[1.02]"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                {event.price === null ? 'Confirmar asistencia' : 'Reservar plaza'}
              </button>
            )}

            <!-- Separador -->
            <div class="h-px bg-white/[0.06] my-6" />

            <!-- Lugar -->
            <div class="mb-4">
              <p class="text-sm text-white/40 mb-1">Lugar</p>
              <p class="font-medium text-white">{event.venue}</p>
              <p class="text-sm text-white/40">{t(`neighborhoods.${event.neighborhood}`)}</p>
            </div>

            <!-- Separador -->
            <div class="h-px bg-white/[0.06] my-6" />

            <!-- Botón compartir -->
            <button 
              id="share-button"
              class="flex items-center justify-center gap-2 w-full px-6 py-3 bg-transparent text-white/50 font-medium text-sm rounded-xl border border-white/[0.08] hover:border-white/[0.2] hover:text-white transition-all duration-200"
              data-title={event.title[locale]}
              data-url={Astro.url.href}
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
              </svg>
              Compartir evento
            </button>
          </div>

          <!-- Eventos relacionados -->
          {relatedEvents.length > 0 && (
            <div class="p-6 bg-white/[0.03] border border-white/[0.06] rounded-2xl">
              <h3 class="text-lg font-bold text-white mb-4">
                Eventos similares
              </h3>
              <div class="space-y-4">
                {relatedEvents.map((relatedEvent) => (
                  <a 
                    href={`/eventos/${relatedEvent.slug}`}
                    class="block group"
                  >
                    <div class="flex items-start gap-3">
                      <div class="w-12 h-12 bg-white/[0.05] rounded-xl flex items-center justify-center flex-shrink-0 border border-white/[0.08] group-hover:border-[#E84D27]/30 transition-colors">
                        <svg class="w-5 h-5 text-white/30 group-hover:text-[#E84D27] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                      </div>
                      <div class="flex-1 min-w-0">
                        <p class="font-medium text-white text-sm group-hover:text-[#E84D27] transition-colors line-clamp-2">
                          {relatedEvent.title[locale]}
                        </p>
                        <p class="text-xs text-white/30 mt-1">
                          {formatDate(relatedEvent.date, locale)}
                        </p>
                        <p class="text-xs text-white/30">
                          {relatedEvent.price === null ? 'Gratis' : `${relatedEvent.price}€`}
                        </p>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      </aside>
    </div>
  </article>

  <!-- Share functionality -->
  <script is:inline>
    (function() {
      const shareButton = document.getElementById('share-button');
      if (!shareButton) return;

      const title = shareButton.dataset.title;
      const url = shareButton.dataset.url;

      shareButton.addEventListener('click', async function() {
        if (navigator.share) {
          try {
            await navigator.share({
              title: title,
              text: `Descubre "${title}" en Granada Vibes`,
              url: url
            });
            return;
          } catch (err) {
            // User cancelled or share failed, fall back to clipboard
          }
        }

        try {
          await navigator.clipboard.writeText(url);
          const originalText = shareButton.innerHTML;
          shareButton.innerHTML = `
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7" />
            </svg>
            Enlace copiado
          `;
          setTimeout(() => {
            shareButton.innerHTML = originalText;
          }, 2000);
        } catch (err) {
          console.error('Failed to copy:', err);
        }
      });
    })();
  </script>
</BaseLayout>

---
import BaseLayout from '@layouts/BaseLayout.astro';
import NavBar from '@components/layout/NavBar.astro';
import Footer from '@components/layout/Footer.astro';
import VenueMap from '@components/ui/VenueMap.astro';
import OptimizedImage from '@components/ui/OptimizedImage.astro';
import EventDetailHero from '@components/events/EventDetailHero.astro';
import EventDetailContent from '@components/events/EventDetailContent.astro';
import { getAllEvents } from '@data/index.js';
import { getVenueCoordinates } from '@data/venues/coordinates.js';
import { useTranslations } from '@i18n/utils';
import { formatFullDate, formatTime } from '@utils/dates';
import { getPriceStatus, formatPriceLabel } from '@utils';

export function getStaticPaths() {
  const events = getAllEvents();
  return events.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
const locale = 'es';
const t = useTranslations(locale);

const venueCoords = getVenueCoordinates(event.venue, event.neighborhood);
const relatedEvents = getAllEvents()
  .filter(e => e.category === event.category && e.id !== event.id)
  .slice(0, 3);

const eventImage = event.imageUrl || event.image;
const ogImage = eventImage || 'https://placehold.co/1200x630/0a0a0a/f0ede8?text=GRN Index';

const priceLabel = formatPriceLabel(event, t);
const priceText = getPriceStatus(event) === 'paid'
  ? `Desde ${event.price}€.`
  : getPriceStatus(event) === 'free'
    ? 'Entrada libre.'
    : 'Consultar precio.';
const seoDescription = `${event.title[locale]} en Granada — ${formatFullDate(event.date, locale)}, ${formatTime(event.time, locale)}. ${t(`categories.${event.category}`)} en ${event.venue}, barrio ${t(`neighborhoods.${event.neighborhood}`)}. ${priceText} Descubre todos los detalles en GRN Index.`;
---

<BaseLayout
  locale={locale}
  title={event.title[locale]}
  description={seoDescription}
  ogImage={ogImage}
  schemaType="event"
  schemaData={event}
>
  <NavBar slot="header" locale={locale} currentPath={Astro.url.pathname} />

  <!-- DARK CINEMATIC HERO -->
  <EventDetailHero event={event} locale={locale} />

  <!-- CREAM EDITORIAL CONTENT WITH UPGRADED UI -->
  <EventDetailContent>
  <div class="det-page">

    <div class="det-content-wrap">
      <div class="det-layout upgraded-layout">

        <!-- MAIN CONTENT (LEFT) -->
        <main id="main-content" class="det-main upgraded-main">

          <!-- 1. Description Block -->
          <article class="upg-block" data-reveal>
            <div class="upg-block-bg"></div>
            <header class="upg-header">
              <span class="upg-num">01</span>
              <div class="upg-line"></div>
              <span class="upg-eyebrow">[ Sobre el evento ]</span>
            </header>

            <h2 class="upg-title">Descripción</h2>

            <div class="upg-body content-rich">
              {event.description[locale] && (
                <p class="upg-lead">{event.description[locale]}</p>
              )}
              {event.longDescription && event.longDescription[locale] && (
                <div class="upg-long-desc">
                  {event.longDescription[locale].split('\n\n').map((paragraph) => (
                    <p>{paragraph}</p>
                  ))}
                </div>
              )}
            </div>
          </article>

          <!-- 2. Venue Block -->
          <article class="upg-block upg-venue-block" data-reveal>
            <div class="upg-block-bg"></div>
            <header class="upg-header">
              <span class="upg-num">02</span>
              <div class="upg-line"></div>
              <span class="upg-eyebrow">[ Ubicación ]</span>
            </header>
            
            <div class="upg-venue-grid">
              <div class="upg-venue-info">
                <h2 class="upg-title upg-venue-title">{event.venue}</h2>
                <div class="upg-venue-badges">
                  <span class="upg-badge">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    {t(`neighborhoods.${event.neighborhood}`)}
                  </span>
                  {event.address && (
                    <span class="upg-badge ghost">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                      {event.address}
                    </span>
                  )}
                </div>
                {event.venueDescription && (
                  <p class="upg-venue-desc">{event.venueDescription[locale]}</p>
                )}
              </div>
              
              <div class="upg-venue-map-wrapper">
                <div class="upg-map-glass-overlay"></div>
                {venueCoords ? (
                  <VenueMap lat={venueCoords.lat} lng={venueCoords.lng} venueName={event.venue} theme="light" />
                ) : (
                  <div class="upg-map-placeholder">
                    <span>{t('detail.mapComingSoon')}</span>
                  </div>
                )}
              </div>
            </div>
          </article>

          <!-- 3. Experience Block -->
          {event.highlights && event.highlights[locale] && event.highlights[locale]!.length > 0 && (
            <article class="upg-block" data-reveal>
              <div class="upg-block-bg"></div>
              <header class="upg-header">
                <span class="upg-num">03</span>
                <div class="upg-line"></div>
                <span class="upg-eyebrow">[ Experiencia ]</span>
              </header>
              <h2 class="upg-title">Qué esperar</h2>
              
              <div class="upg-highlights">
                {event.highlights[locale]!.map((item, i) => (
                  <div class="upg-hl-item" style={`--hl-delay: ${i * 0.1}s`}>
                    <div class="upg-hl-num-wrap">
                      <span class="upg-hl-num">{(i + 1).toString().padStart(2, '0')}</span>
                    </div>
                    <p class="upg-hl-text">{item}</p>
                  </div>
                ))}
              </div>
            </article>
          )}

          <!-- 4. Tips Block -->
          {event.tips && (
            <article class="upg-block block-tips" data-reveal>
              <div class="upg-block-bg"></div>
              <header class="upg-header">
                <span class="upg-num">04</span>
                <div class="upg-line"></div>
                <span class="upg-eyebrow">[ Recomendación ]</span>
              </header>
              <h2 class="upg-title">Consejos prácticos</h2>
              
              <div class="upg-tips-content">
                <div class="upg-tips-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <p class="upg-tips-text">{event.tips[locale]}</p>
              </div>
            </article>
          )}
          
          <!-- Tags -->
          {event.tags.length > 0 && (
             <div class="upg-tags" data-reveal>
               <span class="upg-tags-title">[ Etiquetas ]</span>
               <div class="upg-tags-list">
                 {event.tags.map(tag => (
                   <span class="upg-tag">#{tag}</span>
                 ))}
               </div>
             </div>
          )}

        </main>

        <!-- ENHANCED SIDEBAR (RIGHT) -->
        <aside class="upg-sidebar">
          <div class="upg-sidebar-sticky">

            <!-- Premium Ticket Card -->
            <div class="upg-ticket-card" data-reveal>
              <div class="upg-ticket-glass"></div>
              
              <!-- Ticket Header -->
              <div class="upg-tc-header">
                <div class="upg-tc-date-box">
                  <span class="tc-day">{new Date(event.date).getDate().toString().padStart(2, '0')}</span>
                  <span class="tc-month">{new Intl.DateTimeFormat('es-ES', { month: 'short' }).format(new Date(event.date)).toUpperCase()}</span>
                </div>
                <div class="upg-tc-info">
                  <span class="tc-time">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    {formatTime(event.time, locale)}
                  </span>
                  <span class="tc-category">{t(`categories.${event.category}`)}</span>
                </div>
              </div>

              <!-- Price Box -->
              <div class="upg-tc-price-wrap">
                <span class="tc-price-label">{t('detail.price')}</span>
                <span class:list={['tc-price-val', getPriceStatus(event) === 'free' && 'is-free', getPriceStatus(event) === 'tickets' && 'is-tickets']}>
                  {formatPriceLabel(event, t)}
                </span>
              </div>

              <div class="upg-tc-divider">
                <span class="tcd-hole left"></span>
                <div class="tcd-dashed"></div>
                <span class="tcd-hole right"></span>
              </div>

              <!-- Actions -->
              <div class="upg-tc-actions">
                {(event.ticketsUrl || event.sourceUrl) ? (
                  <a
                    href={event.ticketsUrl || event.sourceUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="upg-btn-primary"
                  >
                    <span>{t('detail.getTickets')}</span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                ) : (
                  <div class="upg-btn-primary inert">
                    <span>{getPriceStatus(event) === 'free' ? t('events.free') : t('detail.unknown')}</span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </div>
                )}
                
                <button id="upg-share-btn" class="upg-btn-secondary"
                  data-title={event.title[locale]}
                  data-url={Astro.url.href}
                >
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
                  <span class="upg-share-label">Compartir</span>
                </button>
              </div>

            </div>

            <!-- Related Events Bento -->
            {relatedEvents.length > 0 && (
              <div class="upg-related-bento" data-reveal>
                <div class="upg-rb-header">
                  <span class="upg-rb-title">[ {locale === 'es' ? 'Próximos eventos' : 'Upcoming events'} ]</span>
                  <a href="/eventos" class="upg-rb-all">Ver todos →</a>
                </div>
                
                <div class="upg-rb-list">
                  {relatedEvents.map((rel, i) => (
                    <a href={`/eventos/${rel.slug}`} class="upg-rel-item" style={`--rd: ${i * 0.15}s`}>
                      <div class="uri-thumb">
                        {(rel.imageUrl || rel.image) ? (
                          <OptimizedImage src={rel.imageUrl || rel.image} alt="" loading="lazy" sizes="(max-width: 640px) 100vw, 280px" />
                        ) : (
                          <div class="uri-thumb-fallback"></div>
                        )}
                      </div>
                      <div class="uri-content">
                        <span class="uri-title">{rel.title[locale]}</span>
                        <span class="uri-meta">
                          {formatFullDate(rel.date, locale)}
                        </span>
                      </div>
                      <div class="uri-arrow">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            )}

          </div>
        </aside>

      </div>
    </div>

    <div class="det-footer-orn" aria-hidden="true">
      <span class="det-orn-line"></span>
      <span class="det-orn-star"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17.2l-6.2 4.1 2.4-7.4L2 9.4h7.6z"/></svg></span>
      <span class="det-orn-line"></span>
    </div>

  </div>
  </EventDetailContent>

  <Footer slot="footer" locale={locale} />
</BaseLayout>

<script is:inline>
  (function () {
    const btn = document.getElementById('upg-share-btn');
    if (!btn) return;
    btn.addEventListener('click', async function () {
      const title = btn.dataset.title;
      const url   = btn.dataset.url;
      const label = btn.querySelector('.upg-share-label');
      if (navigator.share) {
        try { await navigator.share({ title, text: 'Descubre "' + title + '" en GRN Index', url }); return; }
        catch (_) {}
      }
      try {
        await navigator.clipboard.writeText(url ?? '');
        if (label) {
          const orig = label.textContent;
          label.textContent = '¡Copiado!';
          setTimeout(() => { label.textContent = orig; }, 2000);
        }
      } catch (_) {}
    });
  })();
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const io = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } }),
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );
    document.querySelectorAll('[data-reveal]').forEach(el => io.observe(el));
  });
</script>

<style is:global>
  /* UPGRADED LAYOUT */
  .upgraded-layout {
    gap: 5rem;
    grid-template-columns: 1fr 380px; /* Made right column wider */
    max-width: 1300px;
    margin: 0 auto;
  }

  /* LEFT TRACK: MAIN */
  .upgraded-main {
    background: transparent; /* Removing the old continuous border bg */
    gap: 3rem;
  }

  .upg-block {
    position: relative;
    padding: 3rem;
    background: var(--s-bg-hi);
    border: 1px solid var(--s-border);
    border-radius: 20px;
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 4px 20px rgba(0,0,0,0.015);
  }
  
  .upg-block:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.04);
  }

  .upg-block.is-visible { opacity: 1; transform: translateY(0); }

  .upg-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .upg-num { font-family: var(--font-display); font-size: 0.75rem; font-weight: 600; color: var(--s-orange); }
  .upg-line { height: 1px; flex: 1; max-width: 60px; background: linear-gradient(90deg, var(--s-orange), transparent); opacity: 0.5; }
  .upg-eyebrow { font-family: var(--font-display); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--s-ink-3); }

  .upg-title {
    font-family: var(--font-body);
    font-size: 2.2rem;
    font-weight: 300;
    letter-spacing: -0.02em;
    color: var(--s-ink);
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  .upg-lead { font-family: var(--font-display); font-size: 1.1rem; line-height: 1.8; color: var(--s-ink-2); max-width: 68ch; }

  .upg-long-desc { margin-top: 1.5rem; display: flex; flex-direction: column; gap: 1.2rem; }
  .upg-long-desc p { font-family: var(--font-display); font-size: 1rem; line-height: 1.75; color: var(--s-ink-2); max-width: 68ch; }


  /* VENUE BLOCK Upgrades */
  .upg-venue-block { padding: 0; overflow: hidden; }
  .upg-venue-block .upg-header { padding: 3rem 3rem 0; margin-bottom: 1.5rem; }
  
  .upg-venue-grid {
    display: flex;
    flex-direction: column;
  }

  .upg-venue-info { padding: 0 3rem 3rem; }
  .upg-venue-title { font-size: 2.8rem; margin-bottom: 1rem; }
  
  .upg-venue-badges { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
  .upg-badge {
    display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.5rem 1rem;
    border-radius: 8px; font-family: var(--font-display); font-size: 0.75rem; font-weight: 600; letter-spacing: 0.05em;
    background: rgba(201,168,76,0.15); color: #8a6d3b; border: 1px solid rgba(201,168,76,0.3);
  }
  .upg-badge.ghost { background: transparent; border-color: var(--s-border); color: var(--s-ink-2); }
  .upg-badge svg { width: 14px; height: 14px; }

  .upg-venue-desc { font-size: 1rem; line-height: 1.7; color: var(--s-ink-2); max-width: 60ch; }
  
  .upg-venue-map-wrapper {
    position: relative;
    height: 300px;
    border-top: 1px solid var(--s-border);
  }
  .upg-map-glass-overlay {
    position: absolute; inset: 0; pointer-events: none; z-index: 2;
    box-shadow: inset 0 20px 20px rgba(250,248,245,0.8);
  }

  /* HIGHLIGHTS Upgrades */
  .upg-highlights { display: flex; flex-direction: column; gap: 1.5rem; }
  .upg-hl-item {
    display: flex; gap: 1.5rem; align-items: flex-start;
    opacity: 0; transform: translateX(-20px);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1) var(--hl-delay);
  }
  .upg-block.is-visible .upg-hl-item { opacity: 1; transform: translateX(0); }
  
  .upg-hl-num-wrap {
    width: 40px; height: 40px; border-radius: 50%;
    background: var(--s-bg); border: 1px solid var(--s-border);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .upg-hl-num { font-family: var(--font-display); font-size: 0.8rem; font-weight: 600; color: var(--s-ink); }
  .upg-hl-text { font-family: var(--font-display); font-size: 1.05rem; line-height: 1.6; color: var(--s-ink-2); padding-top: 0.45rem; }

  /* TIPS */
  .block-tips {
    background: linear-gradient(135deg, rgba(232,98,42,0.05), transparent);
    border-color: rgba(232,98,42,0.15);
  }
  .upg-tips-content { display: flex; gap: 1.5rem; align-items: flex-start; }
  .upg-tips-icon {
    width: 48px; height: 48px; border-radius: 12px; background: rgba(232,98,42,0.1);
    color: var(--s-orange); display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .upg-tips-icon svg { width: 24px; height: 24px; }
  .upg-tips-text { font-size: 1.1rem; line-height: 1.7; color: var(--s-ink-2); font-style: italic; }

  /* TAGS */
  .upg-tags { opacity: 0; transform: translateY(20px); transition: all 0.6s ease; margin-left: 1rem; }
  .upg-tags.is-visible { opacity: 1; transform: translateY(0); }
  .upg-tags-title { display: block; font-family: var(--font-display); font-size: 0.65rem; font-weight: 700; color: var(--s-ink-3); margin-bottom: 1rem; letter-spacing: 0.1em; }
  .upg-tags-list { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .upg-tag {
    padding: 0.5rem 1rem; background: rgba(26,22,25,0.03); border-radius: 100px;
    font-family: var(--font-display); font-size: 0.75rem; color: var(--s-ink-2);
    transition: all 0.3s ease;
  }
  .upg-tag:hover { background: var(--s-ink); color: #fff; }

  /* RIGHT TRACK: SIDEBAR */
  .upg-sidebar-sticky { position: sticky; top: calc(var(--header-height, 64px) + 2rem); display: flex; flex-direction: column; gap: 2rem; }

  /* Premium Ticket Card */
  .upg-ticket-card {
    position: relative;
    background: #fff;
    border-radius: 24px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.04), 0 1px 3px rgba(0,0,0,0.02);
    overflow: hidden;
    opacity: 0; transform: translateY(40px) scale(0.98);
    transition: all 0.9s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .upg-ticket-card.is-visible { opacity: 1; transform: translateY(0) scale(1); }
  
  .upg-tc-header { padding: 2.5rem 2.5rem 2rem; display: flex; align-items: center; gap: 1.5rem; }
  .upg-tc-date-box {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    width: 64px; height: 64px; border-radius: 16px; background: rgba(201,168,76,0.15); color: #8a6d3b;
    border: 1px solid rgba(201,168,76,0.3);
  }
  .tc-day { font-family: var(--font-body); font-size: 1.5rem; font-weight: 400; line-height: 1; }
  .tc-month { font-family: var(--font-display); font-size: 0.6rem; font-weight: 700; letter-spacing: 0.1em; margin-top: 0.2rem; }
  
  .upg-tc-info { display: flex; flex-direction: column; gap: 0.4rem; }
  .tc-time { display: flex; align-items: center; gap: 0.4rem; font-family: var(--font-display); font-size: 0.95rem; font-weight: 600; color: var(--s-ink); }
  .tc-time svg { width: 16px; height: 16px; color: var(--s-orange); }
  .tc-category { font-family: var(--font-display); font-size: 0.75rem; letter-spacing: 0.05em; color: var(--s-ink-3); text-transform: uppercase; }

  .upg-tc-price-wrap { padding: 0 2.5rem 2rem; display: flex; flex-direction: column; gap: 0.2rem; }
  .tc-price-label { font-family: var(--font-display); font-size: 0.75rem; font-weight: 600; color: var(--s-ink-3); text-transform: uppercase; letter-spacing: 0.1em; }
  .tc-price-val { font-family: var(--font-body); font-size: 3.5rem; font-weight: 300; color: var(--s-ink); line-height: 1; letter-spacing: -0.03em; }
  .tc-price-val.is-free { color: #4a9e6b; font-size: 2.8rem; }
  .tc-price-val.is-tickets { color: var(--s-orange); font-size: 2.8rem; }

  /* Ticket divider (dashed with holes) */
  .upg-tc-divider {
    position: relative; display: flex; align-items: center; height: 32px;
  }
  .tcd-hole {
    width: 32px; height: 32px; background: var(--s-bg); border-radius: 50%;
    position: absolute; top: 0; box-shadow: inset 0 2px 5px rgba(0,0,0,0.02);
  }
  .tcd-hole.left { left: -16px; }

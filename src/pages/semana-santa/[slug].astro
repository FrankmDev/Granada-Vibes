---
import BaseLayout from '@layouts/BaseLayout.astro';
import NavBar from '@components/layout/NavBar.astro';
import Footer from '@components/layout/Footer.astro';
import CofradiaHero from '@components/semana-santa/CofradiaHero.astro';
import CofradiaDetailContent from '@components/semana-santa/CofradiaDetailContent.astro';
import CofradiaMainBlocks from '@components/semana-santa/CofradiaMainBlocks.astro';
import CofradiaSidebar from '@components/semana-santa/CofradiaSidebar.astro';
import { getAllCofradias } from '@data/semana-santa/index.js';

export function getStaticPaths() {
  return getAllCofradias().map((c) => ({
    params: { slug: c.id },
    props: { cofradia: c },
  }));
}

const { cofradia } = Astro.props;
const locale = 'es';
const dia = cofradia.dia;

const sameDayCofradias = getAllCofradias()
  .filter((c) => c.dia.id === dia.id && c.id !== cofradia.id)
  .slice(0, 3)
  .map((c) => {
    const h = c.horario as Record<string, string>;
    return { ...c, salidaDisplay: h.salida ?? h.salidaCasaHermandad ?? '—' };
  });

const salidaTime =
  (cofradia.horario as Record<string, string>).salida ??
  (cofradia.horario as Record<string, string>).salidaCasaHermandad ??
  '';

const seoDescription = `${cofradia.nombrePopular} — ${cofradia.nombreOficial}. ${dia.nombre} de la Semana Santa de Granada 2026. Sale desde ${cofradia.iglesiaSalida}, barrio ${cofradia.barrio}. Horario, itinerario y toda la información en Granada Vibes.`;

const schemaData = {
  '@type': 'SocialEvent',
  name: cofradia.nombreOficial,
  startDate: salidaTime ? `${dia.fecha}T${salidaTime}:00` : dia.fecha,
  location: {
    '@type': 'Place',
    name: cofradia.iglesiaSalida,
    address: 'Granada, España',
  },
  description: seoDescription,
  organizer: {
    '@type': 'Organization',
    name: cofradia.nombrePopular,
  },
};
---

<BaseLayout
  locale={locale}
  title={`${cofradia.nombrePopular} — Semana Santa Granada 2026`}
  description={seoDescription}
  ogImage="https://placehold.co/1200x630/080808/f0ede8?text=Semana+Santa+Granada"
  schemaType="event"
  schemaData={schemaData}
>
  <NavBar slot="header" locale={locale} currentPath={Astro.url.pathname} />

  <CofradiaHero cofradia={cofradia} locale={locale} />

  <CofradiaDetailContent>
    <div class="det-page">
      <div class="det-content-wrap">
        <div class="det-layout">

          <main id="main-content" class="det-main">
            <CofradiaMainBlocks cofradia={cofradia} />
          </main>

          <aside>
            <CofradiaSidebar
              cofradia={cofradia}
              sameDayCofradias={sameDayCofradias}
              currentUrl={Astro.url.href}
            />
          </aside>

        </div>
      </div>

      <div class="det-footer-orn" aria-hidden="true">
        <span class="det-orn-line"></span>
        <span class="det-orn-diamond"></span>
        <span class="det-orn-star">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17.2l-6.2 4.1 2.4-7.4L2 9.4h7.6z"/>
          </svg>
        </span>
        <span class="det-orn-diamond"></span>
        <span class="det-orn-line"></span>
      </div>
    </div>
  </CofradiaDetailContent>

  <Footer slot="footer" locale={locale} />
</BaseLayout>

<script is:inline>
  (function () {
    const btn = document.getElementById('share-btn');
    if (!btn) return;
    btn.addEventListener('click', async function () {
      const title = btn.dataset.title;
      const url   = btn.dataset.url;
      const label = btn.querySelector('.share-label');
      if (navigator.share) {
        try { await navigator.share({ title, text: 'Descubre "' + title + '" en Granada Vibes', url }); return; }
        catch (_) {}
      }
      try {
        await navigator.clipboard.writeText(url ?? '');
        if (label) {
          const orig = label.textContent;
          label.textContent = '¡Copiado!';
          setTimeout(() => { label.textContent = orig; }, 2000);
        }
      } catch (_) {}
    });
  })();
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const io = new IntersectionObserver(
      (entries) => entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          
          // Trigger inner animations for paso cards
          if (e.target.classList.contains('ss-block-02')) {
            e.target.querySelectorAll('.ss-paso-card').forEach((card, i) => {
              setTimeout(() => card.classList.add('is-visible'), 200 + (i * 150));
            });
          }
          
          // Trigger inner animations for musica items
          if (e.target.classList.contains('ss-block-05')) {
            e.target.querySelectorAll('.ss-musica-item').forEach((item, i) => {
              setTimeout(() => item.classList.add('is-visible'), 200 + (i * 150));
            });
          }
          
          io.unobserve(e.target);
        }
      }),
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('[data-reveal]').forEach(el => io.observe(el));
  });
</script>

<script>
  (function () {
    const bar = document.createElement('div');
    bar.id = 'read-progress';
    bar.setAttribute('aria-hidden', 'true');
    document.body.appendChild(bar);
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
          bar.style.setProperty('--scroll-progress', `${progress}%`);
          ticking = false;
        });
        ticking = true;
      }
    });
  })();
</script>

<style is:global>
  #read-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: var(--scroll-progress, 0%);
    height: 3px;
    background: linear-gradient(90deg, #c9a84c, #e6c587, #c9a84c);
    background-size: 200% 100%;
    animation: shimmer 2s linear infinite;
    z-index: 9999;
    transition: width 0.1s linear;
    pointer-events: none;
    box-shadow: 0 2px 10px rgba(201, 168, 76, 0.4);
  }

  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  .det-block-premium {
    position: relative;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
  }

  .det-block-premium:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.06), 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .det-block-footer {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(26, 22, 25, 0.06);
  }

  .det-block-accent-line {
    display: block;
    width: 40px;
    height: 2px;
    background: linear-gradient(90deg, #c9a84c, transparent);
    transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .det-block-premium:hover .det-block-accent-line {
    width: 80px;
  }
</style>

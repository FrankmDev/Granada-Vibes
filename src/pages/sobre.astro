---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/layout/PageHeader.astro';
import { useTranslations } from '@i18n/utils';

const locale = 'es';
const t = useTranslations(locale);

const ogImage = 'https://placehold.co/1200x630/0F0E0C/FAF9F7?text=Granada+Vibes';

const values = [
  {
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
    title: 'Autenticidad',
    desc: 'Solo recomendamos lo que le diríamos a un amigo. Sin pagos por posicionamiento, ni trampas turísticas.'
  },
  {
    icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z',
    title: 'Calidad Curada',
    desc: 'Cada evento es seleccionado a mano. Preferimos menos opciones que realmente merezcan tu tiempo.'
  },
  {
    icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
    title: 'Comunidad Primero',
    desc: 'Amplificamos a creadores locales, artistas y pequeños negocios que hacen cosas interesantes.'
  }
];
---

<BaseLayout 
  locale={locale} 
  title="Sobre nosotros"
  description="Granada Vibes es la guía cultural que Granada merece. Descubre quiénes somos, nuestra misión y cómo colaborar con nosotros."
  ogImage={ogImage}
  schemaType="organization"
>
  {/* Page Header */}
  <PageHeader 
    title="La guía que Granada merece"
    subtitle="Somos un equipo pequeño de granadinos y adoptados construyendo la herramienta que nos hubiera gustado tener. Eventos curados, rutas auténticas, cero ruido."
    accent="terra"
    variant="large"
  />

  {/* Mission Statement */}
  <section class="py-20 lg:py-28 relative" aria-labelledby="mission-heading">
    {/* Background accent */}
    <div class="absolute inset-0 bg-gradient-to-b from-terra/[0.02] to-transparent pointer-events-none" aria-hidden="true" />
    
    <div class="container relative">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="text-amber text-sm font-semibold uppercase tracking-[0.2em] mb-4 block">Nuestra misión</span>
        <h2 id="mission-heading" class="font-display text-3xl lg:text-4xl xl:text-5xl font-bold text-surface leading-tight mb-8">
          Cortar el ruido. <br/>
          <span class="text-surface-secondary">Encontrar la Granada real.</span>
        </h2>
        <p class="text-lg text-surface-secondary leading-relaxed">
          Las guías tradicionales se quedan obsoletas. Las redes sociales están dispersas. Demasiadas experiencias auténticas 
          nunca llegan a quienes las buscan. Filtramos el ruido para que encuentres lo que merece la pena.
        </p>
      </div>
    </div>
  </section>

  {/* Values Grid */}
  <section class="py-20 lg:py-28 relative" aria-labelledby="values-heading">
    <div class="container">
      <div class="text-center mb-16 reveal">
        <span class="text-mint text-sm font-semibold uppercase tracking-[0.2em] mb-4 block">Lo que nos mueve</span>
        <h2 id="values-heading" class="font-display text-3xl lg:text-4xl font-bold text-surface">
          Nuestros valores
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12 stagger-children">
        {values.map((value, i) => (
          <div class="group text-center p-8 rounded-3xl border border-edge bg-base-elevated/30 hover:border-edge-hover transition-all duration-500 hover:-translate-y-2">
            {/* Icon */}
            <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-terra/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-500">
              <svg class="w-8 h-8 text-terra" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={value.icon} />
              </svg>
            </div>
            
            {/* Number */}
            <span class="font-display text-5xl font-bold text-surface/[0.03] block mb-2">
              0{i + 1}
            </span>
            
            {/* Title */}
            <h3 class="font-display text-xl font-semibold text-surface mb-3">
              {value.title}
            </h3>
            
            {/* Description */}
            <p class="text-surface-secondary leading-relaxed text-sm">
              {value.desc}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* How it Works - Visual Timeline */}
  <section class="py-20 lg:py-28 relative overflow-hidden" aria-labelledby="how-heading">
    {/* Background gradient */}
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-mint/[0.02] to-transparent pointer-events-none" aria-hidden="true" />
    
    <div class="container relative">
      <div class="text-center mb-16 reveal">
        <span class="text-amber text-sm font-semibold uppercase tracking-[0.2em] mb-4 block">El proceso</span>
        <h2 id="how-heading" class="font-display text-3xl lg:text-4xl font-bold text-surface">
          Cómo funciona
        </h2>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="space-y-12">
          {/* Step 1 */}
          <div class="flex flex-col md:flex-row gap-8 items-start reveal">
            <div class="flex-shrink-0 w-16 h-16 rounded-2xl bg-terra flex items-center justify-center">
              <span class="font-display text-2xl font-bold text-surface">1</span>
            </div>
            <div class="flex-1 pt-2">
              <h3 class="font-display text-xl font-semibold text-surface mb-2">Exploramos</h3>
              <p class="text-surface-secondary leading-relaxed">
                Cada semana recorremos la ciudad, hablamos con organizadores y visitamos espacios. Sin algoritmos — solo trabajo de campo.
              </p>
            </div>
          </div>

          {/* Divider */}
          <div class="hidden md:block h-px bg-edge ml-16" />

          {/* Step 2 */}
          <div class="flex flex-col md:flex-row gap-8 items-start reveal">
            <div class="flex-shrink-0 w-16 h-16 rounded-2xl bg-amber flex items-center justify-center">
              <span class="font-display text-2xl font-bold text-base">2</span>
            </div>
            <div class="flex-1 pt-2">
              <h3 class="font-display text-xl font-semibold text-surface mb-2">Curamos</h3>
              <p class="text-surface-secondary leading-relaxed">
                Cada evento y ruta se selecciona manualmente. Buscamos autenticidad, calidad y variedad — no solo popularidad.
              </p>
            </div>
          </div>

          {/* Divider */}
          <div class="hidden md:block h-px bg-edge ml-16" />

          {/* Step 3 */}
          <div class="flex flex-col md:flex-row gap-8 items-start reveal">
            <div class="flex-shrink-0 w-16 h-16 rounded-2xl bg-mint flex items-center justify-center">
              <span class="font-display text-2xl font-bold text-surface">3</span>
            </div>
            <div class="flex-1 pt-2">
              <h3 class="font-display text-xl font-semibold text-surface mb-2">Descubres</h3>
              <p class="text-surface-secondary leading-relaxed">
                Desde flamenco en cuevas del Sacromonte hasta exposiciones de arte emergente — encuentra la Granada que existe más allá de la postal.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Collaboration CTA */}
  <section class="py-20 lg:py-28 relative" aria-labelledby="collab-heading">
    <div class="container">
      <div class="relative rounded-[2rem] overflow-hidden">
        {/* Background */}
        <div class="absolute inset-0 bg-gradient-to-br from-terra/10 via-base-elevated to-base-elevated" aria-hidden="true" />
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-terra/10 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/4" aria-hidden="true" />
        
        <div class="relative px-8 py-16 lg:px-16 lg:py-20 text-center reveal">
          <h2 id="collab-heading" class="font-display text-3xl lg:text-4xl font-bold text-surface mb-4 max-w-2xl mx-auto">
            ¿Tienes algo que compartir?
          </h2>
          <p class="text-surface-secondary text-lg max-w-xl mx-auto mb-10">
            Ya sea que organices eventos, ofrezcas tours guiados o tengas un espacio único — nos encantaría saber de ti.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a 
              href="mailto:hola@granadavibes.com?subject=Colaboración%20con%20Granada%20Vibes"
              class="btn btn-primary btn-lg"
            >
              Contactar
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a 
              href="/eventos"
              class="btn btn-secondary btn-lg"
            >
              Explorar eventos
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/layout/PageHeader.astro';
import { useTranslations } from '@i18n/utils';

const locale = 'es';
const t = useTranslations(locale);

const ogImage = 'https://placehold.co/1200x630/0F0E0C/FAF9F7?text=Granada+Vibes';

const values = [
  {
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
    title: 'Autenticidad local',
    desc: 'Solo recomendamos lo que le diríamos a un amigo. Conocemos cada barrio, cada callejón y cada bar de tapas de Granada.'
  },
  {
    icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z',
    title: 'Selección experta',
    desc: 'Cada evento y ruta la probamos personalmente. Solo publicamos lo que realmente vale la pena en la Granada de 2025.'
  },
  {
    icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
    title: 'Apoyo a lo local',
    desc: 'Colaboramos con artistas del Sacromonte, artesanos del Albaicín y bares de toda la vida que mantienen vivas las tradiciones.'
  }
];
---

<BaseLayout 
  locale={locale} 
  title="Sobre nosotros"
  description="Granada Vibes: guía cultural independiente creada por granadinos. Descubre la ciudad como un local: eventos curatorados, rutas auténticas y los mejores planes en Granada."
  ogImage={ogImage}
  schemaType="organization"
>
  {/* Page Header */}
  <PageHeader 
    title="La guía que Granada merece"
    subtitle="Guía cultural independiente creada por granadinos de toda la vida y adoptados. Conocemos cada rincón de la ciudad: desde el Albaicín hasta el Sacromonte, desde la Alhambra hasta el Realejo."
    accent="primary"
    variant="large"
  />

  {/* Mission Statement */}
  <section class="py-20 lg:py-28 relative" aria-labelledby="mission-heading">
    {/* Background accent */}
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background: linear-gradient(to bottom, rgba(232, 77, 39, 0.02), transparent);" />
    
    <div class="container relative">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="text-sm font-semibold uppercase tracking-[0.2em] mb-4 block" style="color: var(--color-secondary);">Nuestra misión</span>
        <h2 id="mission-heading" class="font-display text-3xl lg:text-4xl xl:text-5xl font-bold leading-tight mb-8" style="color: var(--color-surface);">
          La guía de Granada <br/>
          <span style="color: var(--color-surface-secondary);">que los locales usarían.</span>
        </h2>
        <p class="text-lg leading-relaxed" style="color: var(--color-surface-secondary);">
          Granada tiene dos caras: la de las guías turísticas y la de quienes la vivimos. Nosotros te mostramos 
          la segunda. Los mejores miradores del Albaicín, las cuevas flamencas del Sacromonte, los bares de toda 
          la vida donde las tapas siguen siendo gratis. Sin filtros, sin colas, sin sorpresas.
        </p>
      </div>
    </div>
  </section>

  {/* Values Grid */}
  <section class="py-20 lg:py-28 relative" aria-labelledby="values-heading">
    <div class="container">
      <div class="text-center mb-16 reveal">
        <span class="text-sm font-semibold uppercase tracking-[0.2em] mb-4 block" style="color: var(--color-success);">Lo que nos mueve</span>
        <h2 id="values-heading" class="font-display text-3xl lg:text-4xl font-bold" style="color: var(--color-surface);">
          Nuestros valores
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12 stagger-children">
        {values.map((value, i) => (
          <div class="group text-center p-8 rounded-3xl transition-all duration-500 hover:-translate-y-2" style="background: rgba(17, 17, 17, 0.3); border: 1px solid rgba(255, 255, 255, 0.06);" onmouseenter="this.style.borderColor='rgba(255, 255, 255, 0.1)';" onmouseleave="this.style.borderColor='rgba(255, 255, 255, 0.06)';">
            {/* Icon */}
            <div class="w-16 h-16 mx-auto mb-6 rounded-2xl flex items-center justify-center group-hover:scale-110 transition-transform duration-500" style="background: rgba(232, 77, 39, 0.1);">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-primary);">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={value.icon} />
              </svg>
            </div>
            
            {/* Number */}
            <span class="font-display text-5xl font-bold block mb-2" style="color: rgba(240, 237, 232, 0.03);">
              0{i + 1}
            </span>
            
            {/* Title */}
            <h3 class="font-display text-xl font-semibold mb-3" style="color: var(--color-surface);">
              {value.title}
            </h3>
            
            {/* Description */}
            <p class="leading-relaxed text-sm" style="color: var(--color-surface-secondary);">
              {value.desc}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* How it Works - Visual Timeline */}
  <section class="py-20 lg:py-28 relative overflow-hidden" aria-labelledby="how-heading">
    {/* Background gradient */}
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background: linear-gradient(to bottom, transparent, rgba(16, 185, 129, 0.02), transparent);" />
    
    <div class="container relative">
      <div class="text-center mb-16 reveal">
        <span class="text-sm font-semibold uppercase tracking-[0.2em] mb-4 block" style="color: var(--color-secondary);">El proceso</span>
        <h2 id="how-heading" class="font-display text-3xl lg:text-4xl font-bold" style="color: var(--color-surface);">
          Cómo funciona
        </h2>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="space-y-12">
          {/* Step 1 */}
          <div class="flex flex-col md:flex-row gap-8 items-start reveal">
            <div class="flex-shrink-0 w-16 h-16 rounded-2xl flex items-center justify-center" style="background-color: var(--color-primary);">
              <span class="font-display text-2xl font-bold" style="color: var(--color-surface);">1</span>
            </div>
            <div class="flex-1 pt-2">
              <h3 class="font-display text-xl font-semibold mb-2" style="color: var(--color-surface);">Recorremos Granada</h3>
              <p class="leading-relaxed" style="color: var(--color-surface-secondary);">
                Cada semana visitamos el Albaicín, el Sacromonte, el Realejo y el centro. Hablamos con organizadores, 
                probamos bares y descubrimos espacios nuevos. Trabajo de campo, no algoritmos.
              </p>
            </div>
          </div>

          {/* Divider */}
          <div class="hidden md:block h-px ml-16" style="background-color: rgba(255, 255, 255, 0.06);" />

          {/* Step 2 */}
          <div class="flex flex-col md:flex-row gap-8 items-start reveal">
            <div class="flex-shrink-0 w-16 h-16 rounded-2xl flex items-center justify-center" style="background-color: var(--color-secondary);">
              <span class="font-display text-2xl font-bold" style="color: var(--color-bg);">2</span>
            </div>
            <div class="flex-1 pt-2">
              <h3 class="font-display text-xl font-semibold mb-2" style="color: var(--color-surface);">Seleccionamos lo mejor</h3>
              <p class="leading-relaxed" style="color: var(--color-surface-secondary);">
                Cada evento y ruta pasa por nuestro filtro: ¿lo recomendaríamos a un amigo? Buscamos autenticidad, 
                calidad y esa magia que solo tienen los lugares de verdad.
              </p>
            </div>
          </div>

          {/* Divider */}
          <div class="hidden md:block h-px ml-16" style="background-color: rgba(255, 255, 255, 0.06);" />

          {/* Step 3 */}
          <div class="flex flex-col md:flex-row gap-8 items-start reveal">
            <div class="flex-shrink-0 w-16 h-16 rounded-2xl flex items-center justify-center" style="background-color: var(--color-success);">
              <span class="font-display text-2xl font-bold" style="color: var(--color-surface);">3</span>
            </div>
            <div class="flex-1 pt-2">
              <h3 class="font-display text-xl font-semibold mb-2" style="color: var(--color-surface);">Tú descubres</h3>
              <p class="leading-relaxed" style="color: var(--color-surface-secondary);">
                Flamenco auténtico en cuevas del Sacromonte, miradores secretos del Albaicín, bares de toda la vida 
                en el Realejo. La Granada que no sale en las guías turísticas, pero que los locales conocemos bien.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Collaboration CTA */}
  <section class="py-20 lg:py-28 relative" aria-labelledby="collab-heading">
    <div class="container">
      <div class="relative rounded-[2rem] overflow-hidden">
        {/* Background */}
        <div class="absolute inset-0" aria-hidden="true" style="background: linear-gradient(to bottom right, rgba(232, 77, 39, 0.1), var(--color-bg-elevated), var(--color-bg-elevated));" />
        <div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full blur-[120px] -translate-y-1/2 translate-x-1/4" aria-hidden="true" style="background: rgba(232, 77, 39, 0.1);" />
        
        <div class="relative px-8 py-16 lg:px-16 lg:py-20 text-center reveal">
          <h2 id="collab-heading" class="font-display text-3xl lg:text-4xl font-bold mb-4 max-w-2xl mx-auto" style="color: var(--color-surface);">
            ¿Eres de Granada y organizas algo?
          </h2>
          <p class="text-lg max-w-xl mx-auto mb-10" style="color: var(--color-surface-secondary);">
            Si organizas eventos culturales, das tours por el Albaicín o el Sacromonte, o tienes un espacio único 
            en Granada — nos encantaría colaborar contigo.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a 
              href="mailto:hola@granadavibes.com?subject=Colaboración%20con%20Granada%20Vibes"
              class="btn btn-primary btn-lg"
            >
              Contactar
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a 
              href="/eventos"
              class="btn btn-secondary btn-lg"
            >
              Explorar eventos
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/layout/PageHeader.astro';
import Icon from '@components/ui/Icon.astro';
import { useTranslations } from '@i18n/utils';

const locale = 'es';
const t = useTranslations(locale);

const values = [
  {
    icon: 'check' as const,
    title: t('about.values.authentic.title'),
    description: t('about.values.authentic.description'),
    color: 'accent' as const,
  },
  {
    icon: 'star' as const,
    title: t('about.values.quality.title'),
    description: t('about.values.quality.description'),
    color: 'sand' as const,
  },
  {
    icon: 'users' as const,
    title: t('about.values.community.title'),
    description: t('about.values.community.description'),
    color: 'sage' as const,
  },
];

const colors = {
  accent: 'bg-accent/10 text-accent',
  sand: 'bg-sand/10 text-sand',
  sage: 'bg-sage/10 text-sage',
};
---

<BaseLayout 
  locale={locale} 
  title={t('about.title')}
  description={t('about.mission.description')}
  schemaType="organization"
>
  <PageHeader 
    title={t('about.title')}
    accent="accent"
  />

  {/* Mission Statement */}
  <section class="container pb-16" aria-labelledby="mission-heading">
    <div class="max-w-3xl">
      <p id="mission-heading" class="text-lg lg:text-xl text-text-secondary leading-relaxed">
        {t('about.mission.description')}
      </p>
    </div>
  </section>

  {/* Values Section */}
  <section class="container py-16 lg:py-20" aria-labelledby="values-heading">
    <h2 id="values-heading" class="sr-only">{t('about.values.title')}</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
      {values.map((value) => (
        <div class="text-center md:text-left">
          <div class:list={['w-12 h-12 rounded-xl flex items-center justify-center mb-5 mx-auto md:mx-0', colors[value.color]]}>
            <Icon name={value.icon} class="w-6 h-6" />
          </div>
          <h3 class="font-display text-xl font-medium text-text-primary mb-3">
            {value.title}
          </h3>
          <p class="text-text-secondary text-sm leading-relaxed">
            {value.description}
          </p>
        </div>
      ))}
    </div>
  </section>

  {/* Contact CTA */}
  <section class="container py-16 lg:py-20" aria-labelledby="contact-heading">
    <div class="max-w-3xl mx-auto p-8 lg:p-12 bg-bg-card border border-border rounded-2xl text-center">
      <h2 id="contact-heading" class="font-display text-2xl lg:text-3xl font-semibold text-text-primary mb-4">
        ¿Tienes un evento o ruta que compartir?
      </h2>
      <p class="text-text-secondary mb-8 max-w-xl mx-auto">
        Estamos siempre buscando nuevas experiencias para compartir con nuestra comunidad. Si organizas eventos culturales o conoces rutas especiales en Granada, nos encantaría saber de ti.
      </p>
      <a 
        href="mailto:hola@granadavibes.com"
        class="inline-flex items-center gap-2 px-6 py-3.5 bg-accent text-bg font-semibold text-sm uppercase tracking-wider rounded-xl transition-all duration-300 hover:shadow-[0_8px_30px_rgba(224,122,95,0.25)] focus:outline-none focus:ring-2 focus:ring-accent/50"
      >
        Contáctanos
      </a>
    </div>
  </section>
</BaseLayout>

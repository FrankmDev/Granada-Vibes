---
import BaseLayout from '@layouts/BaseLayout.astro';
import NavBar from '@components/layout/NavBar.astro';
import Footer from '@components/layout/Footer.astro';
import BlogDetailHero from '@components/blog/BlogDetailHero.astro';
import BlogDetailContent from '@components/blog/BlogDetailContent.astro';
import { getAllPosts, getRelatedPosts } from '@data/index.js';
import { useTranslations } from '@i18n/utils';
import type { BlogPost } from '@types';

export function getStaticPaths() {
  const posts = getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: BlogPost };
const locale = 'es';
const t = useTranslations(locale);

const relatedPosts = getRelatedPosts(post, 3);

const formattedDate = new Date(post.publishDate).toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const categoryLabel = t(`blog.categories.${post.category}`);
const ogImage = post.image ?? 'https://placehold.co/1200x630/0a0a0a/f0ede8?text=Granada+Vibes+Blog';

const seoDescription = `${post.description[locale]} — ${categoryLabel}. Por ${post.author}. ${t('blog.readingTime', { minutes: post.readingTime })}.`;

const schemaData = {
  '@type': 'Article',
  headline: post.title[locale],
  description: post.description[locale],
  datePublished: post.publishDate,
  author: { '@type': 'Person', name: post.author },
  publisher: { '@type': 'Organization', name: 'Granada Vibes' },
  image: ogImage,
};
---

<BaseLayout
  locale={locale}
  title={post.title[locale]}
  description={seoDescription}
  ogImage={ogImage}
  ogType="article"
  schemaType="website"
  schemaData={schemaData}
>
  <NavBar slot="header" locale={locale} currentPath={Astro.url.pathname} />

  <!-- DARK CINEMATIC HERO -->
  <BlogDetailHero post={post} locale={locale} formattedDate={formattedDate} />

  <!-- CREAM EDITORIAL CONTENT -->
  <BlogDetailContent>
  <div class="det-page">
    <div class="det-content-wrap">
      <div class="det-layout">

        <!-- MAIN COLUMN (70%) -->
        <main id="main-content" class="det-main">

          <!-- Article prose content -->
          <article class="blg-article-block det-block det-block-premium is-visible" aria-label={post.title[locale]}>
            <header class="blg-article-header">
              <span class="blg-article-eyebrow">[ Artículo ]</span>
              <div class="blg-article-divider"></div>
            </header>
            <div class="blg-prose" set:html={post.content[locale]} />
            <footer class="blg-article-footer">
              <span class="blg-article-end">§</span>
            </footer>
            <div class="det-hover-corners" aria-hidden="true">
              <span class="hc tl"></span><span class="hc tr"></span>
              <span class="hc bl"></span><span class="hc br"></span>
            </div>
          </article>

          <!-- Tags -->
          {post.tags.length > 0 && (
            <div class="blg-tags-block det-tags-premium" data-reveal>
              <div class="blg-tags-header">
                <span class="blg-tags-eyebrow">[ {t('detail.tags')} ]</span>
                <div class="blg-tags-divider"></div>
              </div>
              <div class="blg-tags-flow">
                {post.tags.map((tag, i) => (
                  <span class="blg-tag-pill" style={`--ti: ${i}`}>#{tag}</span>
                ))}
              </div>
            </div>
          )}

          <!-- Author card -->
          <div class="blg-author-card" data-reveal>
            <div class="blg-author-avatar">
              <span class="blg-author-initial">{post.author.charAt(0)}</span>
            </div>
            <div class="blg-author-info">
              <span class="blg-author-label">Escrito por</span>
              <span class="blg-author-name">{post.author}</span>
              <span class="blg-author-bio">Colaborador de Granada Vibes especializado en cultura local y turismo experiencial.</span>
            </div>
          </div>

        </main>

        <!-- SIDEBAR (30%) -->
        <aside>
          <div class="det-sidebar-sticky">

            <!-- Info card -->
            <div class="det-sidebar-card det-card-premium" data-reveal>
              <div class="det-sc-head">
                <span class="det-sc-eyebrow">[ {locale === 'es' ? 'Información' : 'Information'} ]</span>
                <div class="det-sc-line"></div>
              </div>

              <div class="det-info-section">
                <div class="det-info-row">
                  <span class="det-info-label">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                    {t('detail.author')}
                  </span>
                  <span class="det-info-val">{post.author}</span>
                </div>
                <div class="det-info-sep"></div>
                <div class="det-info-row">
                  <span class="det-info-label">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    {t('detail.publishDate')}
                  </span>
                  <span class="det-info-val">
                    <time datetime={post.publishDate}>{formattedDate}</time>
                  </span>
                </div>
              </div>

              <div class="det-info-section">
                <div class="det-info-sep"></div>
                <div class="det-info-row">
                  <span class="det-info-label">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    {t('detail.readingTime')}
                  </span>
                  <span class="det-info-val">{t('blog.readingTime', { minutes: post.readingTime })}</span>
                </div>
                <div class="det-info-sep"></div>
                <div class="det-info-row">
                  <span class="det-info-label">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                    </svg>
                    {t('detail.category')}
                  </span>
                  <span class="det-info-val">{categoryLabel}</span>
                </div>
              </div>

              <button
                id="share-btn"
                class="blg-share-btn"
                data-title={post.title[locale]}
                data-url={Astro.url.href}
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
                </svg>
                <span class="share-label" aria-live="polite">{t('detail.share')}</span>
              </button>
            </div>

            <!-- Related posts -->
            {relatedPosts.length > 0 && (
              <div class="det-sidebar-card det-card-premium" data-reveal>
                <div class="det-sc-head">
                  <span class="det-sc-eyebrow">[ {t('detail.relatedPosts')} ]</span>
                  <div class="det-sc-line"></div>
                </div>
                <div class="det-related-list">
                  {relatedPosts.map((related, i) => (
                    <a
                      href={`/blog/${related.slug}`}
                      class="det-related-item"
                      style={`--ri: ${i}`}
                      aria-label={related.title[locale]}
                    >
                      <div class="det-rel-thumb">
                        {related.image ? (
                          <img src={related.image} alt="" loading="lazy" />
                        ) : (
                          <div class="det-rel-thumb-fallback">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                              <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                            </svg>
                          </div>
                        )}
                        <div class="det-rel-thumb-overlay"></div>
                      </div>
                      <div class="det-rel-info">
                        <span class="det-rel-title">{related.title[locale]}</span>
                        <span class="det-rel-meta">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                          </svg>
                          {t('blog.readingTime', { minutes: related.readingTime })}
                        </span>
                      </div>
                      <svg class="det-rel-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  ))}
                </div>
                <a href="/blog" class="det-all-link">
                  {t('detail.allPosts')}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </div>
            )}

          </div>
        </aside>

      </div>
    </div>

    <!-- Footer ornament -->
    <div class="det-footer-orn" aria-hidden="true">
      <span class="det-orn-line"></span>
      <span class="det-orn-diamond"></span>
      <span class="det-orn-star">
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17.2l-6.2 4.1 2.4-7.4L2 9.4h7.6z"/>
        </svg>
      </span>
      <span class="det-orn-diamond"></span>
      <span class="det-orn-line"></span>
    </div>

  </div>
  </BlogDetailContent>

  <Footer slot="footer" locale={locale} />
</BaseLayout>

<script is:inline>
  (function () {
    const btn = document.getElementById('share-btn');
    if (!btn) return;
    btn.addEventListener('click', async function () {
      const title = btn.dataset.title;
      const url   = btn.dataset.url;
      const label = btn.querySelector('.share-label');
      if (navigator.share) {
        try { await navigator.share({ title, text: 'Lee "' + title + '" en Granada Vibes', url }); return; }
        catch (_) {}
      }
      try {
        await navigator.clipboard.writeText(url ?? '');
        if (label) {
          const orig = label.textContent;
          label.textContent = '¡Enlace copiado!';
          setTimeout(() => { label.textContent = orig; }, 2000);
        }
      } catch (_) {}
    });
  })();
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const io = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } }),
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('[data-reveal]').forEach(el => io.observe(el));
  });
</script>

<!-- Reading progress bar -->
<script>
  (function () {
    const bar = document.createElement('div');
    bar.id = 'read-progress';
    bar.setAttribute('aria-hidden', 'true');
    document.body.appendChild(bar);

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
          bar.style.setProperty('--scroll-progress', `${progress}%`);
          ticking = false;
        });
        ticking = true;
      }
    });
  })();
</script>

<style is:global>
  #read-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: var(--scroll-progress, 0%);
    height: 3px;
    background: linear-gradient(90deg, #c9a84c, #e6c587, #c9a84c);
    background-size: 200% 100%;
    animation: shimmer 2s linear infinite;
    z-index: 9999;
    transition: width 0.1s linear;
    pointer-events: none;
    box-shadow: 0 2px 10px rgba(201, 168, 76, 0.4);
  }

  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* Premium block styling */
  .det-block-premium {
    position: relative;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
  }

  .det-block-premium:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.06), 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  /* Blog article enhancements */
  .blg-article-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(26, 22, 25, 0.08);
  }

  .blg-article-eyebrow {
    font-family: var(--font-display, 'DM Sans', sans-serif);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #c9a84c;
    white-space: nowrap;
  }

  .blg-article-divider {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(26, 22, 25, 0.15), transparent);
  }

  .blg-article-footer {
    display: flex;
    justify-content: center;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(26, 22, 25, 0.08);
  }

  .blg-article-end {
    font-family: var(--font-body, 'Fraunces', serif);
    font-size: 1.5rem;
    color: rgba(201, 168, 76, 0.6);
    line-height: 1;
  }

  /* Author card */
  .blg-author-card {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    margin-top: 2rem;
    padding: 1.5rem;
    background: linear-gradient(135deg, rgba(26, 22, 25, 0.03), rgba(26, 22, 25, 0.01));
    border: 1px solid rgba(26, 22, 25, 0.08);
    border-radius: 8px;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .blg-author-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
    border-color: rgba(201, 168, 76, 0.2);
  }

  .blg-author-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(135deg, #c9a84c, #e6c587);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 4px 15px rgba(201, 168, 76, 0.3);
  }

  .blg-author-initial {
    font-family: var(--font-body, 'Fraunces', serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: white;
  }

  .blg-author-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .blg-author-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--s-ink-3, #8a7f77);
  }

  .blg-author-name {
    font-family: var(--font-body, 'Fraunces', serif);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--s-ink-1, #1a1619);
  }

  .blg-author-bio {
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--s-ink-2, #5a5550);
    margin-top: 0.25rem;
  }

  /* Enhanced tags */
  .blg-tags-block {
    margin-top: 2rem;
  }

  .blg-tags-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .blg-tags-divider {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(26, 22, 25, 0.1), transparent);
  }

  .blg-tags-flow {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .blg-tag-pill {
    padding: 0.5rem 1rem;
    background: rgba(26, 22, 25, 0.04);
    border: 1px solid rgba(26, 22, 25, 0.1);
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--s-ink-2, #5a5550);
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    cursor: default;
  }

  .blg-tag-pill:hover {
    transform: translateY(-2px);
    background: rgba(201, 168, 76, 0.12);
    border-color: rgba(201, 168, 76, 0.3);
    color: #8a6d3b;
    box-shadow: 0 4px 12px rgba(201, 168, 76, 0.15);
  }

  /* Premium sidebar cards */
  .det-card-premium {
    position: relative;
    overflow: hidden;
  }

  .det-card-premium::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #c9a84c, #e6c587, #c9a84c);
    background-size: 200% 100%;
    animation: shimmer 3s linear infinite;
  }

  .det-info-section {
    padding: 0.5rem 0;
  }

  .det-info-section:first-of-type {
    padding-top: 0;
  }

  .det-info-label svg {
    width: 16px;
    height: 16px;
    opacity: 0.5;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .det-info-row:hover .det-info-label svg {
    opacity: 0.8;
    transform: scale(1.1);
  }

  /* Enhanced share button */
  .blg-share-btn {
    width: 100%;
    margin-top: 1.25rem;
    padding: 0.9rem 1.25rem;
    background: linear-gradient(135deg, rgba(26, 22, 25, 0.06), rgba(26, 22, 25, 0.02));
    border: 1px solid rgba(26, 22, 25, 0.12);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--s-ink-2, #5a5550);
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .blg-share-btn:hover {
    background: rgba(201, 168, 76, 0.1);
    border-color: rgba(201, 168, 76, 0.3);
    color: #8a6d3b;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(201, 168, 76, 0.15);
  }

  .blg-share-btn svg {
    width: 18px;
    height: 18px;
  }

  /* Enhanced related items */
  .det-related-item {
    position: relative;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .det-related-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(180deg, #c9a84c, #e6c587);
    transform: scaleY(0);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .det-related-item:hover {
    background: rgba(201, 168, 76, 0.04);
    transform: translateX(4px);
  }

  .det-related-item:hover::before {
    transform: scaleY(1);
  }

  .det-rel-meta svg {
    width: 12px;
    height: 12px;
    opacity: 0.5;
  }

  /* Hover corners enhanced */
  .hc {
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .det-block-premium:hover .hc {
    border-color: rgba(201, 168, 76, 0.5);
  }

  /* Prose content enhancements */
  .blg-prose p {
    margin-bottom: 1.5rem;
    line-height: 1.8;
  }

  .blg-prose h2 {
    font-family: var(--font-body, 'Fraunces', serif);
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--s-ink-1, #1a1619);
    position: relative;
    padding-bottom: 0.5rem;
  }

  .blg-prose h2::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 40px;
    height: 2px;
    background: linear-gradient(90deg, #c9a84c, transparent);
  }

  .blg-prose h3 {
    font-family: var(--font-body, 'Fraunces', serif);
    font-size: 1.2rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--s-ink-1, #1a1619);
  }

  .blg-prose blockquote {
    margin: 2rem 0;
    padding: 1.5rem 1.5rem 1.5rem 2rem;
    background: linear-gradient(135deg, rgba(201, 168, 76, 0.06), rgba(201, 168, 76, 0.02));
    border-left: 3px solid rgba(201, 168, 76, 0.4);
    font-style: italic;
    position: relative;
  }

  .blg-prose blockquote::before {
    content: '"';
    position: absolute;
    top: 0.5rem;
    left: 0.75rem;
    font-family: var(--font-body, 'Fraunces', serif);
    font-size: 3rem;
    color: rgba(201, 168, 76, 0.3);
    line-height: 1;
  }

  .blg-prose ul, .blg-prose ol {
    margin: 1.5rem 0;
    padding-left: 1.5rem;
  }

  .blg-prose li {
    margin-bottom: 0.5rem;
    position: relative;
  }

  .blg-prose li::marker {
    color: #c9a84c;
  }
</style>
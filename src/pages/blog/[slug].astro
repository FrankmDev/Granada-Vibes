---
import BaseLayout from '@layouts/BaseLayout.astro';
import NavBar from '@components/layout/NavBar.astro';
import Footer from '@components/layout/Footer.astro';
import BlogDetailHero from '@components/blog/BlogDetailHero.astro';
import OptimizedImage from '@components/ui/OptimizedImage.astro';
import BlogDetailContent from '@components/blog/BlogDetailContent.astro';
import { getAllPosts, getRelatedPosts } from '@data/index.js';
import { useTranslations } from '@i18n/utils';
import type { BlogPost } from '@types';

export function getStaticPaths() {
  const posts = getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: BlogPost };
const locale = 'es';
const t = useTranslations(locale);

const relatedPosts = getRelatedPosts(post, 3);

const pDate = new Date(post.publishDate);
const formattedDate = pDate.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const dayNum = pDate.getDate().toString().padStart(2, '0');
const monthShort = pDate.toLocaleDateString('es-ES', { month: 'short' }).toUpperCase();

const categoryLabel = t(`blog.categories.${post.category}`);
const ogImage = post.image ?? 'https://placehold.co/1200x630/0a0a0a/f0ede8?text=Granada+Vibes+Blog';

const seoDescription = `${post.description[locale]} — ${categoryLabel}. Por ${post.author}. ${t('blog.readingTime', { minutes: post.readingTime })}.`;

const articleSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title[locale],
  description: post.description[locale],
  datePublished: post.publishDate,
  author: { '@type': 'Person', name: post.author },
  publisher: { '@type': 'Organization', name: 'GRN Index', url: 'https://granadavibes.com' },
  image: ogImage,
  url: Astro.url.href,
});
---

<BaseLayout
  locale={locale}
  title={post.title[locale]}
  description={seoDescription}
  ogImage={ogImage}
  ogType="article"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={articleSchema} />
  </Fragment>
  <NavBar slot="header" locale={locale} currentPath={Astro.url.pathname} />

  <!-- DARK CINEMATIC HERO -->
  <BlogDetailHero post={post} locale={locale} formattedDate={formattedDate} />

  <!-- CREAM EDITORIAL CONTENT WITH UPGRADED UI -->
  <BlogDetailContent>
  <div class="det-page blog-page-override">

    <div class="det-content-wrap">
      <div class="det-layout upgraded-layout">

        <!-- MAIN COLUMN -->
        <main id="main-content" class="det-main upgraded-main">

          <!-- 1. The Article -->
          <article class="upg-block" data-reveal aria-label={post.title[locale]}>
            <div class="upg-block-bg"></div>
            <header class="upg-header">
              <span class="upg-num">01</span>
              <div class="upg-line"></div>
              <span class="upg-eyebrow">[ Artículo ]</span>
            </header>
            
            <div class="blg-prose content-rich" set:html={post.content[locale]} />
          </article>

          <!-- 2. The Author Card -->
          <article class="upg-block" data-reveal style="padding: 2.5rem 3rem;">
            <div class="upg-block-bg"></div>
            <div style="display:flex; gap: 1.5rem; align-items: center;">
              <div class="upg-author-avatar">
                <span class="upg-author-initial">{post.author.charAt(0)}</span>
              </div>
              <div>
                <span style="font-family: var(--font-display); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; color: var(--s-ink-3); text-transform: uppercase; display: block; margin-bottom: 0.2rem;">Escrito por</span>
                <span style="font-family: var(--font-body); font-size: 1.5rem; font-weight: 600; color: var(--s-ink); display: block; margin-bottom: 0.4rem;">{post.author}</span>
                <span style="font-family: var(--font-display); font-size: 0.9rem; color: var(--s-ink-2); line-height: 1.5; display: block;">Colaborador de GRN Index especializado en cultura local y turismo experiencial.</span>
              </div>
            </div>
          </article>

          <!-- Tags -->
          {post.tags && post.tags.length > 0 && (
             <div class="upg-tags" data-reveal>
               <span class="upg-tags-title">[ Etiquetas ]</span>
               <div class="upg-tags-list">
                 {post.tags.map((tag: string) => (
                   <span class="upg-tag">#{tag}</span>
                 ))}
               </div>
             </div>
          )}

        </main>

        <!-- ENHANCED SIDEBAR (RIGHT) -->
        <aside class="upg-sidebar">
          <div class="upg-sidebar-sticky">

            <!-- Premium Ticket Card - INFO & SHARE -->
            <div class="upg-ticket-card" data-reveal>
              <div class="upg-ticket-glass"></div>
              
              <!-- Ticket Header -->
              <div class="upg-tc-header">
                <div class="upg-tc-date-box">
                  <span class="tc-day" style="font-size: 1.4rem;">{dayNum}</span>
                  <span class="tc-month">{monthShort}</span>
                </div>
                <div class="upg-tc-info">
                  <span class="tc-time" style="color:var(--s-ink);">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                    {t('blog.readingTime', { minutes: post.readingTime })}
                  </span>
                  <span class="tc-category">{categoryLabel}</span>
                </div>
              </div>

              <!-- Information injected inside Ticket -->
              <div style="padding: 0 2.5rem 1rem;">
                <span class="tc-price-label" style="display:block; margin-bottom:1rem;">INFORMACIÓN</span>
                <div style="display:flex; flex-direction:column; gap:0.75rem;">
                  <div style="display:flex; align-items:center; gap:0.6rem;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:16px;height:16px;color:var(--s-orange);"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    <span style="font-family:var(--font-display); font-size:0.85rem; font-weight:600; color:var(--s-ink);">{post.author}</span>
                  </div>
                  <div style="display:flex; align-items:center; gap:0.6rem;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:16px;height:16px;color:var(--s-orange);"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    <span style="font-family:var(--font-display); font-size:0.85rem; color:var(--s-ink-2);">{formattedDate}</span>
                  </div>
                </div>
              </div>

              <div class="upg-tc-divider">
                <span class="tcd-hole left"></span>
                <div class="tcd-dashed"></div>
                <span class="tcd-hole right"></span>
              </div>

              <!-- Actions -->
              <div class="upg-tc-actions">
                <button id="upg-share-btn" class="upg-btn-primary"
                  data-title={post.title[locale]}
                  data-url={Astro.url.href}
                >
                  <span>Compartir artículo</span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
                </button>
              </div>

            </div>

            <!-- Related Events Bento -->
            {relatedPosts.length > 0 && (
              <div class="upg-related-bento" data-reveal>
                <div class="upg-rb-header">
                  <span class="upg-rb-title">[ {t('detail.relatedPosts')} ]</span>
                  <a href="/blog" class="upg-rb-all">{t('detail.allPosts')} →</a>
                </div>
                
                <div class="upg-rb-list">
                  {relatedPosts.map((rel: any, i: number) => (
                    <a href={`/blog/${rel.slug}`} class="upg-rel-item" style={`--rd: ${i * 0.15}s`}>
                      <div class="uri-thumb">
                        {rel.image ? (
                          <OptimizedImage src={rel.image} alt="" loading="lazy" sizes="(max-width: 640px) 100vw, 280px" />
                        ) : (
                          <div class="uri-thumb-fallback"></div>
                        )}
                      </div>
                      <div class="uri-content">
                        <span class="uri-title">{rel.title[locale]}</span>
                        <span class="uri-meta">
                          {t('blog.readingTime', { minutes: rel.readingTime })}
                        </span>
                      </div>
                      <div class="uri-arrow">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            )}

          </div>
        </aside>

      </div>
    </div>

    <!-- Footer ornament -->
    <div class="det-footer-orn" aria-hidden="true" style="display: flex; align-items: center; justify-content: center; gap: 1rem; padding: 3rem clamp(1.5rem, 5vw, 4rem) 4rem; opacity: 0.3;">
      <span style="flex: 1; max-width: 120px; height: 1px; background: var(--s-border);"></span>
      <span style="width: 6px; height: 6px; background: var(--s-gold); transform: rotate(45deg);"></span>
      <span style="color: var(--s-gold); margin: 0 0.5rem;"><svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17.2l-6.2 4.1 2.4-7.4L2 9.4h7.6z"/></svg></span>
      <span style="width: 6px; height: 6px; background: var(--s-gold); transform: rotate(45deg);"></span>
      <span style="flex: 1; max-width: 120px; height: 1px; background: var(--s-border);"></span>
    </div>

  </div>
  </BlogDetailContent>

  <Footer slot="footer" locale={locale} />
</BaseLayout>

<script is:inline>
  (function () {
    const btn = document.getElementById('upg-share-btn');
    if (!btn) return;
    btn.addEventListener('click', async function () {
      const title = btn.dataset.title;
      const url   = btn.dataset.url;
      const label = btn.querySelector('span');
      if (navigator.share) {
        try { await navigator.share({ title, text: 'Lee "' + title + '" en GRN Index', url }); return; }
        catch (_) {}
      }
      try {
        await navigator.clipboard.writeText(url ?? '');
        if (label) {
          const orig = label.textContent;
          label.textContent = '¡Enlace copiado!';
          setTimeout(() => { label.textContent = orig; }, 2000);
        }
      } catch (_) {}
    });
  })();
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const io = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } }),
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );
    document.querySelectorAll('[data-reveal]').forEach(el => io.observe(el));
  });
</script>

<!-- Reading progress bar -->
<script>
  (function () {
    const bar = document.createElement('div');
    bar.id = 'read-progress';
    bar.setAttribute('aria-hidden', 'true');
    document.body.appendChild(bar);

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
          bar.style.setProperty('--scroll-progress', `${progress}%`);
          ticking = false;
        });
        ticking = true;
      }
    });
  })();
</script>

<style is:global>
  /* BASE DE PAGINA */
  .blog-page-override {
    --s-bg:       #f5f0ea;
    --s-bg-hi:    #faf8f5;
    --s-ink:      #1a1619;
    --s-ink-2:    #5a4f47;
    --s-ink-3:    #8a7f77;
    --s-orange:   #e8622a;
    --s-gold:     #c9a84c;
    --s-border:   rgba(26,22,25,0.10);
    
    background: var(--s-bg);
    position: relative;
    padding-bottom: 0rem;
  }
  .blog-page-override::before {
    content: ''; position: absolute; inset: 0; pointer-events: none; z-index: 1; mix-blend-mode: multiply; opacity: 0.025;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  /* Progress Bar */
  #read-progress {
    position: fixed; top: 0; left: 0; width: var(--scroll-progress, 0%);
    height: 3px; background: linear-gradient(90deg, #c9a84c, #e6c587, #c9a84c);
    background-size: 200% 100%; animation: shimmer 2s linear infinite; z-index: 9999;
    transition: width 0.1s linear; pointer-events: none; box-shadow: 0 2px 10px rgba(201, 168, 76, 0.4);
  }
  @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

  /* UPGRADED LAYOUT */
  .det-content-wrap { max-width: 1440px; margin: 0 auto; padding: 4rem clamp(1.5rem, 5vw, 4rem) 2rem; position: relative; z-index: 2; }
  .upgraded-layout { gap: 5rem; grid-template-columns: 1fr 380px; max-width: 1300px; margin: 0 auto; display: grid; align-items: start; }

  /* LEFT TRACK: MAIN */
  .upgraded-main { display: flex; flex-direction: column; background: transparent; gap: 3rem; }

  .upg-block {
    position: relative; padding: 3.5rem 3rem; background: var(--s-bg-hi);
    border: 1px solid var(--s-border); border-radius: 20px; opacity: 0; transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1); box-shadow: 0 4px 20px rgba(0,0,0,0.015);
  }
  .upg-block:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(0,0,0,0.04); }
  .upg-block.is-visible { opacity: 1; transform: translateY(0); }

  .upg-header { display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem; }
  .upg-num { font-family: var(--font-display); font-size: 0.75rem; font-weight: 600; color: var(--s-orange); }
  .upg-line { height: 1px; flex: 1; max-width: 60px; background: linear-gradient(90deg, var(--s-orange), transparent); opacity: 0.5; }
  .upg-eyebrow { font-family: var(--font-display); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--s-ink-3); }
  
  .upg-author-avatar { width: 56px; height: 56px; border-radius: 50%; background: linear-gradient(135deg, var(--s-gold), #e6c587); display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 15px rgba(201, 168, 76, 0.3); }
  .upg-author-initial { font-family: var(--font-body); font-size: 1.5rem; font-weight: 700; color: white; }

  /* BLOG PROSE STYLES inside upg-block */
  .blg-prose { font-family: var(--font-display); font-size: 1.1rem; line-height: 1.8; color: var(--s-ink-2); }
  .blg-prose p { margin-bottom: 1.5rem; }
  .blg-prose h2 { font-family: var(--font-body); font-size: 1.8rem; font-weight: 600; margin-top: 3rem; margin-bottom: 1.25rem; color: var(--s-ink); position: relative; padding-bottom: 0.75rem; line-height: 1.2; letter-spacing: -0.01em; }
  .blg-prose h2::after { content: ''; position: absolute; bottom: 0; left: 0; width: 40px; height: 2px; background: linear-gradient(90deg, var(--s-gold), transparent); }
  .blg-prose h3 { font-family: var(--font-body); font-size: 1.3rem; font-weight: 600; margin-top: 2rem; margin-bottom: 1rem; color: var(--s-ink); }
  .blg-prose blockquote { margin: 2.5rem 0; padding: 2rem 2rem 2rem 3rem; background: linear-gradient(135deg, rgba(201,168,76,0.06), transparent); border-left: 3px solid rgba(201,168,76,0.4); font-style: italic; position: relative; border-radius: 0 16px 16px 0; font-size: 1.2rem; color: var(--s-ink); }
  .blg-prose blockquote::before { content: '"'; position: absolute; top: 1rem; left: 1rem; font-family: var(--font-body); font-size: 4rem; color: rgba(201,168,76,0.2); line-height: 1; }
  .blg-prose ul, .blg-prose ol { margin: 1.5rem 0; padding-left: 1.5rem; }
  .blg-prose li { margin-bottom: 0.5rem; position: relative; }
  .blg-prose li::marker { color: var(--s-gold); }
  .blg-prose a { color: var(--s-orange); text-decoration: underline; text-underline-offset: 4px; transition: color 0.3s ease; }
  .blg-prose a:hover { color: var(--s-ink); }

  /* TAGS */
  .upg-tags { opacity: 0; transform: translateY(20px); transition: all 0.6s ease; margin-left: 1rem; }
  .upg-tags.is-visible { opacity: 1; transform: translateY(0); }
  .upg-tags-title { display: block; font-family: var(--font-display); font-size: 0.65rem; font-weight: 700; color: var(--s-ink-3); margin-bottom: 1rem; letter-spacing: 0.1em; }
  .upg-tags-list { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .upg-tag {
    padding: 0.5rem 1rem; background: rgba(26,22,25,0.03); border-radius: 100px;
    font-family: var(--font-display); font-size: 0.75rem; color: var(--s-ink-2);
    transition: all 0.3s ease;
  }
  .upg-tag:hover { background: var(--s-ink); color: #fff; }

  /* RIGHT TRACK: SIDEBAR */
  .upg-sidebar-sticky { position: sticky; top: calc(var(--header-height, 64px) + 2rem); display: flex; flex-direction: column; gap: 2rem; }

  /* Premium Ticket Card */
  .upg-ticket-card {
    position: relative; background: #fff; border-radius: 24px; box-shadow: 0 20px 40px rgba(0,0,0,0.04), 0 1px 3px rgba(0,0,0,0.02);
    overflow: hidden; opacity: 0; transform: translateY(40px) scale(0.98); transition: all 0.9s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .upg-ticket-card.is-visible { opacity: 1; transform: translateY(0) scale(1); }
  
  .upg-tc-header { padding: 2.5rem 2.5rem 2rem; display: flex; align-items: center; gap: 1.5rem; }
  .upg-tc-date-box {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    width: 64px; height: 64px; border-radius: 16px; background: rgba(201,168,76,0.15); color: #8a6d3b;
    border: 1px solid rgba(201,168,76,0.3);
  }
  .tc-day { font-family: var(--font-body); font-size: 1.5rem; font-weight: 400; line-height: 1; }
  .tc-month { font-family: var(--font-display); font-size: 0.6rem; font-weight: 700; letter-spacing: 0.1em; margin-top: 0.2rem; }
  
  .upg-tc-info { display: flex; flex-direction: column; gap: 0.4rem; }
  .tc-time { display: flex; align-items: center; gap: 0.4rem; font-family: var(--font-display); font-size: 0.95rem; font-weight: 600; color: var(--s-ink); }
  .tc-time svg { width: 16px; height: 16px; color: var(--s-orange); }
  .tc-category { font-family: var(--font-display); font-size: 0.75rem; letter-spacing: 0.05em; color: var(--s-ink-3); text-transform: uppercase; }

  .tc-price-label { font-family: var(--font-display); font-size: 0.75rem; font-weight: 600; color: var(--s-ink-3); text-transform: uppercase; letter-spacing: 0.1em; }

  /* Ticket divider (dashed with holes) */
  .upg-tc-divider { position: relative; display: flex; align-items: center; height: 32px; }
  .tcd-hole { width: 32px; height: 32px; background: var(--s-bg); border-radius: 50%; position: absolute; top: 0; box-shadow: inset 0 2px 5px rgba(0,0,0,0.02); }
  .tcd-hole.left { left: -16px; }
  .tcd-hole.right { right: -16px; }
  .tcd-dashed { flex: 1; margin: 0 20px; border-top: 2px dashed rgba(26,22,25,0.1); }

  .upg-tc-actions { padding: 2rem 2.5rem 2.5rem; display: flex; flex-direction: column; gap: 1rem; }
  
  .upg-btn-primary {
    display: flex; align-items: center; justify-content: center; gap: 0.75rem;
    padding: 1.25rem 1.5rem; border-radius: 12px; background: var(--s-ink); color: #fff;
    font-family: var(--font-display); font-size: 0.85rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    text-decoration: none; transition: all 0.3s ease; position: relative; overflow: hidden; border: none; cursor: pointer;
  }
  .upg-btn-primary:hover { transform: scale(1.02); background: var(--s-orange); box-shadow: 0 10px 20px rgba(232,98,42,0.2); }
  .upg-btn-primary svg { width: 18px; height: 18px; transition: transform 0.3s ease; }
  .upg-btn-primary:hover svg { transform: translateX(4px); }

  /* Related Bento */
  .upg-related-bento { background: transparent; opacity: 0; transform: translateY(20px); transition: all 0.8s ease; }
  .upg-related-bento.is-visible { opacity: 1; transform: translateY(0); }
  
  .upg-rb-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; padding-left: 0.5rem; }
  .upg-rb-title { font-family: var(--font-display); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.15em; color: var(--s-ink-3); text-transform: uppercase; }
  .upg-rb-all { font-family: var(--font-display); font-size: 0.75rem; font-weight: 600; color: var(--s-orange); text-decoration: none; transition: opacity 0.3s; }
  .upg-rb-all:hover { opacity: 0.7; }

  .upg-rb-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .upg-rel-item {
    display: flex; align-items: center; gap: 1rem; padding: 0.75rem;
    background: var(--s-bg-hi); border: 1px solid var(--s-border); border-radius: 16px;
    text-decoration: none; transition: all 0.3s ease;
  }
  .upg-rel-item:hover { transform: translateX(4px); box-shadow: 0 8px 24px rgba(0,0,0,0.04); border-color: rgba(201,168,76,0.3); }

  .uri-thumb { width: 56px; height: 56px; border-radius: 12px; overflow: hidden; flex-shrink: 0; background: rgba(26,22,25,0.04); }
  .uri-thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; filter: grayscale(20%); }

---
import BaseLayout from '@layouts/BaseLayout.astro';
import BlogCard from '@components/blog/BlogCard.astro';
import { getAllPosts, getPostBySlug, getRelatedPosts } from '@data/index.js';
import { useTranslations } from '@i18n/utils';
import type { BlogPost } from '@types';

export function getStaticPaths() {
  const posts = getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: BlogPost };
const locale = 'es';
const t = useTranslations(locale);

const relatedPosts = getRelatedPosts(post, 3);

const formattedDate = new Date(post.publishDate).toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const categoryLabel = t(`blog.categories.${post.category}`);
const ogImage = post.image ?? 'https://placehold.co/1200x630/E84D27/FFFFFF?text=Granada+Vibes+Blog';

const schemaData = {
  '@type': 'Article',
  headline: post.title[locale],
  description: post.description[locale],
  datePublished: post.publishDate,
  author: { '@type': 'Person', name: post.author },
  publisher: { '@type': 'Organization', name: 'Granada Vibes' },
  image: ogImage,
};
---

<BaseLayout
  locale={locale}
  title={post.title[locale]}
  description={post.description[locale]}
  ogImage={ogImage}
  ogType="article"
  schemaType="website"
  schemaData={schemaData}
>
  {/* Background decorations */}
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-[#E84D27]/5 rounded-full blur-[150px] pointer-events-none -z-10"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-[#F59E0B]/5 rounded-full blur-[120px] pointer-events-none -z-10"></div>

  {/* Breadcrumbs */}
  <div class="container pt-28 lg:pt-36 pb-4 relative z-10">
    <nav class="flex items-center gap-2 text-sm text-white/40" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[#E84D27] transition-colors">{t('nav.home')}</a>
      <span class="text-white/20">/</span>
      <a href="/blog" class="hover:text-[#E84D27] transition-colors">{t('nav.blog')}</a>
      <span class="text-white/20">/</span>
      <span class="text-white/60 truncate max-w-[200px]">{post.title[locale]}</span>
    </nav>
  </div>

  {/* Article header */}
  <header class="container pb-8 lg:pb-12 relative z-10">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-6">
        <span class="px-3 py-1.5 text-xs font-bold uppercase tracking-wider bg-[#E84D27] text-white rounded-full">
          {categoryLabel}
        </span>
        <span class="text-sm text-white/40">
          {t('blog.readingTime', { minutes: post.readingTime })}
        </span>
      </div>

      <h1 class="text-4xl lg:text-5xl xl:text-6xl font-black text-white leading-[0.95] tracking-[-0.03em] mb-6">
        {post.title[locale]}
      </h1>

      <p class="text-lg lg:text-xl text-white/50 leading-relaxed mb-8">
        {post.description[locale]}
      </p>

      <div class="flex items-center gap-4 text-sm text-white/40 pb-8 border-b border-white/[0.06]">
        <span class="font-medium text-white/70">{post.author}</span>
        <span class="w-1 h-1 rounded-full bg-white/30"></span>
        <time datetime={post.publishDate}>{formattedDate}</time>
      </div>
    </div>
  </header>

  {/* Article content */}
  <article class="container pb-16 lg:pb-24 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      {/* Main content */}
      <div class="lg:col-span-8">
        <div class="prose-granada prose-invert" set:html={post.content[locale]} />

        {/* Tags */}
        {post.tags.length > 0 && (
          <div class="mt-12 pt-8 border-t border-white/[0.06]">
            <h3 class="text-xs font-bold uppercase tracking-wider text-white/40 mb-4">{t('detail.tags')}</h3>
            <div class="flex flex-wrap gap-2">
              {post.tags.map((tag) => (
                <span class="px-3 py-1.5 text-xs font-medium text-white/50 bg-white/[0.05] border border-white/[0.08] rounded-full">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        )}
      </div>

      {/* Sidebar */}
      <aside class="lg:col-span-4">
        <div class="lg:sticky lg:top-28 space-y-8">
          {/* Share */}
          <div class="p-6 bg-white/[0.03] backdrop-blur-xl border border-white/[0.06] rounded-2xl">
            <h3 class="text-sm font-bold text-white mb-4">{t('detail.share')}</h3>
            <button
              id="share-btn"
              class="w-full flex items-center justify-center gap-2 px-4 py-3 bg-[#E84D27] text-white text-sm font-semibold rounded-xl hover:bg-[#F06040] transition-all duration-300 hover:shadow-[0_8px_30px_rgba(232,77,39,0.3)]"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
              </svg>
              {t('detail.share')}
            </button>
          </div>

          {/* Related posts */}
          {relatedPosts.length > 0 && (
            <div>
              <h3 class="text-sm font-bold uppercase tracking-wider text-white/40 mb-4">
                {t('blog.relatedPosts')}
              </h3>
              <div class="space-y-4">
                {relatedPosts.map((related) => (
                  <a
                    href={`/blog/${related.slug}`}
                    class="group block p-4 bg-white/[0.04] border border-white/[0.06] rounded-xl hover:border-[#E84D27]/30 hover:bg-white/[0.06] hover:-translate-y-1 transition-all duration-300"
                  >
                    <h4 class="text-sm font-semibold text-white group-hover:text-[#E84D27] transition-colors line-clamp-2 mb-1">
                      {related.title[locale]}
                    </h4>
                    <span class="text-xs text-white/30">
                      {t('blog.readingTime', { minutes: related.readingTime })}
                    </span>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      </aside>
    </div>
  </article>

  <script is:inline>
    (function() {
      const shareBtn = document.getElementById('share-btn');
      if (!shareBtn) return;

      shareBtn.addEventListener('click', async () => {
        const url = window.location.href;
        const title = document.title;

        if (navigator.share) {
          try {
            await navigator.share({ title, url });
          } catch (_) { /* cancelled */ }
        } else {
          try {
            await navigator.clipboard.writeText(url);
            shareBtn.textContent = 'URL copiada';
            setTimeout(() => { shareBtn.textContent = 'Compartir'; }, 2000);
          } catch (_) { /* fallback */ }
        }
      });
    })();
  </script>
</BaseLayout>

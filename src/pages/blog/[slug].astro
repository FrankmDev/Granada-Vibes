---
import BaseLayout from '@layouts/BaseLayout.astro';
import NavBar from '@components/layout/NavBar.astro';
import Footer from '@components/layout/Footer.astro';
import BlogDetailHero from '@components/blog/BlogDetailHero.astro';
import BlogDetailContent from '@components/blog/BlogDetailContent.astro';
import { getAllPosts, getRelatedPosts } from '@data/index.js';
import { useTranslations } from '@i18n/utils';
import type { BlogPost } from '@types';

export function getStaticPaths() {
  const posts = getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: BlogPost };
const locale = 'es';
const t = useTranslations(locale);

const relatedPosts = getRelatedPosts(post, 3);

const formattedDate = new Date(post.publishDate).toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const categoryLabel = t(`blog.categories.${post.category}`);
const ogImage = post.image ?? 'https://placehold.co/1200x630/0a0a0a/f0ede8?text=Granada+Vibes+Blog';

const seoDescription = `${post.description[locale]} — ${categoryLabel}. Por ${post.author}. ${t('blog.readingTime', { minutes: post.readingTime })}.`;

const schemaData = {
  '@type': 'Article',
  headline: post.title[locale],
  description: post.description[locale],
  datePublished: post.publishDate,
  author: { '@type': 'Person', name: post.author },
  publisher: { '@type': 'Organization', name: 'Granada Vibes' },
  image: ogImage,
};
---

<BaseLayout
  locale={locale}
  title={post.title[locale]}
  description={seoDescription}
  ogImage={ogImage}
  ogType="article"
  schemaType="website"
  schemaData={schemaData}
>
  <NavBar slot="header" locale={locale} currentPath={Astro.url.pathname} />

  <!-- DARK CINEMATIC HERO -->
  <BlogDetailHero post={post} locale={locale} formattedDate={formattedDate} />

  <!-- CREAM EDITORIAL CONTENT -->
  <BlogDetailContent>
  <div class="det-page">
    <div class="det-content-wrap">
      <div class="det-layout">

        <!-- MAIN COLUMN (70%) -->
        <main id="main-content" class="det-main">

          <!-- Article prose content -->
          <article class="blg-article-block det-block is-visible" aria-label={post.title[locale]}>
            <div class="blg-prose" set:html={post.content[locale]} />
          </article>

          <!-- Tags -->
          {post.tags.length > 0 && (
            <div class="blg-tags-block">
              <span class="blg-tags-eyebrow">[ {t('detail.tags')} ]</span>
              <div class="blg-tags-flow">
                {post.tags.map((tag) => (
                  <span class="blg-tag-pill">#{tag}</span>
                ))}
              </div>
            </div>
          )}

        </main>

        <!-- SIDEBAR (30%) -->
        <aside>
          <div class="det-sidebar-sticky">

            <!-- Info card -->
            <div class="det-sidebar-card" data-reveal>
              <div class="det-sc-head">
                <span class="det-sc-eyebrow">[ {locale === 'es' ? 'Información' : 'Information'} ]</span>
                <div class="det-sc-line"></div>
              </div>

              <div class="det-info-row">
                <span class="det-info-label">{t('detail.author')}</span>
                <span class="det-info-val">{post.author}</span>
              </div>
              <div class="det-info-sep"></div>
              <div class="det-info-row">
                <span class="det-info-label">{t('detail.publishDate')}</span>
                <span class="det-info-val">
                  <time datetime={post.publishDate}>{formattedDate}</time>
                </span>
              </div>
              <div class="det-info-sep"></div>
              <div class="det-info-row">
                <span class="det-info-label">{t('detail.readingTime')}</span>
                <span class="det-info-val">{t('blog.readingTime', { minutes: post.readingTime })}</span>
              </div>
              <div class="det-info-sep"></div>
              <div class="det-info-row">
                <span class="det-info-label">{t('detail.category')}</span>
                <span class="det-info-val">{categoryLabel}</span>
              </div>

              <button
                id="share-btn"
                class="blg-share-btn"
                data-title={post.title[locale]}
                data-url={Astro.url.href}
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
                </svg>
                <span class="share-label" aria-live="polite">{t('detail.share')}</span>
              </button>
            </div>

            <!-- Related posts -->
            {relatedPosts.length > 0 && (
              <div class="det-sidebar-card" data-reveal>
                <div class="det-sc-head">
                  <span class="det-sc-eyebrow">[ {t('detail.relatedPosts')} ]</span>
                  <div class="det-sc-line"></div>
                </div>
                <div class="det-related-list">
                  {relatedPosts.map((related, i) => (
                    <a
                      href={`/blog/${related.slug}`}
                      class="det-related-item"
                      style={`--ri: ${i}`}
                      aria-label={related.title[locale]}
                    >
                      <div class="det-rel-thumb">
                        {related.image ? (
                          <img src={related.image} alt="" loading="lazy" />
                        ) : (
                          <div class="det-rel-thumb-fallback">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                              <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                            </svg>
                          </div>
                        )}
                        <div class="det-rel-thumb-overlay"></div>
                      </div>
                      <div class="det-rel-info">
                        <span class="det-rel-title">{related.title[locale]}</span>
                        <span class="det-rel-meta">{t('blog.readingTime', { minutes: related.readingTime })}</span>
                      </div>
                      <svg class="det-rel-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  ))}
                </div>
                <a href="/blog" class="det-all-link">
                  {t('detail.allPosts')}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </div>
            )}

          </div>
        </aside>

      </div>
    </div>

    <!-- Footer ornament -->
    <div class="det-footer-orn" aria-hidden="true">
      <span class="det-orn-line"></span>
      <span class="det-orn-diamond"></span>
      <span class="det-orn-star">
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17.2l-6.2 4.1 2.4-7.4L2 9.4h7.6z"/>
        </svg>
      </span>
      <span class="det-orn-diamond"></span>
      <span class="det-orn-line"></span>
    </div>

  </div>
  </BlogDetailContent>

  <Footer slot="footer" locale={locale} />
</BaseLayout>

<script is:inline>
  (function () {
    const btn = document.getElementById('share-btn');
    if (!btn) return;
    btn.addEventListener('click', async function () {
      const title = btn.dataset.title;
      const url   = btn.dataset.url;
      const label = btn.querySelector('.share-label');
      if (navigator.share) {
        try { await navigator.share({ title, text: 'Lee "' + title + '" en Granada Vibes', url }); return; }
        catch (_) {}
      }
      try {
        await navigator.clipboard.writeText(url ?? '');
        if (label) {
          const orig = label.textContent;
          label.textContent = '¡Enlace copiado!';
          setTimeout(() => { label.textContent = orig; }, 2000);
        }
      } catch (_) {}
    });
  })();
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const io = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } }),
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('[data-reveal]').forEach(el => io.observe(el));
  });
</script>

<!-- Reading progress bar -->
<script>
  (function () {
    const bar = document.createElement('div');
    bar.id = 'read-progress';
    bar.setAttribute('aria-hidden', 'true');
    document.body.appendChild(bar);

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
          bar.style.setProperty('--scroll-progress', `${progress}%`);
          ticking = false;
        });
        ticking = true;
      }
    });
  })();
</script>

<style is:global>
  #read-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: var(--scroll-progress, 0%);
    height: 2px;
    background: #c9a84c;
    z-index: 9999;
    transition: width 0.1s linear;
    pointer-events: none;
  }
</style>

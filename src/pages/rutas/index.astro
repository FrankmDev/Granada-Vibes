---
import BaseLayout from '@layouts/BaseLayout.astro';
import SubpageHero from '@components/shared/SubpageHero.astro';
import ScreenFrame from '@components/ui/ScreenFrame.astro';
import { getAllRoutes, getAllMixedRoutes } from '@data/index';
import { useTranslations } from '@i18n/utils';
import type { Route, RouteCategory, RouteDifficulty } from '@types';

const locale = 'es';
const t = useTranslations(locale);
const allRoutes = getAllRoutes();
const mixedRoutes = getAllMixedRoutes();

const categories: RouteCategory[] = ['viewpoint', 'tapas', 'monuments', 'hiking', 'photography', 'secrets', 'history', 'flamenco'];
const difficulties: RouteDifficulty[] = ['easy', 'moderate', 'challenging'];

const difficultyLabels: Record<RouteDifficulty, string> = {
  easy:        t('difficulty.easy'),
  moderate:    t('difficulty.moderate'),
  challenging: t('difficulty.challenging'),
};

const difficultyColors: Record<RouteDifficulty, string> = {
  easy:        '#4a9e6b',
  moderate:    '#d4873a',
  challenging: '#c94a4a',
};

const categoryLabels: Record<RouteCategory, string> = {
  viewpoint:   t('categories.viewpoint'),
  tapas:       t('categories.tapas'),
  monuments:   t('categories.monuments'),
  hiking:      t('categories.hiking'),
  photography: t('categories.photography'),
  secrets:     t('categories.secrets'),
  history:     t('categories.history'),
  flamenco:    t('categories.flamenco'),
};

const categoryIcons: Record<RouteCategory, string> = {
  viewpoint:   '○',
  tapas:       '◐',
  monuments:   '◈',
  hiking:      '△',
  photography: '◉',
  secrets:     '◆',
  history:     '◫',
  flamenco:    '◎',
};

function formatDuration(minutes: number): string {
  const h = Math.floor(minutes / 60);
  const m = minutes % 60;
  return h > 0 ? `${h}H${m > 0 ? ` ${m}M` : ''}` : `${m}M`;
}

// Featured routes for hero accordion
const featuredRoutes = allRoutes.slice(0, 5);
const remainingRoutes = allRoutes.slice(5);

// Hero metadata
const heroMetadata = [
  { label: t('routes.heroMetaTotalLabel'), value: allRoutes.length.toString() },
  { label: t('routes.heroMetaCategoriesLabel'), value: categories.length.toString() },
  { label: t('routes.heroMetaDifficultiesLabel'), value: difficulties.length.toString() },
];

const ROUTE_FALLBACKS: Partial<Record<RouteCategory, string>> & { default: string } = {
  tapas:       'https://images.unsplash.com/photo-1555939594-58d7cb561ad1?w=800&h=1000&fit=crop',
  monuments:   'https://images.unsplash.com/photo-1548013146-72479768bada?w=800&h=1000&fit=crop',
  hiking:      'https://images.unsplash.com/photo-1500534314209-a25ddb2bd429?w=800&h=1000&fit=crop',
  photography: 'https://images.unsplash.com/photo-1452587925148-ce544e77e70d?w=800&h=1000&fit=crop',
  viewpoint:   'https://images.unsplash.com/photo-1523531294919-4bcd7c65e216?w=800&h=1000&fit=crop',
  secrets:     'https://images.unsplash.com/photo-1518709268805-4e9042af9f23?w=800&h=1000&fit=crop',
  history:     'https://images.unsplash.com/photo-1548013146-72479768bada?w=800&h=1000&fit=crop',
  flamenco:    'https://images.unsplash.com/photo-1504609813442-a8924e83f76e?w=800&h=1000&fit=crop',
  default:     'https://images.unsplash.com/photo-1523531294919-4bcd7c65e216?w=800&h=1000&fit=crop',
};

const ogImage = 'https://placehold.co/1200x630/f5f0ea/1a1619?text=Granada+Vibes+Rutas';
---

<BaseLayout 
  locale={locale} 
  title={t('routes.title')}
  description={t('routes.pageDescription')}
  ogImage={ogImage}
>
  <!-- CINEMATIC HERO -->
  <SubpageHero
    locale={locale}
    title={t('routes.heroTitle')}
    subtitle={t('routes.heroSubtitle')}
    eyebrow={t('routes.heroEyebrow')}
    eyebrowRight={t('routes.heroEyebrowRight')}
    description={t('routes.heroDescription')}
    ctaText={t('routes.heroCta')}
    ctaLink="#routes-grid"
    secondaryCtaText={t('routes.heroSecondaryCta')}
    secondaryCtaLink="#time-plans"
    pageNumber="02"
    coordinates="37°11′N 3°36′W"
    metadata={heroMetadata}
    variant="default"
  />

  <!-- CINEMATIC ACCORDION SECTION -->
  <section class="accordion-section" id="featured-routes">
    <div class="section-accent">
      <span class="accent-line"></span>
      <span class="accent-dot"></span>
      <span class="accent-text">{t('routes.accordionEyebrow')}</span>
      <span class="accent-dot"></span>
      <span class="accent-line"></span>
    </div>

    <div class="accordion-container">
      <div class="routes-accordion" id="routes-accordion">
        {featuredRoutes.map((route, idx) => {
          const href = `/rutas/${route.slug}`;
          const bgImage = ROUTE_FALLBACKS[route.category] ?? ROUTE_FALLBACKS.default;
          const diffLabel = difficultyLabels[route.difficulty] ?? route.difficulty;
          const catLabel = categoryLabels[route.category];
          const catIcon = categoryIcons[route.category];

          return (
            <a 
              href={href} 
              class={`accordion-pane ${idx === 0 ? 'is-active' : ''}`} 
              data-index={idx}
              style={`--pane-index: ${idx}`}
            >
              <div class="pane-media">
                <img
                  src={bgImage}
                  alt={route.title[locale]}
                  class="pane-img"
                  loading={idx < 2 ? 'eager' : 'lazy'}
                  decoding="async"
                />
                <div class="pane-gradient"></div>
              </div>

              <!-- Inactive State: Minimal -->
              <div class="pane-minimal">
                <span class="minimal-index">0{idx + 1}</span>
                <span class="minimal-line"></span>
                <span class="minimal-icon">{catIcon}</span>
              </div>

              <!-- Active State: Full Content -->
              <div class="pane-full">
                <div class="full-header">
                  <span class="full-category">
                    <span class="cat-icon">{catIcon}</span>
                    {catLabel}
                  </span>
                  <span class="full-number">{String(idx + 1).padStart(2, '0')}</span>
                </div>

                <div class="full-content">
                  <h3 class="full-title">{route.title[locale]}</h3>
                  
                  <div class="full-meta">
                    <div class="meta-item">
                      <span class="meta-label">{t('routes.accordionMetaDuration')}</span>
                      <span class="meta-value">{formatDuration(route.duration)}</span>
                    </div>
                    <div class="meta-divider"></div>
                    <div class="meta-item">
                      <span class="meta-label">{t('routes.accordionMetaDistance')}</span>
                      <span class="meta-value">{route.distance} KM</span>
                    </div>
                    <div class="meta-divider"></div>
                    <div class="meta-item">
                      <span class="meta-label">{t('routes.accordionMetaDifficulty')}</span>
                      <span class={`meta-value diff-${route.difficulty}`}>{diffLabel}</span>
                    </div>
                  </div>

                  <div class="full-cta">
                    <span>{t('routes.viewRoute')}</span>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                </div>
              </div>

              <!-- Hover Indicator -->
              <div class="pane-indicator">
                <div class="indicator-bar"></div>
              </div>
            </a>
          );
        })}
      </div>
    </div>

    <!-- Mobile Navigation -->
    <div class="accordion-nav">
      {featuredRoutes.map((_, idx) => (
        <button class="nav-dot" data-index={idx} aria-label={t('routes.routeAriaLabel').replace('{{number}}', String(idx + 1))}></button>
      ))}
    </div>
  </section>

  <!-- FILTER SECTION -->
  <section class="filter-section" id="routes-grid">
    <div class="filter-backdrop">
      <div class="backdrop-pattern"></div>
    </div>

    <div class="filter-container">
      <div class="filter-header">
        <div class="filter-title-group">
          <div class="filter-eyebrow-wrapper">
            <span class="eyebrow-bracket">[</span>
            <span class="filter-eyebrow">{t('routes.catalogueEyebrow')}</span>
            <span class="eyebrow-bracket">]</span>
          </div>
          <h2 class="filter-title">
            {t('routes.allRoutes').split('').map((char: string) => (
              char === ' '
                ? <span class="title-space"></span>
                : <span class="title-char">{char}</span>
            ))}
          </h2>
        </div>
        <div class="filter-count">
          <span class="count-value" id="route-count">{allRoutes.length}</span>
          <span class="count-divider"></span>
          <span class="count-label">{t('routes.routesCountLabel')}</span>
        </div>
      </div>

      <div class="filter-bar-wrapper">
        <div class="filter-bar" id="filter-bar">
          <div class="filter-track">
            <button class="filter-chip active" data-filter="all">
              <span class="chip-glow"></span>
              <span class="chip-content">
                <span class="chip-icon">◎</span>
                <span class="chip-label">{t('filters.all')}</span>
                <span class="chip-count">{allRoutes.length}</span>
              </span>
            </button>
            
            {categories.map((cat) => {
              const count = allRoutes.filter(r => r.category === cat).length;
              return (
                <button class="filter-chip" data-filter={cat}>
                  <span class="chip-glow"></span>
                  <span class="chip-content">
                    <span class="chip-icon">{categoryIcons[cat]}</span>
                    <span class="chip-label">{categoryLabels[cat]}</span>
                    <span class="chip-count">{count}</span>
                  </span>
                </button>
              );
            })}
          </div>
        </div>
        
        <div class="filter-scroll-hint left" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="filter-scroll-hint right" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>

        <button class="filter-reset" id="filter-reset" style="display: none;">
          <span class="reset-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M3 3v5h5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <span>{t('routes.resetFilter')}</span>
        </button>
      </div>

      <!-- Archive Grid -->
      <div class="archive-grid" id="routes-grid-container">
        {remainingRoutes.map((route, idx) => {
          const href = `/rutas/${route.slug}`;
          const bgImage = ROUTE_FALLBACKS[route.category] ?? ROUTE_FALLBACKS.default;
          const diffColor = difficultyColors[route.difficulty];
          const catIcon = categoryIcons[route.category];
          
          // Expedition number with leading zeros
          const expeditionNum = String(idx + 1).padStart(2, '0');

          return (
            <article 
              class="expedition-card" 
              data-category={route.category}
              data-index={idx}
              style={`--card-index: ${idx}; --diff-color: ${diffColor}`}
            >
              <a href={href} class="expedition-link">
                {/* Expedition Number Stamp */}
                <div class="expedition-stamp">
                  <span class="stamp-prefix">EXP.</span>
                  <span class="stamp-number">{expeditionNum}</span>
                </div>

                {/* Main Visual */}
                <div class="expedition-visual">
                  <div class="visual-frame">
                    <img
                      src={bgImage}
                      alt={route.title[locale]}
                      class="expedition-img"
                      loading="lazy"
                      decoding="async"
                    />
                    <div class="visual-vignette"></div>
                    
                    {/* Corner Markers */}
                    <div class="corner-marker tl"></div>
                    <div class="corner-marker tr"></div>
                    <div class="corner-marker bl"></div>
                    <div class="corner-marker br"></div>
                  </div>
                  
                  {/* Category Tag */}
                  <div class="legend-tag">
                    <span class="legend-symbol">{catIcon}</span>
                    <span class="legend-text">{categoryLabels[route.category]}</span>
                  </div>
                  
                  {/* Difficulty Stamp */}
                  <div class="difficulty-stamp" style={`--stamp-color: ${diffColor}`}>
                    <div class="stamp-ring">
                      <div class="stamp-dot"></div>
                    </div>
                    <span class="stamp-label">{difficultyLabels[route.difficulty]}</span>
                  </div>
                </div>

                {/* Content */}
                <div class="field-notes">
                  {/* Stats Header */}
                  <div class="coordinates-header">
                    <div class="coord-line">
                      <span class="coord-label">DIST.</span>
                      <span class="coord-value">{route.distance}km</span>
                    </div>
                    <div class="coord-divider"></div>
                    <div class="coord-line">
                      <span class="coord-label">TIEMPO</span>
                      <span class="coord-value">{formatDuration(route.duration)}</span>
                    </div>
                  </div>
                  
                  {/* Title */}
                  <h3 class="expedition-title">
                    {route.title[locale]}
                  </h3>
                </div>
                
                {/* Hover Reveal */}
                <div class="compass-reveal" aria-hidden="true">
                  <div class="compass-container">
                    <svg viewBox="0 0 100 100" class="compass-svg">
                      <circle cx="50" cy="50" r="45" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3"/>
                      <circle cx="50" cy="50" r="35" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.2"/>
                      <path d="M50 10 L55 45 L90 50 L55 55 L50 90 L45 55 L10 50 L45 45 Z" fill="currentColor" opacity="0.8"/>
                      <circle cx="50" cy="50" r="4" fill="currentColor"/>
                    </svg>
                    <span class="compass-text">{t('routes.explore')}</span>
                  </div>
                </div>
              </a>
            </article>
          );
        })}
      </div>

      <!-- Empty State -->
      <div class="empty-state" id="empty-state" style="display: none;">
        <div class="empty-icon">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
            <circle cx="12" cy="12" r="10"/>
            <path d="M8 8l8 8M16 8l-8 8"/>
          </svg>
        </div>
        <h3 class="empty-title">{t('routes.emptyTitle')}</h3>
        <p class="empty-text">{t('routes.emptyText')}</p>
        <button class="empty-btn" id="empty-reset">{t('routes.emptyBtn')}</button>
      </div>
    </div>
  </section>

  <!-- TIME PLANS SECTION -->
  <section class="time-section" id="time-plans">
    <div class="time-container">
      <div class="time-header">
        <div class="header-eyebrow">
          <span class="eyebrow-line"></span>
          <span class="eyebrow-text">{t('routes.timePlansEyebrow')}</span>
          <span class="eyebrow-line"></span>
        </div>
        <h2 class="header-title">{t('routes.timePlansTitle')}</h2>
        <p class="header-subtitle">{t('routes.timePlansSubtitle')}</p>
      </div>

      <div class="time-grid">
        {mixedRoutes.map((plan, idx) => (
          <a href={`/rutas/por-tiempo/${plan.slug}`} class="time-card" style={`--card-index: ${idx}`}>
            <div class="time-card-header">
              <span class="time-duration">{plan.duration}</span>
              <div class="time-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M12 6v6l4 2"/>
                </svg>
              </div>
            </div>

            <div class="time-content">
              <h3 class="time-title">{plan.title[locale]}</h3>
              <p class="time-description">{plan.description[locale]}</p>
            </div>

            <div class="time-footer">
              <span class="time-cta">
                {t('routes.explore')}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="cta-section">
    <div class="cta-container">
      <div class="cta-visual">
        <div class="visual-star">
          <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M50 0L61.8 38.2L100 50L61.8 61.8L50 100L38.2 61.8L0 50L38.2 38.2L50 0Z" fill="currentColor"/>
          </svg>
        </div>
      </div>

      <div class="cta-content">
        <h2 class="cta-title">{t('routes.ctaTitle')}</h2>
        <p class="cta-text">{t('routes.ctaText')}</p>
        <a href="/eventos" class="cta-button">
          <span>{t('routes.ctaBtn')}</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

    <ScreenFrame tagTopLeft="37°N" tagTopRight="03°W" />
  </section>

  <script>
    // Accordion functionality
    function initAccordion() {
      const accordion = document.getElementById('routes-accordion');
      const panes = accordion?.querySelectorAll<HTMLElement>('.accordion-pane');
      const navDots = document.querySelectorAll<HTMLElement>('.nav-dot');

      if (!panes?.length) return;

      // Set initial active state
      panes.forEach((p, i) => {
        if (i === 0) {
          p.classList.add('is-active');
          navDots[i]?.classList.add('is-active');
        }
      });

      // Desktop: hover to activate
      panes.forEach((pane, idx) => {
        pane.addEventListener('mouseenter', () => {
          if (window.innerWidth <= 1024) return;
          
          panes.forEach((p) => p.classList.remove('is-active'));
          navDots.forEach((d) => d.classList.remove('is-active'));
          
          pane.classList.add('is-active');
          navDots[idx]?.classList.add('is-active');
        });

        // Mobile: click to activate
        pane.addEventListener('click', (e) => {
          if (window.innerWidth > 1024) return;
          
          const isActive = pane.classList.contains('is-active');
          
          if (!isActive) {
            e.preventDefault();
            panes.forEach((p) => p.classList.remove('is-active'));
            navDots.forEach((d) => d.classList.remove('is-active'));
            pane.classList.add('is-active');
            navDots[idx]?.classList.add('is-active');
          }
        });
      });

      // Nav dots
      navDots.forEach((dot, idx) => {
        dot.addEventListener('click', () => {
          panes.forEach((p) => p.classList.remove('is-active'));
          navDots.forEach((d) => d.classList.remove('is-active'));
          panes[idx]?.classList.add('is-active');
          dot.classList.add('is-active');
          
          panes[idx]?.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
        });
      });
    }

    // Filter functionality
    function initFilters() {
      const filterChips = document.querySelectorAll<HTMLButtonElement>('.filter-chip');
      const routeCards = document.querySelectorAll<HTMLElement>('.expedition-card');
      const routeCount = document.getElementById('route-count');
      const filterReset = document.getElementById('filter-reset');
      const emptyState = document.getElementById('empty-state');
      const gridContainer = document.getElementById('routes-grid-container');
      const emptyReset = document.getElementById('empty-reset');
      const filterBar = document.getElementById('filter-bar');
      const filterBarWrapper = filterBar?.parentElement;

      // Scroll indicators for filter bar
      if (filterBar && filterBarWrapper) {
        function updateScrollIndicators() {
          const hasOverflow = filterBar.scrollWidth > filterBar.clientWidth;
          const atStart = filterBar.scrollLeft <= 10;
          const atEnd = filterBar.scrollLeft >= filterBar.scrollWidth - filterBar.clientWidth - 10;
          
          filterBarWrapper.classList.toggle('has-scroll-left', hasOverflow && !atStart);
          filterBarWrapper.classList.toggle('has-scroll-right', hasOverflow && !atEnd);
        }

        filterBar.addEventListener('scroll', updateScrollIndicators, { passive: true });
        window.addEventListener('resize', updateScrollIndicators, { passive: true });
        updateScrollIndicators();
      }

      function updateCount(count: number) {
        if (routeCount) {
          routeCount.textContent = count.toString();
          routeCount.classList.add('count-pulse');
          setTimeout(() => routeCount.classList.remove('count-pulse'), 300);
        }
      }

      function resetFilters() {
        filterChips.forEach((c) => c.classList.remove('active'));
        filterChips[0]?.classList.add('active');
        
        routeCards.forEach((card) => {
          card.classList.remove('hidden');
          card.style.display = '';
        });

        updateCount(routeCards.length);
        filterReset?.style.setProperty('display', 'none');
        emptyState?.style.setProperty('display', 'none');
        gridContainer?.style.setProperty('display', '');
      }

      filterChips.forEach((chip) => {
        chip.addEventListener('click', () => {
          const filter = chip.dataset.filter;

          // Update active state
          filterChips.forEach((c) => c.classList.remove('active'));
          chip.classList.add('active');

          // Filter logic
          let visibleCount = 0;
          
          routeCards.forEach((card) => {
            const category = card.dataset.category;
            const shouldShow = filter === 'all' || category === filter;

            if (shouldShow) {
              card.classList.remove('hidden');
              card.style.display = '';
              visibleCount++;
            } else {
              card.classList.add('hidden');
              card.style.display = 'none';
            }
          });

          updateCount(visibleCount);

          // Show/hide reset button
          if (filter !== 'all') {
            filterReset?.style.setProperty('display', 'flex');
          } else {
            filterReset?.style.setProperty('display', 'none');
          }

          // Empty state
          if (visibleCount === 0) {
            gridContainer?.style.setProperty('display', 'none');
            emptyState?.style.setProperty('display', 'flex');
          } else {
            gridContainer?.style.setProperty('display', '');
            emptyState?.style.setProperty('display', 'none');
          }
        });
      });

      filterReset?.addEventListener('click', resetFilters);
      emptyReset?.addEventListener('click', resetFilters);
    }

    // Scroll animations
    function initScrollAnimations() {
      const observerOptions = {
        root: null,
        rootMargin: '0px 0px -50px 0px',
        threshold: 0.1,
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      }, observerOptions);

      document.querySelectorAll('.expedition-card, .time-card').forEach((el) => {
        observer.observe(el);
      });
    }

    // Initialize
    document.addEventListener('DOMContentLoaded', () => {
      initAccordion();
      initFilters();
      initScrollAnimations();
    });

    document.addEventListener('astro:page-load', () => {
      initAccordion();
      initFilters();
      initScrollAnimations();
    });
  </script>

  <style>

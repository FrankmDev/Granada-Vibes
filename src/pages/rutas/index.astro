    .empty-btn {
      padding: 0.875rem 1.5rem;
      background: var(--r-ink);
      border: none;
      border-radius: 100px;
      font-family: var(--font-display);
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      color: white;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .empty-btn:hover {
      background: var(--r-orange);
    }

    /* ═══════════════════════════════════════════════════════════════
       TIME PLANS SECTION
       ═══════════════════════════════════════════════════════════════ */
    .time-section {
      position: relative;
      background: var(--r-cream);
      padding: 6rem 0;
      overflow: hidden;
    }

    .time-container {
      position: relative;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 clamp(1.5rem, 5vw, 3rem);
    }

    .time-header {
      text-align: center;
      margin-bottom: 3.5rem;
    }

    .header-eyebrow {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .eyebrow-line {
      width: 60px;
      height: 1px;
      background: var(--r-border-2);
    }

    .eyebrow-text {
      font-family: var(--font-display);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.25em;
      color: var(--r-orange);
      text-transform: uppercase;

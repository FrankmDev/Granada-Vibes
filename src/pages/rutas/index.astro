---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/layout/PageHeader.astro';
import RouteCard from '@components/routes/RouteCard.astro';
import { getAllRoutes } from '@data/index';
import { useTranslations } from '@i18n/utils';
import type { RouteType, RouteDifficulty, Neighborhood } from '@types';

const locale = 'es';
const t = useTranslations(locale);
const routes = getAllRoutes();

const types: RouteType[] = ['viewpoints', 'tapas', 'monuments', 'hiking', 'photography', 'secrets', 'history', 'flamenco'];
const difficulties: RouteDifficulty[] = ['easy', 'moderate', 'challenging'];
const neighborhoods: Neighborhood[] = ['albaicin', 'sacromonte', 'centro', 'realejo', 'alhambra'];

const ogImage = 'https://placehold.co/1200x630/D4A853/FFFFFF?text=Granada+Vibes+Rutas';
---

<BaseLayout 
  locale={locale} 
  title={t('routes.title')}
  description="Rutas y planes alternativos por Granada: miradores secretos, tapas locales, paseos por el Albaicín y Sacromonte. Guías creadas por granadinos."
  ogImage={ogImage}
>
  <!-- Page Header -->
  <PageHeader
    title={t('routes.title')}
    subtitle={t('routes.subtitle')}
    accent="secondary"
  />

  <!-- Mixed Routes CTA Banner -->
  <section class="relative bg-[#050505] border-b border-white/[0.06] overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-[#FF3366]/5 via-transparent to-[#FF9933]/5" aria-hidden="true"></div>
    <div class="absolute top-1/2 left-1/4 -translate-y-1/2 w-[300px] h-[300px] bg-[#FF3366]/5 rounded-full blur-[100px] pointer-events-none" aria-hidden="true"></div>

    <div class="container relative py-10 lg:py-12">
      <a
        href="/rutas/por-tiempo"
        class="group flex flex-col md:flex-row items-start md:items-center justify-between gap-6 p-6 lg:p-8 bg-white/[0.03] border border-white/[0.08] rounded-2xl hover:border-[#FF3366]/30 hover:bg-white/[0.05] transition-all duration-500 hover:-translate-y-0.5"
      >
        <div class="flex items-center gap-5">
          <div class="w-14 h-14 rounded-2xl bg-[#FF3366]/10 border border-[#FF3366]/20 flex items-center justify-center shrink-0">
            <svg class="w-7 h-7 text-[#FF3366]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <h3 class="font-display text-xl lg:text-2xl font-bold text-white mb-1 group-hover:text-[#FF3366] transition-colors">
              {t('mixedRoutes.sectionTitle')}
            </h3>
            <p class="text-sm text-white/50 max-w-lg">
              {t('mixedRoutes.subtitle')}
            </p>
          </div>
        </div>

        <div class="flex items-center gap-4 shrink-0">
          <div class="hidden lg:flex items-center gap-2">
            {['2h', '6h', '12h', '1d', '2d', '3d'].map((label) => (
              <span class="px-3 py-1.5 text-xs font-bold text-white/40 bg-white/[0.05] border border-white/[0.08] rounded-lg">
                {label}
              </span>
            ))}
          </div>
          <div class="w-10 h-10 rounded-full bg-[#FF3366]/10 border border-[#FF3366]/20 flex items-center justify-center group-hover:bg-[#FF3366]/20 transition-colors">
            <svg class="w-5 h-5 text-[#FF3366] group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </div>
      </a>
    </div>
  </section>

  {/* Filters Bar */}
  <div class="relative border-y border-white/[0.06] bg-[#0a0a0a]">
    <div class="absolute inset-0 bg-gradient-to-r from-[#F59E0B]/[0.03] via-transparent to-[#F59E0B]/[0.03]" aria-hidden="true"></div>
    
    <div class="container relative py-8 lg:py-10">
      {/* Fila 1 - Tipo de ruta */}
      <div class="flex flex-wrap items-center gap-3 mb-6" role="group" aria-label="Filtrar por tipo">
        <button 
          class="filter-type px-6 py-3 text-xs font-bold uppercase tracking-[0.1em] bg-[#F59E0B] text-white rounded-full transition-all duration-300 hover:shadow-lg hover:shadow-[#F59E0B]/20"
          data-type="all"
          aria-pressed="true"
        >
          Todas
        </button>
        {types.map((type) => (
          <button 
            class="filter-type px-6 py-3 text-xs font-bold uppercase tracking-[0.1em] text-white/70 bg-white/[0.05] border border-white/[0.08] rounded-full hover:border-[#F59E0B]/30 hover:text-[#F59E0B] transition-all duration-300"
            data-type={type}
            aria-pressed="false"
          >
            {t(`categories.${type}`)}
          </button>
        ))}
      </div>

      {/* Fila 2 - Filtros secundarios */}
      <div class="flex flex-wrap items-center gap-4 pt-6 border-t border-[var(--color-border)]">
        {/* Dropdown Dificultad */}
        <div class="relative group">
          <select 
            id="filter-difficulty"
            class="appearance-none px-5 py-3 pr-12 text-sm text-[var(--color-text-primary)] bg-white border border-[var(--color-border)] rounded-xl focus:outline-none focus:border-[var(--color-secondary)] cursor-pointer transition-all duration-300 hover:border-[var(--color-secondary)]/30 min-w-[180px]"
            aria-label="Filtrar por dificultad"
          >
            <option value="all">Todas las dificultades</option>
            {difficulties.map((d) => (
              <option value={d}>{t(`difficulty.${d}`)}</option>
            ))}
          </select>
          <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-[var(--color-text-muted)] pointer-events-none transition-colors group-hover:text-[var(--color-secondary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>

        {/* Dropdown Barrio */}
        <div class="relative group">
          <select 
            id="filter-neighborhood"
            class="appearance-none px-5 py-3 pr-12 text-sm text-[var(--color-text-primary)] bg-white border border-[var(--color-border)] rounded-xl focus:outline-none focus:border-[var(--color-secondary)] cursor-pointer transition-all duration-300 hover:border-[var(--color-secondary)]/30 min-w-[180px]"
            aria-label="Filtrar por barrio"
          >
            <option value="all">Todos los barrios</option>
            {neighborhoods.map((n) => (
              <option value={n}>{t(`neighborhoods.${n}`)}</option>
            ))}
          </select>
          <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-[var(--color-text-muted)] pointer-events-none transition-colors group-hover:text-[var(--color-secondary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>

        <div class="flex-1"></div>

        {/* Botón Limpiar filtros */}
        <button 
          id="clear-filters"
          class="hidden items-center gap-2 px-5 py-3 text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-secondary)] transition-all duration-300 rounded-xl hover:bg-[var(--color-secondary-muted)] font-medium"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
          Limpiar filtros
        </button>
      </div>
    </div>
  </div>

  {/* Results counter */}
  <div class="container py-8">
    <div class="flex items-center gap-3 text-sm text-[var(--color-text-secondary)]">
      <span class="w-2 h-2 rounded-full bg-[var(--color-secondary)] animate-pulse"></span>
      Mostrando <span id="results-count" class="font-bold text-[var(--color-text-primary)]">{routes.length}</span> rutas
    </div>
  </div>

  {/* Routes Grid */}
  <section class="container pb-24" aria-labelledby="routes-heading">
    <h2 id="routes-heading" class="sr-only">{t('routes.title')}</h2>
    
    <div id="routes-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {routes.map((route, index) => (
        <div 
          class="route-card-wrapper scroll-animate"
          data-type={route.category}
          data-difficulty={route.difficulty}
          data-neighborhoods={route.neighborhoods.join(',')}
        >
          <RouteCard route={route} locale={locale} t={t} index={index} variant="grid" />
        </div>
      ))}
    </div>
    
    {/* Empty state */}
    <div id="empty-state" class="hidden text-center py-24">
      <div class="relative w-24 h-24 mx-auto mb-8">
        <div class="absolute inset-0 bg-[var(--color-secondary)]/20 rounded-2xl blur-xl"></div>
        <div class="relative w-full h-full bg-[var(--color-bg-cream)] border border-[var(--color-secondary)]/20 rounded-2xl flex items-center justify-center">
          <svg class="w-12 h-12 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
      </div>
      <h3 class="text-2xl font-bold text-[var(--color-text-primary)] mb-3">
        Sin resultados para estos filtros
      </h3>
      <p class="text-[var(--color-text-secondary)] mb-8 max-w-md mx-auto">Prueba a cambiar los filtros o ver todas las rutas disponibles</p>
      <button 
        id="empty-clear-filters"
        class="inline-flex items-center gap-2 px-6 py-3 bg-[var(--color-secondary)] text-white font-semibold rounded-full hover:bg-[var(--color-secondary-dark)] transition-all duration-300 hover:shadow-lg hover:shadow-[var(--color-secondary)]/25"
      >
        Limpiar filtros
      </button>
    </div>
  </section>

  <script is:inline>
    (function() {
      const typeButtons = document.querySelectorAll('.filter-type');
      const difficultySelect = document.getElementById('filter-difficulty');
      const neighborhoodSelect = document.getElementById('filter-neighborhood');
      const clearFiltersBtn = document.getElementById('clear-filters');
      const emptyClearFiltersBtn = document.getElementById('empty-clear-filters');
      const resultsCount = document.getElementById('results-count');
      const emptyState = document.getElementById('empty-state');
      const routesGrid = document.getElementById('routes-grid');
      const routeCards = document.querySelectorAll('.route-card-wrapper');

      let filters = {
        type: 'all',
        difficulty: 'all',
        neighborhood: 'all'
      };

      function applyFilters() {
        let visibleCount = 0;
        
        routeCards.forEach(card => {
          const type = card.dataset.type;
          const difficulty = card.dataset.difficulty;
          const neighborhoods = card.dataset.neighborhoods?.split(',') || [];
          
          const matchesType = filters.type === 'all' || type === filters.type;
          const matchesDifficulty = filters.difficulty === 'all' || difficulty === filters.difficulty;
          const matchesNeighborhood = filters.neighborhood === 'all' || neighborhoods.includes(filters.neighborhood);
          
          const isVisible = matchesType && matchesDifficulty && matchesNeighborhood;
          
          if (isVisible) {
            card.style.display = '';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });
        
        resultsCount.textContent = visibleCount;
        
        if (visibleCount === 0) {
          routesGrid.classList.add('hidden');
          emptyState.classList.remove('hidden');
        } else {
          routesGrid.classList.remove('hidden');
          emptyState.classList.add('hidden');
        }
        
        const hasActiveFilters = filters.type !== 'all' || 
                                 filters.difficulty !== 'all' || 
                                 filters.neighborhood !== 'all';
        
        if (hasActiveFilters) {
          clearFiltersBtn.classList.remove('hidden');
          clearFiltersBtn.classList.add('inline-flex');
        } else {
          clearFiltersBtn.classList.add('hidden');
          clearFiltersBtn.classList.remove('inline-flex');
        }
      }

      typeButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          typeButtons.forEach(b => {
            b.classList.remove('bg-[var(--color-secondary)]', 'text-white');
            b.classList.add('text-[var(--color-text-primary)]', 'bg-white', 'border', 'border-[var(--color-border)]');
            b.setAttribute('aria-pressed', 'false');
          });
          btn.classList.remove('text-[var(--color-text-primary)]', 'bg-white', 'border', 'border-[var(--color-border)]');
          btn.classList.add('bg-[var(--color-secondary)]', 'text-white');
          btn.setAttribute('aria-pressed', 'true');
          
          filters.type = btn.dataset.type;
          applyFilters();
        });
      });

      difficultySelect?.addEventListener('change', (e) => {
        filters.difficulty = e.target.value;
        applyFilters();
      });

      neighborhoodSelect?.addEventListener('change', (e) => {
        filters.neighborhood = e.target.value;
        applyFilters();
      });

      function clearFilters() {
        filters = {
          type: 'all',
          difficulty: 'all',
          neighborhood: 'all'
        };
        
        typeButtons.forEach(b => {
          if (b.dataset.type === 'all') {
            b.classList.remove('text-[var(--color-text-primary)]', 'bg-white', 'border', 'border-[var(--color-border)]');
            b.classList.add('bg-[var(--color-secondary)]', 'text-white');
            b.setAttribute('aria-pressed', 'true');
          } else {
            b.classList.remove('bg-[var(--color-secondary)]', 'text-white');
            b.classList.add('text-[var(--color-text-primary)]', 'bg-white', 'border', 'border-[var(--color-border)]');
            b.setAttribute('aria-pressed', 'false');
          }
        });
        
        difficultySelect.value = 'all';
        neighborhoodSelect.value = 'all';
        
        applyFilters();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }

      clearFiltersBtn?.addEventListener('click', clearFilters);
      emptyClearFiltersBtn?.addEventListener('click', clearFilters);
    })();
  </script>
</BaseLayout>

    .header-title {
      font-family: var(--font-body);
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 300;
      color: var(--r-ink);
      margin: 0 0 0.75rem;
    }

    .header-subtitle {
      font-family: var(--font-display);
      font-size: 1.05rem;
      color: var(--r-ink-3);
      margin: 0;
    }

    .time-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
    }

    .time-card {
      position: relative;
      display: flex;
      flex-direction: column;
      padding: 1.75rem;
      background: var(--r-cream-2);
      border: 1px solid var(--r-border);
      border-radius: 12px;
      text-decoration: none;
      color: inherit;
      overflow: hidden;
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      opacity: 0;
      transform: translateY(30px);
    }

    .time-card.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    .time-card:nth-child(1) { transition-delay: 0.1s; }
    .time-card:nth-child(2) { transition-delay: 0.18s; }
    .time-card:nth-child(3) { transition-delay: 0.26s; }
    .time-card:nth-child(4) { transition-delay: 0.34s; }

    .time-card:hover {
      transform: translateY(-4px);
      border-color: transparent;
      box-shadow: 0 20px 40px rgba(26, 22, 25, 0.1);
    }

    .time-card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.25rem;
    }

    .time-duration {
      font-family: var(--font-display);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: var(--r-orange);
      padding: 0.4rem 0.875rem;
      background: rgba(232, 98, 42, 0.08);
      border-radius: 100px;
    }

    .time-icon {
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--r-cream);
      border-radius: 10px;
      color: var(--r-ink-3);
      transition: all 0.3s ease;
    }

    .time-card:hover .time-icon {
      background: var(--r-ink);
      color: var(--r-gold);
    }

    .time-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 0.625rem;
    }

    .time-title {
      font-family: var(--font-body);
      font-size: 1.25rem;
      font-weight: 500;
      color: var(--r-ink);
      margin: 0;
      line-height: 1.3;

    .stamp-label {
      font-family: var(--font-display);
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      color: var(--r-ink);
    }

    /* Field Notes Content */
    .field-notes {
      position: relative;
      padding: 1.25rem;
      background: var(--r-cream-2);
      z-index: 3;
    }

    /* Stats Header */
    .coordinates-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.875rem;
      padding-bottom: 0.625rem;
      border-bottom: 1px solid var(--r-border);
    }

    .coord-line {
      display: flex;
      align-items: baseline;
      gap: 0.3rem;
    }

    .coord-label {
      font-family: var(--font-display);
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      color: var(--r-ink-3);
    }

    .coord-value {
      font-family: var(--font-display);
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.02em;
      color: var(--r-ink);
      font-variant-numeric: tabular-nums;
    }

    .coord-divider {
      width: 1px;
      height: 10px;
      background: var(--r-border-2);
    }

    /* Expedition Title */
    .expedition-title {
      font-family: var(--font-body);
      font-size: 1.25rem;
      font-weight: 500;
      line-height: 1.3;
      color: var(--r-ink);
      margin: 0;
      letter-spacing: -0.01em;
      position: relative;
      padding-bottom: 0.625rem;
    }

    .expedition-title::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 32px;
      height: 2px;
      background: linear-gradient(90deg, var(--r-gold), transparent);
      transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .expedition-link:hover .expedition-title::after {
      width: 60px;
    }

    /* Compass Reveal on Hover */
    .compass-reveal {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(26, 22, 25, 0.85);
      backdrop-filter: blur(6px);
      opacity: 0;
      transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      z-index: 15;
    }

    .expedition-link:hover .compass-reveal {
      opacity: 1;
    }

    .compass-container {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.875rem;
    }

    .compass-svg {
      width: 52px;
      height: 52px;
      color: var(--r-gold);
      transform: scale(0.6) rotate(-90deg);
      opacity: 0;
      transition: 
        transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.08s,
        opacity 0.4s ease 0.08s;
    }

    .expedition-link:hover .compass-svg {
      transform: scale(1) rotate(0deg);
      opacity: 1;
    }

    .compass-text {
      font-family: var(--font-display);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--r-cream);
      transform: translateY(12px);
      opacity: 0;
      transition: 
        transform 0.4s cubic-bezier(0.16, 1, 0.3, 1) 0.15s,
        opacity 0.4s ease 0.15s;
    }

    .expedition-link:hover .compass-text {
      transform: translateY(0);
      opacity: 1;
    }

    /* Empty State */
    .empty-state {
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
      padding: 4rem 2rem;
      text-align: center;
    }

    .empty-icon {
      color: var(--r-border-2);
    }

    .empty-title {
      font-family: var(--font-body);
      font-size: 1.5rem;
      font-weight: 500;
      color: var(--r-ink);
      margin: 0;
    }

    .empty-text {
      font-family: var(--font-display);
      font-size: 0.95rem;
      color: var(--r-ink-3);
      margin: 0;

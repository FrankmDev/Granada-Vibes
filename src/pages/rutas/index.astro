    /* Responsive */
    @media (max-width: 1024px) {
      .filter-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 1.5rem;
      }

      .filter-count {
        align-self: flex-end;
      }

      .archive-grid {
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));

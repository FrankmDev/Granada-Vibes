---
import BaseLayout from '@layouts/BaseLayout.astro';
import DetailContent from '@components/shared/DetailContent.astro';
import { getAllMixedRoutes } from '@data';
import { useTranslations } from '@i18n/utils';
import type { MixedRoute, MixedRouteStop } from '@types';

export function getStaticPaths() {
  const plans = getAllMixedRoutes();
  return plans.map((plan) => ({
    params: { slug: plan.slug },
    props: { plan },
  }));
}

interface Props {
  plan: MixedRoute;
}

const { plan } = Astro.props;
const locale = 'es';
const t = useTranslations(locale);

const totalStops = plan.days.reduce(
  (acc, day) => acc + day.blocks.reduce((bAcc, block) => bAcc + block.stops.length, 0),
  0
);

const stopCategoryConfig: Record<string, { color: string; bg: string; border: string; icon: string; label: string }> = {
  mirador: { color: '#d4873a', bg: 'rgba(212, 135, 58, 0.12)', border: 'rgba(212, 135, 58, 0.3)', icon: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z', label: t('mixedRoutes.stopCategories.mirador') },
  tapas: { color: '#c94a4a', bg: 'rgba(201, 74, 74, 0.12)', border: 'rgba(201, 74, 74, 0.3)', icon: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z', label: t('mixedRoutes.stopCategories.tapas') },
  monumento: { color: '#4a9e6b', bg: 'rgba(74, 158, 107, 0.12)', border: 'rgba(74, 158, 107, 0.3)', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4', label: t('mixedRoutes.stopCategories.monumento') },
  cultura: { color: '#d4873a', bg: 'rgba(212, 135, 58, 0.12)', border: 'rgba(212, 135, 58, 0.3)', icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z', label: t('mixedRoutes.stopCategories.cultura') },
  paseo: { color: '#4a9e6b', bg: 'rgba(74, 158, 107, 0.12)', border: 'rgba(74, 158, 107, 0.3)', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6', label: t('mixedRoutes.stopCategories.paseo') },
  compras: { color: '#d4873a', bg: 'rgba(212, 135, 58, 0.12)', border: 'rgba(212, 135, 58, 0.3)', icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z', label: t('mixedRoutes.stopCategories.compras') },
  naturaleza: { color: '#4a9e6b', bg: 'rgba(74, 158, 107, 0.12)', border: 'rgba(74, 158, 107, 0.3)', icon: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z', label: t('mixedRoutes.stopCategories.naturaleza') },
  flamenco: { color: '#c94a4a', bg: 'rgba(201, 74, 74, 0.12)', border: 'rgba(201, 74, 74, 0.3)', icon: 'M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3', label: t('mixedRoutes.stopCategories.flamenco') },
};

const slugDurationLabels: Record<string, string> = {
  '30min': t('mixedRoutes.slugDurationLabels.30min'),
  '1h': t('mixedRoutes.slugDurationLabels.1h'),
  '2h': t('mixedRoutes.slugDurationLabels.2h'),
  '6h': t('mixedRoutes.slugDurationLabels.6h'),
  '12h': t('mixedRoutes.slugDurationLabels.12h'),
  'half-day': t('mixedRoutes.slugDurationLabels.half-day'),
  'full-day': t('mixedRoutes.slugDurationLabels.full-day'),
  '1day': t('mixedRoutes.slugDurationLabels.1day'),
  '2days': t('mixedRoutes.slugDurationLabels.2days'),
  '3days': t('mixedRoutes.slugDurationLabels.3days'),
};
const getDurationLabel = (dur: string) => slugDurationLabels[dur] ?? dur;
---

<BaseLayout
  locale={locale}
  title={plan.title[locale]}
  description={plan.description[locale]}
>
  <!-- Hero -->
  <section class="mx-hero">
    <div class="mx-hero-bg" aria-hidden="true">
      <div class="mx-hero-gradient"></div>
      <div class="mx-hero-glow"></div>
    </div>
    
    <div class="mx-hero-content">
      <a href="/rutas/por-tiempo" class="mx-back-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>{t('mixedRoutes.title')}</span>
      </a>

      <div class="mx-hero-meta">
        <span class="mx-duration-badge">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {getDurationLabel(plan.duration)}
        </span>
        <span class="mx-hero-stats">
          {totalStops} {t('mixedRoutes.stops')} · {plan.neighborhoods.length} {t('mixedRoutes.neighborhoods')}
        </span>
      </div>

      <h1 class="mx-hero-title">{plan.title[locale]}</h1>
      <p class="mx-hero-desc">{plan.description[locale]}</p>

      {plan.bestFor && (
        <div class="mx-best-for">
          <span class="mx-best-for-label">{t('mixedRoutes.bestFor')}:</span>
          <span class="mx-best-for-text">{plan.bestFor[locale]}</span>
        </div>
      )}
    </div>

    <div class="mx-hero-dock">
      <div class="mx-dock-item">
        <span class="mx-dock-label">{t('mixedRoutes.dockStops')}</span>
        <span class="mx-dock-value">{totalStops}</span>
      </div>
      <div class="mx-dock-sep"></div>
      <div class="mx-dock-item">
        <span class="mx-dock-label">{t('mixedRoutes.dockDuration')}</span>
        <span class="mx-dock-value">{getDurationLabel(plan.duration)}</span>
      </div>
      <div class="mx-dock-sep"></div>
      <div class="mx-dock-item">
        <span class="mx-dock-label">{t('mixedRoutes.dockZones')}</span>
        <span class="mx-dock-value">{plan.neighborhoods.length}</span>
      </div>
    </div>
  </section>

  <DetailContent>
    <div class="det-page mx-page">
      <div class="det-content-wrap">
        <div class="det-layout mx-layout">

          <main id="main-content" class="det-main mx-main">
            {plan.days.map((day, dayIndex) => (
              <div class="mx-day-section" style={`--day-delay: ${dayIndex * 0.15}s`}>
                {day.label && (
                  <div class="mx-day-header" data-reveal>
                    <div class="mx-day-line"></div>
                    <h2 class="mx-day-title">{day.label[locale]}</h2>
                    <div class="mx-day-line"></div>
                  </div>
                )}

                {day.blocks.map((block, blockIndex) => (
                  <div class="mx-block" data-reveal style={`--block-delay: ${(blockIndex + 1) * 0.1}s`}>
                    <!-- Time block header -->
                    <div class="mx-block-header">
                      <div class="mx-block-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                          <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </div>
                      <h3 class="mx-block-title">{block.label[locale]}</h3>
                      <div class="mx-block-divider"></div>
                    </div>

                    <!-- Stops -->
                    <div class="mx-stops-list">
                      {block.stops.map((stop: MixedRouteStop, stopIndex: number) => {
                        const catConfig = stopCategoryConfig[stop.category] || stopCategoryConfig.paseo;
                        return (
                          <div class="mx-stop" data-reveal-inner style={`--stop-delay: ${stopIndex * 0.08}s`}>
                            <div class="mx-stop-marker">
                              <div class="mx-stop-dot" style={`--dot-color: ${catConfig.color}`}></div>
                              <div class="mx-stop-line"></div>
                            </div>
                            <div class="mx-stop-card" style={`--card-accent: ${catConfig.color}`}>
                              <div class="mx-stop-header">
                                <span class="mx-stop-category" style={`color: ${catConfig.color}; background: ${catConfig.bg}; border-color: ${catConfig.border};`}>
                                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <path d={catConfig.icon} stroke-linecap="round" stroke-linejoin="round"/>
                                  </svg>
                                  {catConfig.label}
                                </span>
                                {stop.neighborhood && (
                                  <span class="mx-stop-zone">{t(`neighborhoods.${stop.neighborhood}`)}</span>
                                )}
                                <span class="mx-stop-duration">~{stop.duration} min</span>
                              </div>
                              <h4 class="mx-stop-name">{stop.name[locale]}</h4>
                              <p class="mx-stop-desc">{stop.description[locale]}</p>
                              {stop.tip && (
                                <div class="mx-stop-tip" style={`--tip-color: ${catConfig.color}`}>
                                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/>
                                  </svg>
                                  <span>{stop.tip[locale]}</span>
                                </div>
                              )}
                            </div>
                          </div>
                        );
                      })}
                    </div>
                  </div>
                ))}
              </div>
            ))}

            <!-- Essential tips -->
            {plan.essentialTips && plan.essentialTips.length > 0 && (
              <div class="mx-tips-section" data-reveal>
                <div class="mx-tips-header">
                  <span class="mx-tips-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                  <h2 class="mx-tips-title">{t('mixedRoutes.essentialTips')}</h2>
                </div>
                <div class="mx-tips-grid">
                  {plan.essentialTips.map((tip, i) => (
                    <div class="mx-tip-card" style={`--tip-delay: ${i * 0.1}s`}>
                      <span class="mx-tip-num">{(i + 1).toString().padStart(2, '0')}</span>
                      <p class="mx-tip-text">{tip[locale]}</p>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </main>

          <aside class="mx-sidebar">
            <div class="det-sidebar-sticky">
              <!-- Stats card -->
              <div class="det-sidebar-card det-card-premium mx-stats-card" data-reveal>
                <div class="mx-card-shimmer"></div>
                <div class="det-sc-head">
                  <span class="det-sc-eyebrow">[ Resumen ]</span>
                  <div class="det-sc-line"></div>
                </div>
                
                <div class="mx-stats-grid">
                  <div class="mx-stat-item">
                    <span class="mx-stat-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                    <div class="mx-stat-content">
                      <span class="mx-stat-val">{getDurationLabel(plan.duration)}</span>
                      <span class="mx-stat-label">{t('mixedRoutes.statDuration')}</span>
                    </div>
                  </div>
                  
                  <div class="mx-stat-item">
                    <span class="mx-stat-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                    <div class="mx-stat-content">
                      <span class="mx-stat-val">{totalStops}</span>
                      <span class="mx-stat-label">{t('mixedRoutes.statStops')}</span>
                    </div>
                  </div>

                  <div class="mx-stat-item">
                    <span class="mx-stat-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                    <div class="mx-stat-content">
                      <span class="mx-stat-val">{plan.neighborhoods.length}</span>
                      <span class="mx-stat-label">{t('mixedRoutes.statNeighborhoods')}</span>
                    </div>
                  </div>
                </div>

                {plan.bestFor && (
                  <div class="mx-best-for-card">
                    <span class="mx-best-for-label-small">{t('mixedRoutes.idealFor')}</span>
                    <p class="mx-best-for-card-text">{plan.bestFor[locale]}</p>
                  </div>
                )}
              </div>

              <!-- Back link -->
              <div class="mx-back-card" data-reveal>
                <a href="/rutas/por-tiempo" class="mx-back-btn">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>{t('mixedRoutes.backToAll')}</span>
                </a>
              </div>
            </div>
          </aside>

        </div>
      </div>

      <div class="det-footer-orn" aria-hidden="true">
        <span class="det-orn-line"></span>
        <span class="det-orn-diamond"></span>
        <span class="det-orn-star">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17.2l-6.2 4.1 2.4-7.4L2 9.4h7.6z"/>
          </svg>
        </span>
        <span class="det-orn-diamond"></span>
        <span class="det-orn-line"></span>
      </div>
    </div>
  </DetailContent>

</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const io = new IntersectionObserver(
      (entries) => entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          
          // Trigger inner animations
          if (e.target.hasAttribute('data-reveal-inner')) {
            const parent = e.target.closest('.mx-stops-list');
            if (parent) {
              parent.querySelectorAll('.mx-stop').forEach((stop, i) => {
                const el = stop as HTMLElement;
                el.style.transitionDelay = `${i * 0.08}s`;
                el.classList.add('is-visible');
              });
            }
          }
          
          io.unobserve(e.target);
        }
      }),
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );
    document.querySelectorAll('[data-reveal]').forEach(el => io.observe(el));
    document.querySelectorAll('[data-reveal-inner]').forEach(el => io.observe(el));
    
    // Also trigger stops when their parent block is visible
    document.querySelectorAll('.mx-stop').forEach(stop => {
      stop.classList.add('is-visible');
    });
  });
</script>

<!-- Reading progress bar -->
<script>
  (function () {
    const bar = document.createElement('div');
    bar.id = 'read-progress';
    bar.setAttribute('aria-hidden', 'true');
    document.body.appendChild(bar);

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
          bar.style.setProperty('--scroll-progress', `${progress}%`);
          ticking = false;
        });
        ticking = true;
      }
    });
  })();
</script>

<style is:global>
  #read-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: var(--scroll-progress, 0%);
    height: 3px;
    background: linear-gradient(90deg, #c9a84c, #e6c587, #c9a84c);
    background-size: 200% 100%;
    animation: shimmer 2s linear infinite;
    z-index: 9999;
    transition: width 0.1s linear;
    pointer-events: none;
    box-shadow: 0 2px 10px rgba(201, 168, 76, 0.4);
  }

  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
</style>

<style>
  /* ============================================
     MIXED ROUTES DETAIL PAGE — Editorial Cream Style
     Premium blocks with animations and micro-interactions
     ============================================ */

  /* Hero Section */
  .mx-hero {
    position: relative;
    padding: 8rem 2rem 4rem;
    background: linear-gradient(180deg, #1a1619 0%, #0a0a0a 100%);
    overflow: hidden;
  }

  .mx-hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .mx-hero-gradient {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 20%, rgba(201, 168, 76, 0.08) 0%, transparent 50%),
                radial-gradient(ellipse at 70% 60%, rgba(232, 98, 42, 0.05) 0%, transparent 40%);
  }

  .mx-hero-glow {
    position: absolute;
    top: 20%;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(201, 168, 76, 0.06), transparent 70%);
    filter: blur(60px);
  }

  .mx-hero-content {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
    z-index: 2;
  }

  .mx-back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(240, 237, 232, 0.5);
    text-decoration: none;
    margin-bottom: 2rem;
    transition: all 0.3s ease;
  }

  .mx-back-link:hover {
    color: var(--s-gold);
    gap: 0.75rem;
  }

  .mx-back-link svg {
    width: 18px;
    height: 18px;
    transition: transform 0.3s ease;
  }

  .mx-back-link:hover svg {
    transform: translateX(-4px);
  }

  .mx-hero-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .mx-duration-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(201, 168, 76, 0.15);
    border: 1px solid rgba(201, 168, 76, 0.3);
    border-radius: 100px;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--s-gold);
  }

  .mx-duration-badge svg {
    width: 16px;
    height: 16px;
  }

  .mx-hero-stats {
    font-family: var(--font-display);
    font-size: 0.82rem;
    color: rgba(240, 237, 232, 0.4);
  }

  .mx-hero-title {
    font-family: var(--font-body);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 300;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: #f0ede8;
    margin-bottom: 1.5rem;
  }

  .mx-hero-desc {
    font-family: var(--font-display);
    font-size: 1.15rem;
    line-height: 1.7;
    color: rgba(240, 237, 232, 0.6);
    max-width: 65ch;
    margin-bottom: 1.5rem;
  }

  .mx-best-for {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.25rem;
    background: rgba(240, 237, 232, 0.05);
    border: 1px solid rgba(240, 237, 232, 0.1);
    border-radius: 8px;
  }

  .mx-best-for-label {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 600;
    color: rgba(240, 237, 232, 0.5);
  }

  .mx-best-for-text {
    font-family: var(--font-display);
    font-size: 0.88rem;
    font-weight: 500;
    color: #f0ede8;
  }

  /* Hero Dock */
  .mx-hero-dock {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    max-width: 600px;
    margin: 3rem auto 0;
    padding: 1.5rem 2rem;
    background: rgba(240, 237, 232, 0.03);
    border: 1px solid rgba(240, 237, 232, 0.08);
    border-radius: 16px;
    backdrop-filter: blur(20px);
  }

  .mx-dock-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .mx-dock-label {
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(240, 237, 232, 0.4);
  }

  .mx-dock-value {
    font-family: var(--font-body);
    font-size: 1.25rem;
    font-weight: 400;
    color: #f0ede8;
  }

  .mx-dock-sep {
    width: 1px;
    height: 40px;

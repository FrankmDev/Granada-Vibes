---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/layout/Breadcrumbs.astro';
import Icon from '@components/ui/Icon.astro';
import { getAllRoutes, getRouteBySlug } from '@data/index.js';
import { useTranslations } from '@i18n/utils';
import { formatDuration, formatDistance } from '@utils/dates';
import type { RouteDifficulty } from '@types';

export function getStaticPaths() {
  const routes = getAllRoutes();
  return routes.map((route) => ({
    params: { slug: route.slug },
    props: { route },
  }));
}

const { route } = Astro.props;
const locale = 'es';
const t = useTranslations(locale);

const breadcrumbs = [
  { label: t('nav.home'), href: '/' },
  { label: t('nav.routes'), href: '/rutas' },
  { label: route.title[locale] },
];

// Difficulty color mapping
const difficultyColors: Record<RouteDifficulty, { bg: string; text: string; bar: string; label: string }> = {
  easy:        { bg: 'bg-emerald-500/15',    text: 'text-emerald-400',    bar: 'bg-emerald-400',    label: 'Fácil' },
  moderate:    { bg: 'bg-[#F59E0B]/15',      text: 'text-[#F59E0B]',      bar: 'bg-[#F59E0B]',      label: 'Moderada' },
  challenging: { bg: 'bg-[#E84D27]/15',      text: 'text-[#E84D27]',      bar: 'bg-[#E84D27]',      label: 'Exigente' },
};

const difficultyConfig = difficultyColors[route.difficulty];

// Difficulty bars (1-3 segments)
const difficultyBars: Record<RouteDifficulty, number> = {
  easy:        1,
  moderate:    2,
  challenging: 3,
};

// Time of day icon
const timeOfDayIcons = {
  morning: 'sun',
  afternoon: 'sun',
  sunset: 'sunset',
  evening: 'moon',
  any: 'sun',
};

// Get related routes (same category or difficulty)
const relatedRoutes = getAllRoutes()
  .filter(r => r.category === route.category && r.id !== route.id)
  .slice(0, 2);

if (relatedRoutes.length < 2) {
  const moreRoutes = getAllRoutes()
    .filter(r => r.difficulty === route.difficulty && r.id !== route.id && !relatedRoutes.find(rr => rr.id === r.id))
    .slice(0, 2 - relatedRoutes.length);
  relatedRoutes.push(...moreRoutes);
}

// OG Image
const ogImage = 'https://placehold.co/1200x630/0a0a0a/f2cc8f?text=Granada+Vibes+Rutas';
---

<BaseLayout 
  locale={locale}
  title={route.title[locale]}
  description={`Ruta de ${t(`categories.${route.category}`)} por ${route.neighborhoods.map(n => t(`neighborhoods.${n}`)).join(', ')} en Granada: ${formatDuration(route.duration, locale)}, ${formatDistance(route.distance, locale)}. Dificultad ${t(`difficulty.${route.difficulty}`)}. Consejos, highlights y mejor momento.`}
  ogImage={ogImage}
  schemaType="route"
  schemaData={route}
>
  {/* Background decorations */}
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-[#F59E0B]/5 rounded-full blur-[150px] pointer-events-none -z-10"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-[#E84D27]/5 rounded-full blur-[120px] pointer-events-none -z-10"></div>

  <article class="container pt-28 pb-20 lg:pt-32 relative z-10">
    <Breadcrumbs items={breadcrumbs} />

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-12 lg:gap-16 mt-8">
      <!-- Columna Principal (70%) -->
      <div class="order-2 lg:order-1">
        <!-- Hero de la ruta -->
        <header class="mb-10">
          <!-- Badges -->
          <div class="flex flex-wrap items-center gap-3 mb-5">
            <span class="px-3 py-1.5 text-[11px] font-bold uppercase tracking-wider bg-[#F59E0B]/10 text-[#F59E0B] rounded-full border border-[#F59E0B]/30">
              {t(`categories.${route.category}`)}
            </span>
            <span class:list={[
              'px-3 py-1.5 text-[11px] font-bold uppercase tracking-wider rounded-full border',
              difficultyConfig.bg,
              difficultyConfig.text,
              'border-white/[0.1]'
            ]}>
              {t(`difficulty.${route.difficulty}`)}
            </span>
            {route.featured && (
              <span class="px-3 py-1.5 text-[11px] font-bold uppercase tracking-wider bg-[#E84D27]/10 text-[#E84D27] rounded-full border border-[#E84D27]/30">
                Destacada
              </span>
            )}
          </div>

          <!-- Headline -->
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-[-0.02em] text-white mb-6 leading-[1.1]">
            {route.title[locale]}
          </h1>

          <!-- Descripción -->
          <p class="text-lg lg:text-xl text-white/50 leading-relaxed max-w-2xl">
            {route.description[locale]}
          </p>
        </header>

        <!-- Barra de métricas visual -->
        <div class="p-6 bg-white/[0.04] rounded-2xl border border-white/[0.06] mb-10">
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
            <!-- Duración -->
            <div class="text-center">
              <div class="w-12 h-12 bg-[#F59E0B]/10 rounded-xl flex items-center justify-center mx-auto mb-3">
                <svg class="w-6 h-6 text-[#F59E0B]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <p class="text-2xl font-black text-white">
                {Math.round(route.duration / 60)}h
              </p>
              <p class="text-xs text-white/30 uppercase tracking-wider mt-1">Duración</p>
            </div>

            <!-- Distancia -->
            <div class="text-center">
              <div class="w-12 h-12 bg-[#F59E0B]/10 rounded-xl flex items-center justify-center mx-auto mb-3">
                <svg class="w-6 h-6 text-[#F59E0B]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0121 18.382V7.618a1 1 0 01-.447-.894L15 7m0 13V7" />
                </svg>
              </div>
              <p class="text-2xl font-black text-white">
                {route.distance} km
              </p>
              <p class="text-xs text-white/30 uppercase tracking-wider mt-1">Distancia</p>
            </div>

            <!-- Dificultad -->
            <div class="text-center">
              <div class:list={['w-12 h-12 rounded-xl flex items-center justify-center mx-auto mb-3', difficultyConfig.bg]}>
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" class:list={[difficultyConfig.text]}>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <p class:list={['text-2xl font-black', difficultyConfig.text]}>
                {difficultyConfig.label}
              </p>
              <p class="text-xs text-white/30 uppercase tracking-wider mt-1">Dificultad</p>
            </div>

            <!-- Mejor momento -->
            <div class="text-center">
              <div class="w-12 h-12 bg-[#F59E0B]/10 rounded-xl flex items-center justify-center mx-auto mb-3">
                {route.timeOfDay === 'evening' || route.timeOfDay === 'sunset' ? (
                  <svg class="w-6 h-6 text-[#F59E0B]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                  </svg>
                ) : (
                  <svg class="w-6 h-6 text-[#F59E0B]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
                  </svg>
                )}
              </div>
              <p class="text-2xl font-black text-white">
                {t(`timeOfDay.${route.timeOfDay}`)}
              </p>
              <p class="text-xs text-white/30 uppercase tracking-wider mt-1">Mejor momento</p>
            </div>
          </div>
        </div>

        <!-- Descripción larga si existe -->
        {route.longDescription && (
          <section class="mb-12" aria-labelledby="description-heading">
            <h2 id="description-heading" class="text-2xl lg:text-3xl font-bold text-white mb-5">
              Sobre esta ruta
            </h2>
            <p class="text-white/50 leading-relaxed">
              {route.longDescription[locale]}
            </p>
          </section>
        )}

        <!-- Puntos del recorrido (Timeline) -->
        {route.highlights.length > 0 && (
          <section class="mb-12" aria-labelledby="highlights-heading">
            <h2 id="highlights-heading" class="text-2xl lg:text-3xl font-bold text-white mb-8">
              Puntos del recorrido
            </h2>
            <div class="relative">
              {/* Línea vertical */}
              <div class="absolute left-5 top-0 bottom-0 w-px bg-white/[0.1]" />
              
              <div class="space-y-8">
                {route.highlights.map((highlight, index) => (
                  <div class="relative flex items-start gap-6">
                    {/* Círculo numerado */}
                    <div class="relative z-10 w-10 h-10 rounded-full bg-[#E84D27] flex items-center justify-center flex-shrink-0">
                      <span class="text-white font-black text-sm">{index + 1}</span>
                    </div>
                    <div class="flex-1 pt-2">
                      <h3 class="text-lg font-bold text-white mb-2">
                        {highlight.title[locale]}
                      </h3>
                      <p class="text-white/50 leading-relaxed">
                        {highlight.description[locale]}
                      </p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </section>
        )}

        <!-- Consejos -->
        {route.tips.length > 0 && (
          <section class="mb-12" aria-labelledby="tips-heading">
            <h2 id="tips-heading" class="text-2xl lg:text-3xl font-bold text-white mb-6">
              Consejos
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {route.tips.map((tip) => (
                <div class="p-5 bg-white/[0.04] rounded-2xl border border-white/[0.06]">
                  <div class="flex items-start gap-3">
                    <div class="w-10 h-10 bg-[#F59E0B]/10 rounded-xl flex items-center justify-center flex-shrink-0">
                      <svg class="w-5 h-5 text-[#F59E0B]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                    </div>
                    <div>
                      <h3 class="text-base font-bold text-white mb-1">
                        {tip.title[locale]}
                      </h3>
                      <p class="text-sm text-white/50 leading-relaxed">
                        {tip.content[locale]}
                      </p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- Qué llevar -->
        {route.whatToBring && route.whatToBring[locale]?.length > 0 && (
          <section class="mb-12" aria-labelledby="what-to-bring-heading">
            <h2 id="what-to-bring-heading" class="text-2xl lg:text-3xl font-bold text-white mb-6">
              Qué llevar
            </h2>
            <div class="p-6 bg-white/[0.04] rounded-2xl border border-white/[0.06]">
              <ul class="space-y-3">
                {route.whatToBring[locale]?.map((item) => (
                  <li class="flex items-center gap-3">
                    <svg class="w-5 h-5 text-[#F59E0B] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7" />
                    </svg>
                    <span class="text-white/50">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </section>
        )}

        <!-- Tags -->
        {route.tags.length > 0 && (
          <section aria-labelledby="tags-heading">
            <h2 id="tags-heading" class="sr-only">Etiquetas</h2>
            <div class="flex flex-wrap gap-2">
              {route.tags.map((tag) => (
                <span class="px-4 py-2 text-sm text-white/50 bg-white/[0.04] rounded-full border border-white/[0.06]">
                  #{tag}
                </span>
              ))}
            </div>
          </section>
        )}
      </div>

      <!-- Sidebar (30%) -->
      <aside class="order-1 lg:order-2">
        <div class="lg:sticky lg:top-28 space-y-6">
          <!-- Card de info sticky -->
          <div class="p-6 lg:p-8 bg-white/[0.04] backdrop-blur-xl border border-white/[0.06] rounded-2xl">
            <!-- Dificultad con barra visual -->
            <div class="mb-6">
              <p class="text-sm text-white/40 mb-3">Dificultad</p>
              <div class="flex items-center gap-3">
                <div class="flex gap-1">
                  {[1, 2, 3].map((bar) => (
                    <div 
                      class:list={[
                        'w-8 h-2 rounded-full',
                        bar <= difficultyBars[route.difficulty] ? difficultyConfig.bar : 'bg-white/[0.05]'
                      ]} 
                    />
                  ))}
                </div>
                <span class:list={['text-sm font-medium', difficultyConfig.text]}>
                  {t(`difficulty.${route.difficulty}`)}
                </span>
              </div>
            </div>

            <!-- Duración -->
            <div class="mb-6">
              <p class="text-sm text-white/40 mb-1">Duración</p>
              <p class="text-xl font-black text-white">
                {formatDuration(route.duration, locale)}
              </p>
            </div>

            <!-- Distancia -->
            <div class="mb-6">
              <p class="text-sm text-white/40 mb-1">Distancia</p>
              <p class="text-xl font-black text-white">
                {formatDistance(route.distance, locale)}
              </p>
            </div>

            <!-- Mejor momento -->
            <div class="mb-6">
              <p class="text-sm text-white/40 mb-1">Mejor momento</p>
              <div class="flex items-center gap-2">
                {route.timeOfDay === 'evening' || route.timeOfDay === 'sunset' ? (
                  <svg class="w-5 h-5 text-[#F59E0B]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                  </svg>
                ) : (
                  <svg class="w-5 h-5 text-[#F59E0B]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
                  </svg>
                )}
                <p class="font-medium text-white">
                  Mejor al {t(`timeOfDay.${route.timeOfDay}`).toLowerCase()}
                </p>
              </div>
            </div>

            <!-- Barrios -->
            <div class="mb-6">
              <p class="text-sm text-white/40 mb-3">Barrios</p>
              <div class="flex flex-wrap gap-2">
                {route.neighborhoods.map((n) => (
                  <span class="px-3 py-1.5 text-xs font-medium bg-white/[0.05] text-white/50 rounded-full border border-white/[0.08]">
                    {t(`neighborhoods.${n}`)}
                  </span>
                ))}
              </div>
            </div>

            <!-- Mejores meses -->
            {route.bestMonths && route.bestMonths.length > 0 && (
              <div class="mb-6">
                <p class="text-sm text-white/40 mb-3">Mejores meses</p>
                <div class="flex flex-wrap gap-1">
                  {route.bestMonths.map((month) => (
                    <span class="px-2 py-1 text-xs text-white/30 capitalize">
                      {month}
                    </span>
                  ))}
                </div>
              </div>
            )}

            <!-- Separador -->
            <div class="h-px bg-white/[0.06] my-6" />

            <!-- Botón compartir -->
            <button 
              id="share-button"
              class="flex items-center justify-center gap-2 w-full px-6 py-3 bg-transparent text-white/50 font-medium text-sm rounded-xl border border-white/[0.08] hover:border-white/[0.2] hover:text-white transition-all duration-200"
              data-title={route.title[locale]}
              data-url={Astro.url.href}
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
              </svg>
              Compartir ruta
            </button>
          </div>

          <!-- Rutas similares -->
          {relatedRoutes.length > 0 && (
            <div class="p-6 bg-white/[0.03] border border-white/[0.06] rounded-2xl">
              <h3 class="text-lg font-bold text-white mb-4">
                Rutas similares
              </h3>
              <div class="space-y-4">
                {relatedRoutes.map((relatedRoute) => (
                  <a 
                    href={`/rutas/${relatedRoute.slug}`}
                    class="block group"
                  >
                    <div class="flex items-start gap-3">
                      <div class="w-12 h-12 bg-white/[0.05] rounded-xl flex items-center justify-center flex-shrink-0 border border-white/[0.08] group-hover:border-[#F59E0B]/30 transition-colors">
                        <svg class="w-5 h-5 text-white/30 group-hover:text-[#F59E0B] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0121 18.382V7.618a1 1 0 01-.447-.894L15 7m0 13V7" />
                        </svg>
                      </div>
                      <div class="flex-1 min-w-0">
                        <p class="font-medium text-white text-sm group-hover:text-[#F59E0B] transition-colors line-clamp-2">
                          {relatedRoute.title[locale]}
                        </p>
                        <p class="text-xs text-white/30 mt-1">
                          {formatDuration(relatedRoute.duration, locale)} · {t(`difficulty.${relatedRoute.difficulty}`)}
                        </p>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      </aside>
    </div>
  </article>

  <!-- Share functionality -->
  <script is:inline>
    (function() {
      const shareButton = document.getElementById('share-button');
      if (!shareButton) return;

      const title = shareButton.dataset.title;
      const url = shareButton.dataset.url;

      shareButton.addEventListener('click', async function() {
        if (navigator.share) {
          try {
            await navigator.share({
              title: title,
              text: `Descubre la ruta "${title}" en Granada Vibes`,
              url: url
            });
            return;
          } catch (err) {
            // User cancelled or share failed, fall back to clipboard
          }
        }

        try {
          await navigator.clipboard.writeText(url);
          const originalText = shareButton.innerHTML;
          shareButton.innerHTML = `
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7" />
            </svg>
            Enlace copiado
          `;
          setTimeout(() => {
            shareButton.innerHTML = originalText;
          }, 2000);
        } catch (err) {
          console.error('Failed to copy:', err);
        }
      });
    })();
  </script>
</BaseLayout>

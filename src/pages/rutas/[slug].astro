---
import BaseLayout from '@layouts/BaseLayout.astro';
import RouteDetailHero from '@components/routes/RouteDetailHero.astro';
import Footer from '@components/layout/Footer.astro';
import { getAllRoutes } from '@data/index.js';
import { useTranslations } from '@i18n/utils';
import { formatDuration, formatDistance } from '@utils/dates';
import type { RouteDifficulty } from '@types';

export function getStaticPaths() {
  const routes = getAllRoutes();
  return routes.map((route) => ({
    params: { slug: route.slug },
    props: { route },
  }));
}

const { route } = Astro.props;
const locale = 'es';
const t = useTranslations(locale);

const relatedRoutes = getAllRoutes()
  .filter(r => r.category === route.category && r.id !== route.id)
  .slice(0, 3);

if (relatedRoutes.length < 3) {
  const more = getAllRoutes()
    .filter(r => r.difficulty === route.difficulty && r.id !== route.id && !relatedRoutes.find(rr => rr.id === r.id))
    .slice(0, 3 - relatedRoutes.length);
  relatedRoutes.push(...more);
}

const routeImage = route.image;
const ogImage = routeImage || 'https://placehold.co/1200x630/0a0a0a/f2cc8f?text=Granada+Vibes+Rutas';

const neighborhoodList = route.neighborhoods.map((n: string) => t(`neighborhoods.${n}` as any)).join(', ');
const seoDescription = `Ruta "${route.title[locale]}" por ${neighborhoodList} en Granada — ${formatDuration(route.duration, locale)} de ${t(`categories.${route.category}` as any).toLowerCase()}, ${formatDistance(route.distance, locale)}. Dificultad ${t(`difficulty.${route.difficulty}` as any).toLowerCase()}. Descubre consejos prácticos, puntos imprescindibles y cómo preparar el itinerario perfecto.`;

const monthsEs = ['enero', 'febrero', 'marzo', 'abril', 'mayo', 'junio', 'julio', 'agosto', 'septiembre', 'octubre', 'noviembre', 'diciembre'];
const monthsShort = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];

// Extraer el número de distancia para destacar
const distString = formatDistance(route.distance, locale);
const distValue = distString.replace(/[^\d.,]/g, '').trim();
const distUnit = distString.replace(/[\d.,]/g, '').trim();

// Icono helper según hora del día
const timeIcon = (route.timeOfDay === 'evening' || route.timeOfDay === 'sunset') 
  ? '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>'
  : '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>';
---

<BaseLayout
  locale={locale}
  title={route.title[locale]}
  description={seoDescription}
  ogImage={ogImage}
  schemaType="route"
  schemaData={route}
>
  <RouteDetailHero route={route} locale={locale} />

  <!-- CREAM EDITORIAL CONTENT WITH UPGRADED UI -->
  <div class="det-page route-page-override">

    <div class="det-content-wrap">
      <div class="det-layout upgraded-layout">

        <!-- MAIN CONTENT (LEFT) -->
        <main id="main-content" class="det-main upgraded-main">

          <!-- 1. Description Block -->
          <article class="upg-block" data-reveal>
            <div class="upg-block-bg"></div>
            <header class="upg-header">
              <span class="upg-num">01</span>
              <div class="upg-line"></div>
              <span class="upg-eyebrow">[ Sobre la ruta ]</span>
            </header>
            
            <h2 class="upg-title">Descripción</h2>
            
            <div class="upg-body content-rich">
              <p class="upg-lead">{route.description[locale]}</p>
              {route.longDescription && <p class="upg-text-secondary">{route.longDescription[locale]}</p>}
            </div>
            
            <!-- Neighborhood tags -->
            {route.neighborhoods && route.neighborhoods.length > 0 && (
              <div class="upg-route-neighs">
                <span class="upg-rn-label">Barrios:</span>
                <div class="upg-tags-list">
                  {route.neighborhoods.map((n: string) => (
                    <span class="upg-badge ghost">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                      {t(`neighborhoods.${n}` as any)}
                    </span>
                  ))}
                </div>
              </div>
            )}
          </article>

          <!-- 2. Tour Highlights (like Events Qué Esperar/Experiencia) -->
          {route.highlights && route.highlights.length > 0 && (
            <article class="upg-block" data-reveal>
              <div class="upg-block-bg"></div>
              <header class="upg-header">
                <span class="upg-num">02</span>
                <div class="upg-line"></div>
                <span class="upg-eyebrow">[ RECORRIDO ]</span>
              </header>
              <h2 class="upg-title">El itinerario</h2>
              
              <div class="upg-highlights">
                {route.highlights.map((hl: any, idx: number) => (
                  <div class="upg-hl-item" style={`--hl-delay: ${idx * 0.1}s`}>
                    <div class="upg-hl-num-wrap">
                      <span class="upg-hl-num">{(idx + 1).toString().padStart(2, '0')}</span>
                    </div>
                    <div class="upg-hl-content">
                      <h3 class="tl-title" style="margin-bottom:0.4rem; font-family: var(--font-display); font-size:1.1rem; color:var(--s-ink);">{hl.title[locale]}</h3>
                      <p class="upg-hl-text" style="padding-top:0;">{hl.description[locale]}</p>
                    </div>
                  </div>
                ))}
              </div>
            </article>
          )}

          <!-- 3. Local Tips Block -->
          {route.tips && route.tips.length > 0 && (
            <article class="upg-block block-tips" data-reveal>
              <div class="upg-block-bg"></div>
              <header class="upg-header">
                <span class="upg-num">03</span>
                <div class="upg-line"></div>
                <span class="upg-eyebrow">[ Recomendación ]</span>
              </header>
              <h2 class="upg-title">Tips de local</h2>
              
              <div class="upg-tips-content" style="flex-direction: column;">
                {route.tips.map((tip: any, i: number) => (
                  <div style="display: flex; gap: 1.5rem; align-items: flex-start; margin-bottom: 2rem;">
                    <div class="upg-tips-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </div>
                    <div>
                      <h3 style="font-family: var(--font-display); font-size: 1.05rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--s-ink);">{tip.title[locale]}</h3>
                      <p class="upg-tips-text" style="font-style: normal;">{tip.content[locale]}</p>
                    </div>
                  </div>
                ))}
              </div>
            </article>
          )}

          <!-- Tags -->
          {route.tags && route.tags.length > 0 && (
             <div class="upg-tags" data-reveal>
               <span class="upg-tags-title">[ Etiquetas ]</span>
               <div class="upg-tags-list">
                 {route.tags.map((tag: string) => (
                   <span class="upg-tag">#{tag}</span>
                 ))}
               </div>
             </div>
          )}

        </main>

        <!-- ENHANCED SIDEBAR (RIGHT) -->
        <aside class="upg-sidebar">
          <div class="upg-sidebar-sticky">

            <!-- Premium Ticket Card - IDENTICAL TO EVENTS TICKET -->
            <div class="upg-ticket-card" data-reveal>
              <div class="upg-ticket-glass"></div>
              
              <!-- Ticket Header -->
              <div class="upg-tc-header">
                <div class="upg-tc-date-box">
                  <span class="tc-day" style="font-size: 1rem; font-weight:600; font-family:var(--font-display);">{t(`timeOfDay.${route.timeOfDay}` as any).slice(0,3).toUpperCase()}</span>
                  <span class="tc-month">HORARIO</span>
                </div>
                <div class="upg-tc-info">
                  <span class="tc-time" style="color:var(--s-ink);">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                    {formatDuration(route.duration, locale)}
                  </span>
                  <span class="tc-category">{t(`categories.${route.category}`)}</span>
                </div>
              </div>

              <!-- Huge Number Box (Distance instead of Price) -->
              <div class="upg-tc-price-wrap">
                <span class="tc-price-label">{t('detail.distance')}</span>
                <span class="tc-price-val">
                  {distValue}<span style="font-size:1.5rem; margin-left:5px;">{distUnit}</span>
                </span>
              </div>
              
              <!-- Difficulty Sub-label injected below big number -->
              <div style="padding: 0 2.5rem 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
                 <span style="font-family: var(--font-display); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: var(--s-orange);">{t(`difficulty.${route.difficulty}` as any)}</span>
                 <div style="flex:1; height: 1px; background: var(--s-border);"></div>
              </div>

              <!-- What to Bring embedded in ticket conditionally -->
              {route.whatToBring && (
                <div style="padding: 0 2.5rem 1rem;">
                  <span class="tc-price-label" style="display:block; margin-bottom:0.75rem;">QUÉ LLEVAR</span>
                  <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0.5rem;">
                    {route.whatToBring[locale].map((item: string) => (
                      <li style="display:flex; align-items:flex-start; gap:0.5rem; font-family:var(--font-display); font-size:0.8rem; color:var(--s-ink-2);">
                        <span style="color:#d4873a; margin-top:-2px;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M5 13l4 4L19 7"/></svg></span>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              <div class="upg-tc-divider">
                <span class="tcd-hole left"></span>
                <div class="tcd-dashed"></div>
                <span class="tcd-hole right"></span>
              </div>

              <!-- Actions -->
              <div class="upg-tc-actions">
                <button id="upg-share-btn" class="upg-btn-primary"
                  data-title={route.title[locale]}
                  data-url={Astro.url.href}
                >
                  <span>Compartir ruta</span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
                </button>
              </div>

            </div>

            <!-- Related Events Bento -->
            {relatedRoutes.length > 0 && (
              <div class="upg-related-bento" data-reveal>
                <div class="upg-rb-header">
                  <span class="upg-rb-title">[ {locale === 'es' ? 'Rutas similares' : 'Similar routes'} ]</span>
                  <a href="/rutas" class="upg-rb-all">Ver todas →</a>
                </div>
                
                <div class="upg-rb-list">
                  {relatedRoutes.map((rel, i) => (
                    <a href={`/rutas/${rel.slug}`} class="upg-rel-item" style={`--rd: ${i * 0.15}s`}>
                      <div class="uri-thumb">
                        {(rel.imageUrl || rel.image) ? (
                          <img src={rel.imageUrl || rel.image} alt="" loading="lazy" />
                        ) : (
                          <div class="uri-thumb-fallback"></div>
                        )}
                      </div>
                      <div class="uri-content">
                        <span class="uri-title">{rel.title[locale]}</span>
                        <span class="uri-meta">
                           {formatDuration(rel.duration, locale)}
                        </span>
                      </div>
                      <div class="uri-arrow">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            )}

          </div>
        </aside>

      </div>
    </div>

    <div class="det-footer-orn" aria-hidden="true" style="display: flex; align-items: center; justify-content: center; gap: 1rem; padding: 3rem clamp(1.5rem, 5vw, 4rem) 4rem; opacity: 0.3;">
      <span style="flex: 1; max-width: 120px; height: 1px; background: var(--s-border);"></span>
      <span style="color: var(--s-gold);"><svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17.2l-6.2 4.1 2.4-7.4L2 9.4h7.6z"/></svg></span>
      <span style="flex: 1; max-width: 120px; height: 1px; background: var(--s-border);"></span>
    </div>

  </div>

  <Footer slot="footer" locale={locale} />
</BaseLayout>

<script is:inline>
  (function () {
    const btn = document.getElementById('upg-share-btn');
    if (!btn) return;
    btn.addEventListener('click', async function () {
      const title = btn.dataset.title;
      const url   = btn.dataset.url;
      const label = btn.querySelector('span');
      if (navigator.share) {
        try { await navigator.share({ title, text: 'Descubre "' + title + '" en Granada Vibes', url }); return; }
        catch (_) {}
      }
      try {
        await navigator.clipboard.writeText(url ?? '');
        if (label) {
          const orig = label.textContent;
          label.textContent = '¡Copiado!';
          setTimeout(() => { label.textContent = orig; }, 2000);
        }
      } catch (_) {}
    });
  })();
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const io = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } }),
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );
    document.querySelectorAll('[data-reveal]').forEach(el => io.observe(el));
  });
</script>

<style is:global>
  /* BASE DE PAGINA */
  .route-page-override {
    --s-bg:       #f5f0ea;
    --s-bg-hi:    #faf8f5;
    --s-ink:      #1a1619;
    --s-ink-2:    #5a4f47;
    --s-ink-3:    #8a7f77;
    --s-orange:   #e8622a;
    --s-gold:     #c9a84c;
    --s-border:   rgba(26,22,25,0.10);
    
    background: var(--s-bg);
    position: relative;
    padding-bottom: 0rem;
  }
  .route-page-override::before {
    content: ''; position: absolute; inset: 0; pointer-events: none; z-index: 1; mix-blend-mode: multiply; opacity: 0.025;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  /* UPGRADED LAYOUT */
  .det-content-wrap { max-width: 1440px; margin: 0 auto; padding: 4rem clamp(1.5rem, 5vw, 4rem) 2rem; position: relative; z-index: 2; }
  .upgraded-layout { gap: 5rem; grid-template-columns: 1fr 380px; max-width: 1300px; margin: 0 auto; display: grid; align-items: start; }

  /* LEFT TRACK: MAIN */
  .upgraded-main { display: flex; flex-direction: column; background: transparent; gap: 3rem; }

  .upg-block {
    position: relative; padding: 3rem; background: var(--s-bg-hi);
    border: 1px solid var(--s-border); border-radius: 20px; opacity: 0; transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1); box-shadow: 0 4px 20px rgba(0,0,0,0.015);
  }
  .upg-block:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(0,0,0,0.04); }
  .upg-block.is-visible { opacity: 1; transform: translateY(0); }

  .upg-header { display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem; }
  .upg-num { font-family: var(--font-display); font-size: 0.75rem; font-weight: 600; color: var(--s-orange); }
  .upg-line { height: 1px; flex: 1; max-width: 60px; background: linear-gradient(90deg, var(--s-orange), transparent); opacity: 0.5; }
  .upg-eyebrow { font-family: var(--font-display); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--s-ink-3); }

  .upg-title { font-family: var(--font-body); font-size: 2.2rem; font-weight: 300; letter-spacing: -0.02em; color: var(--s-ink); margin-bottom: 1.5rem; line-height: 1.2; }
  .upg-lead { font-family: var(--font-display); font-size: 1.1rem; line-height: 1.8; color: var(--s-ink-2); max-width: 68ch; }
  .upg-text-secondary { font-family: var(--font-display); font-size: 1rem; line-height: 1.8; color: var(--s-ink-2); max-width: 70ch; margin-top: 1rem; }

  .upg-route-neighs { margin-top: 2rem; display: flex; align-items: center; gap: 1rem; padding-top: 2rem; border-top: 1px dashed var(--s-border); }
  .upg-rn-label { font-family: var(--font-display); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; color: var(--s-ink-3); text-transform: uppercase; }

  .upg-badge {
    display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.5rem 1rem;
    border-radius: 8px; font-family: var(--font-display); font-size: 0.75rem; font-weight: 600; letter-spacing: 0.05em;
    background: rgba(201,168,76,0.15); color: #8a6d3b; border: 1px solid rgba(201,168,76,0.3);
  }
  .upg-badge.ghost { background: transparent; border-color: var(--s-border); color: var(--s-ink-2); }
  .upg-badge svg { width: 14px; height: 14px; }

  /* HIGHLIGHTS Upgrades */
  .upg-highlights { display: flex; flex-direction: column; gap: 1.5rem; }
  .upg-hl-item {
    display: flex; gap: 1.5rem; align-items: flex-start;
    opacity: 0; transform: translateX(-20px);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1) var(--hl-delay);
  }
  .upg-block.is-visible .upg-hl-item { opacity: 1; transform: translateX(0); }
  
  .upg-hl-num-wrap {
    width: 40px; height: 40px; border-radius: 50%;
    background: var(--s-bg); border: 1px solid var(--s-border);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .upg-hl-num { font-family: var(--font-display); font-size: 0.8rem; font-weight: 600; color: var(--s-ink); }
  .upg-hl-text { font-family: var(--font-display); font-size: 1.05rem; line-height: 1.6; color: var(--s-ink-2); padding-top: 0.45rem; }

  /* TIPS */
  .block-tips {
    background: linear-gradient(135deg, rgba(232,98,42,0.05), transparent);
    border-color: rgba(232,98,42,0.15);
  }
  .upg-tips-content { display: flex; gap: 1.5rem; align-items: flex-start; }
  .upg-tips-icon {
    width: 48px; height: 48px; border-radius: 12px; background: rgba(232,98,42,0.1);
    color: var(--s-orange); display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .upg-tips-icon svg { width: 24px; height: 24px; }
  .upg-tips-text { font-size: 1.1rem; line-height: 1.7; color: var(--s-ink-2); font-style: italic; }

  /* TAGS */
  .upg-tags { opacity: 0; transform: translateY(20px); transition: all 0.6s ease; margin-left: 1rem; }
  .upg-tags.is-visible { opacity: 1; transform: translateY(0); }
  .upg-tags-title { display: block; font-family: var(--font-display); font-size: 0.65rem; font-weight: 700; color: var(--s-ink-3); margin-bottom: 1rem; letter-spacing: 0.1em; }
  .upg-tags-list { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .upg-tag {
    padding: 0.5rem 1rem; background: rgba(26,22,25,0.03); border-radius: 100px;
    font-family: var(--font-display); font-size: 0.75rem; color: var(--s-ink-2);
    transition: all 0.3s ease;
  }
  .upg-tag:hover { background: var(--s-ink); color: #fff; }

  /* RIGHT TRACK: SIDEBAR */
  .upg-sidebar-sticky { position: sticky; top: calc(var(--header-height, 64px) + 2rem); display: flex; flex-direction: column; gap: 2rem; }

  /* Premium Ticket Card */
  .upg-ticket-card {
    position: relative;
    background: #fff;
    border-radius: 24px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.04), 0 1px 3px rgba(0,0,0,0.02);
    overflow: hidden;
    opacity: 0; transform: translateY(40px) scale(0.98);
    transition: all 0.9s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .upg-ticket-card.is-visible { opacity: 1; transform: translateY(0) scale(1); }
  
  .upg-tc-header { padding: 2.5rem 2.5rem 2rem; display: flex; align-items: center; gap: 1.5rem; }
  .upg-tc-date-box {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    width: 64px; height: 64px; border-radius: 16px; background: rgba(201,168,76,0.15); color: #8a6d3b;
    border: 1px solid rgba(201,168,76,0.3);
  }
  .tc-day { font-family: var(--font-body); font-size: 1.5rem; font-weight: 400; line-height: 1; }
  .tc-month { font-family: var(--font-display); font-size: 0.6rem; font-weight: 700; letter-spacing: 0.1em; margin-top: 0.2rem; }
  
  .upg-tc-info { display: flex; flex-direction: column; gap: 0.4rem; }
  .tc-time { display: flex; align-items: center; gap: 0.4rem; font-family: var(--font-display); font-size: 0.95rem; font-weight: 600; color: var(--s-ink); }
  .tc-time svg { width: 16px; height: 16px; color: var(--s-orange); }
  .tc-category { font-family: var(--font-display); font-size: 0.75rem; letter-spacing: 0.05em; color: var(--s-ink-3); text-transform: uppercase; }


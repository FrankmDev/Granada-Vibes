---
import BaseLayout from '@layouts/BaseLayout.astro';
import EventCard from '@components/events/EventCard.astro';
import EventCarousel from '@components/events/EventCarousel.astro';
import RouteCard from '@components/routes/RouteCard.astro';
import HeroSection from '@components/home/HeroSection.astro';
import type { Event, Route } from '@types';
import { getFeaturedEvents, getFeaturedRoutes, getAllEvents } from '@data';
import { useTranslations } from '@i18n/utils';

const locale = 'es';
const t = useTranslations(locale);

const today = new Date().toISOString().split('T')[0];
const allEvents = getAllEvents();

const upcomingEvents = allEvents
  .filter((e: Event) => e.date >= today)
  .sort((a: Event, b: Event) => a.date.localeCompare(b.date));

const featuredRaw = getFeaturedEvents();
const featuredEvents = featuredRaw.length > 0
  ? featuredRaw.slice(0, 3)
  : upcomingEvents.slice(0, 3);

const thisWeekEvents = upcomingEvents.slice(0, 4);

const freeEvents = allEvents
  .filter((e: Event) => e.price === null && e.date >= today)
  .sort((a: Event, b: Event) => a.date.localeCompare(b.date))
  .slice(0, 3);

const featuredRoutes = getFeaturedRoutes().slice(0, 3);

const ogImage = 'https://placehold.co/1200x630/FEFCF8/E84D27?text=Granada+Vibes';
---

<BaseLayout
  locale={locale}
  title="Inicio"
  description="Descubre qué hacer en Granada. Guía local de eventos culturales, rutas por el Albaicín y Sacromonte, y planes alternativos fuera de lo turístico."
  ogImage={ogImage}
>
  <HeroSection thisWeekEvents={thisWeekEvents} locale={locale} />

  <!-- Upcoming Events Carousel -->
  <EventCarousel 
    events={upcomingEvents}
    locale={locale}
    t={t}
    title="Esta semana"
    subtitle="Descubre los mejores planes culturales esta semana en Granada: conciertos, exposiciones, flamenco y experiencias únicas."
    maxEvents={8}
  />

  <!-- Featured Events -->
  <section class="relative py-20 lg:py-28" aria-labelledby="featured-events-heading">
    <div class="container">
      <!-- Header -->
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-12">
        <div class="reveal">
          <div class="flex items-center gap-3 mb-4">
            <span class="w-10 h-[2px] bg-gradient-to-r from-primary to-secondary rounded-full"></span>
            <span class="text-xs font-bold uppercase tracking-[0.25em] text-primary">
              {t('events.featured')}
            </span>
          </div>
          <h2 id="featured-events-heading" class="font-display text-3xl lg:text-4xl font-bold text-surface">
            Eventos destacados
          </h2>
        </div>
        
        <a 
          href="/eventos" 
          class="inline-flex items-center gap-2 text-sm font-medium text-surface-secondary hover:text-primary transition-colors group"
        >
          <span>Ver todos</span>
          <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Asymmetric Grid - Featured event larger -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredEvents.map((event: Event, index: number) => (
          <EventCard event={event} locale={locale} t={t} featured={index === 0} />
        ))}
      </div>
    </div>
  </section>

  <!-- Free Events -->
  {freeEvents.length > 0 && (
    <section class="relative py-20 lg:py-28 bg-gradient-to-b from-base-100 to-base" aria-labelledby="free-events-heading">
      <div class="container">
        <div class="flex items-center gap-3 mb-6 reveal">
          <span class="w-8 h-[2px] bg-gradient-to-r from-secondary to-secondary/60 rounded-full"></span>
          <span class="text-xs font-bold uppercase tracking-[0.25em] text-secondary">
            {locale === 'es' ? 'Gratis' : 'Free'}
          </span>
        </div>
        
        <h2 id="free-events-heading" class="font-display text-3xl lg:text-4xl font-bold text-surface mb-10 reveal">
          Eventos gratuitos
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {freeEvents.map((event: Event) => (
            <EventCard event={event} locale={locale} t={t} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Featured Routes -->
  <section class="relative py-20 lg:py-28" aria-labelledby="routes-heading">
    <div class="container">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-12">
        <div class="reveal">
          <div class="flex items-center gap-3 mb-4">
            <span class="w-10 h-[2px] bg-gradient-to-r from-secondary to-primary rounded-full"></span>
            <span class="text-xs font-bold uppercase tracking-[0.25em] text-secondary">
              {t('routes.title')}
            </span>
          </div>
          <h2 id="routes-heading" class="font-display text-3xl lg:text-4xl font-bold text-surface">
            Rutas recomendadas
          </h2>
        </div>
        
        <a 
          href="/rutas" 
          class="inline-flex items-center gap-2 text-sm font-medium text-surface-secondary hover:text-secondary transition-colors group"
        >
          <span>Ver todas</span>
          <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredRoutes.map((route: Route, index: number) => (
          <RouteCard route={route} locale={locale} t={t} index={index} variant="grid" />
        ))}
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="relative py-20 lg:py-28 bg-gradient-to-b from-base-100 to-base" aria-labelledby="numbers-heading">
    <div class="container">
      <div class="text-center mb-14 reveal">
        <div class="flex items-center justify-center gap-3 mb-4">
          <span class="w-12 h-[1px] bg-gradient-to-r from-transparent to-primary/30"></span>
          <span class="text-[10px] font-bold uppercase tracking-[0.25em] text-surface-muted">Datos</span>
          <span class="w-12 h-[1px] bg-gradient-to-l from-transparent to-primary/30"></span>
        </div>
        <h2 id="numbers-heading" class="font-display text-3xl lg:text-4xl font-bold text-surface">
          Granada en <span class="text-gradient-primary">cifras</span>
        </h2>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
        {[
          { value: '800+', label: 'años', desc: 'de historia', color: 'text-primary', bgColor: 'bg-primary/10', borderColor: 'border-primary/20' },
          { value: '2', label: 'UNESCO', desc: 'Patrimonios', color: 'text-secondary', bgColor: 'bg-secondary/10', borderColor: 'border-secondary/20' },
          { value: '48h', label: 'para', desc: 'perderse', color: 'text-purple', bgColor: 'bg-purple/10', borderColor: 'border-purple/20' },
          { value: '0€', label: 'tapa', desc: 'incluida', color: 'text-amber', bgColor: 'bg-amber/10', borderColor: 'border-amber/20' },
        ].map((stat, index) => (
          <div class:list={[
            'text-center p-6 lg:p-8 rounded-3xl bg-white border-2 transition-all duration-300 hover:shadow-soft-lg hover:-translate-y-1',
            stat.borderColor,
            'hover:border-opacity-50'
          ]} style={`animation-delay: ${index * 100}ms`}>
            <p class:list={['font-display text-4xl lg:text-5xl font-bold mb-2', stat.color]}>{stat.value}</p>
            <p class="text-xs font-semibold text-surface uppercase tracking-wider mb-1">{stat.label}</p>
            <p class="text-xs text-surface-muted">{stat.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="relative py-24 lg:py-32 overflow-hidden" aria-labelledby="cta-title">
    <!-- Background decorations -->
    <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-secondary/5" aria-hidden="true"></div>
    <div class="absolute inset-0 pattern-dots opacity-20" aria-hidden="true"></div>
    
    <!-- Decorative text background -->
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none overflow-hidden">
      <span class="font-display text-[12vw] font-bold text-surface/[0.03] whitespace-nowrap select-none">
        GRANADA
      </span>
    </div>

    <!-- Ambient glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] bg-primary/10 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="container relative">
      <div class="max-w-2xl mx-auto text-center">
        <h2 id="cta-title" class="mb-8 reveal">
          <span class="block font-display text-3xl lg:text-4xl font-bold text-surface mb-2">
            La Alhambra ya la conoces.
          </span>
          <span class="block font-display text-3xl lg:text-4xl font-bold text-gradient-primary">
            Granada todavía no.
          </span>
        </h2>

        <p class="text-base lg:text-lg text-surface-secondary mb-10 max-w-md mx-auto reveal">
          La guía cultural de Granada creada por locales. Eventos, rutas auténticas y los mejores planes.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 reveal">
          <a 
            href="/eventos"
            class="group inline-flex items-center gap-3 px-8 py-4 bg-primary text-white font-semibold text-base rounded-2xl transition-all duration-300 hover:shadow-lg hover:shadow-primary/25 hover:-translate-y-1"
          >
            <span>Descubrir eventos</span>
            <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a 
            href="/rutas"
            class="group inline-flex items-center gap-3 px-8 py-4 bg-white text-surface font-semibold text-base rounded-2xl border-2 border-edge transition-all duration-300 hover:shadow-soft-md hover:-translate-y-1 hover:border-secondary/30"
          >
            <span>Explorar rutas</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

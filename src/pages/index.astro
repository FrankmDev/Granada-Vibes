---
import type { Event } from '../types';
import { getAllEvents, getFeaturedRoutes } from '../data';
import BaseLayout from '../layouts/BaseLayout.astro';
import NavBar from '@components/layout/NavBar.astro';
import Footer from '@components/layout/Footer.astro';
import BrutalHero from '@components/home/BrutalHero.astro';
import EditorialBento from '@components/home/EditorialBento.astro';
import RoutesShowcase from '@components/home/RoutesShowcase.astro';

const locale = 'es';
const currentPath = Astro.url.pathname;
const todayStr = new Date().toISOString().split('T')[0] ?? '';
const allEvents = getAllEvents();
const featuredRoutes = getFeaturedRoutes();

const upcoming = allEvents
  .filter((e: Event) => e.date >= todayStr)
  .sort((a: Event, b: Event) => a.date.localeCompare(b.date));

const gridEvents = upcoming.slice(0, 20);
const displayRoutes = featuredRoutes.slice(0, 4);
---

<BaseLayout
  locale={locale}
  title="Granada Vibes — Guía Cultural"
  description="La guía cultural definitiva de Granada. Eventos, rutas y experiencias reales sin filtros."
  schemaType="website"
>
  <!-- Header -->
  <NavBar slot="header" locale={locale} currentPath={currentPath} />

  <!-- Secciones -->
  <BrutalHero locale={locale} />
  <EditorialBento events={gridEvents} locale={locale} />
  <RoutesShowcase routes={displayRoutes} locale={locale} />

  <!-- Footer -->
  <Footer slot="footer" locale={locale} />
</BaseLayout>

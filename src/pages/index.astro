---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeader from '@components/layout/SectionHeader.astro';
import EventCard from '@components/events/EventCard.astro';
import RouteCard from '@components/routes/RouteCard.astro';
import Button from '@components/ui/Button.astro';
import Badge from '@components/ui/Badge.astro';
import HeroSection from '@components/home/HeroSection.astro';
import { getFeaturedEvents, getFeaturedRoutes, getAllEvents } from '@data';
import { useTranslations } from '@i18n/utils';
import { formatDateShort, getTemporalProximity } from '@utils/dates';

const locale = 'es';
const t = useTranslations(locale);

const featuredEvents = getFeaturedEvents().slice(0, 3);
const featuredRoutes = getFeaturedRoutes().slice(0, 3);

// Get this week's events (next 7 days)
const today = new Date().toISOString().split('T')[0];
const thisWeekEvents = getAllEvents()
  .filter(e => e.date >= today)
  .sort((a, b) => a.date.localeCompare(b.date))
  .slice(0, 4);

// OG Image
const ogImage = 'https://placehold.co/1200x630/E85A3C/FFFFFF?text=Granada+Vibes';
---

<BaseLayout
  locale={locale}
  title="Inicio"
  description="Tu guía cultural e inteligente de Granada. Descubre eventos, rutas y experiencias únicas en la ciudad de la Alhambra."
  ogImage={ogImage}
>
  {/* Hero Section - Neo-Brutalism Andalusí */}
  <HeroSection thisWeekEvents={thisWeekEvents} locale={locale} />

  {/* Featured Events Section */}
  <section class="relative py-24 lg:py-32" aria-labelledby="events-heading">
    {/* Background accent */}
    <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-terra/5 to-transparent pointer-events-none" aria-hidden="true"></div>
    
    {/* Section number */}
    <div class="absolute top-16 right-8 hidden lg:block">
      <span class="section-number">01</span>
    </div>

    <div class="container relative">
      <SectionHeader
        overline={t('events.title')}
        title={t('home.featuredEvents')}
        description="Los eventos más destacados de la semana seleccionados por nuestro equipo"
        href="/eventos"
        linkText={t('actions.viewAll')}
        accent="terra"
      />

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8 stagger-children">
        {featuredEvents[0] && (
          <div class="lg:col-span-7 reveal">
            <EventCard event={featuredEvents[0]} locale={locale} t={t} featured={true} />
          </div>
        )}

        <div class="lg:col-span-5 flex flex-col gap-6">
          {featuredEvents.slice(1, 3).map((event) => (
            <div class="reveal flex-1">
              <EventCard event={event} locale={locale} t={t} />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* Featured Routes Section */}
  <section id="routes" class="relative py-24 lg:py-32 bg-base-elevated" aria-labelledby="routes-heading">
    {/* Background elements */}
    <div class="absolute top-24 left-0 w-64 h-64 bg-amber/5 rounded-full blur-[100px] pointer-events-none" aria-hidden="true"></div>
    
    {/* Section number */}
    <div class="absolute top-32 left-8 hidden lg:block">
      <span class="section-number">02</span>
    </div>

    <div class="container relative">
      <SectionHeader
        overline={t('routes.title')}
        title={t('home.featuredRoutes')}
        description="Rutas diseñadas por locales para descubrir la Granada auténtica"
        href="/rutas"
        linkText={t('actions.viewAll')}
        accent="amber"
      />

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8 stagger-children">
        <div class="lg:col-span-5 flex flex-col gap-6 order-2 lg:order-1">
          {featuredRoutes.slice(0, 2).map((route, index) => (
            <div class="reveal" style={`transition-delay: ${index * 100}ms`}>
              <RouteCard route={route} locale={locale} t={t} index={index} variant="list" />
            </div>
          ))}
        </div>

        {featuredRoutes[2] && (
          <div class="lg:col-span-7 order-1 lg:order-2 reveal">
            <a href={`/rutas/${featuredRoutes[2].slug}`} class="block h-full group">
              <div class="relative h-full bg-base-card border border-amber/20 rounded-3xl overflow-hidden transition-all duration-500 hover:border-amber/40 hover:-translate-y-2 hover:shadow-elevated">
                <div class="aspect-[16/9] lg:aspect-auto lg:h-full bg-base-elevated relative overflow-hidden">
                  <div class="absolute inset-0 bg-gradient-to-br from-amber/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700" />
                  <div class="absolute inset-0 bg-gradient-to-t from-base-card via-base-card/20 to-transparent"></div>

                  <div class="absolute inset-0 flex items-center justify-center">
                    <div class="relative">
                      <div class="absolute inset-0 bg-amber/20 blur-2xl rounded-full scale-150"></div>
                      <div class="relative w-28 h-28 rounded-2xl bg-base border border-amber/30 flex items-center justify-center shadow-elevated group-hover:scale-110 transition-transform duration-500">
                        <svg class="w-14 h-14 text-amber" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 01-.447-.894L15 7m0 13V7" />
                        </svg>
                      </div>
                    </div>
                  </div>

                  <div class="absolute top-6 left-6">
                    <Badge variant="amber" size="md">{t(`categories.${featuredRoutes[2].category}`)}</Badge>
                  </div>
                </div>

                <div class="p-8 lg:p-10">
                  <div class="flex items-center gap-4 text-sm text-surface-muted mb-5">
                    <span class="text-xs font-bold uppercase tracking-wider text-amber">{t(`difficulty.${featuredRoutes[2].difficulty}`)}</span>
                    <span class="w-1 h-1 rounded-full bg-surface-disabled"></span>
                    <span class="flex items-center gap-1.5">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      {Math.round(featuredRoutes[2].duration / 60)}h
                    </span>
                    <span class="w-1 h-1 rounded-full bg-surface-disabled"></span>
                    <span>{featuredRoutes[2].distance} km</span>
                  </div>

                  <h3 class="font-display text-2xl lg:text-3xl font-bold text-surface mb-4 group-hover:text-amber transition-colors duration-300">
                    {featuredRoutes[2].title[locale]}
                  </h3>

                  <p class="text-surface-secondary leading-relaxed text-lg mb-6">
                    {featuredRoutes[2].description[locale]}
                  </p>

                  <div class="flex items-center gap-3 text-amber font-semibold">
                    <span>Explorar ruta</span>
                    <div class="w-10 h-10 rounded-xl border border-amber/30 flex items-center justify-center group-hover:bg-amber group-hover:text-base transition-all duration-300">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                      </svg>
                    </div>
                  </div>
                </div>
              </div>
            </a>
          </div>
        )}
      </div>
    </div>
  </section>

  {/* Stats Section - Modern dark */}
  <section class="relative py-28 lg:py-36 overflow-hidden" aria-labelledby="numbers-heading">
    <div class="absolute inset-0 bg-gradient-to-b from-base via-base-elevated to-base"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-edge to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-edge to-transparent"></div>

    {/* Section number */}
    <div class="absolute top-16 right-8 hidden lg:block">
      <span class="section-number">03</span>
    </div>

    <div class="container relative">
      <div class="text-center mb-20 reveal">
        <div class="flex items-center justify-center gap-4 mb-6">
          <span class="w-16 h-[2px] bg-terra"></span>
          <span class="text-xs font-bold uppercase tracking-[0.25em] text-terra">Datos</span>
          <span class="w-16 h-[2px] bg-terra"></span>
        </div>
        <h2 id="numbers-heading" class="font-display text-4xl lg:text-6xl font-bold text-surface leading-tight">
          Granada en <span class="text-gradient-terra">números</span>
        </h2>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-0 stagger-children">
        {[
          { value: '800+', label: 'años de historia', desc: 'Desde la fundación', color: 'text-terra' },
          { value: '2', label: 'UNESCO', desc: 'Patrimonios mundiales', color: 'text-amber' },
          { value: '48h', label: 'para perderse', desc: 'De tapas y cultura', color: 'text-mint' },
          { value: '0€', label: 'tapa incluida', desc: 'Con cada bebida', color: 'text-terra' },
        ].map((stat, index) => (
          <div class:list={['text-center reveal p-8', index < 3 && 'lg:border-r lg:border-edge']}>
            <p class:list={['font-display text-5xl lg:text-7xl font-bold mb-3 tracking-tight', stat.color]}>{stat.value}</p>
            <p class="text-surface font-bold uppercase tracking-wider text-sm mb-2">{stat.label}</p>
            <p class="text-surface-muted text-sm">{stat.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* CTA Section - Bold finale */}
  <section class="relative py-28 lg:py-36 overflow-hidden" aria-labelledby="cta-title">
    <div class="absolute inset-0 bg-gradient-to-b from-base-elevated to-base"></div>
    
    {/* Large background text */}
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none overflow-hidden">
      <span class="font-display text-[20vw] font-bold text-surface/[0.02] whitespace-nowrap select-none">
        GRANADA
      </span>
    </div>

    {/* Gradient orbs */}
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-terra/10 rounded-full blur-[120px] pointer-events-none" aria-hidden="true"></div>

    <div class="container relative">
      <div class="max-w-3xl mx-auto text-center reveal">
        <div class="flex items-center justify-center gap-4 mb-12">
          <div class="h-px w-20 bg-gradient-to-r from-transparent to-terra/50"></div>
          <div class="w-14 h-14 rounded-2xl border border-terra/30 flex items-center justify-center bg-terra/5">
            <svg class="w-6 h-6 text-terra/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
            </svg>
          </div>
          <div class="h-px w-20 bg-gradient-to-l from-transparent to-terra/50"></div>
        </div>

        <h2 id="cta-title" class="mb-8">
          <span class="block overflow-hidden">
            <span class="block font-display text-3xl md:text-4xl lg:text-5xl font-bold text-surface">
              La Alhambra ya la conoces.
            </span>
          </span>
          <span class="block overflow-hidden mt-3">
            <span class="block font-display text-3xl md:text-4xl lg:text-5xl font-bold text-gradient-terra">
              Granada todavía no.
            </span>
          </span>
        </h2>

        <p class="text-surface-secondary text-lg lg:text-xl mb-12 max-w-2xl mx-auto leading-relaxed">
          Eventos locales curados, rutas que no salen en las guías y experiencias que solo existen aquí.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <Button variant="terra" size="lg" href="/eventos">
            <span>Descubrir ahora</span>
            <svg slot="icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </Button>
          <Button variant="secondary" size="lg" href="/rutas">
            Explorar rutas
          </Button>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

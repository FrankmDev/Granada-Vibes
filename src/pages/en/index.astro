---
import type { Event } from '../../types';
import { getAllEvents, getFeaturedRoutes } from '../../data';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NavBar from '@components/layout/NavBar.astro';
import Footer from '@components/layout/Footer.astro';
import HeroSection from '@components/home/HeroSection.astro';
import EventsGridSection from '@components/home/EventsGridSection.astro';
import SeasonalSection from '@components/home/SeasonalSection.astro';
import RoutesGridSection from '@components/home/RoutesGridSection.astro';
import HomeCTA from '@components/home/HomeCTA.astro';

const locale = 'en';
const currentPath = Astro.url.pathname;
const todayStr = new Date().toISOString().split('T')[0] ?? '';
const allEvents = getAllEvents();
const featuredRoutes = getFeaturedRoutes();

const upcoming = allEvents
  .filter((e: Event) => e.date >= todayStr)
  .sort((a: Event, b: Event) => a.date.localeCompare(b.date));

const gridEvents = upcoming.slice(0, 20);
const displayRoutes = featuredRoutes.slice(0, 7);
---

<BaseLayout
  locale={locale}
  title="Granada Vibes — Cultural Guide"
  description="The definitive cultural guide to Granada. Events, routes and real experiences without filters."
  schemaType="website"
>
  <NavBar slot="header" locale={locale} currentPath={currentPath} />

  <HeroSection locale={locale} />
  <EventsGridSection events={gridEvents} locale={locale} />
  <SeasonalSection locale={locale} />
  <RoutesGridSection routes={displayRoutes} locale={locale} />
  <HomeCTA locale={locale} />

  <Footer slot="footer" locale={locale} />
</BaseLayout>

---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeader from '@components/layout/SectionHeader.astro';
import EventCard from '@components/events/EventCard.astro';
import RouteCard from '@components/routes/RouteCard.astro';
import Icon from '@components/ui/Icon.astro';
import { getFeaturedEvents, getFeaturedRoutes } from '@data';
import { useTranslations } from '@i18n/utils';

const locale = 'en';
const t = useTranslations(locale);

const featuredEvents = getFeaturedEvents().slice(0, 3);
const featuredRoutes = getFeaturedRoutes().slice(0, 3);
---

<BaseLayout locale={locale} seo={{ title: 'Home' }}>
  {/* Hero Section */}
  <section class="relative overflow-hidden" aria-labelledby="hero-title">
    <div class="absolute inset-0 bg-gradient-to-br from-bg via-bg to-bg-raised" />
    
    <div class="container relative">
      <div class="pt-32 lg:pt-40 pb-12">
        <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-end">
          {/* Left: Main Title */}
          <div class="lg:col-span-8">
            <div class="flex items-center gap-3 mb-6">
              <span class="w-8 h-px bg-accent" />
              <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-accent">Granada, Andalucía</span>
            </div>
            
            <h1 id="hero-title" class="font-display text-6xl sm:text-7xl lg:text-8xl xl:text-9xl font-semibold leading-[0.9] tracking-[-0.04em]">
              <span class="block text-text-primary">
                Discover
              </span>
              <span class="block text-gradient mt-2">
                Granada
              </span>
            </h1>
          </div>
          
          {/* Right: Intro Text */}
          <div class="lg:col-span-4 lg:pb-4">
            <p class="text-text-secondary leading-relaxed">
              Your cultural guide for events, routes, and authentic experiences in the city of the Alhambra.
            </p>
          </div>
        </div>
      </div>
      
      {/* Stats Bar */}
      <div class="py-8 border-y border-border/30">
        <div class="flex flex-wrap items-center gap-8 lg:gap-16">
          <div class="flex items-baseline gap-2">
            <span class="text-4xl lg:text-5xl font-display font-semibold text-text-primary">24</span>
            <span class="text-sm text-text-muted">{locale === 'es' ? 'eventos activos' : 'active events'}</span>
          </div>
          <div class="hidden sm:block w-px h-8 bg-border" />
          <div class="flex items-baseline gap-2">
            <span class="text-4xl lg:text-5xl font-display font-semibold text-text-primary">12</span>
            <span class="text-sm text-text-muted">{locale === 'es' ? 'rutas guiadas' : 'guided routes'}</span>
          </div>
          <div class="hidden sm:block w-px h-8 bg-border" />
          <div class="flex items-baseline gap-2">
            <span class="text-4xl lg:text-5xl font-display font-semibold text-text-primary">8</span>
            <span class="text-sm text-text-muted">{locale === 'es' ? 'barrios' : 'neighborhoods'}</span>
          </div>
          <div class="flex-1" />
          <div class="flex items-center gap-4">
            <a href="/en/events" 
              class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent text-bg font-medium text-sm rounded-lg transition-all duration-300 hover:shadow-[0_8px_20px_rgba(224,122,95,0.25)]"
            >
              {t('nav.events')}
            </a>
            <a href="/en/routes" 
              class="inline-flex items-center gap-2 px-5 py-2.5 text-text-primary font-medium text-sm border border-border rounded-lg hover:border-accent hover:text-accent transition-all duration-300"
            >
              {t('nav.routes')}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Featured Events */}
  <section class="relative py-20 lg:py-28 bg-bg-raised/20" aria-labelledby="events-heading">
    <div class="container">
      <SectionHeader
        overline={t('events.title')}
        title={t('home.featuredEvents')}
        href="/en/events"
        linkText={t('actions.viewAll')}
        accent="accent"
      />
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredEvents.map((event) => (
          <EventCard event={event} locale={locale} t={t} />
        ))}
      </div>
    </div>
  </section>

  {/* Featured Routes */}
  <section class="relative py-20 lg:py-28 bg-bg" aria-labelledby="routes-heading">
    <div class="container">
      <SectionHeader
        overline={t('routes.title')}
        title={t('home.featuredRoutes')}
        href="/en/routes"
        linkText={t('actions.viewAll')}
        accent="sand"
      />
      
      <div class="space-y-3">
        {featuredRoutes.map((route, index) => (
          <RouteCard route={route} locale={locale} t={t} index={index} variant="list" />
        ))}
      </div>
    </div>
  </section>

  {/* CTA Section */}
  <section class="relative py-24 lg:py-32 bg-bg-raised/20" aria-labelledby="cta-title">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center">
        <h2 id="cta-title" class="text-3xl md:text-4xl lg:text-5xl font-display font-semibold text-text-primary tracking-[-0.02em] leading-[1.15] mb-5">
          {locale === 'es' ? 'Tu próxima aventura' : 'Your next adventure'}<br />
          <span class="text-gradient">{locale === 'es' ? 'te espera' : 'awaits'}</span>
        </h2>
        
        <p class="text-text-secondary mb-10">
          {locale === 'es' ? 'Descubre eventos únicos y rutas inolvidables en Granada.' : 'Discover unique events and unforgettable routes in Granada.'}
        </p>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href="/en/events" 
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-accent text-bg font-semibold text-sm uppercase tracking-wider rounded-xl transition-all duration-300 hover:shadow-[0_8px_30px_rgba(224,122,95,0.25)]"
          >
            {locale === 'es' ? 'Explorar eventos' : 'Explore events'}
          </a>
          <a href="/en/routes" 
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-transparent text-text-primary font-semibold text-sm uppercase tracking-wider rounded-xl border border-border hover:border-text-primary transition-colors duration-200"
          >
            {locale === 'es' ? 'Ver rutas' : 'View routes'}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

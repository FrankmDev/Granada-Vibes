---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeader from '@components/layout/SectionHeader.astro';
import EventCard from '@components/events/EventCard.astro';
import RouteCard from '@components/routes/RouteCard.astro';
import Button from '@components/ui/Button.astro';
import Badge from '@components/ui/Badge.astro';
import { getFeaturedEvents, getFeaturedRoutes, getAllEvents } from '@data';
import { useTranslations } from '@i18n/utils';
import { formatDateShort, getTemporalProximity } from '@utils/dates';

const locale = 'en';
const t = useTranslations(locale);

const featuredEvents = getFeaturedEvents().slice(0, 3);
const featuredRoutes = getFeaturedRoutes().slice(0, 3);

// Get this week's events (next 7 days)
const today = new Date().toISOString().split('T')[0];
const thisWeekEvents = getAllEvents()
  .filter(e => e.date >= today)
  .sort((a, b) => a.date.localeCompare(b.date))
  .slice(0, 4);

const ogImage = 'https://placehold.co/1200x630/C75B3B/FFFFFF?text=Granada+Vibes';
---

<BaseLayout 
  locale={locale} 
  title="Home"
  description="Your smart cultural guide to Granada, Spain. Discover events, routes, and unique experiences in the city of the Alhambra."
  ogImage={ogImage}
>
  {/* ============================================
      HERO v2 - CINEMATIC ASYMMETRIC EDITORIAL
      ============================================ */}
  <section class="relative min-h-screen overflow-hidden bg-bg" aria-labelledby="hero-title">
    
    {/* ---- BACKGROUND LAYERS ---- */}
    
    {/* Giant Typographic Texture - "GRANADA" */}
    <div class="absolute inset-0 overflow-hidden pointer-events-none select-none">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-[35vw] font-display font-black text-text-primary/[0.015] leading-none whitespace-nowrap tracking-tighter">
        GRANADA
      </div>
    </div>

    {/* Gradient Mesh Background */}
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 right-0 w-[70%] h-[70%] bg-gradient-to-bl from-accent/[0.04] via-transparent to-transparent rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-[50%] h-[60%] bg-gradient-to-tr from-gold/[0.03] via-transparent to-transparent rounded-full blur-3xl"></div>
    </div>

    {/* Diagonal Clip Path Accent */}
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 right-0 w-[55%] h-full bg-gradient-to-l from-bg-raised/50 to-transparent" 
           style="clip-path: polygon(30% 0, 100% 0, 100% 100%, 0% 100%);"></div>
    </div>

    {/* Animated Geometric Ornaments - Alhambra Inspired */}
    <div class="absolute top-[12%] right-[15%] w-40 h-40 hidden xl:block animate-float-slow opacity-60">
      <svg viewBox="0 0 160 160" fill="none" class="w-full h-full">
        <path d="M80 0L160 80L80 160L0 80L80 0Z" stroke="url(#goldGradient)" stroke-width="1" fill="none"/>
        <path d="M80 20L140 80L80 140L20 80L80 20Z" stroke="url(#accentGradient)" stroke-width="1" fill="none" opacity="0.5"/>
        <circle cx="80" cy="80" r="30" stroke="url(#goldGradient)" stroke-width="1" fill="none" opacity="0.3"/>
        <defs>
          <linearGradient id="goldGradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#C9A84C" stop-opacity="0.6"/>
            <stop offset="100%" stop-color="#C9A84C" stop-opacity="0.1"/>
          </linearGradient>
          <linearGradient id="accentGradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#C75B3B" stop-opacity="0.6"/>
            <stop offset="100%" stop-color="#C75B3B" stop-opacity="0.1"/>
          </linearGradient>
        </defs>
      </svg>
    </div>

    <div class="absolute bottom-[25%] right-[8%] w-24 h-24 hidden xl:block animate-float opacity-40" style="animation-delay: 1s;">
      <svg viewBox="0 0 96 96" fill="none" class="w-full h-full">
        <rect x="10" y="10" width="76" height="76" rx="8" stroke="#C75B3B" stroke-width="1.5" fill="none" transform="rotate(15 48 48)"/>
        <rect x="20" y="20" width="56" height="56" rx="6" stroke="#C9A84C" stroke-width="1" fill="none" transform="rotate(-10 48 48)"/>
      </svg>
    </div>

    {/* Floating Particles */}
    <div class="absolute top-[20%] left-[8%] w-2 h-2 rounded-full bg-accent/40 animate-float hidden lg:block"></div>
    <div class="absolute top-[40%] right-[25%] w-3 h-3 rounded-full bg-gold/30 animate-float hidden lg:block" style="animation-delay: 0.5s;"></div>
    <div class="absolute bottom-[35%] left-[45%] w-1.5 h-1.5 rounded-full bg-coral/40 animate-float hidden lg:block" style="animation-delay: 1.2s;"></div>

    {/* ---- MAIN CONTENT ---- */}
    <div class="container relative z-10">
      <div class="min-h-screen flex flex-col justify-center py-20 lg:py-0">
        
        {/* ASYMMETRIC GRID LAYOUT */}
        <div class="grid grid-cols-12 gap-4 lg:gap-8 items-center">
          
          {/* LEFT COLUMN - Main Content (spans 7) */}
          <div class="col-span-12 lg:col-span-7 xl:col-span-6 relative">
            
            {/* Location Pill */}
            <div class="inline-flex items-center gap-3 px-5 py-2.5 bg-white border border-border rounded-full shadow-soft w-fit mb-8 animate-fade-in-up">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
              </span>
              <span class="text-xs font-semibold uppercase tracking-[0.2em] text-text-secondary">Andalusia, Spain</span>
            </div>

            {/* MASSIVE Typography */}
            <h1 id="hero-title" class="relative mb-8">
              {/* First Line */}
              <span class="block overflow-hidden">
                <span class="block font-display text-[14vw] sm:text-[12vw] lg:text-[7vw] xl:text-[6vw] font-bold text-text-primary leading-[0.9] tracking-[-0.04em] animate-slide-up">
                  Discover
                </span>
              </span>
              
              {/* Second Line - with Gradient */}
              <span class="block overflow-hidden -mt-2 lg:-mt-4">
                <span class="block font-display text-[18vw] sm:text-[16vw] lg:text-[9vw] xl:text-[8vw] font-black text-gradient-warm leading-[0.85] tracking-[-0.04em] animate-slide-up" style="animation-delay: 0.15s;">
                  Granada
                </span>
              </span>
              
              {/* Third Line - Italic, lighter */}
              <span class="block overflow-hidden mt-2 lg:mt-4 ml-1">
                <span class="block font-display text-[6vw] sm:text-[5vw] lg:text-[2.5vw] xl:text-[2vw] font-light text-text-secondary leading-[1.2] tracking-[0.15em] uppercase animate-slide-up italic" style="animation-delay: 0.3s;">
                  No guides. No filters.
                </span>
              </span>
            </h1>

            {/* Description with accent line */}
            <div class="max-w-lg mb-10 animate-fade-in-up" style="animation-delay: 0.45s;">
              <div class="flex items-start gap-5">
                <div class="w-1.5 h-16 bg-gradient-to-b from-accent via-coral to-transparent rounded-full shrink-0 mt-1"></div>
                <p class="text-lg text-text-secondary leading-relaxed">
                  Curated cultural events, secret routes, and authentic experiences only granadinos know. 
                  <span class="text-text-primary font-medium">The city you won't find in guidebooks.</span>
                </p>
              </div>
            </div>

            {/* CTA Group */}
            <div class="flex flex-wrap items-center gap-4 animate-fade-in-up" style="animation-delay: 0.55s;">
              <Button variant="primary" size="lg" href="/en/events" icon>
                Explore events
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </Button>
              <a href="/en/routes" class="group inline-flex items-center gap-3 text-sm font-semibold text-text-muted hover:text-text-primary transition-colors">
                <span class="w-12 h-12 rounded-full border border-border flex items-center justify-center group-hover:border-accent group-hover:bg-accent group-hover:text-white transition-all duration-300">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0121 18.382V7.618a1 1 0 01-.447-.894L15 7m0 13V7" />
                  </svg>
                </span>
                See routes
              </a>
            </div>

            {/* Social Proof */}
            <div class="hidden lg:flex items-center gap-6 mt-16 animate-fade-in-up" style="animation-delay: 0.65s;">
              <div class="flex -space-x-3">
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-sage to-sage/60 border-2 border-white flex items-center justify-center text-white text-xs font-bold">A</div>
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-accent to-coral border-2 border-white flex items-center justify-center text-white text-xs font-bold">M</div>
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-gold to-gold-hover border-2 border-white flex items-center justify-center text-white text-xs font-bold">J</div>
                <div class="w-10 h-10 rounded-full bg-bg-raised border-2 border-white flex items-center justify-center text-text-muted text-xs font-bold">+120</div>
              </div>
              <div class="text-sm">
                <p class="font-semibold text-text-primary">Active explorers</p>
                <p class="text-text-muted">Join the community</p>
              </div>
            </div>
          </div>

          {/* RIGHT COLUMN - Floating Cards & Stats (spans 5) */}
          <div class="col-span-12 lg:col-span-5 xl:col-span-6 relative lg:h-[600px] mt-12 lg:mt-0">
            
            {/* Main Feature Card - Events */}
            <div class="lg:absolute lg:top-[5%] lg:right-[5%] w-full lg:w-80 animate-fade-in-up" style="animation-delay: 0.35s;">
              <a href="/en/events" class="group block">
                <div class="relative bg-white border border-border rounded-3xl p-6 shadow-soft-lg hover:shadow-soft-xl hover:-translate-y-1 transition-all duration-500 overflow-hidden">
                  <div class="absolute -top-20 -right-20 w-40 h-40 bg-gradient-to-br from-accent/5 to-transparent rounded-full"></div>
                  
                  <div class="flex items-center gap-2 mb-5">
                    <span class="relative flex h-2.5 w-2.5">
                      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
                      <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-accent"></span>
                    </span>
                    <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-accent">This week</span>
                  </div>

                  <div class="flex items-baseline gap-2 mb-5">
                    <span class="font-display text-7xl font-black text-text-primary tracking-tight">24</span>
                    <span class="text-sm font-semibold text-text-muted uppercase tracking-wider">events</span>
                  </div>

                  <div class="space-y-3 mb-6">
                    <div class="flex items-center gap-3 p-2 bg-bg-raised/50 rounded-xl">
                      <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center shrink-0">
                        <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
                        </svg>
                      </div>
                      <div class="min-w-0">
                        <p class="text-sm font-medium text-text-primary truncate">International Festival</p>
                        <p class="text-xs text-text-muted">Music & Dance</p>
                      </div>
                    </div>
                    <div class="flex items-center gap-3 p-2 bg-bg-raised/50 rounded-xl">
                      <div class="w-10 h-10 rounded-lg bg-gold/10 flex items-center justify-center shrink-0">
                        <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                        </svg>
                      </div>
                      <div class="min-w-0">
                        <p class="text-sm font-medium text-text-primary truncate">Night Visits</p>
                        <p class="text-xs text-text-muted">Alhambra Illuminated</p>
                      </div>
                    </div>
                  </div>

                  <div class="flex items-center justify-between pt-4 border-t border-border">
                    <span class="text-xs font-semibold text-text-muted uppercase tracking-wider">View calendar</span>
                    <div class="w-8 h-8 rounded-full bg-bg-raised flex items-center justify-center group-hover:bg-accent group-hover:text-white transition-all duration-300">
                      <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </div>
                  </div>
                </div>
              </a>
            </div>

            {/* Route Card */}
            <div class="lg:absolute lg:top-[40%] lg:left-[0%] w-full lg:w-72 mt-4 lg:mt-0 animate-fade-in-up" style="animation-delay: 0.5s;">
              <a href="/en/routes" class="group block">
                <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-bg-raised to-white border border-border p-6 hover:border-gold/30 hover:shadow-soft-lg transition-all duration-300">
                  <div class="absolute -right-8 -bottom-8 w-32 h-32 bg-gold/10 rounded-full blur-2xl group-hover:bg-gold/20 transition-colors duration-500"></div>
                  
                  <div class="relative">
                    <div class="flex items-center gap-3 mb-4">
                      <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-gold/20 to-accent/10 flex items-center justify-center">
                        <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0121 18.382V7.618a1 1 0 01-.447-.894L15 7m0 13V7" />
                        </svg>
                      </div>
                      <div>
                        <p class="text-[10px] font-bold uppercase tracking-[0.15em] text-text-muted">Featured route</p>
                        <p class="font-display font-bold text-text-primary group-hover:text-gold transition-colors">Essential Albaicín</p>
                      </div>
                    </div>
                    
                    <div class="flex items-center gap-4 text-xs text-text-muted mb-4">
                      <span class="flex items-center gap-1.5">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        2h
                      </span>
                      <span class="w-1 h-1 rounded-full bg-border"></span>
                      <span>2.5 km</span>
                      <span class="w-1 h-1 rounded-full bg-border"></span>
                      <span class="text-sage font-semibold">Easy</span>
                    </div>

                    <div class="w-full h-1.5 bg-border/50 rounded-full overflow-hidden">
                      <div class="w-3/4 h-full bg-gradient-to-r from-gold to-accent rounded-full"></div>
                    </div>
                  </div>
                </div>
              </a>
            </div>

            {/* Stats Badge */}
            <div class="hidden xl:block lg:absolute lg:bottom-[5%] lg:right-[15%] animate-fade-in-up" style="animation-delay: 0.6s;">
              <div class="bg-white border border-border rounded-2xl p-5 shadow-soft">
                <div class="grid grid-cols-2 gap-6">
                  <div class="text-center">
                    <p class="font-display text-3xl font-bold text-gradient-warm">800+</p>
                    <p class="text-[10px] font-semibold uppercase tracking-wider text-text-muted mt-1">Years</p>
                  </div>
                  <div class="text-center border-l border-border">
                    <p class="font-display text-3xl font-bold text-text-primary">2</p>
                    <p class="text-[10px] font-semibold uppercase tracking-wider text-text-muted mt-1">UNESCO</p>
                  </div>
                </div>
              </div>
            </div>

            {/* Decorative Line */}
            <div class="hidden lg:block lg:absolute lg:top-[20%] lg:left-[35%] w-px h-40 bg-gradient-to-b from-transparent via-border to-transparent"></div>
          </div>
        </div>

        {/* BOTTOM MARQUEE - Events Ticker */}
        <div class="absolute bottom-0 left-0 right-0 border-t border-border bg-bg/80 backdrop-blur-sm">
          <div class="py-4 overflow-hidden">
            <div class="flex animate-marquee whitespace-nowrap">
              {[...Array(2)].map(() => (
                <>
                  <span class="inline-flex items-center gap-3 mx-8">
                    <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
                    <span class="text-sm text-text-secondary">Music & Dance Festival</span>
                    <span class="text-xs text-text-muted">—</span>
                    <span class="text-xs text-accent font-semibold">Today</span>
                  </span>
                  <span class="inline-flex items-center gap-3 mx-8">
                    <span class="w-1.5 h-1.5 rounded-full bg-gold"></span>
                    <span class="text-sm text-text-secondary">Alhambra by Night</span>
                    <span class="text-xs text-text-muted">—</span>
                    <span class="text-xs text-gold font-semibold">Tomorrow</span>
                  </span>
                  <span class="inline-flex items-center gap-3 mx-8">
                    <span class="w-1.5 h-1.5 rounded-full bg-sage"></span>
                    <span class="text-sm text-text-secondary">Darro River Hiking</span>
                    <span class="text-xs text-text-muted">—</span>
                    <span class="text-xs text-sage font-semibold">Saturday</span>
                  </span>
                  <span class="inline-flex items-center gap-3 mx-8">
                    <span class="w-1.5 h-1.5 rounded-full bg-azure"></span>
                    <span class="text-sm text-text-secondary">Flamenco in Sacromonte</span>
                    <span class="text-xs text-text-muted">—</span>
                    <span class="text-xs text-azure font-semibold">Sunday</span>
                  </span>
                </>
              ))}
            </div>
          </div>
        </div>

        {/* Scroll Indicator */}
        <div class="absolute bottom-24 right-8 hidden xl:flex flex-col items-center gap-3">
          <span class="text-[10px] uppercase tracking-[0.3em] text-text-muted font-medium" style="writing-mode: vertical-rl;">Scroll</span>
          <div class="w-px h-12 bg-border relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-1/2 bg-accent animate-scroll-line"></div>
          </div>
        </div>

      </div>
    </div>

    {/* ---- HERO STYLES ---- */}
    <style>
      @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }
      
      .animate-marquee {
        animation: marquee 30s linear infinite;
      }
      
      .animate-marquee:hover {
        animation-play-state: paused;
      }

      @keyframes slideUp {
        from {
          opacity: 0;
          transform: translateY(60px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      
      .animate-slide-up {
        opacity: 0;
        animation: slideUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }
      
      @keyframes scrollLine {
        0% { transform: translateY(-100%); }
        50% { transform: translateY(0); }
        100% { transform: translateY(100%); }
      }
      
      .animate-scroll-line {
        animation: scrollLine 2s ease-in-out infinite;
      }

      @media (prefers-reduced-motion: reduce) {
        .animate-marquee { animation: none; }
        .animate-slide-up { opacity: 1; animation: none; }
        .animate-scroll-line { animation: none; }
      }
    </style>
  </section>

  {/* This week */}
  {thisWeekEvents.length > 0 && (
    <section id="events" class="relative py-24 lg:py-32 bg-bg-raised/30" aria-labelledby="week-events-heading">
      <div class="absolute top-12 left-8 hidden lg:block">
        <span class="font-display text-[120px] font-bold text-text-primary/[0.03] leading-none select-none">01</span>
      </div>
      
      <div class="absolute top-24 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border to-transparent"></div>
      
      <div class="container relative">
        <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-14 reveal">
          <div>
            <div class="flex items-center gap-3 mb-4">
              <span class="w-12 h-[2px] bg-accent"></span>
              <span class="text-xs font-semibold uppercase tracking-[0.25em] text-accent">Now</span>
            </div>
            <div class="flex items-center gap-4">
              <h2 id="week-events-heading" class="font-display text-4xl lg:text-5xl font-bold text-text-primary">
                This week
              </h2>
              <Badge variant="live">Live</Badge>
            </div>
          </div>
          
          <a href="/en/events" class="group inline-flex items-center gap-2 text-sm font-semibold text-text-muted hover:text-accent transition-colors">
            View calendar
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
        
        <div class="flex lg:grid lg:grid-cols-4 gap-6 overflow-x-auto pb-6 lg:pb-0 -mx-4 px-4 lg:mx-0 lg:px-0 snap-x scrollbar-hide stagger-children">
          {thisWeekEvents.map((event, index) => {
            const proximity = getTemporalProximity(event.date);
            return (
              <a 
                href={`/en/events/${event.slug}`}
                class="group flex-shrink-0 w-[320px] lg:w-auto snap-start reveal"
              >
                <div class="relative h-full bg-white border border-border/60 rounded-2xl p-6 transition-all duration-500 hover:border-accent/30 hover:-translate-y-2 hover:shadow-soft-xl overflow-hidden">
                  <span class="absolute top-4 right-4 font-display text-5xl font-bold text-text-primary/[0.03]">{String(index + 1).padStart(2, '0')}</span>
                  
                  <div class="flex items-center gap-3 mb-5 relative">
                    <span class="font-display text-3xl font-bold text-text-primary">{formatDateShort(event.date, locale).split(' ')[0]}</span>
                    <div class="flex flex-col">
                      <span class="text-xs font-semibold uppercase tracking-wider text-text-muted">
                        {formatDateShort(event.date, locale).split(' ').slice(1).join(' ')}
                      </span>
                    </div>
                    {proximity === 'today' && (
                      <Badge variant="live" size="sm" class="ml-auto">Today</Badge>
                    )}
                    {proximity === 'tomorrow' && (
                      <Badge variant="accent" size="sm" class="ml-auto">Tomorrow</Badge>
                    )}
                  </div>
                  
                  <div class="w-12 h-[2px] bg-gradient-to-r from-accent to-coral mb-5 transition-all duration-300 group-hover:w-20"></div>
                  
                  <h3 class="font-display text-lg font-semibold text-text-primary mb-3 group-hover:text-accent transition-colors duration-300 line-clamp-2 leading-tight">
                    {event.title[locale]}
                  </h3>
                  
                  <p class="text-sm text-text-muted flex items-center gap-1.5 mb-4">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    </svg>
                    <span class="truncate">{event.venue}</span>
                  </p>
                  
                  <div class="flex items-center justify-between pt-4 border-t border-border/40">
                    <span class:list={['font-display font-semibold', event.price === null ? 'text-sage' : 'text-text-primary']}>
                      {event.price === null ? 'Free' : `${event.price}€`}
                    </span>
                    <span class="flex items-center gap-1 text-xs font-semibold uppercase tracking-wider text-accent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                      View
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  {/* Featured Events */}
  <section class="relative py-24 lg:py-32" aria-labelledby="events-heading">
    <div class="absolute top-16 right-8 hidden lg:block">
      <span class="font-display text-[120px] font-bold text-text-primary/[0.03] leading-none select-none">02</span>
    </div>
    
    <div class="container relative">
      <SectionHeader
        overline={t('events.title')}
        title={t('home.featuredEvents')}
        description="The most outstanding events of the week selected by our team"
        href="/en/events"
        linkText={t('actions.viewAll')}
        accent="accent"
      />
      
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 stagger-children">
        {featuredEvents[0] && (
          <div class="lg:col-span-7 reveal">
            <EventCard event={featuredEvents[0]} locale={locale} t={t} featured={true} />
          </div>
        )}
        
        <div class="lg:col-span-5 flex flex-col gap-8">
          {featuredEvents.slice(1, 3).map((event) => (
            <div class="reveal">
              <EventCard event={event} locale={locale} t={t} />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* Featured Routes */}
  <section id="routes" class="relative py-24 lg:py-32 bg-bg-raised/30" aria-labelledby="routes-heading">
    <div class="absolute top-24 left-0 w-64 h-64 bg-gradient-to-br from-gold/[0.05] to-transparent rounded-full blur-3xl"></div>
    
    <div class="absolute top-32 left-8 hidden lg:block">
      <span class="font-display text-[120px] font-bold text-text-primary/[0.03] leading-none select-none">03</span>
    </div>
    
    <div class="container relative">
      <SectionHeader
        overline={t('routes.title')}
        title={t('home.featuredRoutes')}
        description="Routes designed by locals to discover authentic Granada"
        href="/en/routes"
        linkText={t('actions.viewAll')}
        accent="gold"
      />
      
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 stagger-children">
        <div class="lg:col-span-5 flex flex-col gap-8 order-2 lg:order-1">
          {featuredRoutes.slice(0, 2).map((route, index) => (
            <div class="reveal" style={`animation-delay: ${index * 0.1}s`}>
              <RouteCard route={route} locale={locale} t={t} index={index} variant="list" />
            </div>
          ))}
        </div>
        
        {featuredRoutes[2] && (
          <div class="lg:col-span-7 order-1 lg:order-2 reveal">
            <a href={`/en/routes/${featuredRoutes[2].slug}`} class="block h-full group">
              <div class="relative h-full bg-white border border-gold/20 rounded-3xl overflow-hidden transition-all duration-500 hover:border-gold/40 hover:-translate-y-2 hover:shadow-soft-xl">
                <div class="aspect-[16/9] bg-bg-raised relative overflow-hidden">
                  <div class="absolute inset-0 bg-gradient-to-br from-gold/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700" />
                  <div class="absolute inset-0 bg-gradient-to-t from-white via-white/20 to-transparent"></div>
                  
                  <div class="absolute inset-0 flex items-center justify-center">
                    <div class="relative">
                      <div class="absolute inset-0 bg-gold/20 blur-2xl rounded-full scale-150"></div>
                      <div class="relative w-28 h-28 rounded-2xl bg-white border border-gold/30 flex items-center justify-center shadow-soft group-hover:scale-110 transition-transform duration-500">
                        <svg class="w-14 h-14 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0121 18.382V7.618a1 1 0 01-.447-.894L15 7m0 13V7" />
                        </svg>
                      </div>
                    </div>
                  </div>
                  
                  <div class="absolute top-6 left-6">
                    <Badge variant="gold" size="md">{t(`categories.${featuredRoutes[2].category}`)}</Badge>
                  </div>
                </div>
                
                <div class="p-8 lg:p-10">
                  <div class="flex items-center gap-4 text-sm text-text-muted mb-5">
                    <span class="text-xs font-semibold uppercase tracking-wider text-gold">{t(`difficulty.${featuredRoutes[2].difficulty}`)}</span>
                    <span class="w-1 h-1 rounded-full bg-border"></span>
                    <span class="flex items-center gap-1.5">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      {Math.round(featuredRoutes[2].duration / 60)}h
                    </span>
                    <span class="w-1 h-1 rounded-full bg-border"></span>
                    <span>{featuredRoutes[2].distance} km</span>
                  </div>
                  
                  <h3 class="font-display text-2xl lg:text-3xl font-bold text-text-primary mb-4 group-hover:text-gold transition-colors duration-300">
                    {featuredRoutes[2].title[locale]}
                  </h3>
                  
                  <p class="text-text-secondary leading-relaxed text-lg mb-6">
                    {featuredRoutes[2].description[locale]}
                  </p>
                  
                  <div class="flex items-center gap-3 text-gold font-semibold">
                    <span>Explore route</span>
                    <div class="w-8 h-8 rounded-full border border-gold/30 flex items-center justify-center group-hover:bg-gold group-hover:text-white transition-all duration-300">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                      </svg>
                    </div>
                  </div>
                </div>
              </div>
            </a>
          </div>
        )}
      </div>
    </div>
  </section>

  {/* Stats Section */}
  <section class="relative py-28 lg:py-36 overflow-hidden" aria-labelledby="numbers-heading">
    <div class="absolute inset-0 bg-gradient-to-b from-bg via-bg-raised to-bg"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border to-transparent"></div>
    
    <div class="absolute top-16 right-8 hidden lg:block">
      <span class="font-display text-[120px] font-bold text-text-primary/[0.03] leading-none select-none">04</span>
    </div>
    
    <div class="container relative">
      <div class="text-center mb-20 reveal">
        <div class="flex items-center justify-center gap-4 mb-6">
          <span class="w-16 h-[2px] bg-accent"></span>
          <span class="text-xs font-semibold uppercase tracking-[0.25em] text-accent">Numbers</span>
          <span class="w-16 h-[2px] bg-accent"></span>
        </div>
        <h2 id="numbers-heading" class="font-display text-4xl lg:text-6xl font-bold text-text-primary leading-tight">
          Granada in <span class="text-gradient-warm">numbers</span>
        </h2>
      </div>
      
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-0 stagger-children">
        {[
          { value: '800+', label: 'years of history', desc: 'Since founding' },
          { value: '2', label: 'UNESCO sites', desc: 'World heritage' },
          { value: '48h', label: 'to get lost', desc: 'Tapas & culture' },
          { value: '0€', label: 'tapas included', desc: 'With every drink' },
        ].map((stat, index) => (
          <div class:list={['text-center reveal p-8', index < 3 && 'lg:border-r lg:border-border/50']}>
            <p class="font-display text-5xl lg:text-7xl font-bold text-gradient-warm mb-3 tracking-tight">{stat.value}</p>
            <p class="text-text-primary font-semibold uppercase tracking-wider text-sm mb-2">{stat.label}</p>
            <p class="text-text-muted text-sm">{stat.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* CTA Section */}
  <section class="relative py-28 lg:py-36 overflow-hidden" aria-labelledby="cta-title">
    <div class="absolute inset-0 bg-gradient-to-b from-bg-raised to-bg"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[900px] bg-gradient-to-br from-accent/[0.03] via-gold/[0.02] to-transparent rounded-full blur-[120px]"></div>
    
    <div class="container relative">
      <div class="max-w-3xl mx-auto text-center reveal">
        <div class="flex items-center justify-center gap-4 mb-12">
          <div class="h-px w-20 bg-gradient-to-r from-transparent to-accent/30"></div>
          <div class="w-12 h-12 rounded-full border border-accent/20 flex items-center justify-center">
            <svg class="w-5 h-5 text-accent/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
            </svg>
          </div>
          <div class="h-px w-20 bg-gradient-to-l from-transparent to-accent/30"></div>
        </div>
        
        <h2 id="cta-title" class="mb-8">
          <span class="block overflow-hidden">
            <span class="block font-display text-3xl md:text-4xl lg:text-5xl font-bold text-text-primary animate-slide-up">
              You already know the Alhambra.
            </span>
          </span>
          <span class="block overflow-hidden mt-3">
            <span class="block font-display text-3xl md:text-4xl lg:text-5xl font-bold text-gradient-warm animate-slide-up" style="animation-delay: 0.1s;">
              Granada you don't.
            </span>
          </span>
        </h2>
        
        <p class="text-text-secondary text-lg lg:text-xl mb-12 max-w-2xl mx-auto leading-relaxed">
          Local curated events, routes not in guidebooks, and experiences that only exist here.
        </p>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <Button variant="primary" size="lg" href="/en/events" icon>
            Discover now
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </Button>
          <Button variant="secondary" size="lg" href="/en/routes">
            Explore routes
          </Button>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

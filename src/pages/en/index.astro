---
import BaseLayout from '@layouts/BaseLayout.astro';
import EventCard from '@components/events/EventCard.astro';
import EventCarousel from '@components/events/EventCarousel.astro';
import RouteCard from '@components/routes/RouteCard.astro';
import HeroSection from '@components/home/HeroSection.astro';
import { getFeaturedEvents, getFeaturedRoutes, getAllEvents } from '@data';
import { useTranslations } from '@i18n/utils';

const locale = 'en';
const t = useTranslations(locale);

const today = new Date().toISOString().split('T')[0];
const allEvents = getAllEvents();

const featuredEvents = getFeaturedEvents().slice(0, 3);

const upcomingEvents = allEvents
  .filter(e => e.date >= today)
  .sort((a, b) => a.date.localeCompare(b.date));

const thisWeekEvents = upcomingEvents.slice(0, 4);

const freeEvents = allEvents
  .filter(e => e.price === null && e.date >= today)
  .sort((a, b) => a.date.localeCompare(b.date))
  .slice(0, 3);

const featuredRoutes = getFeaturedRoutes().slice(0, 3);

const ogImage = 'https://placehold.co/1200x630/252320/F5F4F1?text=Granada+Vibes';
---

<BaseLayout
  locale={locale}
  title="Home"
  description="Discover what to do in Granada. Local guide to cultural events, routes through Albaicín and Sacromonte, and alternative plans beyond tourism."
  ogImage={ogImage}
>
  <HeroSection thisWeekEvents={thisWeekEvents} locale={locale} />

  {/* Upcoming Events Carousel */}
  <EventCarousel 
    events={upcomingEvents}
    locale={locale}
    t={t}
    title="This week"
    subtitle="Discover the best cultural plans this week in Granada: concerts, exhibitions, flamenco and unique experiences."
    maxEvents={8}
  />

  {/* Featured Events */}
  <section class="relative py-20 lg:py-28" aria-labelledby="featured-events-heading">
    <div class="container">
      {/* Header */}
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-10">
        <div>
          <div class="flex items-center gap-2.5 mb-3">
            <span class="w-6 h-[1.5px] bg-terra"></span>
            <span class="text-[10px] font-bold uppercase tracking-[0.25em] text-terra">
              {t('events.featured')}
            </span>
          </div>
          <h2 id="featured-events-heading" class="font-display text-2xl lg:text-3xl font-semibold text-surface">
            Featured events
          </h2>
        </div>
        
        <a 
          href="/en/events" 
          class="inline-flex items-center gap-2 text-sm font-medium text-surface-secondary hover:text-terra transition-colors"
        >
          <span>View all</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      {/* Grid - All equal cards */}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {featuredEvents.map((event) => (
          <EventCard event={event} locale={locale} t={t} />
        ))}
      </div>
    </div>
  </section>

  {/* Free Events */}
  {freeEvents.length > 0 && (
    <section class="relative py-20 lg:py-28 bg-base-elevated/50" aria-labelledby="free-events-heading">
      <div class="container">
        <div class="flex items-center gap-2.5 mb-8">
          <span class="w-6 h-[1.5px] bg-mint"></span>
          <span class="text-[10px] font-bold uppercase tracking-[0.25em] text-mint">
            Free
          </span>
        </div>
        
        <h2 id="free-events-heading" class="font-display text-2xl lg:text-3xl font-semibold text-surface mb-8">
          Free events
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {freeEvents.map((event) => (
            <EventCard event={event} locale={locale} t={t} />
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Featured Routes */}
  <section class="relative py-20 lg:py-28" aria-labelledby="routes-heading">
    <div class="container">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-10">
        <div>
          <div class="flex items-center gap-2.5 mb-3">
            <span class="w-6 h-[1.5px] bg-amber"></span>
            <span class="text-[10px] font-bold uppercase tracking-[0.25em] text-amber">
              {t('routes.title')}
            </span>
          </div>
          <h2 id="routes-heading" class="font-display text-2xl lg:text-3xl font-semibold text-surface">
            Recommended routes
          </h2>
        </div>
        
        <a 
          href="/en/routes" 
          class="inline-flex items-center gap-2 text-sm font-medium text-surface-secondary hover:text-amber transition-colors"
        >
          <span>View all</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {featuredRoutes.map((route, index) => (
          <RouteCard route={route} locale={locale} t={t} index={index} variant="grid" />
        ))}
      </div>
    </div>
  </section>

  {/* Stats */}
  <section class="relative py-20 lg:py-28 bg-base-elevated/50" aria-labelledby="numbers-heading">
    <div class="container">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center gap-3 mb-4">
          <span class="w-8 h-[1px] bg-terra/50"></span>
          <span class="text-[10px] font-bold uppercase tracking-[0.25em] text-surface-muted">Data</span>
          <span class="w-8 h-[1px] bg-terra/50"></span>
        </div>
        <h2 id="numbers-heading" class="font-display text-2xl lg:text-3xl font-semibold text-surface">
          Granada in <span class="text-gradient-terra">numbers</span>
        </h2>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-8">
        {[
          { value: '800+', label: 'years', desc: 'of history', color: 'text-terra' },
          { value: '2', label: 'UNESCO', desc: 'Heritage sites', color: 'text-amber' },
          { value: '48h', label: 'to', desc: 'get lost', color: 'text-terra' },
          { value: '0€', label: 'tapa', desc: 'included', color: 'text-mint' },
        ].map((stat, index) => (
          <div class:list={['text-center p-6 rounded-2xl bg-base-card/40 border border-edge', index < 3 && 'lg:border-r lg:border-edge']}>
            <p class:list={['font-display text-4xl lg:text-5xl font-semibold mb-1', stat.color]}>{stat.value}</p>
            <p class="text-xs font-medium text-surface uppercase tracking-wider mb-0.5">{stat.label}</p>
            <p class="text-[10px] text-surface-muted">{stat.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* CTA */}
  <section class="relative py-24 lg:py-32 overflow-hidden" aria-labelledby="cta-title">
    <div class="absolute inset-0 bg-gradient-to-b from-base-elevated/30 to-base pointer-events-none"></div>
    
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none overflow-hidden">
      <span class="font-display text-[15vw] font-bold text-surface/[0.015] whitespace-nowrap select-none">
        GRANADA
      </span>
    </div>

    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] bg-terra/8 rounded-full blur-[100px] pointer-events-none"></div>

    <div class="container relative">
      <div class="max-w-2xl mx-auto text-center">
        <h2 id="cta-title" class="mb-6">
          <span class="block font-display text-2xl lg:text-3xl font-semibold text-surface">
            You already know the Alhambra.
          </span>
          <span class="block font-display text-2xl lg:text-3xl font-semibold text-gradient-terra mt-1">
            Granada you don't.
          </span>
        </h2>

        <p class="text-sm text-surface-secondary mb-8 max-w-md mx-auto">
          Granada's cultural guide created by locals. Events, authentic routes and the best plans.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a 
            href="/en/events"
            class="inline-flex items-center gap-2 px-7 py-3.5 bg-terra text-surface font-medium text-sm rounded-xl transition-all duration-300 hover:shadow-[0_4px_20px_rgba(232,90,60,0.25)] hover:-translate-y-0.5"
          >
            <span>Discover events</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a 
            href="/en/routes"
            class="inline-flex items-center gap-2 px-7 py-3.5 bg-base-card/60 text-surface font-medium text-sm rounded-xl border border-edge hover:border-amber/30 transition-all duration-300 hover:-translate-y-0.5"
          >
            <span>Explore routes</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

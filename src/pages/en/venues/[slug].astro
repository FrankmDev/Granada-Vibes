---
import DirectoryDetailPage from '@components/pages/DirectoryDetailPage.astro';
import { getAllVenueEntries } from '@data/index.js';

export const getStaticPaths = () =>
  getAllVenueEntries().map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));

const { entry } = Astro.props;
---

<DirectoryDetailPage locale="en" entry={entry} />

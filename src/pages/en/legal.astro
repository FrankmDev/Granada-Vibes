---
import BaseLayout from '@layouts/BaseLayout.astro';
import { useTranslations } from '@i18n/utils';

const locale = 'en';
const t = useTranslations(locale);
---

<BaseLayout 
  locale={locale} 
  title="Legal Notice"
  description="Legal Notice of Granada Vibes."
  noindex={true}
>
  <section class="container pt-32 pb-20">
    <div class="max-w-2xl mx-auto">
      <a href="/en" class="inline-flex items-center gap-2 text-text-muted hover:text-accent transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to home
      </a>

      <h1 class="font-display text-4xl lg:text-5xl font-bold text-text-primary mb-6">
        Legal Notice
      </h1>
      
      <div class="prose prose-invert prose-lg max-w-none">
        <p class="text-text-secondary leading-relaxed">
          This legal notice is being drafted. Coming soon.
        </p>
        
        <p class="text-text-secondary leading-relaxed mt-4">
          In the meantime, if you have any questions about the legal terms of use 
          of this site, you can contact us at <a href="mailto:hola@granadavibes.com" class="text-accent hover:underline">hola@granadavibes.com</a>.
        </p>
      </div>

      <p class="text-text-tertiary text-sm mt-12">
        Last updated: March 2025
      </p>
    </div>
  </section>
</BaseLayout>

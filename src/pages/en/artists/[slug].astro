---
import DirectoryDetailPage from '@components/pages/DirectoryDetailPage.astro';
import { getAllArtistEntries } from '@data/index.js';

export const getStaticPaths = () =>
  getAllArtistEntries().map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));

const { entry } = Astro.props;
---

<DirectoryDetailPage locale="en" kind="artist" entry={entry} />

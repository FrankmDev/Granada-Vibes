---
import BaseLayout from '@layouts/BaseLayout.astro';
import NavBar from '@components/layout/NavBar.astro';
import Footer from '@components/layout/Footer.astro';
import SubpageHero from '@components/shared/SubpageHero.astro';
import ButtonCTA from '@components/ui/ButtonCTA.astro';
import { useTranslations } from '@i18n/utils';
import type { Locale } from '@types';

const locale: Locale = 'en';
const t = useTranslations(locale);

const pageTitle = `${t('collaborate.footerGroup')} — GRN URBAN`;
const pageDescription = t('collaborate.pageDescription');

const cards = [
  {
    num: '01',
    title: t('collaborate.card1Title'),
    description: t('collaborate.card1Desc'),
    cta: t('collaborate.card1Cta'),
    price: t('collaborate.card1Price'),
  },
  {
    num: '02',
    title: t('collaborate.card2Title'),
    description: t('collaborate.card2Desc'),
    cta: t('collaborate.card2Cta'),
    price: t('collaborate.card2Price'),
  },
  {
    num: '03',
    title: t('collaborate.card3Title'),
    description: t('collaborate.card3Desc'),
    cta: t('collaborate.card3Cta'),
    price: t('collaborate.card3Price'),
  },
];

const mailto = `mailto:${t('collaborate.ctaEmail')}?subject=${encodeURIComponent(t('collaborate.ctaSubject'))}`;
---

<BaseLayout
  locale={locale}
  title={pageTitle}
  description={pageDescription}
  ogType="website"
>
  <NavBar slot="header" locale={locale} currentPath={Astro.url.pathname} />

  <SubpageHero
    locale={locale}
    title={t('collaborate.heroTitle')}
    eyebrow={t('collaborate.footerGroup')}
    eyebrowRight="GRANADA"
    description={pageDescription}
    variant="compact"
    pageNumber="04"
  />

  <section class="colab-section" aria-labelledby="colab-heading">
    <div class="colab-container">
      <h2 id="colab-heading" class="colab-heading">{t('collaborate.proposalsHeading')}</h2>

      <div class="colab-grid">
        {cards.map((card, i) => (
          <article class="colab-card" style={`--card-index: ${i}`} data-reveal>
            <div class="colab-card__num">{card.num}</div>
            <div class="colab-card__price">{card.price}</div>
            <h3 class="colab-card__title">{card.title}</h3>
            <p class="colab-card__desc">{card.description}</p>
            <div class="colab-card__footer">
              <ButtonCTA
                href={mailto}
                variant="tertiary"
                size="sm"
                data-track="generate_lead"
                class="colab-card__cta"
              >
                {card.cta}
              </ButtonCTA>
            </div>
          </article>
        ))}
      </div>

      <div class="colab-cta-block" data-reveal>
        <div class="colab-cta-orn">
          <span class="cta-orn-line"></span>
          <span class="cta-orn-diamond"></span>
          <span class="cta-orn-line"></span>
        </div>
        <p class="colab-cta-text">{t('collaborate.ctaText')}</p>
        <ButtonCTA
          href={mailto}
          variant="primary"
          size="lg"
          icon="mail"
          data-track="generate_lead"
          class="colab-cta-btn"
        >
          {t('collaborate.ctaEmail')}
        </ButtonCTA>
      </div>
    </div>
  </section>

  <Footer slot="footer" locale={locale} />
</BaseLayout>

<style>
  .colab-section {
    --s-bg: #f5f0ea;
    --s-bg-2: #ede8e0;
    --s-ink: #1a1619;
    --s-ink-2: #3a3532;
    --s-ink-3: #5a4f47;
    --s-ink-4: #8a7f77;
    --s-orange: #e8622a;
    --s-gold: #c9a84c;
    --s-border: rgba(26, 22, 25, 0.1);
    --s-border-s: rgba(26, 22, 25, 0.06);
    --ease-expo: cubic-bezier(0.16, 1, 0.3, 1);

    background: var(--s-bg);
    position: relative;
    padding: 5rem clamp(1.5rem, 5vw, 4rem) 6rem;
  }
  .colab-section::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.025;
    mix-blend-mode: multiply;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  .colab-container {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .colab-heading {
    font-family: var(--font-body);
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 300;
    color: var(--s-ink);
    letter-spacing: -0.02em;
    margin-bottom: 3rem;
    text-align: center;
  }

  .colab-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 5rem;
  }

  .colab-card {
    position: relative;
    background: linear-gradient(135deg, #fff 0%, var(--s-bg-2) 100%);
    border: 1px solid var(--s-border);
    border-radius: 24px;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    transition: all 0.6s var(--ease-expo);
    opacity: 0;
    transform: translateY(24px);
  }
  .colab-card.is-visible {
    opacity: 1;
    transform: translateY(0);
    transition-delay: calc(var(--card-index) * 0.12s);
  }
  .colab-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 24px 64px rgba(0,0,0,0.06);
    border-color: rgba(232, 98, 42, 0.2);
  }

  .colab-card__num {
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--s-orange);
    text-transform: uppercase;
  }
  .colab-card__price {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--s-gold);
    text-transform: uppercase;
    margin-top: -0.5rem;
  }
  .colab-card__title {
    font-family: var(--font-body);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--s-ink);
    line-height: 1.25;
    letter-spacing: -0.01em;
  }
  .colab-card__desc {
    font-family: var(--font-display);
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--s-ink-3);
    flex: 1;
  }
  .colab-card__footer {
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid var(--s-border-s);
  }

  /* Tertiary override: keep the orange tone from the original card CTA. */
  .colab-card__cta {
    --cta-accent: var(--s-orange);
    color: var(--s-orange);
    padding-inline: 0;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
  }
  .colab-card__cta .cta__rule { background: currentColor; }

  .colab-cta-block {
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s ease 0.3s;
  }
  .colab-cta-block.is-visible { opacity: 1; transform: translateY(0); }

  .colab-cta-orn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .cta-orn-line {
    flex: 1;
    max-width: 80px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--s-border), transparent);
  }
  .cta-orn-diamond {
    width: 8px;
    height: 8px;
    background: var(--s-orange);
    transform: rotate(45deg);
    opacity: 0.7;
  }

  .colab-cta-text {
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--s-ink-2);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  /* colab-cta-btn: primary variant, only needs a small layout override. */
  .colab-cta-btn {
    letter-spacing: 0.02em;
    font-size: 0.85rem;
  }

  @media (max-width: 1024px) {
    .colab-grid { grid-template-columns: 1fr; max-width: 520px; margin: 0 auto 4rem; }
    .colab-card { padding: 2rem; }
  }
  @media (max-width: 640px) {
    .colab-section { padding: 3rem 1.5rem 4rem; }
    .colab-heading { margin-bottom: 2rem; }
    .colab-card__title { font-size: 1.2rem; }
    .colab-cta-btn { width: 100%; justify-content: center; }
  }
</style>

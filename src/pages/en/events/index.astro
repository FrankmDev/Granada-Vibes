---
import BaseLayout from '@layouts/BaseLayout.astro';
import SubpageHero from '@components/shared/SubpageHero.astro';
import EventCard from '@components/events/EventCard.astro';
import { getAllEvents } from '@data';
import { useTranslations } from '@i18n/utils';
import type { EventCategory, Neighborhood } from '@types';

const locale = 'en';
const t = useTranslations(locale);
const events = getAllEvents();

const categories: EventCategory[] = ['concert', 'exhibition', 'festival', 'market', 'theater', 'workshop', 'guided-tour', 'cinema', 'other'];
const neighborhoods: Neighborhood[] = ['albaicin', 'sacromonte', 'centro', 'realejo', 'alhambra', 'cartuja', 'zaidin', 'otro'];

const ogImage = 'https://placehold.co/1200x630/080808/f0ede8?text=Granada+Vibes+Events';

// Hero metadata
const heroMetadata = [
  { label: t('events.heroMetaTotalLabel'), value: events.length.toString() },
  { label: t('events.heroMetaCategoriesLabel'), value: '9' },
  { label: t('events.heroMetaNeighborhoodsLabel'), value: '8' },
];
---

<BaseLayout 
  locale={locale} 
  title={t('events.title')}
  description={t('events.pageDescription')}
  ogImage={ogImage}
>
  <!-- CINEMATIC HERO -->
  <SubpageHero
    locale={locale}
    title={t('events.heroTitle')}
    subtitle={t('events.heroSubtitle')}
    eyebrow="RAWDA"
    eyebrowRight="ED. 2025"
    description={t('events.heroDescription')}
    ctaText={t('events.heroCta')}
    ctaLink="#events-grid"
    secondaryCtaText={t('events.heroSecondaryCta')}
    secondaryCtaLink="/en/routes"
    pageNumber="03"
    coordinates="37°10′N 3°36′W"
    metadata={heroMetadata}
    variant="default"
  />

  {/* Filters Bar - Dark theme */}
  <div class="relative border-y border-edge bg-base-elevated/80 backdrop-blur-sm">
    <div class="absolute inset-0 bg-gradient-to-r from-terra/[0.03] via-transparent to-terra/[0.03]" aria-hidden="true"></div>
    
    <div class="container relative py-6 lg:py-8">
      {/* Row 1 - Category chips */}
      <div class="flex flex-wrap items-center gap-2 mb-6" role="group" aria-label={t('events.filters.title')}>
        <button 
          class="filter-category px-5 py-2.5 text-xs font-bold uppercase tracking-wider bg-terra text-surface rounded-full transition-all duration-300 hover:shadow-lg hover:shadow-terra/30"
          data-category="all"
          aria-pressed="true"
        >
          {t('categories.all')}
        </button>
        {categories.map((cat) => (
          <button 
            class="filter-category px-5 py-2.5 text-xs font-bold uppercase tracking-wider text-surface-secondary bg-base-card border border-edge rounded-full hover:border-terra/50 hover:text-surface transition-all duration-300"
            data-category={cat}
            aria-pressed="false"
          >
            {t(`categories.${cat}`)}
          </button>
        ))}
      </div>

      {/* Row 2 - Secondary filters */}
      <div class="flex flex-wrap items-center gap-4 pt-6 border-t border-edge">
        {/* Neighborhood Dropdown */}
        <div class="relative group">
          <select
            id="filter-neighborhood"
            class="appearance-none px-5 py-2.5 pr-12 text-sm text-surface bg-base-card border border-edge rounded-xl focus:outline-none focus:border-terra cursor-pointer transition-all duration-300 hover:border-edge-hover min-w-[160px]"
            aria-label={t('events.filters.neighborhood')}
          >
            <option value="all">{t('events.filters.allNeighborhoods')}</option>
            {neighborhoods.map((n) => (
              <option value={n}>{t(`neighborhoods.${n}`)}</option>
            ))}
          </select>
          <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-surface-muted pointer-events-none transition-colors group-hover:text-terra" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>

        {/* Date Dropdown */}
        <div class="relative group">
          <select
            id="filter-date"
            class="appearance-none px-5 py-2.5 pr-12 text-sm text-surface bg-base-card border border-edge rounded-xl focus:outline-none focus:border-terra cursor-pointer transition-all duration-300 hover:border-edge-hover min-w-[160px]"
            aria-label={t('events.filters.date')}
          >
            <option value="all">{t('events.filters.anyDate')}</option>
            <option value="today">{t('filters.today')}</option>
            <option value="week">{t('filters.thisWeek')}</option>
            <option value="weekend">{t('filters.thisWeekend')}</option>
            <option value="month">{t('filters.thisMonth')}</option>
          </select>
          <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-surface-muted pointer-events-none transition-colors group-hover:text-terra" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>

        {/* Free toggle */}
        <label class="flex items-center gap-3 px-5 py-2.5 bg-base-card border border-edge rounded-xl cursor-pointer hover:border-terra/50 transition-all duration-300 group">
          <input 
            type="checkbox" 
            id="filter-free"
            class="w-4 h-4 rounded border-edge text-terra focus:ring-terra bg-base-card cursor-pointer"
          />
          <span class="text-sm text-surface-secondary group-hover:text-surface transition-colors font-medium">{t('filters.onlyFree')}</span>
        </label>

        <div class="flex-1"></div>

        {/* Clear filters button (hidden by default) */}
        <button 
          id="clear-filters"
          class="hidden items-center gap-2 px-5 py-2.5 text-sm text-surface-muted hover:text-terra transition-all duration-300 rounded-xl hover:bg-base-card font-medium"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
          {t('filters.clearFilters')}
        </button>
      </div>
    </div>
  </div>

  {/* Results counter */}
  <div class="container py-6">
    <div class="flex items-center gap-2 text-sm text-surface-muted">
      <span class="w-2 h-2 rounded-full bg-terra animate-pulse"></span>
      <span id="results-count" class="font-bold text-surface">{events.length}</span> {t('events.resultsLabel')}
    </div>
  </div>

  {/* Events Grid */}
  <section id="events-grid" class="container pb-20" aria-labelledby="events-heading">
    <h2 id="events-heading" class="sr-only">{t('events.title')}</h2>
    
    <div id="events-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
      {events.map((event) => (
        <div 
          class="event-card-wrapper reveal"
          data-category={event.category}
          data-neighborhood={event.neighborhood}
          data-price={event.price === null ? 'free' : 'paid'}
          data-date={event.date}
        >
          <EventCard event={event} locale={locale} t={t} />
        </div>
      ))}
    </div>
    
    {/* Empty state */}
    <div id="empty-state" class="hidden text-center py-24">
      <div class="relative w-24 h-24 mx-auto mb-8">
        <div class="absolute inset-0 bg-terra/20 rounded-3xl blur-xl"></div>
        <div class="relative w-full h-full bg-base-card border border-edge rounded-3xl flex items-center justify-center">
          <svg class="w-12 h-12 text-surface-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
      </div>
      <h3 class="font-display text-2xl font-semibold text-surface mb-3">
        {t('filters.noResults')}
      </h3>
      <p class="text-surface-secondary mb-8 max-w-md mx-auto">{t('filters.noResultsDesc')}</p>
      <button
        id="empty-clear-filters"
        class="inline-flex items-center gap-2 px-6 py-3 bg-terra text-surface font-semibold text-sm rounded-xl transition-all duration-300 hover:shadow-[0_4px_20px_rgba(232,90,60,0.25)] hover:-translate-y-0.5"
      >
        {t('filters.clearFilters')}
      </button>
    </div>
  </section>

  <script is:inline>
    (function() {
      const categoryButtons = document.querySelectorAll('.filter-category');
      const neighborhoodSelect = document.getElementById('filter-neighborhood');
      const dateSelect = document.getElementById('filter-date');
      const freeCheckbox = document.getElementById('filter-free');
      const clearFiltersBtn = document.getElementById('clear-filters');
      const emptyClearFiltersBtn = document.getElementById('empty-clear-filters');
      const resultsCount = document.getElementById('results-count');
      const emptyState = document.getElementById('empty-state');
      const eventsGrid = document.getElementById('events-grid');
      const eventCards = document.querySelectorAll('.event-card-wrapper');

      let filters = {
        category: 'all',
        neighborhood: 'all',
        date: 'all',
        free: false
      };

      function matchesDateFilter(eventDate, filter) {
        if (filter === 'all') return true;
        
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        const event = new Date(eventDate);
        event.setHours(0, 0, 0, 0);
        
        const diffTime = event - today;
        const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
        
        switch (filter) {
          case 'today':
            return diffDays === 0;
          case 'week':
            return diffDays >= 0 && diffDays <= 7;
          case 'weekend': {
            const dayOfWeek = today.getDay();
            const daysUntilSaturday = dayOfWeek === 0 ? 6 : 6 - dayOfWeek;
            const saturday = new Date(today);
            saturday.setDate(today.getDate() + daysUntilSaturday);
            const sunday = new Date(saturday);
            sunday.setDate(saturday.getDate() + 1);
            return event >= saturday && event <= sunday;
          }
          case 'month':
            return event.getMonth() === today.getMonth() && event.getFullYear() === today.getFullYear();
          default:
            return true;
        }
      }

      function applyFilters() {
        let visibleCount = 0;
        
        eventCards.forEach(card => {
          const category = card.dataset.category;
          const neighborhood = card.dataset.neighborhood;
          const price = card.dataset.price;
          const date = card.dataset.date;
          
          const matchesCategory = filters.category === 'all' || category === filters.category;
          const matchesNeighborhood = filters.neighborhood === 'all' || neighborhood === filters.neighborhood;
          const matchesPrice = !filters.free || price === 'free';
          const matchesDate = matchesDateFilter(date, filters.date);
          
          const isVisible = matchesCategory && matchesNeighborhood && matchesPrice && matchesDate;
          
          if (isVisible) {
            card.style.display = '';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });
        
        resultsCount.textContent = visibleCount;
        
        if (visibleCount === 0) {
          eventsGrid.classList.add('hidden');
          emptyState.classList.remove('hidden');
        } else {
          eventsGrid.classList.remove('hidden');
          emptyState.classList.add('hidden');
        }
        
        const hasActiveFilters = filters.category !== 'all' || 
                                 filters.neighborhood !== 'all' || 
                                 filters.date !== 'all' || 
                                 filters.free;
        
        if (hasActiveFilters) {
          clearFiltersBtn.classList.remove('hidden');
          clearFiltersBtn.classList.add('inline-flex');
        } else {
          clearFiltersBtn.classList.add('hidden');
          clearFiltersBtn.classList.remove('inline-flex');
        }
      }

      categoryButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          categoryButtons.forEach(b => {
            b.classList.remove('bg-terra', 'text-surface', 'shadow-lg');
            b.classList.add('text-surface-secondary', 'bg-base-card', 'border', 'border-edge');
            b.setAttribute('aria-pressed', 'false');
          });
          btn.classList.remove('text-surface-secondary', 'bg-base-card', 'border', 'border-edge');
          btn.classList.add('bg-terra', 'text-surface', 'shadow-lg');
          btn.setAttribute('aria-pressed', 'true');
          
          filters.category = btn.dataset.category;
          applyFilters();
        });
      });

      neighborhoodSelect?.addEventListener('change', (e) => {
        filters.neighborhood = e.target.value;
        applyFilters();
      });

      dateSelect?.addEventListener('change', (e) => {
        filters.date = e.target.value;
        applyFilters();
      });

      freeCheckbox?.addEventListener('change', (e) => {
        filters.free = e.target.checked;
        applyFilters();
      });

      function clearFilters() {
        filters = {
          category: 'all',
          neighborhood: 'all',
          date: 'all',
          free: false
        };
        
        categoryButtons.forEach(b => {
          if (b.dataset.category === 'all') {
            b.classList.remove('text-surface-secondary', 'bg-base-card', 'border', 'border-edge');
            b.classList.add('bg-terra', 'text-surface', 'shadow-lg');
            b.setAttribute('aria-pressed', 'true');
          } else {
            b.classList.remove('bg-terra', 'text-surface', 'shadow-lg');
            b.classList.add('text-surface-secondary', 'bg-base-card', 'border', 'border-edge');
            b.setAttribute('aria-pressed', 'false');
          }
        });
        
        neighborhoodSelect.value = 'all';
        dateSelect.value = 'all';
        freeCheckbox.checked = false;
        
        applyFilters();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }

      clearFiltersBtn?.addEventListener('click', clearFilters);
      emptyClearFiltersBtn?.addEventListener('click', clearFilters);
    })();
  </script>
</BaseLayout>

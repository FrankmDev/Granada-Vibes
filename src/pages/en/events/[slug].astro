---
import BaseLayout from '@layouts/BaseLayout.astro';
import NavBar from '@components/layout/NavBar.astro';
import Footer from '@components/layout/Footer.astro';
import VenueMap from '@components/ui/VenueMap.astro';
import OptimizedImage from '@components/ui/OptimizedImage.astro';
import EventDetailHero from '@components/events/EventDetailHero.astro';
import EventDetailContent from '@components/events/EventDetailContent.astro';
import { getAllEvents } from '@data';
import { getVenueCoordinates } from '../../../data/venues/coordinates';
import { useTranslations } from '@i18n/utils';
import { formatFullDate, formatTime } from '@utils/dates';

export function getStaticPaths() {
  const events = getAllEvents();
  return events.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
const locale = 'en';
const t = useTranslations(locale);

const venueCoords = getVenueCoordinates(event.venue, event.neighborhood);
const relatedEvents = getAllEvents()
  .filter(e => e.category === event.category && e.id !== event.id)
  .slice(0, 3);

const eventImage = event.imageUrl || event.image;
const ogImage = eventImage || 'https://placehold.co/1200x630/0a0a0a/f0ede8?text=GRN Index';

const seoDescription = `${event.title[locale]} in Granada — ${formatFullDate(event.date, locale)}, ${formatTime(event.time, locale)}. ${t(`categories.${event.category}`)} at ${event.venue}, ${t(`neighborhoods.${event.neighborhood}`)}. ${event.price === null ? 'Free entry.' : `From ${event.price}€.`} Get tickets and discover more on GRN Index.`;
---

<BaseLayout
  locale={locale}
  title={event.title[locale]}
  description={seoDescription}
  ogImage={ogImage}
  schemaType="event"
  schemaData={event}
>
  <NavBar slot="header" locale={locale} currentPath={Astro.url.pathname} />

  <!-- DARK CINEMATIC HERO -->
  <EventDetailHero event={event} locale={locale} />

  <!-- CREAM EDITORIAL CONTENT -->
  <EventDetailContent>
  <div class="det-page">

    <div class="det-content-wrap">
      <div class="det-layout">

        <!-- MAIN COLUMN (70%) -->
        <main id="main-content" class="det-main">

          <!-- Description block -->
          <article class="det-block" data-reveal>
            <header class="det-block-head">
              <span class="det-block-num">01</span>
              <div class="det-block-divider"></div>
              <span class="det-block-eyebrow">[ About the event ]</span>
            </header>
            <h2 class="det-block-title">Description</h2>
            {event.description[locale] && (
              <p class="det-lead">{event.description[locale]}</p>
            )}
            {event.longDescription && event.longDescription[locale] && (
              <div class="det-long-desc">
                {event.longDescription[locale].split('\n\n').map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
              </div>
            )}
            <div class="det-hover-corners" aria-hidden="true">
              <span class="hc tl"></span><span class="hc tr"></span>
              <span class="hc bl"></span><span class="hc br"></span>
            </div>
          </article>

          <!-- Venue block -->
          <article class="det-block" data-reveal>
            <header class="det-block-head">
              <span class="det-block-num">02</span>
              <div class="det-block-divider"></div>
              <span class="det-block-eyebrow">[ Location ]</span>
            </header>
            <h2 class="det-block-title">{event.venue}</h2>
            <div class="evt-venue-meta">
              <span class="evt-neighborhood-tag">{t(`neighborhoods.${event.neighborhood}`)}</span>
              {event.address && <span class="evt-address">{event.address}</span>}
            </div>
            {event.venueDescription && (
              <p class="evt-venue-desc">{event.venueDescription[locale]}</p>
            )}
            <div class="evt-map-frame">
              {venueCoords ? (
                <VenueMap lat={venueCoords.lat} lng={venueCoords.lng} venueName={event.venue} theme="light" />
              ) : (
                <div class="evt-map-placeholder">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  <p>{t('detail.mapComingSoon')}</p>
                </div>
              )}
            </div>
            <div class="det-hover-corners" aria-hidden="true">
              <span class="hc tl"></span><span class="hc tr"></span>
              <span class="hc bl"></span><span class="hc br"></span>
            </div>
          </article>

          <!-- Highlights block -->
          {event.highlights && event.highlights[locale] && event.highlights[locale]!.length > 0 && (
            <article class="det-block" data-reveal>
              <header class="det-block-head">
                <span class="det-block-num">03</span>
                <div class="det-block-divider"></div>
                <span class="det-block-eyebrow">[ Experience ]</span>
              </header>
              <h2 class="det-block-title">What to expect</h2>
              <ul class="evt-highlights" role="list">
                {event.highlights[locale]!.map((item, i) => (
                  <li class="evt-highlight-item" style={`--stagger: ${i * 0.08}s`}>
                    <span class="evt-hl-marker" aria-hidden="true">
                      <span class="evt-hl-num">{(i + 1).toString().padStart(2, '0')}</span>
                      <span class="evt-hl-bar"></span>
                    </span>
                    <span class="evt-hl-text">{item}</span>
                  </li>
                ))}
              </ul>
              <div class="det-hover-corners" aria-hidden="true">
                <span class="hc tl"></span><span class="hc tr"></span>
                <span class="hc bl"></span><span class="hc br"></span>
              </div>
            </article>
          )}

          <!-- Tips block -->
          {event.tips && (
            <article class="det-block evt-tips-block" data-reveal>
              <header class="det-block-head">
                <span class="det-block-num">04</span>
                <div class="det-block-divider"></div>
                <span class="det-block-eyebrow">[ Practical tips ]</span>
              </header>
              <h2 class="det-block-title">Good to know</h2>
              <div class="evt-tips-inner">
                <div class="evt-tips-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <p class="evt-tips-text">{event.tips[locale]}</p>
              </div>
            </article>
          )}

          <!-- Tags -->
          {event.tags.length > 0 && (
            <div class="det-tags" data-reveal>
              <span class="det-tags-eyebrow">[ Tags ]</span>
              <div class="det-tags-flow">
                {event.tags.map((tag, i) => (
                  <span class="det-tag-pill" style={`--ti: ${i}`}>#{tag}</span>
                ))}
              </div>
            </div>
          )}

        </main>

        <!-- SIDEBAR (30%) -->
        <aside>
          <div class="det-sidebar-sticky">

            <!-- Info card -->
            <div class="det-sidebar-card det-info-card" data-reveal>
              <div class="det-sc-head">
                <span class="det-sc-eyebrow">[ Event info ]</span>
                <div class="det-sc-line"></div>
              </div>

              <div class="det-info-row">
                <span class="det-info-label">{t('detail.date')}</span>
                <span class="det-info-val evt-info-date">{formatFullDate(event.date, locale)}</span>
              </div>
              <div class="det-info-sep"></div>
              <div class="det-info-row">
                <span class="det-info-label">{t('detail.time')}</span>
                <span class="det-info-val">{formatTime(event.time, locale)}</span>
              </div>
              <div class="det-info-sep"></div>
              <div class="det-info-row">
                <span class="det-info-label">{t('detail.category')}</span>
                <span class="det-info-val">{t(`categories.${event.category}`)}</span>
              </div>
              <div class="det-info-sep"></div>
              <div class="det-info-row">
                <span class="det-info-label">{t('events.filters.neighborhood')}</span>
                <span class="det-info-val">{t(`neighborhoods.${event.neighborhood}`)}</span>
              </div>
              <div class="det-info-sep"></div>
              <div class="det-info-row">
                <span class="det-info-label">{t('detail.price')}</span>
                <span class:list={['det-info-val', 'evt-info-price', event.price === null && 'is-free']}>
                  {event.price === null ? t('detail.free') : `${event.price}€`}
                </span>
              </div>

              <div class="evt-info-actions">
                {(event.ticketsUrl || event.sourceUrl) ? (
                  <a
                    href={event.ticketsUrl || event.sourceUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="evt-btn-primary"
                  >
                    <span>{t('detail.getTickets')}</span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                ) : (
                  <div class="evt-btn-primary">
                    <span>{event.price === null ? t('detail.free') : t('detail.bookPlace')}</span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                )}
                <button id="share-btn" class="evt-btn-secondary"
                  data-title={event.title[locale]}
                  data-url={Astro.url.href}
                >
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
                  </svg>
                  <span class="share-label" aria-live="polite">Share event</span>
                </button>
              </div>
            </div>

            <!-- Related events -->
            {relatedEvents.length > 0 && (
              <div class="det-sidebar-card det-related-card" data-reveal>
                <div class="det-sc-head">
                  <span class="det-sc-eyebrow">[ Similar events ]</span>
                  <div class="det-sc-line"></div>
                </div>
                <div class="det-related-list">
                  {relatedEvents.map((rel, i) => (
                    <a
                      href={`/en/events/${rel.slug}`}
                      class="det-related-item"
                      style={`--ri: ${i}`}
                      aria-label={rel.title[locale]}
                    >
                      <div class="det-rel-thumb">
                        {(rel.imageUrl || rel.image) ? (
                          <OptimizedImage src={rel.imageUrl || rel.image} alt="" loading="lazy" sizes="(max-width: 640px) 100vw, 280px" />
                        ) : (
                          <div class="det-rel-thumb-fallback">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                              <rect x="3" y="3" width="18" height="18" rx="2"/>
                              <circle cx="8.5" cy="8.5" r="1.5"/>
                              <path d="M21 15l-5-5L5 21"/>
                            </svg>
                          </div>
                        )}
                        <div class="det-rel-thumb-overlay"></div>
                      </div>
                      <div class="det-rel-info">
                        <span class="det-rel-title">{rel.title[locale]}</span>
                        <span class="det-rel-meta">
                          {formatFullDate(rel.date, locale)} · {rel.price === null ? t('detail.free') : `${rel.price}€`}
                        </span>
                      </div>
                      <svg class="det-rel-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  ))}
                </div>
                <a href="/en/events" class="det-all-link">
                  {t('detail.allEvents')}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </div>
            )}

          </div>
        </aside>
      </div>
    </div>

    <!-- Footer ornament -->
    <div class="det-footer-orn" aria-hidden="true">
      <span class="det-orn-line"></span>
      <span class="det-orn-diamond"></span>
      <span class="det-orn-star">
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17.2l-6.2 4.1 2.4-7.4L2 9.4h7.6z"/>
        </svg>
      </span>
      <span class="det-orn-diamond"></span>
      <span class="det-orn-line"></span>
    </div>

  </div>
  </EventDetailContent>

  <Footer slot="footer" locale={locale} />
</BaseLayout>

<script is:inline>
  (function () {
    const btn = document.getElementById('share-btn');
    if (!btn) return;
    btn.addEventListener('click', async function () {
      const title = btn.dataset.title;
      const url   = btn.dataset.url;
      const label = btn.querySelector('.share-label');
      if (navigator.share) {
        try { await navigator.share({ title, text: 'Discover "' + title + '" on GRN Index', url }); return; }
        catch (_) {}
      }
      try {
        await navigator.clipboard.writeText(url ?? '');
        if (label) {
          const orig = label.textContent;
          label.textContent = 'Copied!';
          setTimeout(() => { label.textContent = orig; }, 2000);
        }
      } catch (_) {}
    });
  })();
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const io = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } }),
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('[data-reveal]').forEach(el => io.observe(el));
  });
</script>

<style>
  .det-long-desc { margin-top: 1.5rem; display: flex; flex-direction: column; gap: 1.2rem; }
  .det-long-desc p { font-family: var(--font-display); font-size: 1rem; line-height: 1.75; color: var(--s-ink-2); max-width: 68ch; }
</style>

---
import BaseLayout from '@layouts/BaseLayout.astro';
import { useTranslations } from '@i18n/utils';

const locale = 'en';
const t = useTranslations(locale);

const ogImage = 'https://placehold.co/1200x630/0a0a0a/f0ede8?text=Granada+Vibes';
---

<BaseLayout 
  locale={locale} 
  title="About us"
  description="Granada Vibes is the cultural guide Granada deserves. Discover who we are, our mission and how to collaborate with us."
  ogImage={ogImage}
  schemaType="organization"
>
  {/* Hero editorial */}
  <section class="relative min-h-[60vh] flex items-center hero-grain bg-bg" aria-labelledby="hero-title">
    <div class="container relative pt-32 pb-20">
      <h1 id="hero-title" class="max-w-4xl">
        <span class="block font-display text-4xl sm:text-5xl lg:text-7xl font-bold text-text-primary leading-[1.1]">
          Granada deserves
        </span>
        <span class="block font-display text-4xl sm:text-5xl lg:text-7xl font-bold text-text-primary leading-[1.1] mt-2">
          a better guide.
        </span>
        <span class="block font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-accent leading-[1.2] mt-6">
          So we're building it.
        </span>
      </h1>
    </div>
  </section>

  {/* Project Section */}
  <section class="py-20 lg:py-28" aria-labelledby="project-heading">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
        {/* Left column */}
        <div>
          <h2 id="project-heading" class="font-display text-2xl lg:text-3xl font-semibold text-text-primary mb-6">
            What is Granada Vibes
          </h2>
          <div class="space-y-4 text-text-secondary leading-relaxed">
            <p>
              Granada Vibes was born from a shared frustration: the difficulty of discovering 
              what's really happening in a city with as much cultural life as Granada. Traditional 
              tourist guides become outdated, events on social media are scattered, and too many 
              authentic experiences never reach those looking for them.
            </p>
            <p>
              We're a small team of locals and adopted granadinos who decided to create the tool 
              we wish we had. A living guide, constantly updated, that connects curious visitors 
              with local creators, locals with new experiences, and everyone with the Granada 
              that exists beyond the postcard.
            </p>
            <p>
              We're not a travel agency. We don't sell tickets. We just filter the noise so you 
              can find what's worth your time.
            </p>
          </div>
        </div>

        {/* Right column */}
        <div>
          <h2 class="font-display text-2xl lg:text-3xl font-semibold text-text-primary mb-6">
            How it works
          </h2>
          <div class="space-y-4 text-text-secondary leading-relaxed">
            <p>
              Every week we walk the city, talk to organizers, visit venues and manually select 
              what appears on the platform. There are no algorithms or automatic listings: every 
              event and route is chosen because we believe it adds something unique.
            </p>
            <p>
              What sets us apart is curation. We don't include something just because it's popular. 
              We look for authenticity, quality and variety. From flamenco in a Sacromonte cave to 
              emerging art exhibitions in the City Center, to hiking trails only locals know about.
            </p>
            <p>
              In the future we want to add social features: personalized plans, shared lists, 
              event alerts. But the core will always be the same: curated content with criteria 
              and honesty.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Values Section */}
  <section class="py-20 lg:py-28 bg-bg-raised/30" aria-labelledby="values-heading">
    <div class="container">
      <h2 id="values-heading" class="sr-only">Our values</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16">
        {/* Value 1 */}
        <div>
          <span class="font-display text-6xl lg:text-7xl font-bold text-accent/20">01</span>
          <h3 class="font-display text-xl font-semibold text-text-primary mt-4 mb-3">
            Authenticity
          </h3>
          <p class="text-text-secondary leading-relaxed">
            We promote genuine experiences, away from tourist traps. If something is on 
            Granada Vibes, it's because we'd recommend it to a friend. We don't accept 
            payments for positioning or disguised advertising.
          </p>
        </div>

        {/* Value 2 */}
        <div>
          <span class="font-display text-6xl lg:text-7xl font-bold text-accent/20">02</span>
          <h3 class="font-display text-xl font-semibold text-text-primary mt-4 mb-3">
            Curated quality
          </h3>
          <p class="text-text-secondary leading-relaxed">
            Every event and route is carefully selected by our team. We prefer fewer 
            options but guarantee they're all worth your time. No filler, only 
            recommendations with criteria.
          </p>
        </div>

        {/* Value 3 */}
        <div>
          <span class="font-display text-6xl lg:text-7xl font-bold text-accent/20">03</span>
          <h3 class="font-display text-xl font-semibold text-text-primary mt-4 mb-3">
            Community
          </h3>
          <p class="text-text-secondary leading-relaxed">
            We support local creators and businesses in the city. Granada Vibes works 
            because there are artists, organizers and merchants doing interesting things. 
            Our job is to give them visibility.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Work with us Section */}
  <section class="py-20 lg:py-28 bg-bg-raised" aria-labelledby="work-heading">
    <div class="container">
      <div class="max-w-3xl mb-12">
        <h2 id="work-heading" class="font-display text-3xl lg:text-4xl font-bold text-text-primary mb-4">
          Do you have a business in Granada?
        </h2>
        <p class="text-text-secondary text-lg leading-relaxed">
          We reach visitors looking for authentic experiences, not tourist traps. 
          If you organize cultural events, offer guided tours or have an interesting 
          space, we'd love to meet you.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        {/* Proposal 1 */}
        <div class="p-6 bg-bg-card border border-border rounded-2xl">
          <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="font-display text-lg font-semibold text-text-primary mb-2">
            List your events
          </h3>
          <p class="text-text-secondary text-sm leading-relaxed">
            From intimate concerts to temporary exhibitions. If you have something 
            interesting to announce, we want to know.
          </p>
        </div>

        {/* Proposal 2 */}
        <div class="p-6 bg-bg-card border border-border rounded-2xl">
          <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0121 18.382V7.618a1 1 0 01-.447-.894L15 7m0 13V7" />
            </svg>
          </div>
          <h3 class="font-display text-lg font-semibold text-text-primary mb-2">
            Appear in our routes
          </h3>
          <p class="text-text-secondary text-sm leading-relaxed">
            If you have a bar with history, an artisan workshop or a unique space, 
            we can include it in our themed routes.
          </p>
        </div>

        {/* Proposal 3 */}
        <div class="p-6 bg-bg-card border border-border rounded-2xl">
          <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
            </svg>
          </div>
          <h3 class="font-display text-lg font-semibold text-text-primary mb-2">
            Collaborate with content
          </h3>
          <p class="text-text-secondary text-sm leading-relaxed">
            Are you a photographer, writer or content creator? We're looking for 
            collaborations to enrich our guides with fresh perspectives.
          </p>
        </div>
      </div>

      <a 
        href="mailto:hola@granadavibes.com?subject=Collaboration%20with%20Granada%20Vibes"
        class="inline-flex items-center gap-2 px-8 py-4 bg-accent text-bg font-semibold text-base rounded-xl transition-all duration-300 hover:shadow-[0_8px_30px_rgba(224,122,95,0.25)] hover:scale-[1.02]"
      >
        Let's talk
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

  {/* Contact Form */}
  <section class="py-20 lg:py-28" aria-labelledby="contact-heading">
    <div class="container">
      <div class="max-w-2xl mx-auto">
        <h2 id="contact-heading" class="font-display text-3xl lg:text-4xl font-bold text-text-primary mb-4 text-center">
          Get in touch
        </h2>
        <p class="text-text-secondary text-center mb-10">
          Have a suggestion, want to propose an event or just say hello? 
          We're listening.
        </p>

        <form id="contact-form" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-medium text-text-secondary mb-2">
                Name
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 bg-bg-card border border-border rounded-xl text-text-primary placeholder-text-muted focus:outline-none focus:border-accent transition-colors"
                placeholder="Your name"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-text-secondary mb-2">
                Email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 bg-bg-card border border-border rounded-xl text-text-primary placeholder-text-muted focus:outline-none focus:border-accent transition-colors"
                placeholder="you@email.com"
              />
            </div>
          </div>

          <div>
            <label for="type" class="block text-sm font-medium text-text-secondary mb-2">
              Inquiry type
            </label>
            <select
              id="type"
              name="type"
              required
              class="w-full px-4 py-3 bg-bg-card border border-border rounded-xl text-text-primary focus:outline-none focus:border-accent transition-colors appearance-none cursor-pointer"
            >
              <option value="">Select an option</option>
              <option value="event">List an event</option>
              <option value="collaboration">Collaboration</option>
              <option value="suggestion">Suggestion</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-text-secondary mb-2">
              Message
            </label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-3 bg-bg-card border border-border rounded-xl text-text-primary placeholder-text-muted focus:outline-none focus:border-accent transition-colors resize-none"
              placeholder="Tell us what you need..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full md:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 bg-accent text-bg font-semibold text-base rounded-xl transition-all duration-300 hover:shadow-[0_8px_30px_rgba(224,122,95,0.25)] hover:scale-[1.02]"
          >
            Send message
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
            </svg>
          </button>
        </form>
      </div>
    </div>
  </section>

  <script is:inline>
    (function() {
      const form = document.getElementById('contact-form');
      
      form?.addEventListener('submit', function(e) {
        e.preventDefault();
        
        const formData = new FormData(form);
        const name = formData.get('name');
        
        alert(`Thank you ${name} — your message has been received. We'll get back to you in 24-48h.`);
        
        form.reset();
      });
    })();
  </script>
</BaseLayout>

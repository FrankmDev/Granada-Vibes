---
import BaseLayout from '@layouts/BaseLayout.astro';
import { useTranslations } from '@i18n/utils';

const locale = 'en';
const t = useTranslations(locale);
---

<BaseLayout 
  locale={locale} 
  title="Privacy Policy"
  description="Privacy Policy of RAWDA."
  noindex={true}
>
  <section class="container pt-32 pb-20">
    <div class="max-w-2xl mx-auto">
      <a href="/en" class="inline-flex items-center gap-2 text-surface-muted hover:text-terra transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to home
      </a>

      <h1 class="font-display text-4xl lg:text-5xl font-bold text-surface mb-6">
        Privacy Policy
      </h1>
      
      <div class="prose prose-invert prose-lg max-w-none">
        <p class="text-surface-secondary leading-relaxed">
          This privacy policy is being drafted. Coming soon.
        </p>
        
        <p class="text-surface-secondary leading-relaxed mt-4">
          In the meantime, if you have any questions about how we handle your data, 
          you can contact us at <a href="mailto:hola@granadavibes.com" class="text-terra hover:underline">hola@granadavibes.com</a>.
        </p>
      </div>

      <p class="text-surface-muted text-sm mt-12">
        Last updated: March 2025
      </p>
    </div>
  </section>
</BaseLayout>

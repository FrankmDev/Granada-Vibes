---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/layout/Breadcrumbs.astro';
import Icon from '@components/ui/Icon.astro';
import { getAllRoutes, getRouteBySlug } from '@data';
import { useTranslations } from '@i18n/utils';
import { formatDistance } from '@utils/dates';

export function getStaticPaths() {
  const routes = getAllRoutes();
  return routes.map((route) => ({
    params: { slug: route.slug },
    props: { route },
  }));
}

const { route } = Astro.props;
const locale = 'en';
const t = useTranslations(locale);

const breadcrumbs = [
  { label: t('nav.home'), href: '/en' },
  { label: t('nav.routes'), href: '/en/routes' },
  { label: route.title[locale] },
];
---

<BaseLayout 
  locale={locale}
  title={route.title[locale]}
  description={route.description[locale]}
  schemaType="route"
  schemaData={route}
>
  <article class="container pt-32 pb-20">
    <Breadcrumbs items={breadcrumbs} />

    {/* Header */}
    <header class="max-w-4xl mb-12">
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <span class="px-2.5 py-1 text-[10px] font-mono uppercase tracking-wider bg-sand/10 text-sand rounded-full">
          {t(`categories.${route.category}`)}
        </span>
        {route.featured && (
          <span class="px-2.5 py-1 text-[10px] font-mono uppercase tracking-wider bg-sand/10 text-sand rounded-full">
            {t('routes.featured')}
          </span>
        )}
      </div>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-semibold tracking-[-0.02em] mb-6">
        {route.title[locale]}
      </h1>
      <p class="text-lg text-text-secondary leading-relaxed">
        {route.description[locale]}
      </p>
    </header>

    {/* Stats Grid */}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12" role="list" aria-label={locale === 'es' ? 'Estadísticas de la ruta' : 'Route statistics'}>
      <div class="p-5 bg-bg-card border border-border rounded-xl text-center" role="listitem">
        <div class="w-10 h-10 bg-sand/10 rounded-lg flex items-center justify-center mx-auto mb-3">
          <Icon name="clock" class="w-5 h-5 text-sand" />
        </div>
        <p class="text-xs text-text-muted uppercase tracking-wider mb-1">{locale === 'es' ? 'Duración' : 'Duration'}</p>
        <p class="font-display text-xl font-semibold text-text-primary">{route.duration} min</p>
      </div>

      <div class="p-5 bg-bg-card border border-border rounded-xl text-center" role="listitem">
        <div class="w-10 h-10 bg-sand/10 rounded-lg flex items-center justify-center mx-auto mb-3">
          <Icon name="trend" class="w-5 h-5 text-sand" />
        </div>
        <p class="text-xs text-text-muted uppercase tracking-wider mb-1">{locale === 'es' ? 'Distancia' : 'Distance'}</p>
        <p class="font-display text-xl font-semibold text-text-primary">{formatDistance(route.distance, locale)}</p>
      </div>

      <div class="p-5 bg-bg-card border border-border rounded-xl text-center" role="listitem">
        <div class="w-10 h-10 bg-sand/10 rounded-lg flex items-center justify-center mx-auto mb-3">
          <Icon name="lightning" class="w-5 h-5 text-sand" />
        </div>
        <p class="text-xs text-text-muted uppercase tracking-wider mb-1">{t('routes.difficultyLabel')}</p>
        <p class="font-display text-xl font-semibold text-text-primary">{t(`difficulty.${route.difficulty}`)}</p>
      </div>

      <div class="p-5 bg-bg-card border border-border rounded-xl text-center" role="listitem">
        <div class="w-10 h-10 bg-sand/10 rounded-lg flex items-center justify-center mx-auto mb-3">
          <Icon name="sun" class="w-5 h-5 text-sand" />
        </div>
        <p class="text-xs text-text-muted uppercase tracking-wider mb-1">{t('routes.bestTime')}</p>
        <p class="font-display text-xl font-semibold text-text-primary">{t(`timeOfDay.${route.timeOfDay}`)}</p>
      </div>
    </div>

    {/* Highlights */}
    {route.highlights.length > 0 && (
      <section class="mb-12" aria-labelledby="highlights-heading">
        <h2 id="highlights-heading" class="font-mono text-[11px] uppercase tracking-[0.15em] text-text-muted mb-6">
          {t('routes.highlights')}
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {route.highlights.map((highlight) => (
            <div class="p-5 bg-bg-card border border-border rounded-xl">
              <h3 class="font-display text-base font-medium text-text-primary mb-2">{highlight.title[locale]}</h3>
              <p class="text-sm text-text-secondary">{highlight.description[locale]}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    {/* Tips */}
    {route.tips.length > 0 && (
      <section class="mb-12" aria-labelledby="tips-heading">
        <h2 id="tips-heading" class="font-mono text-[11px] uppercase tracking-[0.15em] text-text-muted mb-6">
          {t('routes.tips')}
        </h2>
        <div class="space-y-3">
          {route.tips.map((tip) => (
            <div class="flex items-start gap-4 p-4 bg-bg-card border border-border rounded-xl">
              <div class="w-8 h-8 bg-sand/10 rounded-lg flex items-center justify-center flex-shrink-0">
                <Icon name="information" class="w-4 h-4 text-sand" />
              </div>
              <div>
                <h3 class="font-display text-sm font-medium text-text-primary mb-1">{tip.title[locale]}</h3>
                <p class="text-sm text-text-secondary">{tip.content[locale]}</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    {/* Neighborhoods */}
    <footer>
      <div class="flex flex-wrap items-center gap-2">
        <span class="text-sm text-text-muted mr-2">{locale === 'es' ? 'Barrios:' : 'Neighborhoods:'}</span>
        {route.neighborhoods.map((n) => (
          <span class="px-2.5 py-1 text-xs text-text-secondary bg-bg-raised rounded-full border border-border/50">
            {t(`neighborhoods.${n}`)}
          </span>
        ))}
      </div>
    </footer>
  </article>
</BaseLayout>

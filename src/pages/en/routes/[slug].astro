---
import BaseLayout from '@layouts/BaseLayout.astro';
import RouteDetailHero from '@components/routes/RouteDetailHero.astro';
import RouteDetailContent from '@components/routes/RouteDetailContent.astro';
import OptimizedImage from '@components/ui/OptimizedImage.astro';
import { getAllRoutes } from '@data/index.js';
import { useTranslations } from '@i18n/utils';
import { formatDuration, formatDistance } from '@utils/dates';
import type { RouteDifficulty } from '@types';

export function getStaticPaths() {
  const routes = getAllRoutes();
  return routes.map((route) => ({
    params: { slug: route.slug },
    props: { route },
  }));
}

const { route } = Astro.props;
const locale = 'en';
const t = useTranslations(locale);

const difficultyBars: Record<RouteDifficulty, number> = {
  easy: 1, moderate: 2, challenging: 3,
};

const difficultyColor: Record<RouteDifficulty, string> = {
  easy: '#4a9e6b', moderate: '#d4873a', challenging: '#c94a4a',
};
const diffColor = difficultyColor[route.difficulty];
const diffBars  = difficultyBars[route.difficulty];

const relatedRoutes = getAllRoutes()
  .filter(r => r.category === route.category && r.id !== route.id)
  .slice(0, 2);

if (relatedRoutes.length < 2) {
  const more = getAllRoutes()
    .filter(r => r.difficulty === route.difficulty && r.id !== route.id && !relatedRoutes.find(rr => rr.id === r.id))
    .slice(0, 2 - relatedRoutes.length);
  relatedRoutes.push(...more);
}

const routeImage = route.imageUrl || route.image;
const ogImage = routeImage || 'https://placehold.co/1200x630/0a0a0a/f2cc8f?text=Granada+Vibes+Routes';

const seoDescription = `Discover the "${route.title[locale]}" route through ${route.neighborhoods.map(n => t(`neighborhoods.${n}`)).join(', ')} in Granada: ${formatDuration(route.duration, locale)} ${t(`categories.${route.category}`).toLowerCase()} walk, ${formatDistance(route.distance, locale)}. Difficulty: ${t(`difficulty.${route.difficulty}`).toLowerCase()}. Practical tips and route highlights.`;
---

<BaseLayout
  locale={locale}
  title={route.title[locale]}
  description={seoDescription}
  ogImage={ogImage}
  schemaType="route"
  schemaData={route}
>
  <RouteDetailHero route={route} locale={locale} />

  <RouteDetailContent>
  <div class="det-page">
    <div class="det-content-wrap">
      <div class="det-layout">

        <!-- MAIN (70%) -->
        <main id="main-content" class="det-main">

          <!-- Block 01: Metrics -->
          <article class="det-block" data-reveal>
            <header class="det-block-head">
              <span class="det-block-num">01</span>
              <div class="det-block-divider"></div>
              <span class="det-block-eyebrow">[ At a glance ]</span>
            </header>
            <h2 class="det-block-title">Overview</h2>
            <p class="det-lead">{route.description[locale]}</p>
            <div class="rut-metrics" style={`--dc: ${diffColor}`}>
              <div class="rut-metric-cell">
                <div class="rut-metric-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <span class="rut-metric-val">{formatDuration(route.duration, locale)}</span>
                <span class="rut-metric-label">{t('detail.duration')}</span>
              </div>
              <div class="rut-metric-cell">
                <div class="rut-metric-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.447-.894L15 7m0 13V7"/>
                  </svg>
                </div>
                <span class="rut-metric-val">{formatDistance(route.distance, locale)}</span>
                <span class="rut-metric-label">{t('detail.distance')}</span>
              </div>
              <div class="rut-metric-cell">
                <div class="rut-diff-bars" aria-hidden="true">
                  {[1,2,3].map(n => (
                    <span class:list={['rut-diff-bar', n <= diffBars && 'active']} style={`--dc: ${diffColor}`}></span>
                  ))}
                </div>
                <span class="rut-metric-val is-diff" style={`--dc: ${diffColor}`}>{t(`difficulty.${route.difficulty}`)}</span>
                <span class="rut-metric-label">{t('detail.difficulty')}</span>
              </div>
              <div class="rut-metric-cell">
                <div class="rut-metric-icon" aria-hidden="true">
                  {(route.timeOfDay === 'evening' || route.timeOfDay === 'sunset') ? (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
                    </svg>
                  ) : (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
                    </svg>
                  )}
                </div>
                <span class="rut-metric-val">{t(`timeOfDay.${route.timeOfDay}`)}</span>
                <span class="rut-metric-label">{t('detail.bestTime')}</span>
              </div>
            </div>
            <div class="det-hover-corners" aria-hidden="true">
              <span class="hc tl"></span><span class="hc tr"></span>
              <span class="hc bl"></span><span class="hc br"></span>
            </div>
          </article>

          <!-- Block 02: Long description -->
          {route.longDescription && (
            <article class="det-block" data-reveal>
              <header class="det-block-head">
                <span class="det-block-num">02</span>
                <div class="det-block-divider"></div>
                <span class="det-block-eyebrow">[ The route ]</span>
              </header>
              <h2 class="det-block-title">About this itinerary</h2>
              <p class="det-lead">{route.longDescription[locale]}</p>
              <div class="det-hover-corners" aria-hidden="true">
                <span class="hc tl"></span><span class="hc tr"></span>
                <span class="hc bl"></span><span class="hc br"></span>
              </div>
            </article>
          )}

          <!-- Block 03: Highlights timeline -->
          {route.highlights.length > 0 && (
            <article class="det-block" data-reveal>
              <header class="det-block-head">
                <span class="det-block-num">{route.longDescription ? '03' : '02'}</span>
                <div class="det-block-divider"></div>
                <span class="det-block-eyebrow">[ Itinerary ]</span>
              </header>
              <h2 class="det-block-title">Route highlights</h2>
              <div class="rut-timeline">
                {route.highlights.map((hl, i) => (
                  <div class="rut-tl-item" style={`--ti: ${i}`}>
                    <span class="rut-tl-marker" aria-hidden="true">
                      <span class="rut-tl-num">{(i + 1).toString().padStart(2, '0')}</span>
                    </span>
                    <p class="rut-tl-title">{hl.title[locale]}</p>
                    <p class="rut-tl-desc">{hl.description[locale]}</p>
                  </div>
                ))}
              </div>
              <div class="det-hover-corners" aria-hidden="true">
                <span class="hc tl"></span><span class="hc tr"></span>
                <span class="hc bl"></span><span class="hc br"></span>
              </div>
            </article>
          )}

          <!-- Block 04: Tips grid -->
          {route.tips.length > 0 && (
            <article class="det-block" data-reveal>
              <header class="det-block-head">
                <span class="det-block-num">0{route.highlights.length > 0 ? (route.longDescription ? 4 : 3) : (route.longDescription ? 3 : 2)}</span>
                <div class="det-block-divider"></div>
                <span class="det-block-eyebrow">[ Local advice ]</span>
              </header>
              <h2 class="det-block-title">Practical tips</h2>
              <div class="rut-tips-grid">
                {route.tips.map((tip, i) => (
                  <div class="rut-tip-card" style={`--tc: ${i}`}>
                    <p class="rut-tip-title">{tip.title[locale]}</p>
                    <p class="rut-tip-text">{tip.content[locale]}</p>
                  </div>
                ))}
              </div>
              <div class="det-hover-corners" aria-hidden="true">
                <span class="hc tl"></span><span class="hc tr"></span>
                <span class="hc bl"></span><span class="hc br"></span>
              </div>
            </article>
          )}

          <!-- Block 05: What to bring -->
          {route.whatToBring && route.whatToBring[locale]?.length > 0 && (
            <article class="det-block" data-reveal>
              <header class="det-block-head">
                <span class="det-block-num">—</span>
                <div class="det-block-divider"></div>
                <span class="det-block-eyebrow">[ Kit ]</span>
              </header>
              <h2 class="det-block-title">{t('detail.whatToBring')}</h2>
              <ul class="rut-bring-list" role="list">
                {route.whatToBring[locale]?.map((item) => (
                  <li class="rut-bring-item">
                    <span class="rut-bring-check" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                      </svg>
                    </span>
                    {item}
                  </li>
                ))}
              </ul>
              <div class="det-hover-corners" aria-hidden="true">
                <span class="hc tl"></span><span class="hc tr"></span>
                <span class="hc bl"></span><span class="hc br"></span>
              </div>
            </article>
          )}

          <!-- Tags -->
          {route.tags.length > 0 && (
            <div class="det-tags" data-reveal>
              <span class="det-tags-eyebrow">[ {t('detail.tags')} ]</span>
              <div class="det-tags-flow">
                {route.tags.map((tag, i) => (
                  <span class="det-tag-pill" style={`--ti: ${i}`}>#{tag}</span>
                ))}
              </div>
            </div>
          )}

        </main>

        <!-- SIDEBAR (30%) -->
        <aside>
          <div class="det-sidebar-sticky">

            <!-- Info card -->
            <div class="det-sidebar-card" data-reveal>
              <div class="det-sc-head">
                <span class="det-sc-eyebrow">[ Route info ]</span>
                <div class="det-sc-line"></div>
              </div>

              <div class="det-info-row">
                <span class="det-info-label">{t('detail.difficulty')}</span>
                <div class="rut-sb-diff" style={`--dc: ${diffColor}`}>
                  <div class="rut-sb-bars">
                    {[1,2,3].map(n => (
                      <span class:list={['rut-sb-bar', n <= diffBars && 'active']}></span>
                    ))}
                  </div>
                  <span class="rut-sb-diff-label">{t(`difficulty.${route.difficulty}`)}</span>
                </div>
              </div>
              <div class="det-info-sep"></div>

              <div class="det-info-row">
                <span class="det-info-label">{t('detail.duration')}</span>
                <span class="det-info-val">{formatDuration(route.duration, locale)}</span>
              </div>
              <div class="det-info-sep"></div>

              <div class="det-info-row">
                <span class="det-info-label">{t('detail.distance')}</span>
                <span class="det-info-val">{formatDistance(route.distance, locale)}</span>
              </div>
              <div class="det-info-sep"></div>

              <div class="det-info-row">
                <span class="det-info-label">{t('detail.bestTime')}</span>
                <span class="det-info-val">{t(`timeOfDay.${route.timeOfDay}`)}</span>
              </div>
              <div class="det-info-sep"></div>

              <div class="det-info-row">
                <span class="det-info-label">{t('detail.neighborhoods')}</span>
                <div class="rut-neigh-flow" style="justify-content: flex-end;">
                  {route.neighborhoods.map(n => (
                    <span class="rut-neigh-pill">{t(`neighborhoods.${n}`)}</span>
                  ))}
                </div>
              </div>

              {route.bestMonths && route.bestMonths.length > 0 && (
                <>
                  <div class="det-info-sep"></div>
                  <div class="det-info-row">
                    <span class="det-info-label">{t('detail.bestMonths')}</span>
                    <div class="rut-months-flow" style="justify-content: flex-end;">
                      {route.bestMonths.map(m => (
                        <span class="rut-month-tag">{m}</span>
                      ))}
                    </div>
                  </div>
                </>
              )}

              <button
                id="share-btn"
                class="rut-btn-share"
                data-title={route.title[locale]}
                data-url={Astro.url.href}
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
                </svg>
                <span class="share-label" aria-live="polite">Share route</span>
              </button>
            </div>

            <!-- Related routes -->
            {relatedRoutes.length > 0 && (
              <div class="det-sidebar-card" data-reveal>
                <div class="det-sc-head">
                  <span class="det-sc-eyebrow">[ {t('detail.similarRoutes')} ]</span>
                  <div class="det-sc-line"></div>
                </div>
                <div class="det-related-list">
                  {relatedRoutes.map((rel, i) => (
                    <a
                      href={`/en/routes/${rel.slug}`}
                      class="det-related-item"
                      style={`--ri: ${i}`}
                      aria-label={rel.title[locale]}
                    >
                      <div class="det-rel-thumb">
                        {(rel.imageUrl || rel.image) ? (
                          <OptimizedImage src={rel.imageUrl || rel.image} alt="" loading="lazy" sizes="(max-width: 640px) 100vw, 280px" />
                        ) : (
                          <div class="det-rel-thumb-fallback">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                              <path d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.447-.894L15 7m0 13V7"/>
                            </svg>
                          </div>
                        )}
                        <div class="det-rel-thumb-overlay"></div>
                      </div>
                      <div class="det-rel-info">
                        <span class="det-rel-title">{rel.title[locale]}</span>
                        <span class="det-rel-meta">{formatDuration(rel.duration, locale)} · {t(`difficulty.${rel.difficulty}`)}</span>
                      </div>
                      <svg class="det-rel-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  ))}
                </div>
                <a href="/en/routes" class="det-all-link">
                  {t('detail.allRoutes')}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </div>
            )}

          </div>
        </aside>

      </div>
    </div>

    <!-- Footer ornament -->
    <div class="det-footer-orn" aria-hidden="true">
      <span class="det-orn-line"></span>
      <span class="det-orn-diamond"></span>
      <span class="det-orn-star">
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17.2l-6.2 4.1 2.4-7.4L2 9.4h7.6z"/>
        </svg>
      </span>
      <span class="det-orn-diamond"></span>
      <span class="det-orn-line"></span>
    </div>

  </div>
  </RouteDetailContent>

</BaseLayout>

<script is:inline>
  (function () {
    const btn = document.getElementById('share-btn');
    if (!btn) return;
    btn.addEventListener('click', async function () {
      const title = btn.dataset.title;
      const url   = btn.dataset.url;
      const label = btn.querySelector('.share-label');
      if (navigator.share) {
        try { await navigator.share({ title, text: 'Discover the route "' + title + '" on GRN INDEX', url }); return; }
        catch (_) {}
      }
      try {
        await navigator.clipboard.writeText(url ?? '');
        if (label) {
          const orig = label.textContent;
          label.textContent = 'Link copied!';
          setTimeout(() => { label.textContent = orig; }, 2000);
        }
      } catch (_) {}
    });
  })();
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const io = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } }),
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('[data-reveal]').forEach(el => io.observe(el));
  });
</script>

---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/layout/PageHeader.astro';
import RouteCard from '@components/routes/RouteCard.astro';
import { getAllRoutes } from '@data';
import { useTranslations } from '@i18n/utils';
import type { RouteCategory, RouteDifficulty, TimeOfDay } from '@types';

const locale = 'en';
const t = useTranslations(locale);
const routes = getAllRoutes();

const categories: RouteCategory[] = ['viewpoint', 'tapas', 'monuments', 'hiking', 'photography', 'secrets', 'history', 'flamenco'];
const difficulties: RouteDifficulty[] = ['easy', 'moderate', 'challenging'];
const timeOfDayOptions: TimeOfDay[] = ['morning', 'afternoon', 'sunset', 'evening'];

const difficultyColors = {
  easy: { bg: 'bg-mint/15', text: 'text-mint', border: 'border-mint/30' },
  moderate: { bg: 'bg-amber/15', text: 'text-amber', border: 'border-amber/30' },
  challenging: { bg: 'bg-terra/15', text: 'text-terra', border: 'border-terra/30' },
};

const ogImage = 'https://placehold.co/1200x630/F5A623/0F0E0C?text=Granada+Vibes+Routes';
---

<BaseLayout 
  locale={locale} 
  title={t('routes.title')}
  description="Guided routes through Granada: Albaicín viewpoints, traditional tapas with free tapas, hiking along the Darro and Realejo secrets. Original plans created by locals."
  ogImage={ogImage}
>
  <!-- Page Header -->
  <PageHeader
    title={t('routes.title')}
    subtitle={t('routes.subtitle')}
    accent="secondary"
  />

  <!-- Mixed Routes CTA Banner -->
  <section class="relative bg-base-elevated/50 border-b border-edge overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-terra/[0.03] via-transparent to-amber/[0.03]" aria-hidden="true"></div>

    <div class="container relative py-10 lg:py-12">
      <a
        href="/en/routes/by-time"
        class="group flex flex-col md:flex-row items-start md:items-center justify-between gap-6 p-6 lg:p-8 bg-base-card/40 border border-edge rounded-2xl hover:border-terra/30 hover:bg-base-card/60 transition-all duration-500 hover:-translate-y-0.5"
      >
        <div class="flex items-center gap-5">
          <div class="w-14 h-14 rounded-2xl bg-terra/10 border border-terra/20 flex items-center justify-center shrink-0">
            <svg class="w-7 h-7 text-terra" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <h3 class="font-display text-xl lg:text-2xl font-semibold text-surface mb-1 group-hover:text-terra transition-colors">
              {t('mixedRoutes.sectionTitle')}
            </h3>
            <p class="text-sm text-surface-secondary max-w-lg">
              {t('mixedRoutes.subtitle')}
            </p>
          </div>
        </div>

        <div class="flex items-center gap-4 shrink-0">
          <div class="hidden lg:flex items-center gap-2">
            {['2h', '6h', '12h', '1d', '2d', '3d'].map((label) => (
              <span class="px-3 py-1.5 text-xs font-bold text-surface-muted bg-base-card border border-edge rounded-lg">
                {label}
              </span>
            ))}
          </div>
          <div class="w-10 h-10 rounded-full bg-terra/10 border border-terra/20 flex items-center justify-center group-hover:bg-terra/20 transition-colors">
            <svg class="w-5 h-5 text-terra group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </div>
      </a>
    </div>
  </section>

  {/* Filters Bar - Dark theme */}
  <div class="relative border-y border-edge bg-base-elevated/80 backdrop-blur-sm">
    <div class="absolute inset-0 bg-gradient-to-r from-amber/[0.03] via-transparent to-amber/[0.03]" aria-hidden="true"></div>
    
    <div class="container relative py-6 lg:py-8">
      {/* Row 1 - Category chips */}
      <div class="flex flex-wrap items-center gap-2 mb-6" role="group" aria-label="Filter by category">
        <button 
          class="filter-category px-5 py-2.5 text-xs font-bold uppercase tracking-wider bg-terra text-base rounded-full transition-all duration-300 hover:shadow-lg hover:shadow-amber/30"
          data-category="all"
          aria-pressed="true"
        >
          {t('categories.all')}
        </button>
        {categories.map((cat) => (
          <button 
            class="filter-category px-5 py-2.5 text-xs font-bold uppercase tracking-wider text-surface-secondary bg-base-card border border-edge rounded-full hover:border-amber/50 hover:text-surface transition-all duration-300"
            data-category={cat}
            aria-pressed="false"
          >
            {t(`categories.${cat}`)}
          </button>
        ))}
      </div>

      {/* Row 2 - Secondary filters */}
      <div class="flex flex-wrap items-center gap-4 pt-6 border-t border-edge">
        {/* Difficulty chips */}
        <div class="flex items-center gap-2 flex-wrap">
          <span class="text-sm text-surface-muted mr-1 font-medium">Difficulty:</span>
          <button 
            class="filter-difficulty px-4 py-2 text-xs font-bold rounded-full border transition-all duration-300 bg-terra text-base border-amber shadow-lg shadow-amber/20"
            data-difficulty="all"
            aria-pressed="true"
          >
            All
          </button>
          {difficulties.map((diff) => (
            <button 
              class:list={[
                'filter-difficulty px-4 py-2 text-xs font-bold rounded-full border transition-all duration-300 hover:scale-105',
                difficultyColors[diff].bg,
                difficultyColors[diff].text,
                difficultyColors[diff].border
              ]}
              data-difficulty={diff}
              aria-pressed="false"
            >
              {t(`difficulty.${diff}`)}
            </button>
          ))}
        </div>

        {/* Duration Dropdown */}
        <div class="relative group">
          <select 
            id="filter-duration"
            class="appearance-none px-5 py-2.5 pr-12 text-sm text-surface bg-base-card border border-edge rounded-xl focus:outline-none focus:border-amber cursor-pointer transition-all duration-300 hover:border-edge-hover min-w-[160px]"
            aria-label="Filter by duration"
          >
            <option value="all">Any duration</option>
            <option value="short">Less than 2h</option>
            <option value="medium">2-4h</option>
            <option value="long">More than 4h</option>
          </select>
          <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-surface-muted pointer-events-none transition-colors group-hover:text-amber" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>

        {/* Best time Dropdown */}
        <div class="relative group">
          <select 
            id="filter-time"
            class="appearance-none px-5 py-2.5 pr-12 text-sm text-surface bg-base-card border border-edge rounded-xl focus:outline-none focus:border-amber cursor-pointer transition-all duration-300 hover:border-edge-hover min-w-[160px]"
            aria-label="Filter by best time"
          >
            <option value="all">Any time</option>
            {timeOfDayOptions.map((time) => (
              <option value={time}>{t(`timeOfDay.${time}`)}</option>
            ))}
          </select>
          <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-surface-muted pointer-events-none transition-colors group-hover:text-amber" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>

        <div class="flex-1"></div>

        {/* Clear filters button (hidden by default) */}
        <button 
          id="clear-filters"
          class="hidden items-center gap-2 px-5 py-2.5 text-sm text-surface-muted hover:text-amber transition-all duration-300 rounded-xl hover:bg-base-card font-medium"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
          Clear filters
        </button>
      </div>
    </div>
  </div>

  {/* Results counter */}
  <div class="container py-6">
    <div class="flex items-center gap-2 text-sm text-surface-muted">
      <span class="w-2 h-2 rounded-full bg-amber animate-pulse"></span>
      Showing <span id="results-count" class="font-bold text-surface">{routes.length}</span> routes
    </div>
  </div>

  {/* Routes Grid */}
  <section class="container pb-20" aria-labelledby="routes-heading">
    <h2 id="routes-heading" class="sr-only">{t('routes.title')}</h2>
    
    <div id="routes-grid" class="grid grid-cols-1 lg:grid-cols-2 gap-6 stagger-children">
      {routes.map((route, index) => (
        <div 
          class="route-card-wrapper reveal"
          data-category={route.category}
          data-difficulty={route.difficulty}
          data-duration={route.duration}
          data-time={route.timeOfDay}
          data-featured={route.featured ? 'true' : 'false'}
        >
          <RouteCard route={route} locale={locale} t={t} variant="grid" index={index} />
        </div>
      ))}
    </div>
    
    {/* Empty state */}
    <div id="empty-state" class="hidden text-center py-24">
      <div class="relative w-24 h-24 mx-auto mb-8">
        <div class="absolute inset-0 bg-amber/20 rounded-3xl blur-xl"></div>
        <div class="relative w-full h-full bg-base-card border border-edge rounded-3xl flex items-center justify-center">
          <svg class="w-12 h-12 text-surface-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0121 18.382V7.618a1 1 0 01-.447-.894L15 7m0 13V7" />
          </svg>
        </div>
      </div>
      <h3 class="font-display text-2xl font-semibold text-surface mb-3">
        No routes for these filters
      </h3>
      <p class="text-surface-secondary mb-8 max-w-md mx-auto">Try changing the filters or view all available routes in Granada</p>
      <button 
        id="empty-clear-filters"
        class="inline-flex items-center gap-2 px-6 py-3 bg-terra text-base font-semibold text-sm rounded-xl transition-all duration-300 hover:shadow-[0_4px_20px_rgba(232,158,58,0.25)] hover:-translate-y-0.5"
      >
        Clear filters
      </button>
    </div>
  </section>

  <script is:inline>
    (function() {
      const categoryButtons = document.querySelectorAll('.filter-category');
      const difficultyButtons = document.querySelectorAll('.filter-difficulty');
      const durationSelect = document.getElementById('filter-duration');
      const timeSelect = document.getElementById('filter-time');
      const clearFiltersBtn = document.getElementById('clear-filters');
      const emptyClearFiltersBtn = document.getElementById('empty-clear-filters');
      const resultsCount = document.getElementById('results-count');
      const emptyState = document.getElementById('empty-state');
      const routesGrid = document.getElementById('routes-grid');
      const routeCards = document.querySelectorAll('.route-card-wrapper');

      const difficultyColors = {
        easy: { bg: 'bg-mint/15', text: 'text-mint', border: 'border-mint/30' },
        moderate: { bg: 'bg-amber/15', text: 'text-amber', border: 'border-amber/30' },
        challenging: { bg: 'bg-terra/15', text: 'text-terra', border: 'border-terra/30' },
      };

      let filters = {
        category: 'all',
        difficulty: 'all',
        duration: 'all',
        time: 'all'
      };

      function matchesDurationFilter(routeDuration, filter) {
        if (filter === 'all') return true;
        const durationHours = routeDuration / 60;
        
        switch (filter) {
          case 'short':
            return durationHours < 2;
          case 'medium':
            return durationHours >= 2 && durationHours <= 4;
          case 'long':
            return durationHours > 4;
          default:
            return true;
        }
      }

      function applyFilters() {
        let visibleCount = 0;
        
        routeCards.forEach(card => {
          const category = card.dataset.category;
          const difficulty = card.dataset.difficulty;
          const duration = parseInt(card.dataset.duration, 10);
          const time = card.dataset.time;
          
          const matchesCategory = filters.category === 'all' || category === filters.category;
          const matchesDifficulty = filters.difficulty === 'all' || difficulty === filters.difficulty;
          const matchesDuration = matchesDurationFilter(duration, filters.duration);
          const matchesTime = filters.time === 'all' || time === filters.time;
          
          const isVisible = matchesCategory && matchesDifficulty && matchesDuration && matchesTime;
          
          if (isVisible) {
            card.style.display = '';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });
        
        resultsCount.textContent = visibleCount;
        
        if (visibleCount === 0) {
          routesGrid.classList.add('hidden');
          emptyState.classList.remove('hidden');
        } else {
          routesGrid.classList.remove('hidden');
          emptyState.classList.add('hidden');
        }
        
        const hasActiveFilters = filters.category !== 'all' || 
                                 filters.difficulty !== 'all' || 
                                 filters.duration !== 'all' || 
                                 filters.time !== 'all';
        
        if (hasActiveFilters) {
          clearFiltersBtn.classList.remove('hidden');
          clearFiltersBtn.classList.add('inline-flex');
        } else {
          clearFiltersBtn.classList.add('hidden');
          clearFiltersBtn.classList.remove('inline-flex');
        }
      }

      categoryButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          categoryButtons.forEach(b => {
            b.classList.remove('bg-amber', 'text-base', 'shadow-lg');
            b.classList.add('text-surface-secondary', 'bg-base-card', 'border', 'border-edge');
            b.setAttribute('aria-pressed', 'false');
          });
          btn.classList.remove('text-surface-secondary', 'bg-base-card', 'border', 'border-edge');
          btn.classList.add('bg-amber', 'text-base', 'shadow-lg');
          btn.setAttribute('aria-pressed', 'true');
          
          filters.category = btn.dataset.category;
          applyFilters();
        });
      });

      difficultyButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          const difficulty = btn.dataset.difficulty;
          
          difficultyButtons.forEach(b => {
            const diff = b.dataset.difficulty;
            b.setAttribute('aria-pressed', 'false');
            
            if (diff === 'all') {
              b.className = 'filter-difficulty px-4 py-2 text-xs font-bold rounded-full border transition-all duration-300 bg-terra text-base border-amber shadow-lg shadow-amber/20';
            } else {
              b.className = `filter-difficulty px-4 py-2 text-xs font-bold rounded-full border transition-all duration-300 hover:scale-105 ${difficultyColors[diff].bg} ${difficultyColors[diff].text} ${difficultyColors[diff].border}`;
            }
          });
          
          btn.setAttribute('aria-pressed', 'true');
          btn.className = 'filter-difficulty px-4 py-2 text-xs font-bold rounded-full border transition-all duration-300 bg-terra text-base border-amber shadow-lg shadow-amber/20';
          
          filters.difficulty = difficulty;
          applyFilters();
        });
      });

      durationSelect?.addEventListener('change', (e) => {
        filters.duration = e.target.value;
        applyFilters();
      });

      timeSelect?.addEventListener('change', (e) => {
        filters.time = e.target.value;
        applyFilters();
      });

      function clearFilters() {
        filters = {
          category: 'all',
          difficulty: 'all',
          duration: 'all',
          time: 'all'
        };
        
        categoryButtons.forEach(b => {
          if (b.dataset.category === 'all') {
            b.classList.remove('text-surface-secondary', 'bg-base-card', 'border', 'border-edge');
            b.classList.add('bg-amber', 'text-base', 'shadow-lg');
            b.setAttribute('aria-pressed', 'true');
          } else {
            b.classList.remove('bg-amber', 'text-base', 'shadow-lg');
            b.classList.add('text-surface-secondary', 'bg-base-card', 'border', 'border-edge');
            b.setAttribute('aria-pressed', 'false');
          }
        });
        
        difficultyButtons.forEach(b => {
          const diff = b.dataset.difficulty;
          if (diff === 'all') {
            b.className = 'filter-difficulty px-4 py-2 text-xs font-bold rounded-full border transition-all duration-300 bg-terra text-base border-amber shadow-lg shadow-amber/20';
            b.setAttribute('aria-pressed', 'true');
          } else {
            b.className = `filter-difficulty px-4 py-2 text-xs font-bold rounded-full border transition-all duration-300 hover:scale-105 ${difficultyColors[diff].bg} ${difficultyColors[diff].text} ${difficultyColors[diff].border}`;
            b.setAttribute('aria-pressed', 'false');
          }
        });
        
        durationSelect.value = 'all';
        timeSelect.value = 'all';
        
        applyFilters();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }

      clearFiltersBtn?.addEventListener('click', clearFilters);
      emptyClearFiltersBtn?.addEventListener('click', clearFilters);
    })();
  </script>
</BaseLayout>

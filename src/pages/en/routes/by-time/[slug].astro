---
import MixedRouteDetailPage from '@components/pages/MixedRouteDetailPage.astro';
import { getAllMixedRoutes } from '@data';
import type { MixedRoute } from '@types';

export function getStaticPaths() {
  const plans = getAllMixedRoutes();
  return plans.map((plan) => ({
    params: { slug: plan.slug },
    props: { plan },
  }));
}

interface Props {
  plan: MixedRoute;
}

const { plan } = Astro.props;
---

<MixedRouteDetailPage locale="en" plan={plan} />

---
import BaseLayout from '@layouts/BaseLayout.astro';
import { useTranslations } from '@i18n/utils';
import { getRoute } from '@utils/routes';

const locale = 'es';
const t = useTranslations(locale);
---

<BaseLayout 
  locale={locale} 
  title={t('legalPages.privacySeoTitle')}
  description={t('legalPages.privacySeoDescription')}
  noindex={true}
>
  <section class="container pt-32 pb-20">
    <div class="max-w-2xl mx-auto">
      {/* Back link */}
      <a href={getRoute('home', locale)} class="inline-flex items-center gap-2 text-surface-muted hover:text-terra transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        {t('legalPages.backLink')}
      </a>

      <h1 class="font-display text-4xl lg:text-5xl font-bold text-surface mb-6">
        {t('legalPages.privacyTitle')}
      </h1>
      
      <div class="prose prose-invert prose-lg max-w-none">
        <p class="text-surface-secondary leading-relaxed">
          {t('legalPages.privacyIntro')}
        </p>
        
        <p class="text-surface-secondary leading-relaxed mt-4">
          {t('legalPages.privacyContact')} <a href="mailto:info@granadaurban.com" class="text-terra hover:underline">info@granadaurban.com</a>.
        </p>
      </div>

      {/* Last updated */}
      <p class="text-surface-muted text-sm mt-12">
        {t('legalPages.lastUpdated')}
      </p>
    </div>
  </section>
</BaseLayout>

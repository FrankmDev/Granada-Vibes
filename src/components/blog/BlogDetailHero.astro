---
/**
 * BlogDetailHero — v14 "ALHAMBRA SPREAD · Calibrated"
 *
 * Editorial magazine-cover spread for individual guides.
 *  - Cover image on the LEFT with cinematic treatment
 *    (corner brackets, vignette, glare, stamp, glow, shadow)
 *  - Editorial lockup on the RIGHT
 *    (eyebrow + meta badges + huge title with hanging-indent focal + lead)
 *  - No data dock, no ghost label
 *  - Minimal bottom bar (category · VOL. I · coords)
 *
 * Geometry: hero is exactly 100svh - 72px (NavBar). Content must fit.
 * Aligned with GRN URBAN "Alhambra Noir" — global tokens only.
 * Title uses Fraunces Thin (100) + ExtraLight italic (200) for editorial weight.
 * `text-wrap: pretty` prevents mid-word breaks.
 * Reduced-motion safe.
 */
import type { BlogPost, Locale } from '@types';
import { useTranslations } from '@i18n/utils';
import ScreenFrame from '@components/ui/ScreenFrame.astro';
import OptimizedImage from '@components/ui/OptimizedImage.astro';

interface Props {
  post: BlogPost;
  locale: Locale;
  readingMinutes: number;
  sectionCount: number;
  displayTitle?: string;
}

const {
  post,
  locale,
  readingMinutes,
  sectionCount,
  displayTitle = post.title[locale],
} = Astro.props;
const t = useTranslations(locale);

const guidesIndexUrl = locale === 'es' ? '/guias/' : '/en/guides/';
const backLabel = t('detail.backToGuides');
const catLabel = t(`blog.categories.${post.category}`).toUpperCase();
const catLabelRaw = t(`blog.categories.${post.category}`);
const featuredLabel = post.featured ? t('routes.featured').toUpperCase() : null;

const idMatch = post.id.match(/(\d+)/);
const archiveRef = idMatch?.[1]?.padStart(3, '0') ?? '000';

const coordinates = t('detail.coordinates');
const refCode = `GD / ${archiveRef} · ${new Date().getFullYear()}`;

const eyebrowText = `${t('home.cta.vol').split(' · ')[0] ?? 'EDICIÓN'} · ${t('detail.guideLabel').toUpperCase()}`;

const shortDesc = post.description[locale];
const descTrimmed = shortDesc.length > 220 ? `${shortDesc.slice(0, 220).trim()}…` : shortDesc;

const titleWords = displayTitle.split(/\s+/).filter(Boolean);
const skipWords = new Set([
  'el', 'la', 'las', 'los', 'un', 'una', 'unos', 'unas',
  'de', 'del', 'en', 'a', 'al', 'por', 'para', 'con', 'sin',
  'sobre', 'tras', 'entre', 'y', 'o', 'u',
  'que', 'qué', 'como', 'cuál', 'cuáles', 'lo', 'le', 'les',
  'mi', 'tu', 'su', 'the', 'of', 'in', 'on', 'at', 'to', 'for',
  'with', 'and', 'or',
]);
const isSkip = (w: string | undefined): boolean => !w || w.length < 4 || skipWords.has(w.toLowerCase());
const isStrong = (w: string | undefined): boolean => !!w && w.length >= 5 && !skipWords.has(w.toLowerCase());

let titleLead = '';
let titleFocal = '';
if (titleWords.length <= 1) {
  titleLead = titleWords[0] ?? displayTitle;
} else if (titleWords.length === 2) {
  titleLead = titleWords[0] ?? '';
  titleFocal = titleWords[1] ?? '';
} else {
  const w0 = titleWords[0] ?? '';
  const w1 = titleWords[1] ?? '';
  if (isSkip(w0) && !isSkip(w1)) {
    titleLead = `${w0} ${w1}`;
    titleFocal = titleWords.slice(2).join(' ');
  } else if (isStrong(w0) && isStrong(w1)) {
    titleLead = `${w0} ${w1}`;
    titleFocal = titleWords.slice(2).join(' ');
  } else {
    titleLead = w0;
    titleFocal = titleWords.slice(1).join(' ');
  }
}

const leadSegments = titleLead.split(/(\s+)/).filter((s) => s.length > 0);
const focalSegments = titleFocal.split(/(\s+)/).filter((s) => s.length > 0);
let leadCharIndex = 0;
let focalCharIndex = 0;
const leadTokens = leadSegments.map((seg) => {
  if (/^\s+$/.test(seg)) {
    leadCharIndex += 1;
    return { kind: 'space' as const };
  }
  const chars = seg.split('').map((c) => {
    const d = 0.35 + leadCharIndex * 0.028;
    leadCharIndex += 1;
    return { char: c, delay: d };
  });
  return { kind: 'word' as const, chars };
});
const focalTokens = focalSegments.map((seg) => {
  if (/^\s+$/.test(seg)) {
    focalCharIndex += 1;
    return { kind: 'space' as const };
  }
  const chars = seg.split('').map((c) => {
    const d = 0.35 + (leadCharIndex + focalCharIndex) * 0.028;
    focalCharIndex += 1;
    return { char: c, delay: d };
  });
  return { kind: 'word' as const, chars };
});

const hasImage = !!post.image;
const imageAlt = `${displayTitle} — ${catLabelRaw}`;
---

<section class="bhero" aria-label={displayTitle} data-bhero>
  <!-- ScreenFrame -->
  <ScreenFrame
    tagTopLeft={`${t('detail.archiveTag')} · ${archiveRef}`}
    tagTopRight={catLabel}
    tagBottomLeft="GRN URBAN"
    tagBottomRight={coordinates}
  />

  <!-- Ambient canvas: 6 stacked layers for depth -->
  <div class="bhero-canvas" aria-hidden="true">
    <div class="bhero-mesh"></div>
    <div class="bhero-radial"></div>
    <div class="bhero-shaft"></div>
    <div class="bhero-grid"></div>
    <div class="bhero-vignette"></div>
    <div class="bhero-grain"></div>
  </div>

  <!-- Atmospheric decorative line + dot, no ghost label -->
  <div class="bhero-deco" aria-hidden="true">
    <span class="deco-ring r1"></span>
    <span class="deco-ring r2"></span>
    <span class="deco-line v1"></span>
    <span class="deco-line h1"></span>
    <span class="deco-dot d1"></span>
    <span class="deco-compass c1"></span>
    <span class="deco-axis a1"></span>
  </div>

  <!-- Nav scrim -->
  <div class="bhero-nav-scrim" aria-hidden="true"></div>

  <!-- Back link -->
  <a href={guidesIndexUrl} class="bhero-back">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M19 12H5M12 19l-7-7 7-7"/>
    </svg>
    <span>{backLabel}</span>
  </a>

  <!-- Archive REF badge -->
  <div class="bhero-ref" aria-hidden="true">
    <span class="ref-label">REF.</span>
    <span class="ref-num">{archiveRef}</span>
  </div>

  <!-- Main spread: image left, text right -->
  <div class="bhero-stage">
    <div class="bhero-spread">

      <!-- LEFT: Cover image with cinematic treatment -->
      <figure class="bhero-figure">
        <div class="bhero-figure-wrap">
          {hasImage ? (
            <OptimizedImage
              src={post.image as string}
              alt={imageAlt}
              class="bhero-img"
              loading="eager"
              decoding="async"
              fetchpriority="high"
              sizes="(max-width: 768px) 100vw, 38vw"
              width={900}
              height={1200}
            />
          ) : (
            <div class="bhero-img-fallback" aria-hidden="true">
              <svg viewBox="0 0 60 60" fill="none">
                <path d="M30 4 L34.5 22.5 L52 15 L39 28.5 L56 30 L39 31.5 L52 45 L34.5 37.5 L30 56 L25.5 37.5 L8 45 L21 31.5 L4 30 L21 28.5 L8 15 L25.5 22.5 Z"
                  stroke="var(--h-gold)" stroke-width="0.6" stroke-opacity="0.45" fill="none"/>
                <path d="M30 12 L32.5 24.5 L42 20 L36 28.5 L46 30 L36 31.5 L42 40 L32.5 35.5 L30 48 L27.5 35.5 L18 40 L24 31.5 L14 30 L24 28.5 L18 20 L27.5 24.5 Z"
                  fill="var(--h-gold)" fill-opacity="0.10" stroke="none"/>
              </svg>
            </div>
          )}
          <div class="bhero-figure-vignette" aria-hidden="true"></div>
          <div class="bhero-figure-glare" aria-hidden="true"></div>

          <!-- Corner brackets -->
          <span class="bracket tl" aria-hidden="true"></span>
          <span class="bracket tr" aria-hidden="true"></span>
          <span class="bracket bl" aria-hidden="true"></span>
          <span class="bracket br" aria-hidden="true"></span>

          <!-- Expedition stamp -->
          <div class="bhero-stamp" aria-hidden="true">
            <span class="stamp-prefix">{catLabel}</span>
            <span class="stamp-num">Nº {archiveRef}</span>
          </div>

          <!-- Featured ribbon -->
          {featuredLabel && (
            <div class="bhero-ribbon" aria-hidden="true">
              <svg viewBox="0 0 12 12" fill="currentColor">
                <path d="M6 0l1.5 4.5H12L8.5 7l1.5 5L6 9.5 2 12l1.5-5L0 4.5h4.5z" />
              </svg>
              <span>{featuredLabel}</span>
            </div>
          )}
        </div>

        <!-- Glow + shadow behind the figure -->
        <div class="bhero-figure-glow" aria-hidden="true"></div>
        <div class="bhero-figure-shadow" aria-hidden="true"></div>

        <!-- Caption below the image -->
        <figcaption class="bhero-caption">
          <span class="caption-line"></span>
          <span class="caption-text">{t('detail.archiveTag')} · {archiveRef} · {coordinates}</span>
        </figcaption>
      </figure>

      <!-- RIGHT: Editorial lockup -->
      <div class="bhero-text">
        <div class="lockup-rule" aria-hidden="true"></div>

        <!-- Eyebrow -->
        <div class="bhero-eyebrow">
          <span class="eyebrow-line"></span>
          <span class="eyebrow-text">
            {eyebrowText}
            <span class="eyebrow-slash">/</span>
            {catLabel}
          </span>
          <span class="eyebrow-line"></span>
        </div>

        <!-- Meta badges -->
        <div class="bhero-meta">
          <span class="bhero-cat">{catLabel}</span>
          {sectionCount > 0 && (
            <span class="bhero-sections">{t('detail.sectionCount', { count: sectionCount })}</span>
          )}
        </div>

        <!-- Huge title: lead + hanging italic focal (Thin/ExtraLight) -->
        <h1 class="bhero-title" style="text-wrap: pretty; word-break: normal; overflow-wrap: normal; hyphens: none;">
          <span class="bhero-title-aura" aria-hidden="true"></span>
          <span class="bhero-title-mark" aria-hidden="true"></span>
          <span class="bhero-title-lead">
            {leadTokens.map((tok) => (
              tok.kind === 'word' ? (
                <span class="bhero-word">
                  {tok.chars.map((c) => (
                    <span class="bhero-char" style={`--delay: ${c.delay}s`}>{c.char}</span>
                  ))}
                </span>
              ) : (
                <span class="bhero-space" aria-hidden="true">{'\u00A0'}</span>
              )
            ))}
          </span>
          {titleFocal && (
            <span class="bhero-title-focal">
              {focalTokens.map((tok) => (
                tok.kind === 'word' ? (
                  <span class="bhero-word">
                    {tok.chars.map((c) => (
                      <span class="bhero-char bhero-char--focal" style={`--delay: ${c.delay}s`}>{c.char}</span>
                    ))}
                  </span>
                ) : (
                  <span class="bhero-space bhero-space--focal" aria-hidden="true">{'\u00A0'}</span>
                )
              ))}
            </span>
          )}
        </h1>

        <!-- Lead description -->
        <p class="bhero-lead">
          <span class="lead-quote">“</span>
          {descTrimmed}
          <span class="lead-quote">”</span>
        </p>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="bhero-bottom-bar">
    <div class="bar-line"></div>
    <div class="bar-content">
      <span class="bar-item">{catLabel}</span>
      <span class="bar-diamond" aria-hidden="true">
        <svg viewBox="0 0 12 12" width="10" height="10"><polygon points="6,0 12,6 6,12 0,6" fill="var(--h-muted)"/></svg>
      </span>
      <span class="bar-item">VOL. I · 2026</span>
      <span class="bar-diamond" aria-hidden="true">
        <svg viewBox="0 0 12 12" width="10" height="10"><polygon points="6,0 12,6 6,12 0,6" fill="var(--h-muted)"/></svg>
      </span>
      <span class="bar-item">{coordinates}</span>
    </div>
    <div class="bar-line"></div>
  </div>

  <!-- Scroll indicator (mobile only) -->
  <div class="scroll-hint" aria-hidden="true">
    <div class="scroll-line"></div>
    <span class="scroll-text">{t('detail.scrollToRead')}</span>
  </div>
</section>

<style>
  /* ================================================================
     BlogDetailHero v14 — "Alhambra Spread · Calibrated"
     Image-left, text-right editorial magazine cover.
     Hero is exactly 100svh - 72px (NavBar) — content must fit.
     Title uses Fraunces Thin (100) + ExtraLight italic (200).
     ================================================================ */
  .bhero {
    --h-gold:     var(--color-gold);
    --h-gold-dim: var(--color-gold-dim);
    --h-orange:   var(--color-accent);
    --h-cream:    var(--color-text-primary);
    --h-muted:    rgba(240, 237, 232, 0.45);
    --ease-expo:  var(--ease-out-expo);

    position: relative;
    width: 100%;
    height: calc(100svh - 72px);
    min-height: 560px;
    margin-top: 72px;
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    contain: layout;
  }

  /* ---- ScreenFrame overrides — frame aligned to 1.5rem inset ---- */
  .bhero :global(.cin-screen-frame) {
    top: 1.5rem; left: 1.5rem; right: 1.5rem; bottom: 1.5rem;
    border-color: rgba(255, 255, 255, 0.07);
  }
  .bhero :global(.cin-corner::before),
  .bhero :global(.cin-corner::after) { background: var(--h-gold); opacity: 0.3; }
  .bhero :global(.cin-frame-tag) {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.55rem;
    letter-spacing: 0.2em;
  }

  /* ================================================================
     CANVAS — 6 atmospheric layers for real depth
     ================================================================ */
  .bhero-canvas { position: absolute; inset: 0; z-index: 1; pointer-events: none; overflow: hidden; }

  /* L1: Base color mesh — three radial gradients on deep neutral */
  .bhero-mesh {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 70% 50% at 78% 12%, rgba(201, 168, 76, 0.10) 0%, transparent 55%),
      radial-gradient(ellipse 55% 45% at 18% 88%, rgba(232, 98, 42, 0.07) 0%, transparent 50%),
      radial-gradient(ellipse 90% 60% at 50% 50%, rgba(201, 168, 76, 0.03) 0%, transparent 65%),
      var(--color-bg);
  }

  /* L2: Spotlight radial behind the text */
  .bhero-radial {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 35% 30% at 75% 45%, rgba(201, 168, 76, 0.12) 0%, transparent 60%),
      radial-gradient(ellipse 28% 22% at 20% 65%, rgba(232, 98, 42, 0.05) 0%, transparent 55%);
  }

  /* L3: Diagonal light shaft from upper-right */
  .bhero-shaft {
    position: absolute; inset: 0;
    background:
      linear-gradient(118deg, transparent 32%, rgba(201, 168, 76, 0.05) 42%, rgba(232, 98, 42, 0.025) 50%, transparent 62%),
      linear-gradient(118deg, transparent 60%, rgba(255, 255, 255, 0.018) 75%, transparent 92%);
    mix-blend-mode: screen;
    opacity: 0.85;
  }

  /* L4: Architectural grid (80px squares, masked to fade at edges) */
  .bhero-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.022) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.022) 1px, transparent 1px);
    background-size: 80px 80px;
    background-position: center;
    -webkit-mask-image: radial-gradient(ellipse 80% 75% at center, black 25%, transparent 85%);
    mask-image: radial-gradient(ellipse 80% 75% at center, black 25%, transparent 85%);
    opacity: 0.9;
  }

  /* L5: Vignette — corners darker to focus center */
  .bhero-vignette {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 110% 90% at center, transparent 55%, rgba(0, 0, 0, 0.55) 100%);
  }

  /* L6: Film grain */
  .bhero-grain {
    position: absolute; inset: 0;
    mix-blend-mode: soft-light;
    opacity: 0.06;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  /* ================================================================
     DECORATIVE LAYER (no ghost)
     ================================================================ */
  .bhero-deco { position: absolute; inset: 0; z-index: 2; pointer-events: none; overflow: hidden; }
  .deco-ring { position: absolute; border-radius: 50%; border: 1px solid var(--h-gold); opacity: 0; animation: deco-ring-in 2s var(--ease-expo) forwards; }
  .deco-ring.r1 { width: 320px; height: 320px; top: 12%; right: 8%; animation-delay: 0.4s; --target-opacity: 0.10; }
  .deco-ring.r2 { width: 520px; height: 520px; top: -8%; right: -4%; animation-delay: 0.7s; --target-opacity: 0.05; border-color: rgba(255, 255, 255, 0.12); }
  @keyframes deco-ring-in { from { opacity: 0; transform: scale(0.8); } to { opacity: var(--target-opacity, 0.1); transform: scale(1); } }
  .deco-line { position: absolute; background: linear-gradient(to bottom, transparent, rgba(255, 255, 255, 0.06) 20%, rgba(255, 255, 255, 0.06) 80%, transparent); }
  .deco-line.v1 { top: 0; left: 38%; width: 1px; height: 100%; }
  .deco-line.h1 { top: 30%; right: 0; width: 18%; height: 1px; background: linear-gradient(to left, transparent, rgba(255, 255, 255, 0.10) 30%, rgba(255, 255, 255, 0.10) 70%, transparent); }
  .deco-dot { position: absolute; border-radius: 50%; animation: ev-float 7s ease-in-out infinite; }
  .deco-dot.d1 { width: 140px; height: 140px; top: 65%; left: 4%; background: radial-gradient(circle, rgba(201, 168, 76, 0.20), transparent 70%); animation-duration: 9s; }
  @keyframes ev-float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }
  .deco-compass {
    position: absolute;
    width: clamp(160px, 18vw, 280px);
    aspect-ratio: 1;
    right: clamp(3rem, 8vw, 8rem);
    bottom: clamp(4rem, 10vh, 7rem);
    opacity: 0;
    transform: rotate(22deg) scale(0.9);
    animation: compass-in 1.8s var(--ease-expo) 0.85s forwards;
  }
  .deco-compass::before,
  .deco-compass::after {
    content: "";
    position: absolute;
    inset: 16%;
    border: 1px solid rgba(201, 168, 76, 0.18);
    transform: rotate(45deg);
  }
  .deco-compass::after {
    inset: 31%;
    border-color: rgba(240, 237, 232, 0.08);
    transform: rotate(0deg);
  }
  .deco-axis {
    position: absolute;
    width: clamp(80px, 10vw, 150px);
    height: 1px;
    right: clamp(2.5rem, 7vw, 7rem);
    bottom: clamp(3.5rem, 8vh, 6rem);
    background: linear-gradient(90deg, transparent, rgba(201, 168, 76, 0.42), transparent);
    opacity: 0;
    transform: rotate(-18deg) scaleX(0.35);
    transform-origin: center;
    animation: axis-in 1.4s var(--ease-expo) 1.05s forwards;
  }
  .deco-axis::before,
  .deco-axis::after {
    content: "";
    position: absolute;
    top: -4px;
    width: 9px;
    height: 9px;
    border: 1px solid rgba(201, 168, 76, 0.34);
    transform: rotate(45deg);
  }
  .deco-axis::before { left: 8%; }
  .deco-axis::after { right: 8%; }
  @keyframes compass-in { to { opacity: 0.42; transform: rotate(0deg) scale(1); } }
  @keyframes axis-in { to { opacity: 1; transform: rotate(-18deg) scaleX(1); } }

  /* ---- NAV SCRIM ---- */
  .bhero-nav-scrim { position: absolute; top: 0; left: 0; right: 0; height: 160px; background: linear-gradient(180deg, rgba(0, 0, 0, 0.70) 0%, rgba(0, 0, 0, 0.20) 60%, transparent 100%); pointer-events: none; z-index: 5; }

  /* ---- BACK LINK — inside the frame's safe area (2.25rem) ---- */
  .bhero-back {
    position: absolute; top: 2.25rem; left: 2.25rem; z-index: 30;
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-family: var(--font-display); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(240, 237, 232, 0.85); text-decoration: none;
    padding: 0.55rem 1rem; border-radius: 100px;
    background: rgba(0, 0, 0, 0.45); backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.14);
    transition: all 0.3s ease;
    opacity: 0; animation: fadeInUp 0.8s ease 0.2s both;
  }
  .bhero-back svg { transition: transform 0.25s ease; }
  .bhero-back:hover { background: rgba(201, 168, 76, 0.15); border-color: rgba(201, 168, 76, 0.3); transform: translateY(-1px); }
  .bhero-back:hover svg { transform: translateX(-3px); }

  /* ---- ARCHIVE REF — mirrored to back link position ---- */
  .bhero-ref {
    position: absolute; top: 2.25rem; right: 2.25rem; z-index: 30;
    display: flex; align-items: center; gap: 0.35rem;
    font-family: var(--font-display); font-size: 0.6rem; font-weight: 700; letter-spacing: 0.15em;
    color: rgba(240, 237, 232, 0.5);
    opacity: 0; animation: fadeInUp 0.8s ease 0.3s both;
  }
  .ref-label { text-transform: uppercase; }
  .ref-num { color: var(--h-gold); font-weight: 800; }

  /* ================================================================
     STAGE — flex column, allows children to shrink
     Top padding 4.5rem keeps the image below the back-link area.
     ================================================================ */
  .bhero-stage {
    position: relative; z-index: 10;
    flex: 1 1 auto;
    min-height: 0;
    display: flex; align-items: center;
    max-width: 1480px; margin: 0 auto; width: 100%;
    padding: 4.5rem clamp(2.25rem, 5vw, 3.5rem) 1.5rem;
  }

  /* ================================================================
     SPREAD: 38fr / 62fr (image left, text right)
     align-items: center keeps both columns visually balanced.
     ================================================================ */
  .bhero-spread {
    display: grid;
    grid-template-columns: 38fr 62fr;
    gap: clamp(2rem, 4.5vw, 4rem);
    align-items: center;
    width: 100%;
    height: 100%;
    min-height: 0;
  }

  /* ============================
     LEFT — COVER IMAGE
     ============================ */
  .bhero-figure {
    position: relative;
    margin: 0;
    display: flex; flex-direction: column; align-items: stretch; gap: 0.85rem;
    min-height: 0;
    opacity: 0; transform: translateX(-30px) rotate(-1deg);
    animation: figure-enter 1.4s var(--ease-expo) 0.4s forwards;
  }
  @keyframes figure-enter {
    to { opacity: 1; transform: translateX(0) rotate(0deg); }
  }

  .bhero-figure-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    max-height: calc(100svh - 220px);
    align-self: center;
    overflow: hidden;
    border-radius: 14px;
    background: #14110d;
    box-shadow:
      0 40px 80px rgba(0, 0, 0, 0.55),
      0 16px 32px rgba(0, 0, 0, 0.35),

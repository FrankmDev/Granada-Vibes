---
/**
 * BlogDetailHero — cinematic hero for blog post detail pages.
 * Thin wrapper of CinematicHero with blog-specific dock: reading time | author | date | category.
 */
import type { BlogPost, Locale } from '@types';
import { useTranslations } from '../../i18n/utils';
import CinematicHero from '@components/shared/CinematicHero.astro';

interface Props {
  post: BlogPost;
  locale: Locale;
  formattedDate: string;
}

const { post, locale, formattedDate } = Astro.props;
const t = useTranslations(locale);

const year = new Date(post.publishDate).getFullYear();
// Derive a stable 3-digit code from the slug if id is non-numeric
const numericId = parseInt(post.id, 10);
const refNum = isNaN(numericId)
  ? post.slug.split('').reduce((acc, c) => acc + c.charCodeAt(0), 0) % 1000
  : numericId;
const refCode = `BLOG / ${refNum.toString().padStart(3, '0')} · ${year}`;

const backHref   = locale === 'es' ? '/blog' : '/en/blog';
const backLabel  = locale === 'es' ? 'Blog' : 'Blog';
const catLabel   = t(`blog.categories.${post.category}`).toUpperCase();
const dockLabel  = locale === 'es' ? 'Información del artículo' : 'Article information';
const description = post.description[locale];

const readingDisplay = t('blog.readingTime', { minutes: post.readingTime });
---

<CinematicHero
  locale={locale}
  backHref={backHref}
  backLabel={backLabel}
  refCode={refCode}
  title={post.title[locale]}
  imageUrl={post.image}
  eyebrowText={catLabel}
  featuredLabel={post.featured ? (locale === 'es' ? 'DESTACADO' : 'FEATURED') : undefined}
  dockAriaLabel={dockLabel}
  description={description}
>
  <div slot="dock" class="cin-dock-cell">
    <div class="cin-dock-cell-icon orange">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>
    </div>
    <span class="cin-dock-label">{t('detail.readingTime')}</span>
    <span class="cin-dock-value">{readingDisplay}</span>
  </div>
  <div slot="dock" class="cin-dock-sep" aria-hidden="true"></div>
  <div slot="dock" class="cin-dock-cell">
    <div class="cin-dock-cell-icon cream">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    </div>
    <span class="cin-dock-label">{t('detail.author')}</span>
    <span class="cin-dock-value blg-dock-author">{post.author}</span>
  </div>
  <div slot="dock" class="cin-dock-sep" aria-hidden="true"></div>
  <div slot="dock" class="cin-dock-cell">
    <div class="cin-dock-cell-icon gold">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
    </div>
    <span class="cin-dock-label">{t('detail.publishDate')}</span>
    <span class="cin-dock-value"><time datetime={post.publishDate}>{formattedDate}</time></span>
  </div>
  <div slot="dock" class="cin-dock-sep" aria-hidden="true"></div>
  <div slot="dock" class="cin-dock-cell">
    <div class="cin-dock-cell-icon green">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
    </div>
    <span class="cin-dock-label">{t('detail.category')}</span>
    <span class="cin-dock-value">{t(`blog.categories.${post.category}`)}</span>
  </div>
</CinematicHero>

<style>
  .blg-dock-author { font-size: 1.15rem; }
</style>

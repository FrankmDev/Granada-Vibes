---
/**
 * BlogCoverReveal — Full-bleed cover image treatment for guide detail pages.
 *
 * The hero keeps the image as a atmospheric background; this block gives the
 * photograph its own editorial moment just below the fold, like a magazine
 * opening spread. It reveals on scroll with a slow, cinematic wipe.
 */
import type { BlogPost, Locale } from '@types';
import { useTranslations } from '@i18n/utils';
import OptimizedImage from '@components/ui/OptimizedImage.astro';

interface Props {
  post: BlogPost;
  locale: Locale;
}

const { post, locale } = Astro.props;
const t = useTranslations(locale);

if (!post.image) return null;

const label = t('blog.coverPhotograph');
const alt = post.title[locale];
---

<figure class="bcr-section" data-reveal="cover" aria-label={label}>
  <div class="bcr-frame">
    <div class="bcr-wipe" aria-hidden="true"></div>
    <div class="bcr-img-wrap">
      <OptimizedImage
        src={post.image}
        alt={alt}
        class="bcr-img"
        loading="eager"
        fetchpriority="high"
        sizes="100vw"
        width={1600}
        height={900}
      />
    </div>
    <div class="bcr-glass" aria-hidden="true"></div>
  </div>

  <figcaption class="bcr-caption">
    <span class="bcr-caption-line" aria-hidden="true"></span>
    <span class="bcr-caption-text">{label}</span>
    <span class="bcr-caption-glyph" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="currentColor" width="10" height="10">
        <path d="M12 1 L13.5 9 L22 10.5 L13.5 12 L12 23 L10.5 12 L2 10.5 L10.5 9 Z" />
      </svg>
    </span>
  </figcaption>
</figure>

<style>
  .bcr-section {
    --bcr-bg: #f5f0ea;
    --bcr-ink: #1a1619;
    --bcr-ink-2: #5a4f47;
    --bcr-gold: #c9a84c;
    --bcr-gold-dim: rgba(201, 168, 76, 0.35);
    --bcr-border: rgba(26, 22, 25, 0.10);
    --ease-editorial: cubic-bezier(0.16, 1, 0.3, 1);

    position: relative;
    margin: 0;
    padding: clamp(2.5rem, 6vw, 5rem) clamp(1.25rem, 4vw, 4rem);
    background: var(--bcr-bg);
    overflow: hidden;
  }

  .bcr-frame {
    position: relative;
    max-width: 1300px;
    margin: 0 auto;
    border: 1px solid var(--bcr-gold-dim);
    border-radius: 4px;
    box-shadow:
      0 40px 100px rgba(10, 8, 7, 0.22),
      0 12px 32px rgba(10, 8, 7, 0.12),
      inset 0 0 0 1px rgba(255, 255, 255, 0.35);
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: #0a0807;
  }

  .bcr-img-wrap {
    position: absolute;
    inset: 0;
    transform: scale(1.08);
    transition: transform 1.4s var(--ease-editorial);
  }
  .bcr-section.is-visible .bcr-img-wrap {
    transform: scale(1.0);
  }

  .bcr-img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    filter: contrast(1.04) saturate(1.08);
  }

  /* Cinematic wipe reveal */
  .bcr-wipe {
    position: absolute;
    inset: 0;
    background: var(--bcr-bg);
    transform: translateY(0);
    transition: transform 1.2s var(--ease-editorial);
    z-index: 3;
  }
  .bcr-section.is-visible .bcr-wipe {
    transform: translateY(-101%);
  }

  /* Subtle inner glass glare */
  .bcr-glass {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    background:
      linear-gradient(120deg, rgba(255,255,255,0.10) 0%, rgba(255,255,255,0) 35%),
      linear-gradient(to top, rgba(10, 8, 7, 0.28) 0%, transparent 35%);
  }

  .bcr-caption {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.75rem;
    max-width: 1300px;
    margin: 1rem auto 0;
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--bcr-ink-2);
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.8s var(--ease-editorial) 0.6s, transform 0.8s var(--ease-editorial) 0.6s;
  }
  .bcr-section.is-visible .bcr-caption {
    opacity: 1;
    transform: translateY(0);
  }

  .bcr-caption-line {
    flex: 0 0 auto;
    width: clamp(24px, 4vw, 48px);
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--bcr-gold-dim));
  }

  .bcr-caption-glyph {
    color: var(--bcr-gold);
    opacity: 0.75;
  }

  @media (max-width: 768px) {
    .bcr-frame { aspect-ratio: 4 / 3; }
    .bcr-caption { justify-content: flex-start; }
  }

  @media (prefers-reduced-motion: reduce) {
    .bcr-img-wrap,
    .bcr-wipe,
    .bcr-caption {
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
  }
</style>

<script is:inline>
  (function() {
    const sections = document.querySelectorAll('[data-reveal="cover"]');
    if (sections.length === 0) return;
    if (!('IntersectionObserver' in window)) {
      sections.forEach((el) => el.classList.add('is-visible'));
      return;
    }
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -5% 0px' }
    );
    sections.forEach((section) => io.observe(section));
  })();
</script>

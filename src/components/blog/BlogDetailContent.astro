---
/**
 * BlogDetailContent — blog-specific CSS wrapper.
 * Shared layout CSS lives in DetailContent.astro (.det-* classes).
 * This component adds blog-specific styles: .blg-prose, .blg-share, .blg-price-free.
 */
import DetailContent from '@components/shared/DetailContent.astro';
---
<DetailContent>
  <slot />
</DetailContent>

<style is:global>
  /* ── Blog-specific styles ── */

  /* Share button in sidebar */
  .blg-share-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    width: 100%;
    padding: 1rem 1.5rem;
    background: var(--s-ink);
    color: var(--s-bg);
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    border: none;
    position: relative;
    overflow: hidden;
    margin-top: 1.5rem;
  }

  .blg-share-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--s-orange);
    transform: translateX(-100%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .blg-share-btn:hover::before { transform: translateX(0); }
  .blg-share-btn span, .blg-share-btn svg { position: relative; z-index: 1; }
  .blg-share-btn svg { width: 16px; height: 16px; }

  /* Tags in main column */
  .blg-tags-block {
    padding: 2.5rem;
    background: var(--s-bg);
    border-top: 2px solid var(--s-border);
  }

  .blg-tags-eyebrow {
    display: block;
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--s-ink-3);
    margin-bottom: 1rem;
  }

  .blg-tags-flow { display: flex; flex-wrap: wrap; gap: 0.5rem; }

  .blg-tag-pill {
    display: inline-flex;
    padding: 0.4rem 1rem;
    font-family: var(--font-display);
    font-size: 0.75rem;
    color: var(--s-ink-2);
    background: var(--s-bg-hi);
    border: 1px solid var(--s-border);
    border-radius: 100px;
  }

  /* Prose styles for HTML blog content */
  .blg-prose {
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--s-ink-2);
    max-width: 70ch;
  }

  .blg-prose p { margin-bottom: 1.5em; }

  .blg-prose h2 {
    font-family: var(--font-body);
    font-size: clamp(1.3rem, 2vw, 1.75rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--s-ink);
    margin-top: 2.5em;
    margin-bottom: 0.75em;
    padding-left: 1.25rem;
    border-left: 3px solid var(--s-gold);
  }

  .blg-prose h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--s-ink);
    margin-top: 2em;
    margin-bottom: 0.6em;
  }

  .blg-prose h4 {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--s-ink);
    margin-top: 1.5em;
    margin-bottom: 0.5em;
  }

  .blg-prose blockquote {
    padding: 1.25rem 1.5rem;
    border-left: 3px solid var(--s-orange);
    background: rgba(232,98,42,0.04);
    margin: 2em 0;
    font-style: italic;
    color: var(--s-ink);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .blg-prose blockquote p { margin: 0; }

  .blg-prose a {
    color: var(--s-orange);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: color 0.2s ease;
  }

  .blg-prose a:hover { color: var(--s-ink); }

  .blg-prose ul,
  .blg-prose ol {
    padding-left: 1.5rem;
    margin-bottom: 1.5em;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .blg-prose li { line-height: 1.65; }

  .blg-prose ul li::marker { color: var(--s-orange); }
  .blg-prose ol li::marker { color: var(--s-gold); font-weight: 600; font-size: 0.85rem; }

  .blg-prose strong { font-weight: 700; color: var(--s-ink); }

  .blg-prose em { font-style: italic; }

  .blg-prose code {
    font-family: 'Courier New', monospace;
    font-size: 0.85em;
    background: var(--s-bg-hi);
    border: 1px solid var(--s-border);
    padding: 0.15em 0.45em;
    border-radius: 2px;
    color: var(--s-ink);
  }

  .blg-prose pre {
    background: var(--s-bg-hi);
    border: 1px solid var(--s-border);
    border-left: 3px solid var(--s-gold);
    padding: 1.5rem;
    margin: 2em 0;
    overflow-x: auto;
    border-radius: 2px;
  }

  .blg-prose pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.88rem;
    line-height: 1.6;
  }

  .blg-prose img {
    width: 100%;
    height: auto;
    display: block;
    margin: 2em 0;
    border: 1px solid var(--s-border);
  }

  .blg-prose hr {
    border: none;
    height: 1px;
    background: var(--s-border);
    margin: 3em 0;
    position: relative;
  }

  .blg-prose hr::after {
    content: '◆';
    position: absolute;
    left: 50%;
    top: -0.65em;
    transform: translateX(-50%);
    font-size: 0.7rem;
    color: var(--s-gold);
    background: var(--s-bg);
    padding: 0 0.5rem;
  }

  /* Article block (wraps blg-prose) */
  .blg-article-block {
    padding: 2.5rem;
    background: var(--s-bg);
  }

  /* Decorative opening quote */
  .blg-article-block::before {
    content: '"';
    display: block;
    font-family: var(--font-body);
    font-size: 6rem;
    line-height: 0.7;
    color: rgba(201,168,76,0.15);
    margin-bottom: 0.5rem;
    font-weight: 300;
    letter-spacing: -0.05em;
    user-select: none;
  }

  @media (max-width: 640px) {
    .blg-article-block { padding: 1.75rem 1.25rem; }
    .blg-tags-block { padding: 1.75rem 1.25rem; }
    .blg-prose h2 { font-size: 1.25rem; }
  }
</style>

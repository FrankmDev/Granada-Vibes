    padding: 2px;
    background: linear-gradient(135deg, var(--accent), var(--gold), var(--accent));
    background-size: 200% 200%;
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.4s ease;
    animation: borderRotate 3s linear infinite;
    pointer-events: none;
    z-index: 2;
  }

  .notes-frame:focus-within::before {
    opacity: 1;
  }

  .notes-frame:focus-within {
    border-color: transparent;
    box-shadow: 0 0 0 3px rgba(232,98,42,0.06), var(--shadow-md);
    background: linear-gradient(135deg, rgba(232,98,42,0.02), var(--card-bg));
  }

  @keyframes borderRotate {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .notes-frame textarea {
    width: 100%;
    background: transparent;
    border: none;
    padding: 1.75rem;
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--ink);
    resize: vertical;
    outline: none;
    line-height: 1.7;
    min-height: 110px;
  }

  .notes-frame textarea::placeholder {
    color: var(--ink-3);
    font-style: italic;
  }

  .notes-counter {
    margin-top: 0.875rem;
    text-align: right;
    font-family: var(--font-display);
    font-size: 0.72rem;
    color: var(--ink-3);
    letter-spacing: 0.05em;
  }

  /* ── Submit ── */
  .submit-area {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    padding-top: 2.5rem;
  }

  .submit-glow-bg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 360px;
    height: 90px;
    border-radius: 100px;
    background: radial-gradient(ellipse, rgba(232,98,42,0.12), transparent 65%);
    filter: blur(28px);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .submit-btn:not(:disabled) ~ .submit-glow-bg {
    opacity: 1;
    animation: glowBreathe 3s ease-in-out infinite;
  }

  @keyframes glowBreathe {
    0%, 100% { opacity: 0.5; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 1; transform: translate(-50%, -50%) scale(1.12); }
  }

  .submit-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    padding: 1.35rem 3.5rem;
    background: var(--ink);
    border: 2px solid var(--ink);
    border-radius: 100px;
    color: var(--bg);
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.55s var(--ease-out-expo);
    box-shadow: 0 12px 40px rgba(26,22,25,0.15);
    z-index: 1;
  }

  .submit-btn:disabled {
    opacity: 0.2;
    cursor: not-allowed;
    background: var(--ink-4);
    border-color: transparent;
    box-shadow: none;
    color: var(--ink);
  }

  .submit-btn:not(:disabled):hover {
    background: var(--accent);
    border-color: var(--accent);
    transform: translateY(-5px);
    box-shadow:
      0 24px 60px rgba(232,98,42,0.30),
      0 0 0 2px rgba(232,98,42,0.10);
  }

  .submit-btn:not(:disabled):active {
    transform: translateY(-2px) scale(0.97);
    transition-duration: 0.1s;
  }

  .submit-gleam {
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.20) 50%, transparent 60%);
    transform: translateX(-100%);
    pointer-events: none;
  }

  .submit-btn:not(:disabled):hover .submit-gleam {
    animation: gleamSweep 0.7s ease forwards;
  }

  @keyframes gleamSweep {
    to { transform: translateX(100%); }
  }

  .submit-arrow {
    transition: transform 0.35s var(--ease-out-expo);
  }

  .submit-btn:not(:disabled):hover .submit-arrow {
    transform: translateX(6px);
  }

  .submit-tooltip {
    font-family: var(--font-display);
    font-size: 0.75rem;
    color: var(--ink-3);
    text-align: center;
    margin: 0;
    opacity: 0;
    transform: translateY(4px);
    transition: all 0.3s ease;
  }

  .submit-tooltip:not(.hidden) {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Loading — cinematic orbital system ── */
  .loading-stage {
    position: relative;
    min-height: 70vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3rem;
    z-index: 1;
  }

  .loading-visual {
    position: relative;
    width: 240px;
    height: 240px;
  }

  .load-ring {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    border: 1px solid transparent;
  }

  .load-ring-1 {
    width: 240px; height: 240px;
    border-color: rgba(201,168,76,0.18);
    animation: spinCW 14s linear infinite;
  }

  .load-ring-2 {
    width: 180px; height: 180px;
    border-color: rgba(232,98,42,0.12);
    border-style: dashed;
    animation: spinCCW 10s linear infinite;
  }

  .load-ring-3 {
    width: 120px; height: 120px;
    border-color: rgba(201,168,76,0.08);
    border-style: dotted;
    animation: spinCW 6s linear infinite;
  }

  @keyframes spinCW {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to   { transform: translate(-50%, -50%) rotate(360deg); }
  }

  @keyframes spinCCW {
    from { transform: translate(-50%, -50%) rotate(360deg); }
    to   { transform: translate(-50%, -50%) rotate(0deg); }
  }

  .load-core {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--accent), #ff8c5a);
    box-shadow: 0 0 30px rgba(232,98,42,0.4), 0 0 60px rgba(232,98,42,0.15), inset 0 0 8px rgba(255,255,255,0.3);
    animation: corePulse 1.6s ease-in-out infinite;
  }

  @keyframes corePulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
    50% { transform: translate(-50%, -50%) scale(1.5); opacity: 0.6; }
  }

  /* Orbiting particles */
  .load-orbiter {
    position: absolute;
    top: 50%; left: 50%;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--gold);
    box-shadow: 0 0 10px rgba(201,168,76,0.5);
    will-change: transform;
  }

  .orbiter-1 { animation: orbit1 4s linear infinite; }
  .orbiter-2 { animation: orbit2 5.5s linear infinite; background: var(--accent); box-shadow: 0 0 10px rgba(232,98,42,0.5); }
  .orbiter-3 { animation: orbit3 7s linear infinite; width: 4px; height: 4px; }

  @keyframes orbit1 {
    from { transform: translate(-50%, -50%) rotate(0deg) translateX(115px) rotate(0deg); }
    to   { transform: translate(-50%, -50%) rotate(360deg) translateX(115px) rotate(-360deg); }
  }
  @keyframes orbit2 {
    from { transform: translate(-50%, -50%) rotate(120deg) translateX(88px) rotate(-120deg); }
    to   { transform: translate(-50%, -50%) rotate(480deg) translateX(88px) rotate(-480deg); }
  }
  @keyframes orbit3 {
    from { transform: translate(-50%, -50%) rotate(240deg) translateX(62px) rotate(-240deg); }
    to   { transform: translate(-50%, -50%) rotate(600deg) translateX(62px) rotate(-600deg); }
  }

  /* Scanline overlay */
  .load-scanline {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: linear-gradient(to bottom, transparent 50%, rgba(232,98,42,0.04) 50%);
    background-size: 100% 4px;
    pointer-events: none;
    opacity: 0.5;
    animation: scanlineMove 6s linear infinite;
  }

  @keyframes scanlineMove {
    from { transform: translateY(-100%); }
    to { transform: translateY(100%); }
  }

  .loading-text-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .load-text {
    font-family: var(--font-body);
    font-size: clamp(1.2rem, 2.2vw, 1.6rem);
    font-weight: 300;
    color: var(--ink-2);
    text-align: center;
    margin: 0;
    transition: opacity 0.3s ease;
    letter-spacing: -0.01em;
    min-height: 1.6em;
  }

  .load-dots {
    display: flex;
    gap: 8px;
  }

  .load-dots span {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--gold);
    animation: dotBounce 1.4s ease-in-out infinite;
  }

  .load-dots span:nth-child(2) { animation-delay: 0.2s; }
  .load-dots span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes dotBounce {
    0%, 80%, 100% { transform: translateY(0); opacity: 0.3; }
    40% { transform: translateY(-10px); opacity: 1; }
  }

  /* ── Results ── */
  .results-stage {
    position: relative;
    z-index: 1;
    max-width: 960px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  @media (min-width: 768px) {
    .results-stage { padding: 4rem 2.5rem 6rem; }
  }

  .results-stage.is-entering {
    animation: stageEnter 0.7s var(--ease-out-expo) forwards;
  }

  @keyframes stageEnter {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .result-hero {
    position: relative;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 2.5rem;
    overflow: hidden;
    box-shadow: var(--shadow-md);
    opacity: 0;
    animation: fadeInUp 0.8s var(--ease-out-expo) 0.1s forwards;
  }

  @media (min-width: 768px) {
    .result-hero { padding: 3rem; }
  }

  .result-hero-glow {
    position: absolute;
    top: -60%;
    left: -20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(232,98,42,0.06), transparent 60%);
    filter: blur(60px);
    pointer-events: none;
  }

  .result-hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .result-ref-badge {
    display: inline-flex;
    align-self: flex-start;
    padding: 0.4rem 1rem;
    background: var(--gold-bg);
    border: 1px solid rgba(201,168,76,0.22);
    border-radius: 100px;
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    opacity: 0;
    animation: fadeInUp 0.6s var(--ease-out-expo) 0.2s forwards;
  }

  .result-hero-title {
    font-family: var(--font-body);
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0;
    opacity: 0;
    animation: fadeInUp 0.7s var(--ease-out-expo) 0.3s forwards;
  }

  .result-hero-subtitle {
    font-family: var(--font-display);
    font-size: clamp(0.95rem, 1.2vw, 1.1rem);
    color: var(--ink-3);
    line-height: 1.6;
    margin: 0;
    opacity: 0;
    animation: fadeInUp 0.7s var(--ease-out-expo) 0.4s forwards;
  }

  .result-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    opacity: 0;
    animation: fadeInUp 0.6s var(--ease-out-expo) 0.5s forwards;
  }

  .result-pill {
    display: inline-flex;
    padding: 0.4rem 0.875rem;
    background: rgba(26,22,25,0.03);
    border: 1px solid var(--border);
    border-radius: 100px;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--ink-2);
    letter-spacing: 0.02em;
  }

  .result-hero-summary {
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--ink-2);
    margin: 0;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
    opacity: 0;
    animation: fadeInUp 0.7s var(--ease-out-expo) 0.6s forwards;
  }

  /* ── Days Timeline ── */
  .result-days {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  .day-section {
    opacity: 0;
    animation: dayReveal 0.7s var(--ease-out-expo) forwards;
    animation-delay: var(--day-delay, 0s);
  }

  @keyframes dayReveal {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .day-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.75rem;
  }

  .day-number {
    font-family: var(--font-body);
    font-size: 2.2rem;
    font-weight: 300;
    color: var(--gold);
    line-height: 1;
    opacity: 0.6;
  }

  .day-title {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-3);
  }

  .day-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--border), transparent);
  }

  .timeline {
    position: relative;
    padding-left: 2.25rem;
  }

  @media (min-width: 768px) {
    .timeline { padding-left: 2.75rem; }
  }

  .timeline-track {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--gold-dim), rgba(232,98,42,0.20), transparent);
    border-radius: 1px;
    transform-origin: top;
    animation: trackGrow 1.2s var(--ease-out-expo) forwards;
    animation-delay: var(--track-delay, 0s);
  }

  @keyframes trackGrow {
    from { transform: scaleY(0); }
    to { transform: scaleY(1); }
  }

  .stop-card {
    position: relative;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 1.75rem;
    margin-bottom: 1.25rem;
    opacity: 0;
    transform: translateX(-14px);
    animation: slideIn 0.55s var(--ease-out-expo) forwards;
    transition: transform 0.4s var(--ease-out-expo), border-color 0.4s ease, box-shadow 0.4s ease, background 0.4s ease;
    box-shadow: var(--shadow-sm);
  }

  .stop-card:hover {
    border-color: rgba(201,168,76,0.25);
    background: var(--card-bg-hover);
    transform: translateX(6px) translateY(-2px);
    box-shadow: -4px 8px 24px rgba(0,0,0,0.25), 0 0 0 1px rgba(201,168,76,0.08);
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateX(-14px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .stop-dot {
    position: absolute;
    left: -2.25rem;
    top: 2rem;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--gold);
    border: 2px solid var(--bg);
    box-shadow: 0 0 14px rgba(201,168,76,0.25);
    transform: translateX(-5px);
  }

  .stop-dot::after {
    content: '';
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    border: 1px solid var(--gold);
    opacity: 0;
    animation: dotPing 2.5s ease-out infinite;
    animation-delay: var(--dot-delay, 0s);
  }

  @keyframes dotPing {
    0% { transform: scale(0.6); opacity: 0.5; }
    100% { transform: scale(2.2); opacity: 0; }
  }

  @media (min-width: 768px) {
    .stop-dot { left: -2.75rem; transform: translateX(-6px); }
  }

  .stop-header {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    margin-bottom: 0.875rem;
  }

  .stop-order {
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 700;
    color: var(--gold);
    letter-spacing: 0.1em;
  }

  .stop-time {
    font-family: var(--font-display);
    font-size: 0.7rem;
    color: var(--ink-3);
    letter-spacing: 0.05em;
  }

  .stop-name {
    font-family: var(--font-body);
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--ink);
    margin: 0 0 0.75rem;
    letter-spacing: -0.01em;
  }

  .stop-badges {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .stop-badge {
    display: inline-flex;
    padding: 0.25rem 0.625rem;
    border-radius: 100px;
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .stop-badge.type {
    background: rgba(232,98,42,0.08);
    color: var(--accent);
    border: 1px solid rgba(232,98,42,0.15);
  }

  .stop-badge.neighborhood {
    background: rgba(201,168,76,0.08);
    color: var(--gold);
    border: 1px solid rgba(201,168,76,0.15);
  }

  .stop-desc {
    font-family: var(--font-display);
    font-size: 0.88rem;
    line-height: 1.65;
    color: var(--ink-2);
    margin: 0 0 1rem;
  }

  .stop-tip {
    background: rgba(201,168,76,0.04);
    border: 1px solid rgba(201,168,76,0.12);
    border-radius: 12px;
    padding: 1rem 1.25rem;
    margin-bottom: 1rem;
  }

  .stop-tip-label {
    display: block;
    font-family: var(--font-display);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.35rem;
  }

  .stop-tip-text {
    font-family: var(--font-display);
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--ink-3);
    margin: 0;
    font-style: italic;
  }

  .stop-meta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    font-family: var(--font-display);
    font-size: 0.7rem;
    color: var(--ink-3);
  }

  .stop-transition {
    margin-top: 1rem;
    padding: 0.875rem 1.25rem;
    background: rgba(26,22,25,0.02);
    border-left: 2px solid var(--gold-dim);
    border-radius: 0 10px 10px 0;
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-style: italic;
    color: var(--ink-3);
    line-height: 1.5;
  }

  /* Stop corner brackets (rendered by JS) */
  .stop-corner {
    position: absolute;
    width: 16px;
    height: 16px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .stop-corner::before,
  .stop-corner::after {
    content: '';
    position: absolute;
    background: var(--gold);
    transition: all 0.4s ease;
  }

  .stop-corner::before { width: 16px; height: 2px; }
  .stop-corner::after  { width: 2px; height: 16px; }

  .stop-corner.tl { top: 12px; left: 12px; }
  .stop-corner.tl::before { top: 0; left: 0; }
  .stop-corner.tl::after  { top: 0; left: 0; }

  .stop-corner.tr { top: 12px; right: 12px; }
  .stop-corner.tr::before { top: 0; right: 0; }
  .stop-corner.tr::after  { top: 0; right: 0; }

  .stop-corner.bl { bottom: 12px; left: 12px; }
  .stop-corner.bl::before { bottom: 0; left: 0; }
  .stop-corner.bl::after  { bottom: 0; left: 0; }

  .stop-corner.br { bottom: 12px; right: 12px; }
  .stop-corner.br::before { bottom: 0; right: 0; }
  .stop-corner.br::after  { bottom: 0; right: 0; }

  .stop-card:hover .stop-corner {
    opacity: 0.7;
  }

  /* ── Result Footer ── */
  .result-footer {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-top: 1rem;
    opacity: 0;
    animation: fadeInUp 0.7s var(--ease-out-expo) 0.7s forwards;
  }

  .result-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .result-stat {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 18px;
    transition: all 0.4s var(--ease-out-expo);
    box-shadow: var(--shadow-sm);
  }

  .result-stat:hover {
    border-color: rgba(201,168,76,0.25);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .result-stat-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 14px;
    background: linear-gradient(135deg, var(--gold-bg), rgba(232,98,42,0.05));
    border: 1px solid rgba(201,168,76,0.18);
    color: var(--gold);
    flex-shrink: 0;
  }

  .result-stat-icon :global(svg) { width: 20px; height: 20px; }

  .result-stat-body {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .result-stat-label {
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;

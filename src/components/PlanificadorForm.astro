  footprints: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 16v-2.38C4 11.5 2.97 10.5 3 8c.03-2.72 1.49-6 4.5-6C9.37 2 11 3.8 11 8c0 1.25-.5 2-1 3.5L8 16"/><path d="M20 16v-2.38c0-2.12 1.03-3.12 1-5.62-.03-2.72-1.49-6-4.5-6C14.63 2 13 3.8 13 8c0 1.25.5 2 1 3.5L16 16"/><path d="M9.5 17a2.5 2.5 0 0 0-2.5 2.5c0 .83.67 1.5 1.5 1.5h1c.83 0 1.5-.67 1.5-1.5 0-1.38-1-2.5-2.5-2.5z"/><path d="M14.5 17a2.5 2.5 0 0 0-2.5 2.5c0 .83.67 1.5 1.5 1.5h1c.83 0 1.5-.67 1.5-1.5 0-1.38-1-2.5-2.5-2.5z"/></svg>',

const selectorGroups = [
  {
    name: 'tiempo',
    label: t('planner.form.time.label'),
    icon: 'hourglass',
    multi: false,
    gridClass: 'grid-cols-2 md:grid-cols-4',
    options: [
      { value: '2h', title: t('planner.form.time.2h.title'), description: t('planner.form.time.2h.description'), icon: 'clock' },
      { value: 'medio-dia', title: t('planner.form.time.halfDay.title'), description: t('planner.form.time.halfDay.description'), icon: 'sun' },
      { value: 'dia-completo', title: t('planner.form.time.fullDay.title'), description: t('planner.form.time.fullDay.description'), icon: 'sunrise' },
      { value: 'fin-de-semana', title: t('planner.form.time.weekend.title'), description: t('planner.form.time.weekend.description'), icon: 'calendar' },
    ],
  },
  {
    name: 'categorias',
    label: t('planner.form.categories.label'),
    icon: 'grid',
    multi: true,
    gridClass: 'grid-cols-2 md:grid-cols-4',
    options: [
      { value: 'historia', title: t('planner.form.categories.history.title'), icon: 'landmark' },
      { value: 'gastronomia', title: t('planner.form.categories.food.title'), icon: 'utensils' },
      { value: 'naturaleza', title: t('planner.form.categories.nature.title'), icon: 'mountain' },
      { value: 'fotografia', title: t('planner.form.categories.photo.title'), icon: 'camera' },
      { value: 'flamenco', title: t('planner.form.categories.flamenco.title'), icon: 'music' },
      { value: 'arte', title: t('planner.form.categories.art.title'), icon: 'palette' },
      { value: 'compras', title: t('planner.form.categories.shopping.title'), icon: 'shopping-bag' },
      { value: 'secreto', title: t('planner.form.categories.secrets.title'), icon: 'eye-off' },
    ],
  },
  {
    name: 'compania',
    label: t('planner.form.company.label'),
    icon: 'users',
    multi: false,
    gridClass: 'grid-cols-2 md:grid-cols-5',
    options: [
      { value: 'solo', title: t('planner.form.company.solo.title'), icon: 'user' },
      { value: 'pareja', title: t('planner.form.company.couple.title'), icon: 'heart' },
      { value: 'amigos', title: t('planner.form.company.friends.title'), icon: 'users' },
      { value: 'familia', title: t('planner.form.company.family.title'), icon: 'home' },
      { value: 'grupo', title: t('planner.form.company.group.title'), icon: 'users-2' },
    ],
  },
  {
    name: 'presupuesto',
    label: t('planner.form.budget.label'),
    icon: 'piggy-bank',
    multi: false,
    gridClass: 'grid-cols-2 md:grid-cols-5',
    options: [
      { value: 'minimo', title: t('planner.form.budget.minimum.title'), description: t('planner.form.budget.minimum.description'), icon: 'coins' },
      { value: 'ajustado', title: t('planner.form.budget.tight.title'), description: t('planner.form.budget.tight.description'), icon: 'wallet' },
      { value: 'moderado', title: t('planner.form.budget.moderate.title'), description: t('planner.form.budget.moderate.description'), icon: 'banknote' },
      { value: 'holgado', title: t('planner.form.budget.comfortable.title'), description: t('planner.form.budget.comfortable.description'), icon: 'credit-card' },
      { value: 'sin-limite', title: t('planner.form.budget.unlimited.title'), description: t('planner.form.budget.unlimited.description'), icon: 'gem' },
    ],
  },
  {
    name: 'ritmo',
    label: t('planner.form.pace.label'),
    icon: 'gauge',
    multi: false,
    gridClass: 'grid-cols-1 md:grid-cols-3',
    options: [
      { value: 'tranquilo', title: t('planner.form.pace.relaxed.title'), description: t('planner.form.pace.relaxed.description'), icon: 'coffee' },
      { value: 'equilibrado', title: t('planner.form.pace.balanced.title'), description: t('planner.form.pace.balanced.description'), icon: 'activity' },
      { value: 'intenso', title: t('planner.form.pace.intense.title'), description: t('planner.form.pace.intense.description'), icon: 'zap' },
    ],
  },
  {
    name: 'movilidad',
    label: t('planner.form.mobility.label'),
    icon: 'map-pin',
    multi: false,
    gridClass: 'grid-cols-2 md:grid-cols-4',
    options: [
      { value: 'pie', title: t('planner.form.mobility.walk.title'), description: t('planner.form.mobility.walk.description'), icon: 'footprints' },
      { value: 'publico', title: t('planner.form.mobility.public.title'), description: t('planner.form.mobility.public.description'), icon: 'bus' },
      { value: 'coche', title: t('planner.form.mobility.car.title'), description: t('planner.form.mobility.car.description'), icon: 'car' },
      { value: 'sin-restriccion', title: t('planner.form.mobility.free.title'), icon: 'infinity' },
    ],
  },
] as const;

const plannerCopy = {
  loadingMessages: [
    t('planner.loading.step1'),
    t('planner.loading.step2'),
    t('planner.loading.step3'),
    t('planner.loading.step4'),
  ],
  shareCopied: t('planner.results.shareCopied'),
  valueLabels: {
    tiempo: {
      '2h': t('planner.values.time.2h'),
      'medio-dia': t('planner.values.time.halfDay'),
      'dia-completo': t('planner.values.time.fullDay'),
      'fin-de-semana': t('planner.values.time.weekend'),
    },
    compania: {
      solo: t('planner.values.company.solo'),
      pareja: t('planner.values.company.couple'),
      amigos: t('planner.values.company.friends'),
      familia: t('planner.values.company.family'),
      grupo: t('planner.values.company.group'),
    },
    presupuesto: {
      minimo: t('planner.values.budget.minimum'),
      ajustado: t('planner.values.budget.tight'),
      moderado: t('planner.values.budget.moderate'),
      holgado: t('planner.values.budget.comfortable'),
      'sin-limite': t('planner.values.budget.unlimited'),
    },
    ritmo: {
      tranquilo: t('planner.values.pace.relaxed'),
      equilibrado: t('planner.values.pace.balanced'),
      intenso: t('planner.values.pace.intense'),
    },
  },
  placeTypes: {
    monumento: t('planner.placeTypes.monument'),
    mirador: t('planner.placeTypes.viewpoint'),
    bar: t('planner.placeTypes.bar'),
    restaurante: t('planner.placeTypes.restaurant'),
    tienda: t('planner.placeTypes.shop'),
    parque: t('planner.placeTypes.park'),
    experiencia: t('planner.placeTypes.experience'),
    barrio: t('planner.placeTypes.neighborhood'),
    museo: t('planner.placeTypes.museum'),
  },
  labels: {
    referencePrefix: t('planner.results.referencePrefix'),
    localTip: t('planner.results.localTip'),
  },
};
---

<div id="planner-app" class="planner-app" data-locale={locale}>
  <script type="application/json" id="planner-copy" set:html={JSON.stringify(plannerCopy)}></script>

  {/* Hidden progress tracker for JS compatibility */}
  <div id="planner-progress" class="planner-progress" aria-hidden="true">
    <div class="progress-rail">
      <div class="rail-track"></div>
      <div class="rail-fill"></div>
    </div>
    <div class="progress-track">
      {selectorGroups.map((group, i) => (
        <div class="progress-step" data-step={i}>
          <div class="step-node">
            <span class="step-icon" set:html={iconSvg[group.icon]} />
            <span class="step-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="step-check" set:html={iconSvg.check} />
          </div>
          <div class="step-label">
            <span class="step-title">{group.label}</span>
          </div>
        </div>
      ))}
    </div>
  </div>

  {/* Ambient background */}

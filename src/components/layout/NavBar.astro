  /* ── RIGHT PANEL: Navigation ── */
  .gate-right {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 3rem 3.5rem 3rem 3.5rem;
    opacity: 0;
    transition: opacity 0.5s ease 0.3s;
  }

  .gate.is-open .gate-right { opacity: 1; }

  /* Gate header */
  .gate-header {
    display: flex;
    flex-direction: column;
    gap: 4px;
    opacity: 0;
    transform: translateY(-16px);
    transition: opacity 0.6s var(--gg-expo) 0.45s, transform 0.6s var(--gg-expo) 0.45s;

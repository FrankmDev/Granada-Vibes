  /* Corner brackets */
  .gate-corners { position: absolute; inset: 0; pointer-events: none; z-index: 15; }

  .gcb {
    position: absolute;
    width: 28px;
    height: 28px;
    opacity: 0;
    transition: opacity 0.5s ease 0.65s;
  }

  .gate.is-open .gcb { opacity: 1; }

  .gcb::before,
  .gcb::after {
    content: '';
    position: absolute;
    background: rgba(201, 168, 76, 0.35);
  }

  .gcb::before { width: 28px; height: 1px; }
  .gcb::after  { width: 1px; height: 28px; }

  .gcb--tl { top: 1.75rem; left: 1.75rem; }
  .gcb--tl::before { top: 0; left: 0; }
  .gcb--tl::after  { top: 0; left: 0; }

  .gcb--tr { top: 1.75rem; right: 1.75rem; }
  .gcb--tr::before { top: 0; right: 0; }
  .gcb--tr::after  { top: 0; right: 0; }

  .gcb--bl { bottom: 1.75rem; left: 1.75rem; }
  .gcb--bl::before { bottom: 0; left: 0; }
  .gcb--bl::after  { bottom: 0; left: 0; }

  .gcb--br { bottom: 1.75rem; right: 1.75rem; }
  .gcb--br::before { bottom: 0; right: 0; }
  .gcb--br::after  { bottom: 0; right: 0; }

  /* ═══════════════════════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════════════════════ */
  @media (max-width: 960px) {
    .nb-bar { padding: 0 1.5rem; }
    .nb-rule { left: 1.5rem; right: 1.5rem; }
    .nb-center { display: none; }
    .nb-logo-tagline { display: none; }
    .nb-trigger-label { display: none; }
    .nb-trigger { padding: 0.45rem 0.75rem; gap: 0; }
    .nb-lang { padding: 0.35rem 0.625rem; }

    /* Capsule: reduce padding and spacing */
    .nb-capsule-inner {
      padding: 0 0.625rem;
      height: 44px;
      gap: 0.25rem;
    }
    .cap-link {
      padding: 0.25rem 0.625rem;
      font-size: 0.55rem;
      letter-spacing: 0.08em;
    }
    .cap-divider { margin: 0 0.125rem; }

    .gate-body { grid-template-columns: 1fr; }
    .gate-left { display: none; }
    .gate-right { padding: 5rem 2rem 2.5rem; }
    .gate-close { top: 1.75rem; right: 1.75rem; }

    .gi-label { font-size: clamp(1.6rem, 8vw, 2.6rem); }
    .gate-footer { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .gcb { display: none; }
  }

  /* Mobile: compact nav links - show only numbers */
  @media (max-width: 640px) {
    .nb-capsule {
      left: 50%;
      transform: translateX(-50%) translateY(-80px);
    }
    .nb.is-scrolled .nb-capsule {
      transform: translateX(-50%) translateY(0);
    }
    .nb-capsule-inner {
      padding: 0 0.625rem;

    .nb-capsule,
    .nb-logo-star,
    .cap-logo,
    .gate-curtain,
    .gate-left,
    .gate-right,
    .gate-header,
    .gate-item,
    .gate-footer,
    .gate-coord,
    .ghost-num,
    .gate-close,
    .gcb {

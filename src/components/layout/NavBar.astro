---
import '@styles/components/navbar.css';
import type { Locale } from '@types';
import { useTranslations } from '@i18n/utils';
import { LOCALE_PATHS } from '@config/site';
import { getRoute, getSwitchLangUrl } from '@utils/routes';
import GrandGate from './GrandGate.astro';

interface Props {
  locale: Locale;
  currentPath?: string;
}

const { locale, currentPath } = Astro.props;
const t = useTranslations(locale);
const localePath = LOCALE_PATHS[locale];

function getMobileLabel(label: string): string {
  const lower = label.toLowerCase();
  if (lower.startsWith('plan')) return 'Plan';
  return label.slice(0, 3);
}

const navLinks = [
  { href: getRoute('events', locale), label: t('nav.events'),  shortLabel: t('nav.events'),  num: '01', abbr: 'EV', mobileLabel: getMobileLabel(t('nav.events')) },
  { href: getRoute('routes', locale), label: t('nav.routes'),  shortLabel: t('nav.routes'),  num: '02', abbr: 'RT', mobileLabel: getMobileLabel(t('nav.routes')) },
  { href: getRoute('blog', locale),   label: t('nav.blog'),    shortLabel: t('nav.blog'),    num: '03', abbr: 'GU', mobileLabel: getMobileLabel(t('nav.blog')) },
  { href: getRoute('planner', locale), label: t('nav.planner'), shortLabel: t('nav.planner'), num: '04', abbr: 'PL', mobileLabel: getMobileLabel(t('nav.planner')) },
];

const isHome = currentPath === '/' || currentPath === '/en/';
const altHref = getSwitchLangUrl(locale);
const altLabel = locale === 'es' ? 'EN' : 'ES';
const homeHref = getRoute('home', locale);
---

<header class="nb" data-nav-grand aria-label={t('nav.mainNavLabel')}>

  <!-- ░░░ TRANSPARENT TOP BAR (hero state) ░░░ -->
  <div class="nb-bar">

    <!-- Ambient gradient: black to transparent for legibility over video -->
    <div class="nb-ambient" aria-hidden="true"></div>

    <!-- Filmstrip tick marks along top edge -->
    <div class="nb-ticks" aria-hidden="true">
      <span class="tick"></span><span class="tick"></span><span class="tick"></span>
      <span class="tick t-center"></span>
      <span class="tick"></span><span class="tick"></span><span class="tick"></span>
    </div>

    <!-- Left: Logo -->
    <a href={homeHref} class="nb-logo" aria-label="GRN URBAN — Inicio">
      <span class="nb-logo-star" aria-hidden="true">
        <svg viewBox="0 0 44 44" fill="none">
          <path d="M22 3 L25.2 13.8 L36 8 L29.2 17.5 L38 22 L29.2 26.5 L36 36 L25.2 30.2 L22 41 L18.8 30.2 L8 36 L14.8 26.5 L6 22 L14.8 17.5 L8 8 L18.8 13.8 Z" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linejoin="round"/>
          <circle cx="22" cy="22" r="3.5" fill="currentColor"/>
        </svg>
      </span>
      <span class="nb-logo-text">
        <span class="nb-logo-name">GRN URBAN</span>
        <span class="nb-logo-tagline">{t('nav.guideLabel')}</span>
      </span>
    </a>

    <!-- Center: Coded nav links -->
    <nav class="nb-center" aria-label={t('nav.mainNavLabel')}>
      {navLinks.map((link) => {
        const active = currentPath?.startsWith(link.href) && link.href !== '/';
        return (
          <a
            href={link.href}
            class:list={['nb-link', { 'is-active': active }]}
            aria-current={active ? 'page' : undefined}
          >
            <span class="nb-link-num" aria-hidden="true">[{link.num}]</span>
            <span class="nb-link-label">{link.label}</span>
            <span class="nb-link-line" aria-hidden="true"></span>
          </a>
        );
      })}
    </nav>

    <!-- Right: Language + Menu trigger -->
    <div class="nb-actions">
      <a href={altHref} class="nb-lang" aria-label={t('nav.changeLanguage')}>
        <span class="nb-lang-inner">
          <span class="nb-lang-dot" aria-hidden="true"></span>
          <span class="nb-lang-code">{altLabel}</span>
        </span>
      </a>

      <button
        class="nb-trigger"
        aria-label={t('nav.openMenu')}
        aria-expanded="false"
        data-grand-trigger
      >
        <span class="nb-trigger-lines" aria-hidden="true">
          <span class="tl"></span>
          <span class="tl"></span>
          <span class="tl tl--short"></span>
        </span>
        <span class="nb-trigger-label" aria-hidden="true">{t('nav.menu')}</span>
      </button>
    </div>

    <!-- Bottom rule: fades horizontal in gold-dim -->
    <div class="nb-rule" aria-hidden="true"></div>
  </div>

  <!-- ░░░ SCROLLED CAPSULE BAR ░░░ -->
  <div class="nb-capsule" aria-hidden="true">
    <!-- Gold accent line at top of capsule -->
    <div class="nb-capsule-accent" aria-hidden="true"></div>
    <div class="nb-capsule-inner">
      <a href={homeHref} class="cap-logo" tabindex="-1" aria-label="GRN URBAN">
        <svg viewBox="0 0 32 32" fill="none" width="22" height="22">
          <path d="M16 2.5 L18.5 10.2 L26.5 7 L21.5 13.5 L28 16 L21.5 18.5 L26.5 25 L18.5 21.8 L16 29.5 L13.5 21.8 L5.5 25 L10.5 18.5 L4 16 L10.5 13.5 L5.5 7 L13.5 10.2 Z" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linejoin="round"/>
          <circle cx="16" cy="16" r="2.5" fill="currentColor"/>
        </svg>
      </a>

      <div class="cap-divider" aria-hidden="true"></div>

      <nav class="cap-nav">
        {navLinks.map((link) => {
          const active = currentPath?.startsWith(link.href) && link.href !== '/';
          return (
            <a
              href={link.href}
              class:list={['cap-link', { 'is-active': active }]}
              tabindex="-1"
              data-initial={link.mobileLabel.charAt(0)}
            >
              <span class="cap-link-num" aria-hidden="true">{link.num}</span>
              <span class="cap-link-abbr" aria-hidden="true">{link.abbr}</span>
              <span class="cap-link-text">{link.shortLabel}</span>
              <span class="cap-link-mobile" aria-hidden="true">{link.mobileLabel}</span>
            </a>
          );
        })}
      </nav>

      <div class="cap-divider" aria-hidden="true"></div>

      <a href={altHref} class="cap-lang" tabindex="-1" aria-hidden="true">{altLabel}</a>

      <button class="cap-menu" tabindex="-1" data-scrolled-menu aria-label={t('nav.openMenu')}>
        <span class="cm-bar"></span>
        <span class="cm-bar"></span>
      </button>
    </div>
  </div>

</header>

<!-- Scroll sentinel -->
<div class="nb-sentinel" aria-hidden="true"></div>

<GrandGate
  locale={locale}
  homeHref={homeHref}
  altHref={altHref}
  altLabel={altLabel}
  navLinks={navLinks}
  currentPath={currentPath}
/>


<script>
  (function () {
    const nav    = document.querySelector('[data-nav-grand]') as HTMLElement | null;
    const trigger = document.querySelector('[data-grand-trigger]') as HTMLButtonElement | null;
    const scrolledMenuBtn = document.querySelector('[data-scrolled-menu]') as HTMLButtonElement | null;
    const gate   = document.querySelector('.gate') as HTMLElement | null;
    const closeButtons = document.querySelectorAll('[data-gate-close]') as NodeListOf<Element>;
    const navLinks = document.querySelectorAll('[data-nav-link]') as NodeListOf<Element>;
    const sentinel = document.querySelector('.nb-sentinel');

    // Scroll state via IntersectionObserver (no scroll listener)
    if (sentinel && nav) {
      new IntersectionObserver(
        ([entry]) => {
          if (entry) {
            nav.classList.toggle('is-scrolled', !entry.isIntersecting);
          }
        },
        { threshold: 0 }
      ).observe(sentinel);
    }

    const openGate = () => {
      gate?.classList.add('is-open');
      gate?.setAttribute('aria-hidden', 'false');
      trigger?.setAttribute('aria-expanded', 'true');
      document.documentElement.style.overflow = 'hidden';
    };

    const closeGate = () => {
      gate?.classList.remove('is-open');
      gate?.setAttribute('aria-hidden', 'true');
      trigger?.setAttribute('aria-expanded', 'false');
      document.documentElement.style.overflow = '';
    };

    trigger?.addEventListener('click', () => {
      trigger.getAttribute('aria-expanded') === 'true' ? closeGate() : openGate();
    });

    scrolledMenuBtn?.addEventListener('click', openGate);
    closeButtons.forEach(el => el.addEventListener('click', closeGate));
    navLinks.forEach(el => el.addEventListener('click', closeGate));

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') closeGate();
    });
  })();
</script>

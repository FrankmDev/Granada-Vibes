  .gate.is-open .gate-footer { opacity: 1; transform: translateY(0); }

  .gf-lang {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    padding: 0.6rem 1.25rem;
    border: 1px solid rgba(201, 168, 76, 0.2);
    transition: border-color 0.3s ease, background 0.3s ease;

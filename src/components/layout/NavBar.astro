---
import type { Locale } from '@types';
import { useTranslations } from '@i18n/utils';
import { LOCALE_PATHS } from '@config/site';

interface Props {
  locale: Locale;
  currentPath?: string;
}

const { locale, currentPath } = Astro.props;
const t = useTranslations(locale);
const localePath = LOCALE_PATHS[locale];

const navLinks = [
  { href: locale === 'es' ? '/eventos'           : '/en/events',        label: t('nav.events'),  shortLabel: t('nav.events'),  num: '01' },
  { href: locale === 'es' ? '/rutas'             : '/en/routes',        label: t('nav.routes'),  shortLabel: t('nav.routes'),  num: '02' },
  { href: locale === 'es' ? '/blog'              : '/en/blog',          label: t('nav.blog'),    shortLabel: t('nav.blog'),    num: '03' },
  { href: locale === 'es' ? '/rutas/por-tiempo'  : '/en/routes/by-time', label: t('nav.byTime'), shortLabel: t('nav.byTime'), num: '04' },
];

const isHome = currentPath === '/' || currentPath === '/en/';
const altHref = locale === 'es' ? '/en/' : '/';
const altLabel = locale === 'es' ? 'EN' : 'ES';
const homeHref = locale === 'es' ? '/' : '/en/';
---

<header class="nb" data-nav-grand aria-label={t('nav.mainNavLabel')}>

  <!-- ░░░ TRANSPARENT TOP BAR (hero state) ░░░ -->
  <div class="nb-bar">

    <!-- Ambient gradient: black to transparent for legibility over video -->
    <div class="nb-ambient" aria-hidden="true"></div>

    <!-- Filmstrip tick marks along top edge -->
    <div class="nb-ticks" aria-hidden="true">
      <span class="tick"></span><span class="tick"></span><span class="tick"></span>
      <span class="tick t-center"></span>
      <span class="tick"></span><span class="tick"></span><span class="tick"></span>
    </div>

    <!-- Left: Logo -->
    <a href={homeHref} class="nb-logo" aria-label="RAWDA — Inicio">
      <span class="nb-logo-star" aria-hidden="true">
        <svg viewBox="0 0 44 44" fill="none">
          <path d="M22 3 L25.2 13.8 L36 8 L29.2 17.5 L38 22 L29.2 26.5 L36 36 L25.2 30.2 L22 41 L18.8 30.2 L8 36 L14.8 26.5 L6 22 L14.8 17.5 L8 8 L18.8 13.8 Z" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linejoin="round"/>
          <circle cx="22" cy="22" r="3.5" fill="currentColor"/>
        </svg>
      </span>
      <span class="nb-logo-text">
        <span class="nb-logo-name">RAWDA</span>
        <span class="nb-logo-tagline">{t('nav.guideLabel')}</span>
      </span>
    </a>

    <!-- Center: Coded nav links -->
    <nav class="nb-center" aria-label={t('nav.mainNavLabel')}>
      {navLinks.map((link) => {
        const active = currentPath?.startsWith(link.href) && link.href !== '/';
        return (
          <a
            href={link.href}
            class:list={['nb-link', { 'is-active': active }]}
            aria-current={active ? 'page' : undefined}
          >
            <span class="nb-link-num" aria-hidden="true">[{link.num}]</span>
            <span class="nb-link-label">{link.label}</span>
            <span class="nb-link-line" aria-hidden="true"></span>
          </a>
        );
      })}
    </nav>

    <!-- Right: Language + Menu trigger -->
    <div class="nb-actions">
      <a href={altHref} class="nb-lang" aria-label={t('nav.changeLanguage')}>
        <span class="nb-lang-inner">
          <span class="nb-lang-dot" aria-hidden="true"></span>
          <span class="nb-lang-code">{altLabel}</span>
        </span>
      </a>

      <button
        class="nb-trigger"
        aria-label={t('nav.openMenu')}
        aria-expanded="false"
        data-grand-trigger
      >
        <span class="nb-trigger-lines" aria-hidden="true">
          <span class="tl"></span>
          <span class="tl"></span>
          <span class="tl tl--short"></span>
        </span>
        <span class="nb-trigger-label" aria-hidden="true">MENÚ</span>
      </button>
    </div>

    <!-- Bottom rule: fades horizontal in gold-dim -->
    <div class="nb-rule" aria-hidden="true"></div>
  </div>

  <!-- ░░░ SCROLLED CAPSULE BAR ░░░ -->
  <div class="nb-capsule" aria-hidden="true">
    <!-- Gold accent line at top of capsule -->
    <div class="nb-capsule-accent" aria-hidden="true"></div>
    <div class="nb-capsule-inner">
      <a href={homeHref} class="cap-logo" tabindex="-1" aria-label="RAWDA">
        <svg viewBox="0 0 32 32" fill="none" width="22" height="22">
          <path d="M16 2.5 L18.5 10.2 L26.5 7 L21.5 13.5 L28 16 L21.5 18.5 L26.5 25 L18.5 21.8 L16 29.5 L13.5 21.8 L5.5 25 L10.5 18.5 L4 16 L10.5 13.5 L5.5 7 L13.5 10.2 Z" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linejoin="round"/>
          <circle cx="16" cy="16" r="2.5" fill="currentColor"/>
        </svg>
      </a>

      <div class="cap-divider" aria-hidden="true"></div>

      <nav class="cap-nav">
        {navLinks.map((link) => {
          const active = currentPath?.startsWith(link.href) && link.href !== '/';
          return (
            <a
              href={link.href}
              class:list={['cap-link', { 'is-active': active }]}
              tabindex="-1"
            >
              <span class="cap-link-num" aria-hidden="true">{link.num}</span>
              {link.shortLabel}
            </a>
          );
        })}
      </nav>

      <div class="cap-divider" aria-hidden="true"></div>

      <a href={altHref} class="cap-lang" tabindex="-1" aria-hidden="true">{altLabel}</a>

      <button class="cap-menu" tabindex="-1" data-scrolled-menu aria-label={t('nav.openMenu')}>
        <span class="cm-bar"></span>
        <span class="cm-bar"></span>
      </button>
    </div>
  </div>

</header>

<!-- Scroll sentinel -->
<div class="nb-sentinel" aria-hidden="true"></div>

<!-- ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
     GRAND GATE — Full-screen split overlay
     ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
<div class="gate" role="dialog" aria-label={t('nav.mainNavLabel')} aria-hidden="true">

  <!-- Curtain panels that slide open -->
  <div class="gate-curtain gate-curtain--l" aria-hidden="true"></div>
  <div class="gate-curtain gate-curtain--r" aria-hidden="true"></div>

  <!-- Grain overlay -->
  <div class="gate-grain" aria-hidden="true"></div>

  <!-- Close button -->
  <button class="gate-close" data-gate-close aria-label={t('nav.closeMenu')}>
    <span class="gc-line"></span>
    <span class="gc-line"></span>
  </button>

  <!-- Content: two-column split -->
  <div class="gate-body">

    <!-- Left: Ghost numbers + decorative -->
    <div class="gate-left" aria-hidden="true">
      <div class="gate-ghost-nums">
        <span class="ghost-num" style="--gn: 0">00</span>
        <span class="ghost-num" style="--gn: 1">01</span>
        <span class="ghost-num" style="--gn: 2">02</span>
        <span class="ghost-num" style="--gn: 3">03</span>
        <span class="ghost-num" style="--gn: 4">04</span>
      </div>
      <div class="gate-coord">
        <span class="coord-line">37°10'N · 3°35'W</span>
        <span class="coord-line">GRANADA, ESPAÑA</span>
      </div>
      <!-- Nazari star watermark -->
      <svg class="gate-star" viewBox="0 0 200 200" fill="none" aria-hidden="true">
        <path d="M100 10 L112 46 L150 34 L126 64 L150 90 L112 78 L100 114 L88 78 L50 90 L74 64 L50 34 L88 46 Z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round" opacity="0.15"/>
        <path d="M100 38 L107 62 L133 54 L115 72 L133 90 L107 82 L100 106 L93 82 L67 90 L85 72 L67 54 L93 62 Z" stroke="currentColor" stroke-width="1" fill="none" stroke-linejoin="round" opacity="0.1"/>
        <circle cx="100" cy="72" r="8" stroke="currentColor" stroke-width="1" opacity="0.2"/>
        <!-- Rotating outer ring -->
        <circle cx="100" cy="100" r="90" stroke="currentColor" stroke-width="0.5" stroke-dasharray="4 8" opacity="0.08" class="gate-ring"/>
      </svg>
    </div>

    <!-- Right: Navigation links -->
    <div class="gate-right">

      <!-- Top: Logo -->
      <div class="gate-header">
        <span class="gate-header-logo">RAWDA</span>
        <span class="gate-header-sub">Guía Cultural · {new Date().getFullYear()}</span>
      </div>

      <!-- Nav items — full-width rows -->
      <nav class="gate-nav" aria-label={t('nav.mainNavLabel')}>
        <div class="gate-item" style="--gi: 0">
          <a href={homeHref} class="gate-link" data-nav-link>
            <span class="gi-num">00</span>
            <span class="gi-label">{t('nav.home')}</span>
            <span class="gi-arrow" aria-hidden="true">→</span>
          </a>
        </div>

        {navLinks.map((link, i) => {
          const active = currentPath?.startsWith(link.href) && link.href !== '/';
          return (
            <div class="gate-item" style={`--gi: ${i + 1}`}>
              <a
                href={link.href}
                class:list={['gate-link', { 'is-active': active }]}
                data-nav-link
                aria-current={active ? 'page' : undefined}
              >
                <span class="gi-num">{link.num}</span>
                <span class="gi-label">{link.label}</span>
                <span class="gi-arrow" aria-hidden="true">→</span>
              </a>
            </div>
          );
        })}
      </nav>

      <!-- Footer: Lang switch + copyright -->
      <div class="gate-footer">
        <a href={altHref} class="gf-lang" data-gate-close>
          <span class="gf-lang-label">{t('nav.switchLanguage')}</span>
          <span class="gf-lang-val">{altLabel}</span>
        </a>
        <p class="gf-copy">© 2026 RAWDA</p>
      </div>

    </div>
  </div>

  <!-- Decorative corner brackets -->
  <div class="gate-corners" aria-hidden="true">
    <span class="gcb gcb--tl"></span>
    <span class="gcb gcb--tr"></span>
    <span class="gcb gcb--bl"></span>
    <span class="gcb gcb--br"></span>
  </div>

</div>

<style>
  /* ═══════════════════════════════════════════════════════
     LOCAL TOKENS
     ═══════════════════════════════════════════════════════ */
  .nb, .gate {
    --gg-gold:      #c9a84c;
    --gg-gold-b:    #e6c587;
    --gg-gold-d:    rgba(201, 168, 76, 0.28);
    --gg-accent:    #e8622a;
    --gg-cream:     #f0ede8;
    --gg-ink:       #080808;
    --gg-expo:      cubic-bezier(0.16, 1, 0.3, 1);
    --gg-spring:    cubic-bezier(0.34, 1.56, 0.64, 1);
    --gg-editorial: cubic-bezier(0.65, 0, 0.35, 1);
  }

  /* ═══════════════════════════════════════════════════════
     HEADER WRAPPER
     ═══════════════════════════════════════════════════════ */
  .nb {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 900;
    pointer-events: none;
  }

  /* ═══════════════════════════════════════════════════════
     TOP BAR — filmstrip, transparent
     ═══════════════════════════════════════════════════════ */
  .nb-bar {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 0 2.5rem;
    height: 72px;
    pointer-events: auto;
    transition: opacity 0.45s var(--gg-expo), transform 0.45s var(--gg-expo);
  }

  .nb.is-scrolled .nb-bar {
    opacity: 0;
    transform: translateY(-8px);
    pointer-events: none;
  }

  /* Ambient gradient for readability over video */
  .nb-ambient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.18) 70%, transparent 100%);
    pointer-events: none;
    z-index: 0;
  }

  /* Filmstrip tick marks along top edge */
  .nb-ticks {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    padding: 0 1.25rem;
    pointer-events: none;
    z-index: 2;
  }

  .tick {
    display: block;
    width: 1px;
    height: 6px;
    background: rgba(201, 168, 76, 0.32);
  }

  /* Center tick is slightly taller — film reference marker */
  .tick.t-center {
    height: 10px;
    background: rgba(201, 168, 76, 0.5);
  }

  /* Bottom rule */
  .nb-rule {
    position: absolute;
    bottom: 0;
    left: 2.5rem;
    right: 2.5rem;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(201, 168, 76, 0.12) 15%,
      rgba(201, 168, 76, 0.35) 50%,
      rgba(201, 168, 76, 0.12) 85%,
      transparent 100%
    );
    z-index: 2;
  }

  /* ── LOGO ── */
  .nb-logo {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nb-logo-star {
    display: flex;
    color: var(--gg-gold);
    width: 38px;
    height: 38px;
    filter: drop-shadow(0 0 8px rgba(201, 168, 76, 0.5)) drop-shadow(0 0 24px rgba(201, 168, 76, 0.2));
    transition: filter 0.55s var(--gg-expo), transform 0.8s var(--gg-expo);
    flex-shrink: 0;
  }

  .nb-logo-star svg {
    width: 100%;
    height: 100%;
  }

  .nb-logo:hover .nb-logo-star {
    filter: drop-shadow(0 0 14px rgba(201, 168, 76, 0.9)) drop-shadow(0 0 40px rgba(201, 168, 76, 0.35));
    transform: rotate(22.5deg);
  }

  .nb-logo-text {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .nb-logo-name {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.26em;
    color: var(--gg-cream);
    line-height: 1;
    text-shadow: 0 1px 16px rgba(0,0,0,1);
  }

  .nb-logo-tagline {
    font-family: var(--font-display);
    font-size: 0.5rem;
    font-weight: 400;
    letter-spacing: 0.14em;
    color: rgba(201, 168, 76, 0.5);
    line-height: 1;
    text-transform: uppercase;
  }

  /* ── CENTER NAV ── */
  .nb-center {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nb-link {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.65rem 1.5rem;
    text-decoration: none;
    overflow: hidden;
  }

  /* Subtle hover wash */
  .nb-link::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(201, 168, 76, 0.04);
    opacity: 0;
    transition: opacity 0.3s ease;
    border-radius: 2px;
  }

  .nb-link:hover::before { opacity: 1; }

  .nb-link-num {
    font-family: var(--font-display);
    font-size: 0.5rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: rgba(201, 168, 76, 0.4);
    transition: color 0.35s ease;
    font-variant-numeric: tabular-nums;
    position: relative;
    z-index: 1;
  }

  .nb-link-label {
    font-family: var(--font-display);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(240, 237, 232, 0.65);
    transition: color 0.35s var(--gg-expo);
    position: relative;
    z-index: 1;
    text-shadow: 0 1px 8px rgba(0,0,0,0.8);
  }

  /* animated underline — scales from left */
  .nb-link-line {
    position: absolute;
    bottom: 7px;
    left: 1.5rem;
    right: 1.5rem;
    height: 1px;
    background: var(--gg-gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.45s var(--gg-expo);
  }

  .nb-link:hover .nb-link-label,
  .nb-link.is-active .nb-link-label {
    color: var(--gg-gold-b);
  }

  .nb-link:hover .nb-link-num {
    color: rgba(201, 168, 76, 0.75);
  }

  .nb-link:hover .nb-link-line,
  .nb-link.is-active .nb-link-line {
    transform: scaleX(1);
  }

  .nb-link.is-active .nb-link-label {
    color: var(--gg-accent);
  }

  .nb-link.is-active .nb-link-num {
    color: rgba(232, 98, 42, 0.6);
  }

  .nb-link.is-active .nb-link-line {
    background: var(--gg-accent);
  }

  /* ── ACTIONS ── */
  .nb-actions {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-shrink: 0;
  }

  /* Language pill */
  .nb-lang {
    display: flex;
    align-items: center;
    text-decoration: none;
    border: 1px solid rgba(201, 168, 76, 0.3);
    border-radius: 100px;
    padding: 0.35rem 0.875rem;
    transition: border-color 0.3s ease, background 0.3s ease;
    background: rgba(201, 168, 76, 0.04);
  }

  .nb-lang:hover {
    border-color: rgba(201, 168, 76, 0.65);
    background: rgba(201, 168, 76, 0.09);
  }

  .nb-lang-inner {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .nb-lang-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--gg-gold);
    opacity: 0.6;
    flex-shrink: 0;
    transition: opacity 0.3s ease;
  }

  .nb-lang:hover .nb-lang-dot { opacity: 1; }

  .nb-lang-code {
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    color: var(--gg-gold);
    transition: color 0.3s ease;
  }

  .nb-lang:hover .nb-lang-code { color: var(--gg-gold-b); }

  /* Menu trigger */
  .nb-trigger {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.45rem 1rem 0.45rem 0.9rem;
    background: transparent;
    border: 1px solid rgba(240, 237, 232, 0.16);
    border-radius: 2px;
    cursor: pointer;
    transition: border-color 0.3s ease, background 0.3s ease;
    pointer-events: auto;
  }

  .nb-trigger:hover {
    border-color: rgba(201, 168, 76, 0.45);
    background: rgba(201, 168, 76, 0.06);
  }

  .nb-trigger-lines {
    display: flex;
    flex-direction: column;
    gap: 4px;
    align-items: flex-start;
  }

  .tl {
    display: block;
    height: 1px;
    background: rgba(240, 237, 232, 0.7);
    transition: width 0.4s var(--gg-expo), background 0.3s ease, transform 0.4s var(--gg-expo);
  }

  .tl:nth-child(1) { width: 18px; }
  .tl:nth-child(2) { width: 14px; }
  .tl--short       { width: 10px; }

  .nb-trigger:hover .tl { background: var(--gg-gold); }
  .nb-trigger:hover .tl:nth-child(2) { width: 18px; }
  .nb-trigger:hover .tl--short { width: 18px; }

  .nb-trigger[aria-expanded="true"] .tl:nth-child(1) {
    transform: translateY(5px) rotate(45deg);
    width: 18px;
  }
  .nb-trigger[aria-expanded="true"] .tl:nth-child(2) {
    opacity: 0;
  }
  .nb-trigger[aria-expanded="true"] .tl--short {
    transform: translateY(-5px) rotate(-45deg);
    width: 18px;
  }

  .nb-trigger-label {
    font-family: var(--font-display);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    color: rgba(240, 237, 232, 0.6);
    transition: color 0.3s ease;
  }

  .nb-trigger:hover .nb-trigger-label {
    color: var(--gg-gold-b);
  }

  /* ═══════════════════════════════════════════════════════
     SENTINEL
     ═══════════════════════════════════════════════════════ */
  .nb-sentinel {
    position: absolute;
    top: 75vh;
    left: 0;
    width: 1px;
    height: 1px;
    pointer-events: none;
  }

  /* ═══════════════════════════════════════════════════════
     CAPSULE BAR — scrolled state (floating pill)
     ═══════════════════════════════════════════════════════ */
  .nb-capsule {
    position: fixed;
    top: 14px;
    left: 50%;
    transform: translateX(-50%) translateY(-80px);
    opacity: 0;
    z-index: 902;
    pointer-events: none;
    transition: transform 0.55s var(--gg-expo), opacity 0.45s var(--gg-expo);
    white-space: nowrap;
  }

  .nb.is-scrolled .nb-capsule {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  /* Thin gold accent line sits above capsule */
  .nb-capsule-accent {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 48px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gg-gold), transparent);
    opacity: 0.55;
    border-radius: 1px;
    z-index: 1;
  }

  .nb-capsule-inner {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0 0.875rem;
    height: 46px;
    background: rgba(6, 6, 6, 0.92);
    backdrop-filter: blur(40px) saturate(160%);
    border: 1px solid rgba(201, 168, 76, 0.2);
    border-radius: 100px;
    box-shadow:
      0 2px 0 rgba(201, 168, 76, 0.12),
      0 10px 40px rgba(0,0,0,0.65),
      inset 0 1px 0 rgba(255,255,255,0.04);
  }

  .cap-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gg-gold);
    filter: drop-shadow(0 0 6px rgba(201, 168, 76, 0.45));
    transition: filter 0.45s ease, transform 0.55s var(--gg-expo);
    padding: 0 0.25rem;
  }

  .cap-logo:hover {
    filter: drop-shadow(0 0 14px rgba(201, 168, 76, 0.8));
    transform: rotate(22.5deg);
  }

  .cap-divider {
    width: 1px;
    height: 18px;
    background: rgba(255,255,255,0.09);
    margin: 0 0.25rem;
    flex-shrink: 0;
  }

  .cap-nav {
    display: flex;
    gap: 0.0625rem;
  }

  .cap-link {
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(240, 237, 232, 0.5);
    padding: 0.3rem 0.875rem;
    border-radius: 100px;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    transition: color 0.25s ease, background 0.25s ease;
  }

  .cap-link-num {
    font-size: 0.48rem;
    letter-spacing: 0.05em;
    color: rgba(201, 168, 76, 0.4);
    font-variant-numeric: tabular-nums;
    transition: color 0.25s ease;
  }

  .cap-link:hover {
    color: var(--gg-cream);
    background: rgba(255,255,255,0.06);
  }

  .cap-link:hover .cap-link-num {
    color: rgba(201, 168, 76, 0.7);
  }

  .cap-link.is-active {
    color: var(--gg-accent);
    background: rgba(232, 98, 42, 0.1);
  }

  .cap-link.is-active .cap-link-num {
    color: rgba(232, 98, 42, 0.55);
  }

  .cap-lang {
    font-family: var(--font-display);
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-decoration: none;
    color: rgba(201, 168, 76, 0.75);
    padding: 0.25rem 0.625rem;
    transition: color 0.25s ease;
  }

  .cap-lang:hover { color: var(--gg-gold-b); }

  .cap-menu {
    display: flex;
    flex-direction: column;
    gap: 4px;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 28px;
    padding: 0;
    background: rgba(201, 168, 76, 0.1);
    border: 1px solid rgba(201, 168, 76, 0.28);
    border-radius: 100px;
    cursor: pointer;
    transition: background 0.25s ease, border-color 0.25s ease;
    margin-left: 0.0625rem;
    flex-shrink: 0;
  }

  .cap-menu:hover {
    background: rgba(201, 168, 76, 0.22);
    border-color: rgba(201, 168, 76, 0.55);
  }

  .cm-bar {
    display: block;
    height: 1px;
    background: var(--gg-gold);
    transition: width 0.3s var(--gg-expo);
  }

  .cm-bar:first-child { width: 11px; }
  .cm-bar:last-child  { width: 7px; }

  .cap-menu:hover .cm-bar { width: 11px; }

  /* ═══════════════════════════════════════════════════════
     GRAND GATE — Full-screen overlay
     ═══════════════════════════════════════════════════════ */
  .gate {
    position: fixed;
    inset: 0;
    z-index: 1000;
    pointer-events: none;
    visibility: hidden;
  }

  .gate.is-open {
    pointer-events: auto;
    visibility: visible;
  }

  /* Curtain panels — slide from center outward (reveal on open, close inward) */
  .gate-curtain {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 50%;
    background: #060606;
    transition: transform 0.75s var(--gg-editorial);
    will-change: transform;
  }

  .gate-curtain--l {
    left: 0;
    transform: translateX(-100%);
  }

  .gate-curtain--r {
    right: 0;
    transform: translateX(100%);
  }

  .gate.is-open .gate-curtain--l { transform: translateX(0); transition-delay: 0s; }
  .gate.is-open .gate-curtain--r { transform: translateX(0); transition-delay: 0.05s; }

  /* Grain texture */
  .gate-grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    mix-blend-mode: soft-light;
  }

  /* Close button */
  .gate-close {
    position: absolute;
    top: 2.5rem;
    right: 2.75rem;
    z-index: 20;
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid rgba(240, 237, 232, 0.12);
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.4s ease 0.6s, border-color 0.3s ease, transform 0.5s var(--gg-expo);
  }

  .gate.is-open .gate-close {
    opacity: 1;
  }

  .gate-close:hover {
    border-color: rgba(232, 98, 42, 0.5);
    transform: rotate(90deg);
  }

  .gc-line {
    position: absolute;
    width: 22px;
    height: 1px;
    background: var(--gg-cream);
    transition: background 0.3s ease;
  }

  .gc-line:first-child { transform: rotate(45deg); }
  .gc-line:last-child  { transform: rotate(-45deg); }

  .gate-close:hover .gc-line { background: var(--gg-accent); }

  /* Body: two-column split */
  .gate-body {
    position: relative;
    z-index: 10;
    width: 100%;
    height: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  /* ── LEFT PANEL: Ghost numbers ── */
  .gate-left {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 3rem 3.5rem;
    border-right: 1px solid rgba(255,255,255,0.05);
    overflow: hidden;
    opacity: 0;
    transition: opacity 0.5s ease 0.4s;
  }

  .gate.is-open .gate-left { opacity: 1; }

  .gate-ghost-nums {
    position: absolute;
    top: 50%;
    left: -0.5rem;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 0;
    pointer-events: none;
  }

  .ghost-num {
    font-family: var(--font-body);
    font-size: clamp(6rem, 12vw, 11rem);
    font-weight: 900;
    line-height: 0.85;
    letter-spacing: -0.04em;
    color: transparent;
    -webkit-text-stroke: 1px rgba(201, 168, 76, 0.12);
    opacity: 0;
    transform: translateX(-30px);
    transition: opacity 0.7s var(--gg-expo), transform 0.7s var(--gg-expo);
    transition-delay: calc(0.35s + var(--gn) * 0.1s);
    user-select: none;
  }

  .gate.is-open .ghost-num {
    opacity: 1;
    transform: translateX(0);
  }

  /* Nazari star watermark */
  .gate-star {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 70%;
    color: var(--gg-gold);
    pointer-events: none;
  }

  .gate-ring {
    animation: ring-spin 30s linear infinite;
    transform-origin: 100px 100px;
  }

  @keyframes ring-spin {
    to { transform: rotate(360deg); }
  }

  /* Coordinate info */
  .gate-coord {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 3px;
    opacity: 0;
    transform: translateY(16px);

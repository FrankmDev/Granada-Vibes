---
import type { Locale } from '@types';
import { SITE_CONFIG, LOCALE_PATHS } from '@config/site';
import { useTranslations } from '@i18n/utils';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const t = useTranslations(locale);

const localePath = LOCALE_PATHS[locale];
const otherLocale = locale === 'es' ? 'en' : 'es';
const otherLocalePath = LOCALE_PATHS[otherLocale];
const switchUrl = otherLocalePath + currentPath.replace(/^\/en/, '');

const navLinks = [
  { href: `${localePath}/`, label: t('nav.home') },
  { href: `${localePath}/eventos`, label: t('nav.events') },
  { href: `${localePath}/rutas`, label: t('nav.routes') },
  { href: `${localePath}/sobre`, label: t('nav.about') },
];

const isActive = (href: string) => {
  if (href === `${localePath}/`) {
    return currentPath === href || currentPath === `${localePath}`;
  }
  return currentPath.startsWith(href);
};
---

<!-- Sentinel for scroll detection -->
<div id="nav-sentinel" class="h-px absolute top-[100px]" aria-hidden="true"></div>

<header
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  id="header"
  role="banner"
>
  <!-- Background -->
  <div
    class="absolute inset-0 transition-all duration-300 opacity-0"
    id="header-bg"
    style="background: rgba(250, 250, 250, 0.85); backdrop-filter: blur(16px); border-bottom: 1px solid rgba(0, 0, 0, 0.06);"
  />

  <div class="container relative">
    <div class="flex items-center justify-between h-[72px]">
      
      <!-- Logo -->
      <a
        href={localePath || '/'}
        class="relative z-10 flex items-center gap-3 group"
        aria-label={`${SITE_CONFIG.name} - ${t('nav.home')}`}
      >
        <!-- Logo icon - Vibrant coral circle -->
        <div class="relative w-10 h-10 rounded-xl bg-primary flex items-center justify-center shadow-soft group-hover:scale-105 transition-transform duration-200">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        
        <!-- Logo text -->
        <div class="flex flex-col">
          <span class="font-display text-lg font-semibold text-surface leading-none tracking-tight">
            {SITE_CONFIG.name}
          </span>
          <span class="text-[10px] text-surface-muted font-medium">Guía Cultural</span>
        </div>
      </a>

      <!-- Desktop Navigation - Clean pill style -->
      <nav class="hidden md:flex items-center gap-1 p-1 bg-white/80 backdrop-blur-sm rounded-full border border-edge/50 shadow-soft-sm" aria-label={t('nav.mainNavLabel')}>
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'relative px-5 py-2.5 text-sm font-medium transition-all duration-200 rounded-full',
              isActive(link.href)
                ? 'bg-surface text-white shadow-soft-sm'
                : 'text-surface-secondary hover:text-surface hover:bg-base-100',
            ]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Right side actions -->
      <div class="flex items-center gap-2 relative z-10">
        <!-- Language switcher -->
        <a
          href={switchUrl}
          class="hidden sm:flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-surface-secondary hover:text-surface bg-white border border-edge/50 rounded-lg hover:border-edge shadow-soft-sm transition-all duration-200"
          aria-label={t('nav.changeLanguage')}
        >
          <span class={locale === 'es' ? 'text-primary' : 'opacity-60'} aria-hidden="true">ES</span>
          <span class="text-edge">/</span>
          <span class={locale === 'en' ? 'text-primary' : 'opacity-60'} aria-hidden="true">EN</span>
        </a>

        <!-- CTA Button -->
        <a
          href={`${localePath}/eventos`}
          class="hidden lg:flex items-center gap-2 px-5 py-2.5 bg-primary text-white text-sm font-semibold rounded-lg hover:bg-primary-hover transition-all duration-200 hover:shadow-glow-primary hover:-translate-y-0.5"
        >
          <span>Explorar</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>

        <!-- Mobile menu button -->
        <button
          type="button"
          class="md:hidden p-2.5 text-surface-secondary hover:text-surface bg-white border border-edge/50 rounded-lg transition-all duration-200 shadow-soft-sm"
          aria-label={t('nav.openMenu')}
          aria-expanded="false"
          aria-controls="mobile-menu"
          id="mobile-menu-button"
        >
          <svg class="w-5 h-5 transition-transform duration-200" id="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden fixed inset-0 top-[72px] bg-white/98 backdrop-blur-2xl z-40"
    role="navigation"
    aria-label={t('nav.mobileNavLabel')}
  >
    <div class="container py-8">
      <nav class="flex flex-col gap-2">
        {navLinks.map((link, index) => (
          <a
            href={link.href}
            class:list={[
              'px-6 py-4 text-xl font-display font-medium rounded-2xl transition-all duration-200',
              isActive(link.href)
                ? 'bg-primary text-white'
                : 'text-surface-secondary hover:text-surface hover:bg-base-100',
            ]}
            style={`animation-delay: ${index * 50}ms`}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Mobile CTA -->
      <div class="mt-8">
        <a
          href={`${localePath}/eventos`}
          class="flex items-center justify-center gap-2 w-full px-6 py-4 bg-primary text-white text-lg font-semibold rounded-2xl hover:bg-primary-hover transition-all duration-200 shadow-glow-primary"
        >
          <span>Explorar eventos</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <div class="mt-6 pt-6 border-t border-edge">
        <a
          href={switchUrl}
          class="flex items-center gap-3 px-6 py-4 text-surface-secondary hover:text-surface rounded-2xl hover:bg-base-100 transition-all duration-200"
          aria-label={t('nav.changeLanguage')}
        >
          <span class="text-sm font-medium">{t('nav.switchLanguage')}</span>
          <span class="font-semibold text-sm uppercase tracking-wider">
            <span class={locale === 'es' ? 'text-primary' : ''}>Español</span>
            <span class="mx-2 text-edge">/</span>
            <span class={locale === 'en' ? 'text-primary' : ''}>English</span>
          </span>
        </a>
      </div>
    </div>
  </div>
</header>

<script src="../../scripts/navBar.ts"></script>

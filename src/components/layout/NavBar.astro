  .gate-link:hover { padding-left: 0.75rem; }
  .gate-link:hover::before { transform: scaleX(1); }

  .gate-link.is-active::before {
    background: linear-gradient(90deg, rgba(232, 98, 42, 0.08) 0%, transparent 80%);

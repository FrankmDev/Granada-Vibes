---
import type { Locale } from '@types';
import { useTranslations } from '@i18n/utils';
import { LOCALE_PATHS } from '@config/site';

interface Props {
  locale: Locale;
  currentPath?: string;
}

const { locale, currentPath } = Astro.props;
const t = useTranslations(locale);
const localePath = LOCALE_PATHS[locale];

const navLinks = [
  { href: `${localePath}/eventos`, label: t('nav.events') },
  { href: `${localePath}/rutas`,   label: t('nav.routes') },
  { href: `${localePath}/sobre`,   label: t('nav.about') },
];
---

<header class="glass-nav" data-nav>
  <div class="nav-pill">
    
    <!-- Branding -->
    <a href={`/${locale === 'es' ? '' : locale}`} class="nav-brand">
      <span class="brand-text">GRANADA</span>
    </a>

    <!-- Primary Links -->
    <nav class="nav-main">
      <ul class="nav-list">
        {navLinks.map((link) => (
          <li class="nav-item">
            <a href={link.href} class={`nav-link ${currentPath === link.href ? 'is-active' : ''}`}>
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Actions / Mobile Toggle -->
    <div class="nav-actions">
      <a href={`${localePath}/rutas`} class="pill-btn hide-mobile">
        {locale === 'es' ? 'PLANIFICAR' : 'PLAN VISIT'}
      </a>

      <button class="burger-btn" aria-label="Menu" data-mobile-toggle>
        <div class="burger-lines">
          <span class="burger-line top"></span>
          <span class="burger-line bottom"></span>
        </div>
      </button>
    </div>
    
  </div>

  <!-- Mobile Menu Splash Overlay -->
  <div class="nav-mobile" data-mobile-menu>
    <div class="mobile-content">
      <div class="mobile-header">
        <span class="brand-text">GRANADA</span>
        <button class="mobile-close" data-mobile-close aria-label="Close">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 6L6 18M6 6L18 18" stroke-linecap="round"/>
          </svg>
        </button>
      </div>

      <nav class="mobile-links">
        {navLinks.map((link) => (
          <a href={link.href} class={`mobile-link ${currentPath === link.href ? 'is-active' : ''}`}>
            {link.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>

<style>
  :root {
    --glass-bg: rgba(30, 30, 30, 0.35);
    --glass-border: rgba(255, 255, 255, 0.15);
    --glass-glow: rgba(255, 255, 255, 0.05);
    --text-primary: #ffffff;
    --text-muted: rgba(255, 255, 255, 0.7);
  }

  /* 
   * LUXURY GLASS PILL NAVIGATION
   */
  .glass-nav {
    position: fixed;
    top: 2rem;
    left: 0; 
    right: 0;
    z-index: 100;
    display: flex;
    justify-content: center;
    padding: 0 1.5rem;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), top 0.6s ease;
  }

  .glass-nav.is-scrolled {
    top: 1rem; /* Clings slightly tighter to top on scroll */
    transform: scale(0.98);
  }

  .nav-pill {
    width: 100%;
    max-width: 1200px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1rem 0 2rem;
    
    /* Elegant Glassmorphism */
    background: var(--glass-bg);
    backdrop-filter: blur(24px) saturate(120%);
    -webkit-backdrop-filter: blur(24px) saturate(120%);
    border: 1px solid var(--glass-border);
    border-radius: 100px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2), inset 0 1px 0 var(--glass-glow);
    transition: all 0.5s ease;
  }

  .glass-nav.is-scrolled .nav-pill {
    background: rgba(15, 15, 15, 0.6);
    border-color: rgba(255,255,255,0.1);
  }

  /* BRANDING */
  .nav-brand {
    text-decoration: none;
    color: var(--text-primary);
  }

  .brand-text {
    font-family: var(--font-body, 'Lora', serif);
    font-size: 1.25rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* DESKTOP LINKS */
  .nav-main { display: none; }
  
  @media (min-width: 1024px) {
    .nav-main {
      display: flex;
      flex: 1;
      justify-content: center;
    }
  }

  .nav-list {
    display: flex;
    gap: 3rem;
    list-style: none;
    margin: 0; padding: 0;
  }

  .nav-link {
    font-family: var(--font-display, 'Inter', sans-serif);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    padding: 0.5rem 1rem;
    border-radius: 100px;
    transition: all 0.3s ease;
  }

  .nav-link:hover, .nav-link.is-active {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.1);
  }

  /* ACTIONS */
  .nav-actions {
    display: flex;
    align-items: center;
  }

  .hide-mobile { display: none; }
  @media (min-width: 1024px) {
    .hide-mobile { display: block; }
  }

  .pill-btn {
    font-family: var(--font-display, 'Inter', sans-serif);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #000;
    background: #fff;
    padding: 0.75rem 1.5rem;
    border-radius: 100px;
    text-decoration: none;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), background 0.3s;
  }

  .pill-btn:hover {
    transform: scale(1.05);
    background: #e0e0e0;
  }

  /* BURGER TOGGLE */
  .burger-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: transparent;
    border: none;
    cursor: pointer;
    z-index: 200;
  }

  @media (min-width: 1024px) {
    .burger-btn { display: none; }
  }

  .burger-lines {
    width: 22px;
    height: 8px;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .burger-line {
    width: 100%;
    height: 1.5px;
    background: var(--text-primary);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .glass-nav.is-mobile-open .burger-line.top { transform: translateY(3.25px) rotate(45deg); width: 100%;}
  .glass-nav.is-mobile-open .burger-line.bottom { transform: translateY(-3.25px) rotate(-45deg); width: 100%;}

  /* MOBILE MENU SPLASH */
  .nav-mobile {
    position: fixed;
    inset: 0;
    background: rgba(10, 10, 10, 0.5);
    backdrop-filter: blur(40px) saturate(150%);
    -webkit-backdrop-filter: blur(40px) saturate(150%);
    z-index: 150;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1), visibility 0.5s;
    display: flex;
    flex-direction: column;
  }

  .glass-nav.is-mobile-open .nav-mobile {
    opacity: 1;
    visibility: visible;
  }

  .mobile-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 2rem;
  }

  .mobile-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 64px;
  }

  .mobile-close {
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 50%;
    color: var(--text-primary);
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .mobile-links {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 2rem;
  }

  .mobile-link {
    font-family: var(--font-body, 'Lora', serif);
    font-size: clamp(2rem, 10vw, 4rem);
    text-decoration: none;
    color: var(--text-primary);
    text-transform: uppercase;
    transition: color 0.3s, transform 0.3s;
  }

  .mobile-link:hover {
    color: #c9a84c; /* Warm tourism gold accent */
    transform: scale(1.05);
  }

  @media (max-width: 768px) {
    .glass-nav {
      top: 1rem;
      padding: 0 1rem;
    }
  }
</style>

<script>
  (function() {
    const nav = document.querySelector('[data-nav]');
    const handleScroll = () => {
      if (window.scrollY > 50) nav?.classList.add('is-scrolled');
      else nav?.classList.remove('is-scrolled');
    };
    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();

    // Mobile Menu
    const toggle = document.querySelector('[data-mobile-toggle]');
    const close = document.querySelector('[data-mobile-close]');
    const links = document.querySelectorAll('.mobile-link');
    
    const setMenu = (open: boolean) => {
      if (open) {
        nav?.classList.add('is-mobile-open');
        document.documentElement.style.overflow = 'hidden';
      } else {
        nav?.classList.remove('is-mobile-open');
        document.documentElement.style.overflow = '';
      }
    };

    toggle?.addEventListener('click', () => setMenu(true));
    close?.addEventListener('click', () => setMenu(false));
    links.forEach(l => l.addEventListener('click', () => setMenu(false)));
  })();
</script>
    position: relative;
    z-index: 1;
    transition: color 0.4s var(--gg-expo);
  }

  .gate-link:hover .gi-label { color: var(--gg-gold-b); }
  .gate-link.is-active .gi-label { color: var(--gg-accent); }

  .gi-arrow {
    font-size: 1.1rem;

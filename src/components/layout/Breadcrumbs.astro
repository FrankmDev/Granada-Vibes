---
import { icons } from '@config/ui';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
  variant?: 'dark' | 'light';
}

const { items, variant = 'dark' } = Astro.props;

const isLight = variant === 'light';
const linkClass = isLight
  ? 'text-ink-3 hover:text-orange transition-colors'
  : 'text-white/40 hover:text-accent transition-colors';
const activeClass = isLight
  ? 'text-ink font-medium'
  : 'text-white font-medium';
const sepClass = isLight
  ? 'text-ink-3/30'
  : 'text-white/30';
---

<nav aria-label="Breadcrumb" class="mb-8">
  <ol class="flex flex-wrap items-center gap-2 text-sm">
    {items.map((item, index) => (
      <li class="flex items-center gap-2">
        {index > 0 && (
          <svg class={`w-4 h-4 ${sepClass}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icons.chevronRight} />
          </svg>
        )}
        {item.href ? (
          <a href={item.href} class={linkClass}>
            {item.label}
          </a>
        ) : (
          <span class={activeClass} aria-current="page">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<style>
  .text-ink { color: var(--s-ink, #1a1619); }
  .text-ink-3 { color: var(--s-ink-3, #8a7f77); }
  .text-orange { color: var(--s-orange, #e8622a); }
</style>

---
import type { Locale } from '@types';
import { LOCALE_PATHS } from '@config/site';

interface NavLink {
  href: string;
  label: string;
}

interface Props {
  locale: Locale;
  navLinks: NavLink[];
  switchUrl: string;
  isActive: (href: string) => boolean;
  t: (key: string) => string;
}

const { locale, navLinks, switchUrl, isActive, t } = Astro.props;
const localePath = LOCALE_PATHS[locale];
---

<div
  id="mobile-menu"
  class="nav-mobile hidden"
  role="navigation"
  aria-label={t('nav.mobileNavLabel')}
>
  <!-- Full-screen overlay -->
  <div class="nav-mobile__inner">
    <!-- Header row with logo placeholder + close implicit via btn -->
    <div class="nav-mobile__top" aria-hidden="true">
      <span class="nav-mobile__gv">GV</span>
    </div>

    <!-- Links -->
    <nav class="nav-mobile__nav">
      {navLinks.map((link, index) => (
        <a
          href={link.href}
          class:list={['nav-mobile__link', isActive(link.href) && 'is-active']}
          style={`--idx: ${index}`}
          aria-current={isActive(link.href) ? 'page' : undefined}
        >
          <span class="nav-mobile__link-num">{String(index + 1).padStart(2, '0')}</span>
          <span class="nav-mobile__link-text">{link.label}</span>
          <span class="nav-mobile__link-arrow" aria-hidden="true">→</span>
        </a>
      ))}
    </nav>

    <!-- Footer row -->
    <div class="nav-mobile__footer">
      <a href={`${localePath}/eventos`} class="nav-mobile__cta">
        <span>{locale === 'es' ? 'explorar eventos' : 'explore events'}</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>

      <a href={switchUrl} class="nav-mobile__lang">
        <span class="nav-mobile__lang-label">{locale === 'es' ? 'Switch to English' : 'Ver en español'}</span>
        <span class="nav-mobile__lang-badge">{locale === 'es' ? 'EN' : 'ES'}</span>
      </a>
    </div>
  </div>
</div>

<style>
  .nav-mobile {
    position: fixed;
    inset: 0;
    z-index: 40;
    background: var(--color-bg);
    overflow: hidden;
    width: 100vw;
    max-width: 100vw;
  }

  .nav-mobile.is-open .nav-mobile__inner {
    opacity: 1;
    transform: translateY(0);
  }

  .nav-mobile__inner {
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    opacity: 0;
    transform: translateY(-12px);
    transition: opacity 0.32s var(--ease-editorial), transform 0.32s var(--ease-editorial);
    box-sizing: border-box;
    width: 100%;
    max-width: 100vw;
    overflow-x: hidden;
  }

  .nav-mobile__top {
    display: flex;
    align-items: center;
    height: var(--header-height);
    margin-bottom: 3rem;
  }

  .nav-mobile__gv {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 900;
    font-style: italic;
    color: var(--color-accent);
    letter-spacing: -0.04em;
  }

  /* ── Nav links ── */
  .nav-mobile__nav {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0;
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
  }

  .nav-mobile__link {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border-subtle);
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 7vw, 2.5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: all 0.25s ease;
    max-width: 100%;
    overflow-wrap: break-word;
    word-wrap: break-word;
    hyphens: auto;
  }

  .nav-mobile__link:first-child {
    border-top: 1px solid var(--color-border-subtle);
  }

  .nav-mobile__link:hover,
  .nav-mobile__link.is-active {
    color: var(--color-text-primary);
    padding-left: 0.5rem;
  }

  .nav-mobile__link.is-active {
    color: var(--color-accent);
  }

  .nav-mobile__link-num {
    font-family: var(--font-body);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
    flex-shrink: 0;
    align-self: center;
  }

  .nav-mobile__link-text {
    flex: 1;
    text-transform: lowercase;
    min-width: 0;
    overflow-wrap: break-word;
    word-wrap: break-word;
  }

  .nav-mobile__link-arrow {
    font-size: 1rem;
    color: var(--color-accent);
    opacity: 0;
    transition: opacity 0.2s ease;
    align-self: center;
  }

  .nav-mobile__link:hover .nav-mobile__link-arrow,
  .nav-mobile__link.is-active .nav-mobile__link-arrow {
    opacity: 1;
  }

  /* ── Footer row ── */
  .nav-mobile__footer {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border-subtle);
    width: 100%;
    max-width: 100%;
  }

  .nav-mobile__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 1rem 1.5rem;
    background: var(--color-accent);
    color: #ffffff;
    transition: background 0.2s ease;
  }

  .nav-mobile__cta:hover {
    background: var(--color-accent-hover);
  }

  .nav-mobile__lang {
    display: flex;
    align-items: center;
    justify-content: space-between;
    text-decoration: none;
    padding: 0.75rem 0;
  }

  .nav-mobile__lang-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: lowercase;
  }

  .nav-mobile__lang-badge {
    font-family: var(--font-body);
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--color-text-secondary);
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--color-border);
    transition: all 0.2s ease;
  }

  .nav-mobile__lang:hover .nav-mobile__lang-badge {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
</style>

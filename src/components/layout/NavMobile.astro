---
import type { Locale } from '@types';
import { LOCALE_PATHS } from '@config/site';

interface NavLink {
  href: string;
  label: string;
  abbr?: string;
}

interface Props {
  locale: Locale;
  navLinks: NavLink[];
  switchUrl: string;
  isActive: (href: string) => boolean;
  t: (key: string) => string;
}

const { locale, navLinks, switchUrl, isActive, t } = Astro.props;
const localePath = LOCALE_PATHS[locale];

function getAbbr(link: NavLink): string {
  if (link.abbr) return link.abbr.toUpperCase();
  // Derive a two-letter code from the label (e.g. "Eventos" → "EV")
  return link.label.slice(0, 2).toUpperCase();
}
---

<div
  id="mobile-menu"
  class="nav-mobile hidden"
  role="navigation"
  aria-label={t('nav.mobileNavLabel')}
>
  <!-- Full-screen overlay -->
  <div class="nav-mobile__inner">
    <!-- Header row with logo placeholder + close implicit via btn -->
    <div class="nav-mobile__top" aria-hidden="true">
      <span class="nav-mobile__gv">GV</span>
    </div>

    <!-- Links — large, tappable rows with single-letter orbit badges -->
    <nav class="nav-mobile__nav">
      {navLinks.map((link, index) => {
        const active = isActive(link.href);
        return (
          <a
            href={link.href}
            class:list={['nav-mobile__link', active && 'is-active']}
            style={`--idx: ${index}`}
            aria-current={active ? 'page' : undefined}
          >
            <span class="nav-mobile__link-orbit" aria-hidden="true">
              <span class="nav-mobile__link-initial">{link.label.charAt(0)}</span>
            </span>
            <span class="nav-mobile__link-body">
              <span class="nav-mobile__link-text">{link.label}</span>
              <span class="nav-mobile__link-meta">{active ? 'Estás aquí' : 'Ir a sección'}</span>
            </span>
            <span class="nav-mobile__link-arrow" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </a>
        );
      })}
    </nav>

    <!-- Footer row -->
    <div class="nav-mobile__footer">
      <a href={`${localePath}/eventos/`} class="nav-mobile__cta">
        <span>{t('common.exploreEvents')}</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>

      <a href={switchUrl} class="nav-mobile__lang">
        <span class="nav-mobile__lang-label">{t('nav.changeLanguage')}</span>
        <span class="nav-mobile__lang-badge">{locale === 'es' ? 'EN' : 'ES'}</span>
      </a>
    </div>
  </div>
</div>

<style>
  .nav-mobile {
    position: fixed;
    inset: 0;
    z-index: 40;
    background: var(--color-bg);
    overflow: hidden;
    width: 100vw;
    max-width: 100vw;
  }

  .nav-mobile.is-open .nav-mobile__inner {
    opacity: 1;
    transform: translateY(0);
  }

  .nav-mobile__inner {
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: 1.5rem 2rem;
    opacity: 0;
    transform: translateY(-12px);
    transition: opacity 0.32s var(--ease-editorial), transform 0.32s var(--ease-editorial);
    box-sizing: border-box;
    width: 100%;
    max-width: 100vw;
    overflow-x: hidden;
  }

  .nav-mobile__top {
    display: flex;
    align-items: center;
    height: var(--header-height);
    margin-bottom: 3rem;
  }

  .nav-mobile__gv {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 900;
    font-style: italic;
    color: var(--color-accent);
    letter-spacing: -0.04em;
  }

  /* ── Nav links — large tappable rows ── */
  .nav-mobile__nav {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
  }

  .nav-mobile__link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    font-family: var(--font-display);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: all 0.25s var(--ease-editorial);
    max-width: 100%;
  }

  .nav-mobile__link:hover,
  .nav-mobile__link.is-active {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(232, 98, 42, 0.25);
    color: var(--color-text-primary);
  }

  .nav-mobile__link.is-active {
    background: rgba(232, 98, 42, 0.08);
    border-color: rgba(232, 98, 42, 0.35);
    box-shadow: 0 0 24px rgba(232, 98, 42, 0.08);
  }

  /* Orbit badge with initial */
  .nav-mobile__link-orbit {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(201, 168, 76, 0.08);
    border: 1px solid rgba(201, 168, 76, 0.25);
    flex-shrink: 0;
    transition: all 0.3s ease;
  }

  .nav-mobile__link:hover .nav-mobile__link-orbit,
  .nav-mobile__link.is-active .nav-mobile__link-orbit {
    background: rgba(232, 98, 42, 0.12);
    border-color: rgba(232, 98, 42, 0.45);
    transform: scale(1.05);
  }

  .nav-mobile__link-initial {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-gold);
    text-transform: uppercase;
    line-height: 1;
  }

  .nav-mobile__link.is-active .nav-mobile__link-initial {
    color: var(--color-accent);
  }

  /* Body: label + meta */
  .nav-mobile__link-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .nav-mobile__link-text {
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    line-height: 1.2;
  }

  .nav-mobile__link-meta {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-text-secondary);
    text-transform: lowercase;
  }

  .nav-mobile__link.is-active .nav-mobile__link-meta {
    color: rgba(232, 98, 42, 0.7);
  }

  /* Arrow */
  .nav-mobile__link-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    opacity: 0;
    transform: translateX(-6px);
    transition: all 0.3s var(--ease-editorial);
    flex-shrink: 0;
  }

  .nav-mobile__link:hover .nav-mobile__link-arrow,
  .nav-mobile__link.is-active .nav-mobile__link-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── Footer row ── */
  .nav-mobile__footer {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border-subtle);
    width: 100%;
    max-width: 100%;
  }

  .nav-mobile__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 1rem 1.5rem;
    background: var(--color-accent);
    color: #ffffff;
    transition: background 0.2s ease;
  }

  .nav-mobile__cta:hover {
    background: var(--color-accent-hover);
  }

  .nav-mobile__lang {
    display: flex;
    align-items: center;
    justify-content: space-between;
    text-decoration: none;
    padding: 0.75rem 0;
  }

  .nav-mobile__lang-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: lowercase;
  }

  .nav-mobile__lang-badge {
    font-family: var(--font-body);
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--color-text-secondary);
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--color-border);
    transition: all 0.2s ease;
  }

  .nav-mobile__lang:hover .nav-mobile__lang-badge {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
</style>

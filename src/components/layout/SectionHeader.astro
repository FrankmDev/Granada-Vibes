---
interface Props {
  overline: string;
  title: string;
  description?: string;
  href?: string;
  linkText?: string;
  accent?: 'terra' | 'amber' | 'mint';
  centered?: boolean;
}

const { 
  overline, 
  title, 
  description, 
  href, 
  linkText,
  accent = 'terra',
  centered = false 
} = Astro.props;

const accentColors = {
  terra: 'text-terra',
  amber: 'text-amber',
  mint: 'text-mint',
};

const accentBgColors = {
  terra: 'bg-terra',
  amber: 'bg-amber',
  mint: 'bg-mint',
};

const accentBorderColors = {
  terra: 'border-terra/30 hover:border-terra/50',
  amber: 'border-amber/30 hover:border-amber/50',
  mint: 'border-mint/30 hover:border-mint/50',
};

const accentTextHoverColors = {
  terra: 'group-hover:text-terra',
  amber: 'group-hover:text-amber',
  mint: 'group-hover:text-mint',
};
---

<div class:list={['mb-12 lg:mb-16', centered && 'text-center']}>
  {/* Overline */}
  <div class:list={['flex items-center gap-3 mb-5', centered && 'justify-center']}>
    <span class:list={['w-12 h-[2px]', accentBgColors[accent]]}></span>
    <span class:list={['text-xs font-bold uppercase tracking-[0.2em]', accentColors[accent]]}>
      {overline}
    </span>
    <span class:list={['w-12 h-[2px]', accentBgColors[accent], centered ? 'block' : 'hidden']}></span>
  </div>
  
  {/* Title and link row */}
  <div class:list={['flex flex-col lg:flex-row lg:items-end gap-6', centered && 'flex-col items-center']}>
    <div class:list={[centered && 'max-w-2xl']}> 
      <h2 class="font-display text-4xl lg:text-5xl font-bold text-surface mb-4 leading-tight">
        {title}
      </h2>
      {description && (
        <p class="text-lg text-surface-secondary max-w-xl">
          {description}
        </p>
      )}
    </div>
    
    {href && linkText && (
      <div class:list={['lg:ml-auto', centered && 'lg:mx-auto lg:mt-4']}>
        <a 
          href={href} 
          class:list={[
            'group inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold text-surface-secondary border rounded-xl transition-all duration-300 hover:-translate-y-0.5',
            accentBorderColors[accent]
          ]}
        >
          <span class:list={['transition-colors duration-300', accentTextHoverColors[accent]]}>
            {linkText}
          </span>
          <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    )}
  </div>
</div>

---
interface Props {
  title: string;
  subtitle?: string;
  accent?: 'primary' | 'secondary' | 'tertiary' | 'success';
  centered?: boolean;
  variant?: 'default' | 'large' | 'minimal';
  overline?: string;
  backgroundVideo?: boolean;
  backgroundImage?: string;
}

const {
  title,
  subtitle,
  accent = 'primary',
  centered = false,
  variant = 'default',
  overline,
  backgroundVideo = false,
  backgroundImage,
} = Astro.props;

const accentColorMap = {
  primary: '#e8622a',
  secondary: '#c9a84c',
  tertiary: '#06b6d4',
  success: '#4a9e6b',
};

const accentColor = accentColorMap[accent];

const sizeClasses = {
  minimal: { height: 'min-h-[40vh]', padding: 'py-16', title: 'text-3xl md:text-4xl lg:text-5xl' },
  default: { height: 'min-h-[55vh]', padding: 'py-20 md:py-28', title: 'text-4xl md:text-5xl lg:text-6xl xl:text-7xl' },
  large: { height: 'min-h-[70vh]', padding: 'py-24 md:py-36', title: 'text-5xl md:text-6xl lg:text-7xl xl:text-8xl' },
};
---

<section
  class:list={['page-header', sizeClasses[variant].height]}
  style={`--accent: ${accentColor}`}
  aria-labelledby="page-title"
>
  <!-- Capa 1: Background -->
  {backgroundVideo ? (
    <div class="page-header__video-layer" aria-hidden="true">
      <video 
        class="page-header__video" 
        autoplay 
        muted 
        loop 
        playsinline
      >
        <source src="/heroVideo.mp4" type="video/mp4" />
      </video>
      <div class="page-header__video-vignette"></div>
    </div>
  ) : backgroundImage ? (
    <div class="page-header__image-layer" aria-hidden="true">
      <img src={backgroundImage} alt="" class="page-header__image" />
      <div class="page-header__image-vignette"></div>
    </div>
  ) : (
    <div class="page-header__gradient-bg" aria-hidden="true"></div>
  )}
  
  <!-- Capa 2: Glows atmosfericos -->
  <div class="page-header__atmosphere" aria-hidden="true">
    <div class="page-header__glow page-header__glow--1"></div>
    <div class="page-header__glow page-header__glow--2"></div>
  </div>

  <!-- Capa 3: Particulas sutiles -->
  <div class="page-header__particles" aria-hidden="true">
    {[...Array(15)].map((_, i) => (
      <div 
        class="particle" 
        style={`--delay: ${Math.random() * 5}s; --duration: ${20 + Math.random() * 15}s; --size: ${1 + Math.random() * 3}px; --x: ${Math.random() * 100}%`}
      />
    ))}
  </div>

  <!-- Capa 4: Gradiente de profundidad -->
  <div class="page-header__depth" aria-hidden="true"></div>

  <!-- Contenido -->
  <div class="page-header__content">
    <div class:list={['page-header__inner', centered && 'items-center text-center', !centered && 'items-start text-left']}>
      
      {overline && (
        <div class="page-header__tag-wrapper">
          <span class="page-header__tag-dot"></span>
          <span class="page-header__overline">{overline}</span>
        </div>
      )}

      <h1 
        id="page-title" 
        class:list={['page-header__title', sizeClasses[variant].title]}
      >
        {title}
      </h1>

      {subtitle && (
        <p class="page-header__subtitle">
          {subtitle}
        </p>
      )}

      <div class="page-header__accent"></div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="page-header__bottom-bar">
    <slot name="bottom-bar" />
  </div>
</section>

<style>
  .page-header {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    background: #050505;
  }

  .page-header__video-layer,
  .page-header__image-layer {
    position: absolute;
    inset: 0;
    z-index: 1;
    overflow: hidden;
  }

  .page-header__video,
  .page-header__image {
    position: absolute;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.7;
    filter: contrast(1.1) saturate(1.1);
  }

  .page-header__video-vignette,
  .page-header__image-vignette {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(5, 5, 5, 0.98) 0%, rgba(5, 5, 5, 0.8) 40%, rgba(5, 5, 5, 0.6) 70%, rgba(5, 5, 5, 0.75) 100%);
  }

  .page-header__gradient-bg {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(135deg, #0a0a0a 0%, #050505 50%, #080808 100%);
  }

  .page-header__atmosphere {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }

  .page-header__glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.3;
    animation: glow-pulse 10s ease-in-out infinite;
  }

  .page-header__glow--1 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(232, 98, 42, 0.25) 0%, transparent 70%);
    top: -5%;
    right: -5%;
    animation-delay: 0s;
  }

  .page-header__glow--2 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(201, 168, 76, 0.2) 0%, transparent 70%);
    bottom: 10%;
    left: -5%;
    animation-delay: -5s;
  }

  @keyframes glow-pulse {
    0%, 100% { transform: scale(1); opacity: 0.3; }
    50% { transform: scale(1.15); opacity: 0.5; }
  }

  .page-header__particles {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    overflow: hidden;
  }

  .particle {
    position: absolute;
    width: var(--size);
    height: var(--size);
    left: var(--x);
    bottom: -10px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.8) 0%, rgba(201, 168, 76, 0.4) 50%, transparent 100%);
    border-radius: 50%;
    animation: particle-float var(--duration) ease-in-out infinite;
    animation-delay: var(--delay);
    opacity: 0;
  }

  @keyframes particle-float {
    0% {
      transform: translateY(0);
      opacity: 0;
    }
    10% {
      opacity: 0.6;
    }
    90% {
      opacity: 0.6;
    }
    100% {
      transform: translateY(-100vh);
      opacity: 0;
    }
  }

  .page-header__depth {
    position: absolute;
    inset: 0;
    z-index: 4;
    background: linear-gradient(180deg, rgba(0,0,0,0.4) 0%, transparent 40%, transparent 60%, rgba(0,0,0,0.6) 100%);
    pointer-events: none;
  }

  .page-header__content {
    position: relative;
    z-index: 10;
    flex: 1;
    display: flex;
    align-items: flex-end;
    padding: clamp(2rem, 5vw, 4rem);
    padding-top: calc(var(--nav-height, 80px) + 2rem);
  }

  .page-header__inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 900px;
    animation: fade-in-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
  }

  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .page-header__tag-wrapper {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    padding: 0.625rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(10px);
    width: fit-content;
    animation: fade-in 0.6s ease 0.1s both;
  }

  .page-header__tag-dot {
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 50%;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.3); opacity: 0.7; }
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .page-header__title {
    margin: 0;
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    line-height: 0.95;
    color: #fff;
    animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
  }

  @keyframes slide-up {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .page-header__subtitle {
    font-family: 'Inter', sans-serif;
    font-size: clamp(0.9375rem, 1.5vw, 1.125rem);
    font-weight: 400;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.7);
    margin: 0.5rem 0 0;
    max-width: 600px;
    animation: fade-in 0.6s ease 0.3s both;
  }

  .page-header__accent {
    width: 80px;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), rgba(201, 168, 76, 0.8), transparent);
    margin-top: 1.5rem;
    animation: accent-grow 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.4s both;
  }

  @keyframes accent-grow {
    from { transform: scaleX(0); transform-origin: left; }
    to { transform: scaleX(1); transform-origin: left; }
  }

  .page-header__inner.items-center .page-header__accent {
    transform-origin: center;
  }

  .page-header__bottom-bar {
    position: relative;
    z-index: 10;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    background: rgba(5, 5, 5, 0.8);
    backdrop-filter: blur(20px);
  }

  .page-header__bottom-bar:empty {
    display: none;
  }
</style>

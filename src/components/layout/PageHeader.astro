---
interface Props {
  title: string;
  subtitle?: string;
  accent?: 'primary' | 'secondary' | 'success';
  centered?: boolean;
  variant?: 'default' | 'large' | 'minimal';
  overline?: string;
  backgroundVideo?: boolean;
  backgroundImage?: string;
  frameTagTopLeft?: string;
  frameTagTopRight?: string;
  frameTagBottomLeft?: string;
  frameTagBottomRight?: string;
  showParallax?: boolean;
}

const {
  title,
  subtitle,
  accent = 'primary',
  centered = false,
  variant = 'default',
  overline,
  backgroundVideo = false,
  backgroundImage,
  frameTagTopLeft = 'GV',
  frameTagTopRight = '37°10′28″N',
  frameTagBottomLeft,
  frameTagBottomRight = '2026',
  showParallax = true,
} = Astro.props;

const accentTokenMap = {
  primary: 'var(--color-accent)',
  secondary: 'var(--color-gold)',
  success: 'var(--color-success)',
};

const accentToken = accentTokenMap[accent];

const variantMap = {
  minimal: { minHeight: '40vh', paddingTop: 'calc(var(--header-height) + 3rem)', paddingBottom: '2.5rem' },
  default: { minHeight: '55vh', paddingTop: 'calc(var(--header-height) + 4rem)', paddingBottom: '3.5rem' },
  large:   { minHeight: '78vh', paddingTop: 'calc(var(--header-height) + 5rem)', paddingBottom: '4.5rem' },
};

const v = variantMap[variant];

// Split title for char animation with word grouping
const titleWords = title.split(' ');
---

<section
  class:list={['page-header', `page-header--${variant}`, centered && 'page-header--centered']}
  style={`--ph-accent: ${accentToken}; --ph-min-height: ${v.minHeight}; --ph-pt: ${v.paddingTop}; --ph-pb: ${v.paddingBottom};`}
  aria-labelledby="page-title"
  data-parallax={showParallax}
>
  <!-- Organic Cinematic Frame -->
  <div class="ph-frame" aria-hidden="true">
    <div class="ph-frame-layer ph-frame-layer--outer"></div>
    <div class="ph-frame-layer ph-frame-layer--inner"></div>
    
    <!-- Corner Elements -->
    <div class="ph-corner ph-corner--tl">
      <span class="corner-line corner-line--h"></span>
      <span class="corner-line corner-line--v"></span>
      <span class="corner-dot"></span>
    </div>
    <div class="ph-corner ph-corner--tr">
      <span class="corner-line corner-line--h"></span>
      <span class="corner-line corner-line--v"></span>
      <span class="corner-dot"></span>
    </div>
    <div class="ph-corner ph-corner--bl">
      <span class="corner-line corner-line--h"></span>
      <span class="corner-line corner-line--v"></span>
      <span class="corner-dot"></span>
    </div>
    <div class="ph-corner ph-corner--br">
      <span class="corner-line corner-line--h"></span>
      <span class="corner-line corner-line--v"></span>
      <span class="corner-dot"></span>
    </div>
    
    <!-- Frame Tags with Animation -->
    {frameTagTopLeft && (
      <span class="ph-frame-tag ph-frame-tag--tl">
        <span class="tag-bracket">[</span>
        <span class="tag-text">{frameTagTopLeft}</span>
        <span class="tag-bracket">]</span>
      </span>
    )}
    {frameTagTopRight && (
      <span class="ph-frame-tag ph-frame-tag--tr">
        <span class="tag-text">{frameTagTopRight}</span>
      </span>
    )}
    {frameTagBottomLeft && (
      <span class="ph-frame-tag ph-frame-tag--bl">
        <span class="tag-text">{frameTagBottomLeft}</span>
      </span>
    )}
    {frameTagBottomRight && (
      <span class="ph-frame-tag ph-frame-tag--br">
        <span class="tag-bracket">[</span>
        <span class="tag-text">{frameTagBottomRight}</span>
        <span class="tag-bracket">]</span>
      </span>
    )}
  </div>

  <!-- Anamorphic Grid Overlay -->
  <div class="ph-anamorphic-grid" aria-hidden="true">
    <div class="ana-line ana-line--thirds ana-line--h-1"></div>
    <div class="ana-line ana-line--thirds ana-line--h-2"></div>
    <div class="ana-line ana-line--thirds ana-line--v-1"></div>
    <div class="ana-line ana-line--thirds ana-line--v-2"></div>
    <div class="ana-crosshair ana-crosshair--center">
      <span class="crosshair-h"></span>
      <span class="crosshair-v"></span>
    </div>
  </div>

  <!-- Background Layers -->
  {backgroundVideo ? (
    <div class="ph-bg-layer ph-bg-layer--video" aria-hidden="true">
      <video class="ph-bg-media" autoplay muted loop playsinline>
        <source src="/heroVideo.mp4" type="video/mp4" />
      </video>
      <div class="ph-bg-vignette ph-bg-vignette--cinematic"></div>
      <div class="ph-bg-bleach"></div>
    </div>
  ) : backgroundImage ? (
    <div class="ph-bg-layer ph-bg-layer--image" aria-hidden="true">
      <img src={backgroundImage} alt="" class="ph-bg-media" />
      <div class="ph-bg-vignette ph-bg-vignette--cinematic"></div>
      <div class="ph-bg-bleach"></div>
    </div>
  ) : (
    <div class="ph-bg-layer ph-bg-layer--gradient" aria-hidden="true">
      <div class="ph-bg-aurora"></div>
      <div class="ph-bg-noise-bg"></div>
    </div>
  )}

  <!-- Volumetric Light Rays -->
  <div class="ph-light-rays" aria-hidden="true">
    <div class="light-ray light-ray--1"></div>
    <div class="light-ray light-ray--2"></div>
    <div class="light-ray light-ray--3"></div>
    <div class="light-ray light-ray--4"></div>
  </div>

  <!-- Atmospheric Glows -->
  <div class="ph-atmosphere" aria-hidden="true">
    <div class="ph-glow ph-glow--primary"></div>
    <div class="ph-glow ph-glow--secondary"></div>
    <div class="ph-glow ph-glow--tertiary"></div>
    <div class="ph-glow ph-glow--ambient"></div>
  </div>

  <!-- Floating Particles -->
  <div class="ph-particles" aria-hidden="true">
    {Array.from({ length: 12 }).map((_, i) => (
      <span 
        class="particle" 
        style={`--p-x: ${20 + Math.random() * 60}%; --p-y: ${20 + Math.random() * 60}%; --p-delay: ${i * 0.3}s; --p-duration: ${8 + Math.random() * 8}s;`}
      ></span>
    ))}
  </div>

  <!-- Texture Layers -->
  <div class="ph-texture ph-texture--grain" aria-hidden="true"></div>
  <div class="ph-texture ph-texture--dust" aria-hidden="true"></div>
  <div class="ph-texture ph-texture--scanlines" aria-hidden="true"></div>

  <!-- Depth & Fog -->
  <div class="ph-depth" aria-hidden="true">
    <div class="depth-layer depth-layer--foreground"></div>
    <div class="depth-layer depth-layer--mid"></div>
  </div>

  <!-- Main Content -->
  <div class="ph-content">
    <div class="ph-inner">

      {overline && (
        <div class="ph-eyebrow" aria-label={overline}>
          <span class="eyebrow-line eyebrow-line--left"></span>
          <span class="eyebrow-bracket eyebrow-bracket--open">[</span>
          <span class="eyebrow-text">{overline}</span>
          <span class="eyebrow-bracket eyebrow-bracket--close">]</span>
          <span class="eyebrow-line eyebrow-line--right"></span>
        </div>
      )}

      <h1 id="page-title" class="ph-title">
        {titleWords.map((word, wIndex) => (
          <span class="title-word" style={`--word-delay: ${wIndex * 0.15}s`}>
            {word.split('').map((char, cIndex) => (
              <span 
                class="title-char" 
                style={`--char-delay: ${wIndex * 0.15 + cIndex * 0.04}s`}
                class:list={[{ 'title-char--special': char === 'A' || char === 'O' || char === 'G' }]}
              >
                {char}
              </span>
            ))}
          </span>
        ))}
      </h1>

      {subtitle && (
        <div class="ph-subtitle-wrapper">
          <div class="subtitle-line subtitle-line--left"></div>
          <p class="ph-subtitle">
            <span class="subtitle-text">{subtitle}</span>
          </p>
          <div class="subtitle-line subtitle-line--right"></div>
        </div>
      )}

      <!-- Decorative Separator -->
      <div class="ph-separator" aria-hidden="true">
        <div class="sep-line sep-line--long sep-line--left"></div>
        <div class="sep-ornament">
          <span class="orn-diamond"></span>
          <span class="orn-circle"></span>
          <span class="orn-diamond orn-diamond--small"></span>
        </div>
        <div class="sep-line sep-line--long sep-line--right"></div>
      </div>

      <slot name="meta" />

    </div>
  </div>

  <!-- Glass Bottom Dock -->
  <div class="ph-dock">
    <div class="dock-glass">
      <div class="dock-content">
        <slot name="bottom-bar" />
      </div>
      <div class="dock-highlight"></div>
    </div>
  </div>
</section>

<style>
  /* ============================================
     BASE & VARIABLES
     ============================================ */
  .page-header {
    --ph-accent: var(--color-accent);
    --ph-min-height: 55vh;
    --ph-pt: calc(var(--header-height) + 4rem);
    --ph-pb: 3.5rem;
    --ease-cinematic: cubic-bezier(0.16, 1, 0.3, 1);
    --ease-dramatic: cubic-bezier(0.87, 0, 0.13, 1);
    --ease-elastic: cubic-bezier(0.68, -0.3, 0.265, 1.3);

    position: relative;
    width: 100%;
    min-height: var(--ph-min-height);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    background: var(--color-bg);
    isolation: isolate;
  }

  /* ============================================
     ORGANIC CINEMATIC FRAME
     ============================================ */
  .ph-frame {
    position: absolute;
    inset: 1rem;
    pointer-events: none;
    z-index: 100;
  }

  .ph-frame-layer {
    position: absolute;
    inset: 0;
    border-radius: 2px;
    opacity: 0;
    animation: frame-appear 1.2s var(--ease-cinematic) 0.3s forwards;
  }

  .ph-frame-layer--outer {
    border: 1px solid rgba(255, 255, 255, 0.04);
    inset: 0;
  }

  .ph-frame-layer--inner {
    border: 1px solid rgba(255, 255, 255, 0.02);
    inset: 4px;
  }

  @keyframes frame-appear {
    from { opacity: 0; transform: scale(1.02); }
    to { opacity: 1; transform: scale(1); }
  }

  /* Corner Elements */
  .ph-corner {
    position: absolute;
    width: 24px;
    height: 24px;
  }

  .corner-line {
    position: absolute;
    background: var(--color-gold-dim);
    opacity: 0;
    animation: corner-draw 0.6s var(--ease-cinematic) 0.8s forwards;
  }

  .corner-line--h {
    height: 1px;
    width: 0;
    animation: corner-draw-h 0.5s var(--ease-cinematic) 0.8s forwards;
  }

  .corner-line--v {
    width: 1px;
    height: 0;
    animation: corner-draw-v 0.5s var(--ease-cinematic) 1s forwards;
  }

  @keyframes corner-draw-h {
    to { width: 16px; opacity: 0.6; }
  }

  @keyframes corner-draw-v {
    to { height: 16px; opacity: 0.6; }
  }

  .corner-dot {
    position: absolute;
    width: 3px;
    height: 3px;
    background: var(--ph-accent);
    border-radius: 50%;
    opacity: 0;
    animation: dot-appear 0.4s ease 1.3s forwards;
  }

  @keyframes dot-appear {
    to { opacity: 0.8; transform: scale(1); }
  }

  .ph-corner--tl { top: 0; left: 0; }
  .ph-corner--tl .corner-line--h { top: 0; left: 0; }
  .ph-corner--tl .corner-line--v { top: 0; left: 0; }
  .ph-corner--tl .corner-dot { top: -1px; left: -1px; transform: scale(0); }

  .ph-corner--tr { top: 0; right: 0; }
  .ph-corner--tr .corner-line--h { top: 0; right: 0; }
  .ph-corner--tr .corner-line--v { top: 0; right: 0; }
  .ph-corner--tr .corner-dot { top: -1px; right: -1px; transform: scale(0); }

  .ph-corner--bl { bottom: 0; left: 0; }
  .ph-corner--bl .corner-line--h { bottom: 0; left: 0; }
  .ph-corner--bl .corner-line--v { bottom: 0; left: 0; }
  .ph-corner--bl .corner-dot { bottom: -1px; left: -1px; transform: scale(0); }

  .ph-corner--br { bottom: 0; right: 0; }
  .ph-corner--br .corner-line--h { bottom: 0; right: 0; }
  .ph-corner--br .corner-line--v { bottom: 0; right: 0; }
  .ph-corner--br .corner-dot { bottom: -1px; right: -1px; transform: scale(0); }

  /* Frame Tags */
  .ph-frame-tag {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-display);
    font-size: 0.52rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0;
    animation: tag-slide 0.7s var(--ease-cinematic) 1.2s forwards;
  }

  @keyframes tag-slide {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .ph-frame-tag--tl { top: 0.6rem; left: 0.75rem; }
  .ph-frame-tag--tr { top: 0.6rem; right: 0.75rem; color: rgba(255,255,255,0.3); }
  .ph-frame-tag--bl { bottom: 0.6rem; left: 0.75rem; color: rgba(255,255,255,0.25); }
  .ph-frame-tag--br { bottom: 0.6rem; right: 0.75rem; }

  .tag-bracket {
    color: var(--ph-accent);
    font-weight: 300;
    opacity: 0.7;
  }

  .tag-text {
    color: rgba(255,255,255,0.35);
  }

  /* ============================================
     ANAMORPHIC GRID
     ============================================ */
  .ph-anamorphic-grid {
    position: absolute;
    inset: 5%;
    pointer-events: none;
    z-index: 8;
    opacity: 0;
    animation: grid-fade 1.5s ease 2s forwards;
  }

  @keyframes grid-fade {
    to { opacity: 0.15; }
  }

  .ana-line {
    position: absolute;
    background: rgba(255, 255, 255, 0.1);
  }

  .ana-line--thirds.ana-line--h-1 { top: 33.333%; left: 0; right: 0; height: 1px; }
  .ana-line--thirds.ana-line--h-2 { top: 66.666%; left: 0; right: 0; height: 1px; }
  .ana-line--thirds.ana-line--v-1 { left: 33.333%; top: 0; bottom: 0; width: 1px; }
  .ana-line--thirds.ana-line--v-2 { left: 66.666%; top: 0; bottom: 0; width: 1px; }

  .ana-crosshair {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 40px;
    height: 40px;
  }

  .crosshair-h,
  .crosshair-v {
    position: absolute;
    background: rgba(255, 255, 255, 0.2);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .crosshair-h { width: 100%; height: 1px; }
  .crosshair-v { width: 1px; height: 100%; }

  /* ============================================
     BACKGROUND LAYERS
     ============================================ */
  .ph-bg-layer {
    position: absolute;
    inset: 0;
    z-index: 1;
    overflow: hidden;
  }

  .ph-bg-media {
    position: absolute;
    inset: -10%;
    width: 120%;
    height: 120%;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    filter: contrast(1.1) saturate(1.08) brightness(0.85);
    animation: media-enter 2s var(--ease-cinematic) 0.1s forwards;
    transform: scale(1.15);
  }

  @keyframes media-enter {
    to { 
      opacity: 0.6;
      transform: scale(1.05);
    }
  }

  .ph-bg-vignette--cinematic {
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse 80% 60% at 50% 100%, var(--color-bg) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 50% 0%, rgba(0,0,0,0.5) 0%, transparent 50%),
      linear-gradient(to top, var(--color-bg) 0%, transparent 40%, rgba(0,0,0,0.3) 100%);
  }

  .ph-bg-bleach {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 50% 30% at 50% 20%, rgba(255,255,255,0.03) 0%, transparent 70%);
    mix-blend-mode: overlay;
  }

  /* Gradient Background */
  .ph-bg-aurora {
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse 100% 80% at 20% 80%, rgba(232, 98, 42, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse 80% 60% at 80% 20%, rgba(201, 168, 76, 0.08) 0%, transparent 45%),
      radial-gradient(ellipse 60% 40% at 50% 50%, rgba(139, 69, 19, 0.06) 0%, transparent 40%),
      linear-gradient(165deg, #0c0c0c 0%, #080808 50%, #0a0808 100%);
  }

  .ph-bg-noise-bg {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.025'/%3E%3C/svg%3E");
    mix-blend-mode: soft-light;
    opacity: 0.6;
  }

  /* ============================================
     VOLUMETRIC LIGHT RAYS
     ============================================ */
  .ph-light-rays {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    overflow: hidden;
    opacity: 0;
    animation: rays-fade 2s ease 0.5s forwards;
  }

  @keyframes rays-fade {
    to { opacity: 0.4; }
  }

  .light-ray {
    position: absolute;
    width: 2px;
    height: 150%;
    background: linear-gradient(to bottom, 
      transparent 0%, 
      rgba(232, 98, 42, 0.15) 20%, 
      rgba(201, 168, 76, 0.1) 50%, 
      rgba(232, 98, 42, 0.08) 80%, 
      transparent 100%
    );
    filter: blur(1px);
    transform-origin: top center;
    animation: ray-sway 8s ease-in-out infinite;
  }

  .light-ray--1 { left: 25%; top: -25%; transform: rotate(15deg); animation-delay: 0s; }
  .light-ray--2 { left: 45%; top: -25%; transform: rotate(-8deg); animation-delay: 2s; }
  .light-ray--3 { left: 65%; top: -25%; transform: rotate(12deg); animation-delay: 4s; }
  .light-ray--4 { left: 80%; top: -25%; transform: rotate(-15deg); animation-delay: 6s; }

  @keyframes ray-sway {
    0%, 100% { opacity: 0.3; transform: rotate(var(--rot, 0deg)) translateX(0); }
    50% { opacity: 0.6; transform: rotate(var(--rot, 0deg)) translateX(10px); }
  }

  /* ============================================
     ATMOSPHERIC GLOWS
     ============================================ */
  .ph-atmosphere {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }

  .ph-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0;
  }

  .ph-glow--primary {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(232, 98, 42, 0.22) 0%, transparent 70%);
    top: -10%;
    right: -5%;
    animation: glow-enter 1.5s ease 0.3s forwards, glow-drift-1 15s ease-in-out infinite alternate;
  }

  .ph-glow--secondary {
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(201, 168, 76, 0.18) 0%, transparent 65%);
    bottom: 5%;
    left: -8%;
    animation: glow-enter 1.5s ease 0.5s forwards, glow-drift-2 18s ease-in-out infinite alternate-reverse;
  }

  .ph-glow--tertiary {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(139, 69, 19, 0.12) 0%, transparent 60%);
    bottom: -15%;
    right: 15%;
    animation: glow-enter 1.5s ease 0.7s forwards, glow-drift-3 20s ease-in-out infinite alternate;
  }

  .ph-glow--ambient {
    width: 600px;
    height: 200px;
    background: radial-gradient(ellipse, rgba(201, 168, 76, 0.06) 0%, transparent 70%);
    top: 30%;
    left: 50%;
    transform: translateX(-50%);
    animation: glow-enter 2s ease 0.4s forwards;
  }

  @keyframes glow-enter {
    from { opacity: 0; transform: scale(0.8); }
    to { opacity: 1; transform: scale(1); }
  }

  @keyframes glow-drift-1 {
    to { transform: translate(25px, -20px) scale(1.1); }
  }

  @keyframes glow-drift-2 {
    to { transform: translate(-15px, 25px) scale(1.15); }
  }

  @keyframes glow-drift-3 {
    to { transform: translate(20px, -10px) scale(1.08); }
  }

  /* ============================================
     FLOATING PARTICLES
     ============================================ */
  .ph-particles {
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none;
    overflow: hidden;
  }

  .particle {
    position: absolute;
    left: var(--p-x);
    top: var(--p-y);
    width: 2px;
    height: 2px;
    background: rgba(201, 168, 76, 0.6);
    border-radius: 50%;
    opacity: 0;
    animation: 
      particle-fade 1s ease var(--p-delay) forwards,
      particle-float var(--p-duration) ease-in-out infinite;
    animation-delay: var(--p-delay), calc(var(--p-delay) + 1s);
  }

  .particle:nth-child(3n) {
    width: 3px;
    height: 3px;
    background: rgba(232, 98, 42, 0.5);
  }

  .particle:nth-child(5n) {
    width: 1px;
    height: 1px;
    background: rgba(255, 255, 255, 0.4);
  }

  @keyframes particle-fade {
    to { opacity: 0.8; }
  }

  @keyframes particle-float {
    0%, 100% { transform: translateY(0) translateX(0); opacity: 0.3; }
    25% { transform: translateY(-20px) translateX(5px); opacity: 0.8; }
    50% { transform: translateY(-10px) translateX(-5px); opacity: 0.5; }
    75% { transform: translateY(-30px) translateX(3px); opacity: 0.7; }
  }

  /* ============================================
     TEXTURE LAYERS
     ============================================ */
  .ph-texture {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .ph-texture--grain {
    z-index: 6;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
    mix-blend-mode: overlay;
    opacity: 0.7;
  }

  .ph-texture--dust {
    z-index: 7;
    background: radial-gradient(ellipse at 30% 20%, rgba(201, 168, 76, 0.03) 0%, transparent 50%),

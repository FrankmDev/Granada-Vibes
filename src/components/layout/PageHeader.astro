---
interface Props {
  title: string;
  subtitle?: string;
  accent?: 'terra' | 'amber' | 'mint';
  centered?: boolean;
}

const { title, subtitle, accent = 'terra', centered = true } = Astro.props;

const accentColors = {
  terra: 'from-terra/20 via-transparent to-transparent',
  amber: 'from-amber/20 via-transparent to-transparent',
  mint: 'from-mint/20 via-transparent to-transparent',
};

const accentTextColors = {
  terra: 'text-terra',
  amber: 'text-amber',
  mint: 'text-mint',
};
---

<section class="relative pt-32 pb-16 lg:pt-40 lg:pb-20 overflow-hidden">
  {/* Background gradient */}
  <div class:list={['absolute inset-0 bg-gradient-to-b', accentColors[accent]]} aria-hidden="true"></div>
  
  {/* Decorative elements */}
  <div class="absolute top-20 right-[10%] w-64 h-64 bg-terra/5 rounded-full blur-[100px] pointer-events-none" aria-hidden="true"></div>
  
  <div class="container relative">
    <div class:list={['max-w-3xl', centered && 'mx-auto text-center']}>
      {/* Overline */}
      <div class:list={['flex items-center gap-3 mb-6', centered && 'justify-center']}>
        <span class:list={['w-12 h-[2px]', accent === 'terra' ? 'bg-terra' : accent === 'amber' ? 'bg-amber' : 'bg-mint']}></span>
        <span class:list={['text-xs font-bold uppercase tracking-[0.2em]', accentTextColors[accent]]}>
          Granada Vibes
        </span>
        <span class:list={['w-12 h-[2px]', accent === 'terra' ? 'bg-terra' : accent === 'amber' ? 'bg-amber' : 'bg-mint', centered ? 'block' : 'hidden']}></span>
      </div>
      
      {/* Title */}
      <h1 class="font-display text-5xl lg:text-6xl xl:text-7xl font-bold text-surface mb-6 leading-[0.95] tracking-[-0.03em]">
        {title}
      </h1>
      
      {/* Subtitle */}
      {subtitle && (
        <p class="text-lg lg:text-xl text-surface-secondary max-w-2xl leading-relaxed">
          {subtitle}
        </p>
      )}
    </div>
  </div>
</section>

---
interface Props {
  title: string;
  subtitle?: string;
  accent?: 'accent' | 'sand' | 'sage';
}

const { title, subtitle, accent = 'accent' } = Astro.props;

const accentColors = {
  accent: 'bg-accent text-accent',
  sand: 'bg-sand text-sand',
  sage: 'bg-sage text-sage',
};

const [bgColor, textColor] = accentColors[accent].split(' ');
---

<section class="relative pt-32 pb-12">
  <div class="container">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-4">
        <span class:list={['w-8 h-px', bgColor]} />
        <span class:list={['font-mono text-[11px] uppercase tracking-[0.2em]', textColor]}>Granada Vibes</span>
      </div>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-semibold tracking-[-0.02em] mb-4">
        {title}
      </h1>
      {subtitle && (
        <p class="text-lg text-text-secondary">
          {subtitle}
        </p>
      )}
    </div>
  </div>
</section>

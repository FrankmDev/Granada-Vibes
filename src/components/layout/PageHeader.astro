---
import OptimizedImage from '@components/ui/OptimizedImage.astro';

interface Props {
  title: string;
  subtitle?: string;
  accent?: 'primary' | 'secondary' | 'success';
  centered?: boolean;
  variant?: 'default' | 'large' | 'minimal';
  overline?: string;
  backgroundVideo?: boolean;
  backgroundImage?: string;
  frameTagTopLeft?: string;
  frameTagTopRight?: string;
  frameTagBottomLeft?: string;
  frameTagBottomRight?: string;
  showParallax?: boolean;
}

const {
  title,
  subtitle,
  accent = 'primary',
  centered = false,
  variant = 'default',
  overline,
  backgroundVideo = false,
  backgroundImage,
  frameTagTopLeft = 'GV',
  frameTagTopRight = '37°10′28″N',
  frameTagBottomLeft,
  frameTagBottomRight = '2026',
  showParallax = true,
} = Astro.props;

const accentTokenMap = {
  primary: 'var(--color-accent)',
  secondary: 'var(--color-gold)',
  success: 'var(--color-success)',
};

const accentToken = accentTokenMap[accent];

const variantMap = {
  minimal: { minHeight: '40vh', paddingTop: 'calc(var(--header-height) + 3rem)', paddingBottom: '2.5rem' },
  default: { minHeight: '56vh', paddingTop: 'calc(var(--header-height) + 4rem)', paddingBottom: '3.5rem' },
  large:   { minHeight: '78vh', paddingTop: 'calc(var(--header-height) + 5rem)', paddingBottom: '4.5rem' },
};

const v = variantMap[variant];

const displayTitle = title.trim().toUpperCase();
const isSecondary = accent === 'secondary';
const useCompactTitle = displayTitle.length <= 28;
const editionLabel = overline ? `№ 01 · ${overline} · 2026` : null;
---

<section
  class:list={['page-header', `page-header--${variant}`, centered && 'page-header--centered']}
  style={`--ph-accent: ${accentToken}; --ph-min-height: ${v.minHeight}; --ph-pt: ${v.paddingTop}; --ph-pb: ${v.paddingBottom};`}
  aria-labelledby="page-title"
  data-parallax={showParallax}
>

  <!-- Frame: all 4 corners, asymmetric sizing -->
  <div class="ph-frame" aria-hidden="true">
    <!-- Primary corners (TL + BR) — 20px arms, accent color -->
    <div class="ph-corner ph-corner--tl ph-corner--primary">
      <span class="corner-arm corner-arm--h"></span>
      <span class="corner-arm corner-arm--v"></span>
    </div>
    <div class="ph-corner ph-corner--br ph-corner--primary">
      <span class="corner-arm corner-arm--h"></span>
      <span class="corner-arm corner-arm--v"></span>
    </div>
    <!-- Secondary corners (TR + BL) — 10px arms, gold dim, lower opacity -->
    <div class="ph-corner ph-corner--tr ph-corner--secondary">
      <span class="corner-arm corner-arm--h"></span>
      <span class="corner-arm corner-arm--v"></span>
    </div>
    <div class="ph-corner ph-corner--bl ph-corner--secondary">
      <span class="corner-arm corner-arm--h"></span>
      <span class="corner-arm corner-arm--v"></span>
    </div>

    {frameTagTopLeft && (
      <span class="ph-frame-tag ph-frame-tag--tl">[{frameTagTopLeft}]</span>
    )}
    {frameTagTopRight && (
      <span class="ph-frame-tag ph-frame-tag--tr">{frameTagTopRight}</span>
    )}
    {frameTagBottomLeft && (
      <span class="ph-frame-tag ph-frame-tag--bl">{frameTagBottomLeft}</span>
    )}
    {frameTagBottomRight && (
      <span class="ph-frame-tag ph-frame-tag--br">[{frameTagBottomRight}]</span>
    )}
  </div>

  <!-- Background -->
  {backgroundVideo ? (
    <div class="ph-bg" aria-hidden="true">
      <video class="ph-bg-media" autoplay muted loop playsinline preload="none">
        <source src="/heroVideo-apex-20260526.mp4" type="video/mp4" />
      </video>
      <div class="ph-bg-vignette"></div>
    </div>
  ) : backgroundImage ? (
    <div class="ph-bg" aria-hidden="true">
      <OptimizedImage src={backgroundImage} alt="" class="ph-bg-media" loading="eager" decoding="async" sizes="100vw" />
      <div class="ph-bg-vignette"></div>
    </div>
  ) : (
    <div class="ph-bg ph-bg--aurora" aria-hidden="true">
      <!-- Intense orange glow — bottom-left -->
      <div class="ph-aurora-glow ph-aurora-glow--orange"></div>
      <!-- Vivid gold glow — top-right -->
      <div class="ph-aurora-glow ph-aurora-glow--gold"></div>
      <!-- Subtle crimson depth — center-right -->
      <div class="ph-aurora-glow ph-aurora-glow--crimson"></div>
      <!-- Luminous horizon line -->
      <div class="ph-aurora-horizon"></div>
      <!-- Diagonal shimmer -->
      <div class="ph-aurora-diagonal"></div>
    </div>
  )}

  <!-- Grain texture -->
  <div class="ph-grain" aria-hidden="true"></div>

  <!-- Main content layer — colosssal bg number lives here, outside ph-inner -->
  <div class="ph-content">
    <!-- Colossal background page number -->
    <span class="ph-bg-number" aria-hidden="true">01</span>

    <div class="ph-inner">

      {editionLabel && (
        <div class="ph-eyebrow" aria-label={overline}>
          <span class="eyebrow-rule" aria-hidden="true"></span>
          <span class="eyebrow-text">{editionLabel}</span>
        </div>
      )}

      <h1 id="page-title" class:list={['ph-title', useCompactTitle && 'ph-title--compact']}>
        {useCompactTitle ? (
          <span class="ph-title-line">{displayTitle}</span>
        ) : (
          displayTitle.split(' ').map((word, wIndex) => (
            <span
              class:list={['title-word', { 'title-word--gold': isSecondary && wIndex === 0 }]}
              style={`--word-delay: ${wIndex * 0.14}s`}
            >
              {word}
            </span>
          ))
        )}
      </h1>

      {subtitle && (
        <p class="ph-subtitle">{subtitle}</p>
      )}

      <!-- Full-width editorial separator -->
      {variant !== 'minimal' && (
        <div class="ph-separator" aria-hidden="true">
          <span class="sep-bar"></span>
        </div>
      )}

      <slot name="meta" />

      <!-- Data strip -->
      {variant !== 'minimal' && (
        <div class="ph-data-strip" aria-hidden="true">
          GRANADA · ANDALUCÍA · ESPAÑA &nbsp;·&nbsp; 37°10′N 3°35′W &nbsp;·&nbsp; ALT. 738 M
        </div>
      )}

    </div>
  </div>

  <!-- Glass dock -->
  <div class="ph-dock">
    <div class="dock-inner">
      <span class="dock-line-number" aria-hidden="true">— 001 —</span>
      <slot name="bottom-bar" />
    </div>
  </div>

</section>

<style>
  /* ====================================================
     BASE
     ==================================================== */
  .page-header {
    --ph-accent: var(--color-accent);
    --ph-min-height: 56vh;
    --ph-pt: calc(var(--header-height) + 4rem);
    --ph-pb: 3.5rem;
    --ph-gutter: clamp(1.25rem, 4vw, 4rem);
    --ph-frame-inset: clamp(0.75rem, 1.6vw, 1.25rem);
    --ph-content-max: 1200px;

    position: relative;
    width: 100%;
    min-height: max(var(--ph-min-height), 30rem);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    background: var(--color-bg);
    isolation: isolate;
  }

  /* ====================================================
     FRAME — 4 corners, asymmetric
     ==================================================== */
  .ph-frame {
    position: absolute;
    inset: var(--ph-frame-inset);
    pointer-events: none;
    z-index: 50;
  }

  .ph-corner {
    position: absolute;
  }

  /* Primary corners: 20px arms */
  .ph-corner--primary {
    width: 20px;
    height: 20px;
  }

  /* Secondary corners: 10px arms */
  .ph-corner--secondary {
    width: 10px;
    height: 10px;
    opacity: 0.4;
  }

  .ph-corner--tl { top: 0; left: 0; }
  .ph-corner--br { bottom: 0; right: 0; }
  .ph-corner--tr { top: 0; right: 0; }
  .ph-corner--bl { bottom: 0; left: 0; }

  .corner-arm {
    position: absolute;
  }

  /* Primary corners: accent orange */
  .ph-corner--primary .corner-arm {
    background: var(--color-accent);
  }

  /* Secondary corners: gold dim */
  .ph-corner--secondary .corner-arm {
    background: var(--color-gold-dim);
  }

  .corner-arm--h {
    width: 100%;
    height: 1px;
    top: 0;
    left: 0;
    transform-origin: left;
    transform: scaleX(0);
    animation: ph-draw-h 0.5s var(--ease-out-expo) 0.3s forwards;
  }

  .corner-arm--v {
    width: 1px;
    height: 100%;
    top: 0;
    left: 0;
    transform-origin: top;
    transform: scaleY(0);
    animation: ph-draw-v 0.5s var(--ease-out-expo) 0.45s forwards;
  }

  /* BR and TR: arms point inward from right/bottom */
  .ph-corner--br .corner-arm--h {
    left: auto;
    right: 0;
    transform-origin: right;
  }
  .ph-corner--br .corner-arm--v {
    top: auto;
    bottom: 0;
    transform-origin: bottom;
  }

  /* TR: H arm from right, V arm from top going down */
  .ph-corner--tr .corner-arm--h {
    left: auto;
    right: 0;
    transform-origin: right;
  }

  /* BL: H arm from left, V arm from bottom */
  .ph-corner--bl .corner-arm--v {
    top: auto;
    bottom: 0;
    transform-origin: bottom;
  }

  /* Frame tags */
  .ph-frame-tag {
    position: absolute;
    font-family: var(--font-display);
    font-size: 0.5rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.22);
    opacity: 0;
    animation: ph-fade-in 0.8s ease 0.9s forwards;
  }

  .ph-frame-tag--tl { top: -1.1rem; left: 0; }
  .ph-frame-tag--tr { top: -1.1rem; right: 0; }
  .ph-frame-tag--bl { bottom: -1.1rem; left: 0; }
  .ph-frame-tag--br { bottom: -1.1rem; right: 0; }

  /* ====================================================
     BACKGROUND
     ==================================================== */
  .ph-bg {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .ph-bg-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: brightness(0.4) saturate(0.65);
  }

  .ph-bg-vignette {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 100%, rgba(0,0,0,0.88) 0%, transparent 70%),
      linear-gradient(to bottom, rgba(0,0,0,0.45) 0%, transparent 40%, rgba(0,0,0,0.65) 100%);
  }

  /* Aurora default background — dramatically intensified */
  .ph-bg--aurora {
    background: var(--color-bg);
  }

  .ph-aurora-glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  /* Intense orange — bottom-left, wide coverage */
  .ph-aurora-glow--orange {
    width: 65%;
    height: 80%;
    bottom: -25%;
    left: -8%;
    background: radial-gradient(ellipse, rgba(232, 98, 42, 0.35) 0%, rgba(232, 98, 42, 0.12) 40%, transparent 70%);
    filter: blur(120px);
    animation: ph-pulse-glow 9s ease-in-out infinite alternate;
  }

  /* Vivid gold — top-right */
  .ph-aurora-glow--gold {
    width: 55%;
    height: 65%;
    top: -20%;
    right: -8%;
    background: radial-gradient(ellipse, rgba(201, 168, 76, 0.22) 0%, rgba(201, 168, 76, 0.07) 45%, transparent 70%);
    filter: blur(100px);
    animation: ph-pulse-glow 13s ease-in-out 1.5s infinite alternate-reverse;
  }

  /* Subtle crimson depth — center-right, for warmth and distance */
  .ph-aurora-glow--crimson {
    width: 50%;
    height: 60%;
    top: 20%;
    right: 10%;
    background: radial-gradient(ellipse, rgba(120, 40, 40, 0.15) 0%, transparent 70%);
    filter: blur(150px);
    animation: ph-pulse-glow 17s ease-in-out 3s infinite alternate;
  }

  /* Luminous horizon line at ~62% height */
  .ph-aurora-horizon {
    position: absolute;
    left: 0;
    right: 0;
    top: 62%;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent 0%,
      rgba(232, 98, 42, 0.2) 25%,
      rgba(201, 168, 76, 0.15) 55%,
      transparent 100%
    );
    pointer-events: none;
    opacity: 0;
    animation: ph-fade-in 1.2s ease 1.1s forwards;
  }

  .ph-aurora-diagonal {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      127deg,
      transparent 30%,
      rgba(201, 168, 76, 0.04) 50%,
      transparent 70%
    );
    pointer-events: none;
  }

  /* ====================================================
     GRAIN — more intense
     ==================================================== */
  .ph-grain {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='grain'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23grain)'/%3E%3C/svg%3E");
    background-size: 200px 200px;
    mix-blend-mode: overlay;
    opacity: 0.06;
  }

  /* ====================================================
     CONTENT
     ==================================================== */
  .ph-content {
    position: relative;
    z-index: 10;
    padding-top: var(--ph-pt);
    padding-bottom: var(--ph-pb);
    padding-inline: var(--ph-gutter);
    flex: 1;
    display: flex;
    align-items: flex-end;
    width: 100%;
  }

  /* Colossal background page number */
  .ph-bg-number {
    position: absolute;
    right: -2%;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-body);
    font-size: clamp(12rem, 25vw, 22rem);
    font-weight: 900;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.04);
    pointer-events: none;
    user-select: none;
    opacity: 0;
    animation: ph-bg-number-reveal 2s ease 0.3s forwards;
    z-index: 1;
  }

  .ph-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--ph-content-max);
    margin: 0 auto;
    padding-right: clamp(0rem, 10vw, 9rem);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .page-header--centered .ph-inner {
    align-items: center;
    text-align: center;
    padding-right: 0;
  }

  /* ====================================================
     EYEBROW — with accent rule
     ==================================================== */
  .ph-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeInUp 0.7s var(--ease-out-expo) 0.2s forwards;
  }

  .eyebrow-rule {
    display: block;
    width: 2px;
    height: 24px;
    background: var(--ph-accent);
    flex-shrink: 0;
  }

  .eyebrow-text {
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-gold-text);
    opacity: 0.7;
  }

  /* ====================================================
     TITLE — colossal, cinematic
     ==================================================== */
  .ph-title {
    font-family: var(--font-body);
    font-size: clamp(4.5rem, 12.5vw, 10.5rem);
    font-weight: 100;
    letter-spacing: -0.02em;
    line-height: 0.9;
    -webkit-font-smoothing: antialiased;
    color: var(--color-text-primary);
    margin: 0 0 1.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.2em;
    overflow: visible;
    word-break: keep-all;
    overflow-wrap: normal;
    max-width: 11ch;
  }

  /* Short label (e.g. EVENTOS) — same scale, fewer words */
  .ph-title--compact {
    flex-wrap: nowrap;
    max-width: 100%;
  }

  .page-header--centered .ph-title {
    justify-content: center;
    max-width: 12ch;
  }

  .ph-title-line {
    display: block;
    opacity: 0;
    animation: ph-word-rise 1.2s var(--ease-out-expo) 0.1s forwards;
  }

  .page-header--large .ph-title {
    font-size: clamp(5.5rem, 16vw, 13rem);
  }

  .page-header--minimal .ph-title {
    font-size: clamp(2.5rem, 6.5vw, 4.5rem);
    font-weight: 100;
    line-height: 1.0;
  }

  .title-word {
    display: inline-block;
    white-space: nowrap;
    opacity: 0;
    transform: translateY(80%) skewX(-12deg) scale(0.95);
    animation: ph-word-rise 1.4s var(--ease-out-expo) var(--word-delay, 0s) forwards;
  }

  .title-word--gold {
    color: var(--color-gold-text);
  }

  /* ====================================================
     SUBTITLE
     ==================================================== */
  .ph-subtitle {
    font-family: var(--font-display);
    font-size: clamp(0.95rem, 1.5vw, 1.15rem);
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin: 0 0 2.25rem;
    max-width: 52ch;
    opacity: 0;
    animation: fadeInUp 0.8s var(--ease-out-expo) 0.75s forwards;
  }

  .page-header--centered .ph-subtitle {
    max-width: 44ch;
    margin-inline: auto;
  }

  /* ====================================================
     SEPARATOR — full-width chromatic bar
     ==================================================== */
  .ph-separator {
    margin-bottom: 1.25rem;
    opacity: 0;
    animation: fadeInUp 0.5s var(--ease-out-expo) 0.9s forwards;
  }

  .sep-bar {
    display: block;
    height: 1px;
    background: linear-gradient(
      to right,
      var(--color-accent) 0%,
      var(--color-gold) 30%,
      rgba(255, 255, 255, 0.08) 60%,
      transparent 100%
    );
    transform-origin: left;
    transform: scaleX(0);
    animation: ph-sep-expand 0.8s var(--ease-out-expo) 1s forwards;
  }

  .page-header--centered .sep-bar {
    background: linear-gradient(
      to right,
      transparent 0%,
      var(--color-accent) 20%,
      var(--color-gold) 50%,
      var(--color-accent) 80%,
      transparent 100%
    );
    transform-origin: center;
  }

  /* ====================================================
     DATA STRIP
     ==================================================== */
  .ph-data-strip {
    font-family: var(--font-display);
    font-size: 0.48rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-top: 0.75rem;
    opacity: 0;
    animation: ph-data-strip-reveal 0.8s ease 1.8s forwards;
  }

  /* ====================================================
     DOCK — editorial bar with line number
     ==================================================== */
  .ph-dock {
    position: relative;
    z-index: 20;
    width: 100%;
  }

  .dock-inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1.5rem;
    width: 100%;
    min-height: 4.5rem;
    padding: 0.95rem var(--ph-gutter);
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(32px) saturate(140%);
    -webkit-backdrop-filter: blur(32px) saturate(140%);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  /* Accent gradient line above dock */
  .dock-inner::before {
    content: '';
    position: absolute;
    top: -1px;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent 0%,
      var(--color-accent) 20%,
      var(--color-gold) 50%,
      var(--color-accent) 80%,
      transparent 100%
    );
    opacity: 0.3;
    pointer-events: none;
  }

  .dock-line-number {
    font-family: var(--font-display);
    font-size: 0.45rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.2);
    white-space: nowrap;
    flex-shrink: 0;
    pointer-events: none;
    user-select: none;
  }

  .ph-dock :global(a),
  .ph-dock :global(button),
  .ph-dock :global(.btn) {
    min-height: 2.75rem;
  }

  .ph-dock :global(.btn),
  .ph-dock :global(a.btn),
  .ph-dock :global(button.btn) {
    padding-inline: clamp(1rem, 3vw, 2rem);
    text-align: center;
  }

  .ph-dock :global([class*='bar']),
  .ph-dock :global([class*='actions']),
  .ph-dock :global([class*='meta']) {
    min-width: 0;
  }

  .ph-dock :global([class*='actions']) {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  /* Hide line number when dock slot is empty */
  .dock-inner:not(:has(*:not(.dock-line-number))) .dock-line-number {
    display: none;
  }

  /* ====================================================
     KEYFRAMES
     ==================================================== */
  @keyframes ph-draw-h {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }

  @keyframes ph-draw-v {
    from { transform: scaleY(0); }
    to   { transform: scaleY(1); }
  }

  @keyframes ph-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @keyframes ph-word-rise {
    from {
      opacity: 0;
      transform: translateY(80%) skewX(-12deg) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) skewX(0deg) scale(1);
    }
  }

  @keyframes ph-pulse-glow {
    from { opacity: 0.75; transform: scale(1); }
    to   { opacity: 1; transform: scale(1.06); }
  }

  @keyframes ph-sep-expand {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }

  @keyframes ph-bg-number-reveal {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @keyframes ph-data-strip-reveal {
    from { opacity: 0; }
    to   { opacity: 0.55; }
  }

  /* ====================================================
     REDUCED MOTION
     ==================================================== */
  @media (prefers-reduced-motion: reduce) {
    .corner-arm--h,
    .corner-arm--v,
    .ph-frame-tag,
    .ph-eyebrow,
    .title-word,
    .ph-title-line,
    .ph-subtitle,
    .ph-separator,
    .sep-bar,
    .ph-data-strip,
    .ph-bg-number,
    .ph-aurora-horizon {
      animation-duration: 0.01ms !important;
      animation-delay: 0ms !important;
      opacity: 1 !important;
      transform: none !important;
    }

    .ph-aurora-glow--orange,
    .ph-aurora-glow--gold,
    .ph-aurora-glow--crimson {
      animation: none;
    }
  }

  /* ====================================================
     RESPONSIVE

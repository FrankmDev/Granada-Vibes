---
import type { Locale } from '@types';
import { LOCALE_PATHS } from '@config/site';
import { getAllEvents } from '@data/index';
import { getTemporalProximity } from '@utils/dates';

interface Props {
  locale: Locale;
  t: (key: string) => string;
}

const { locale, t } = Astro.props;
const localePath = LOCALE_PATHS[locale];

const today = new Date().toISOString().split('T')[0] ?? '';
const allEvents = getAllEvents() ?? [];
const upcomingEvents = allEvents
  .filter((e: { date: string }) => e.date >= today)
  .sort((a: { date: string }, b: { date: string }) => a.date.localeCompare(b.date))
  .slice(0, 3);

function getEventDateLabel(date: string): string | undefined {
  const proximity = getTemporalProximity(date);
  if (proximity === 'today') return locale === 'es' ? 'Hoy' : 'Today';
  if (proximity === 'tomorrow') return locale === 'es' ? 'Mañana' : 'Tomorrow';
  return undefined;
}
---

<div>
  <h3 class="footer__heading">{t('footer.thisWeek')}</h3>

  {upcomingEvents.length > 0 ? (
    <div class="space-y-3">
      {upcomingEvents.map((event: { slug: string; date: string; title: { [key: string]: string }; venue: string; price: number | null }) => {
        const dateLabel = getEventDateLabel(event.date);
        return (
          <a href={`${localePath}/eventos/${event.slug}`} class="footer-event group">
            <div class="footer-event__date">
              <span class="text-base font-bold text-white leading-none">{new Date(event.date).getDate()}</span>
              <span class="text-[10px] text-white/40 uppercase font-medium">
                {new Date(event.date).toLocaleDateString(locale, { month: 'short' })}
              </span>
            </div>
            <div class="flex-1 min-w-0">
              {dateLabel && <span class="text-[10px] font-bold text-accent uppercase tracking-wider">{dateLabel}</span>}
              <h4 class="font-semibold text-sm text-white group-hover:text-accent transition-colors line-clamp-1">{event.title[locale]}</h4>
              <p class="text-xs text-white/30">{event.venue}</p>
            </div>
            <div class="flex-shrink-0">
              {event.price === null ? (
                <span class="text-[10px] font-bold text-success bg-success-muted px-2 py-1 rounded-full border border-success/20">FREE</span>
              ) : (
                <span class="text-xs font-semibold text-white/30">{event.price}€</span>
              )}
            </div>
          </a>
        );
      })}
    </div>
  ) : (
    <p class="text-sm text-white/30">{locale === 'es' ? 'No hay eventos próximos.' : 'No upcoming events.'}</p>
  )}

  <a href={`${localePath}/eventos`} class="footer-event__link group">
    {t('footer.viewAllEvents')}
    <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
    </svg>
  </a>
</div>

<style>
  .footer-event {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.03);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all var(--duration-normal);
  }

  .footer-event:hover {
    border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
    background: rgba(255, 255, 255, 0.05);
    transform: translateY(-2px);
  }

  .footer-event__date {
    flex-shrink: 0;
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, color-mix(in srgb, var(--color-accent) 10%, transparent), color-mix(in srgb, var(--color-secondary) 10%, transparent));
    border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .footer-event__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
    transition: color var(--duration-normal);
  }

  .footer-event__link:hover { color: var(--color-secondary); }
</style>

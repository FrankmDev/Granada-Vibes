---
import type { Locale } from '@types';
import { SITE_CONFIG, LOCALE_PATHS } from '@config/site';
import { useTranslations } from '@i18n/utils';

interface Props { locale: Locale; }

const { locale } = Astro.props;
const t = useTranslations(locale);
const localePath = LOCALE_PATHS[locale];
const currentYear = new Date().getFullYear();

const exploreLinks = [
  { href: `${localePath}/eventos`, label: t('nav.events') },
  { href: `${localePath}/rutas`,   label: t('nav.routes') },
  { href: `${localePath}/sobre`,   label: t('nav.about') },
];

const legalLinks = [
  { href: `${localePath}/privacidad`,  label: t('footer.links.privacy') },
  { href: `${localePath}/aviso-legal`, label: t('footer.links.legalNotice') },
];
---

<footer class="sacrom-footer">
  <div class="sacrom-footer-inner">
    <div class="sacrom-footer-top">
      <div class="sacrom-footer-desc-col">
        <p class="sacrom-footer-desc">
          {locale === 'es'
            ? 'Sacrom es un repositorio digital dedicado a la preservación y difusión de la herencia viva de Granada. Desde las cumbres de Sierra Nevada hasta las profundidades del Albaicín.'
            : 'Sacrom is a digital repository dedicated to the preservation and dissemination of Granada\'s living heritage. From the peaks of Sierra Nevada to the depths of the Albayzín.'}
        </p>
      </div>
      
      <div class="sacrom-footer-links-grid">
        {exploreLinks.map((link) => (
          <a href={link.href} class="sacrom-footer-link">{link.label}</a>
        ))}
        {legalLinks.map((link) => (
          <a href={link.href} class="sacrom-footer-link">{link.label}</a>
        ))}
        <a href="mailto:hola@granadavibes.com" class="sacrom-footer-link">CONTACT</a>
        {SITE_CONFIG.social.instagram && (
          <a href={SITE_CONFIG.social.instagram} class="sacrom-footer-link" target="_blank" rel="noopener noreferrer">
            INSTAGRAM
          </a>
        )}
      </div>
    </div>
    
    <span class="sacrom-footer-huge">
      SAKROM
    </span>
    
    <div class="sacrom-footer-bottom">
      <span>© {currentYear} SACROM MONOCHROME.</span>
      <span>ARCHIVAL DATA 37.1773° N, 3.5986° W.</span>
    </div>
  </div>
</footer>

<style>
  .sacrom-footer {
    background-color: var(--color-bg);
    width: 100%;
    position: relative;
    border-top: 2px solid var(--color-border);
  }

  .sacrom-footer-inner {
    display: flex;
    flex-direction: column;
    width: 100%;
    padding: 5rem 1.5rem;
    gap: 3rem;
  }

  .sacrom-footer-top {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
  }

  .sacrom-footer-desc-col {
    max-width: 28rem;
  }

  .sacrom-footer-desc {
    font-family: var(--font-body); /* Lora serif */
    font-style: italic;
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    line-height: 1.2;
    color: var(--color-text-primary);
    margin: 0;
  }

  .sacrom-footer-links-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem 3rem;
  }

  @media (min-width: 768px) {
    .sacrom-footer-links-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .sacrom-footer-link {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    font-size: 0.875rem;
    color: var(--color-text-primary);
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .sacrom-footer-link:hover {
    font-style: italic;
  }

  .sacrom-footer-huge {
    font-family: var(--font-display);
    font-size: 18vw;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.08em; /* kerning-v-tight */
    text-transform: uppercase;
    display: block;
    width: 100%;
    text-align: center;
    border-top: 2px solid var(--color-border);
    padding-top: 2rem;
    color: var(--color-text-primary);
  }

  .sacrom-footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 900;
    letter-spacing: 0.3em; /* kerning-widest */
    text-transform: uppercase;
    color: var(--color-text-primary);
  }

  @media (max-width: 640px) {
    .sacrom-footer-bottom {
      flex-direction: column;
      gap: 0.5rem;
      align-items: center;
      text-align: center;
    }
  }
</style>

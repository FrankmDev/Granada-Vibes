---
import type { Locale } from '@types';
import { useTranslations } from '@i18n/utils';
import { getRoute } from '@utils/routes';
import ScreenFrame from '@components/ui/ScreenFrame.astro';
import '@styles/components/footer.css';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const currentYear = new Date().getFullYear();

const coords = '37°10′28″N';
const altCoords = '03°35′56″W';

const exploreLinks = [
  { label: t('nav.routes'), href: getRoute('routes', locale), num: '01' },
  { label: t('nav.blog'),   href: getRoute('blog', locale),   num: '02' },
  { label: t('nav.planner'), href: getRoute('planner', locale), num: '03' },
  { label: t('nav.events'), href: getRoute('events', locale), num: '04' },
];

const legalLinks = [
  { label: t('footer.links.privacy'),     href: getRoute('privacy', locale), num: '01' },
  { label: t('footer.links.legalNotice'), href: getRoute('legal', locale),   num: '02' },
];

// Wordmark chars for animation
const wordmarkChars = t('footer.brand.title').split('');
---

<footer class="site-footer">
  <!-- Transition from previous section -->
  <div class="footer-transition" aria-hidden="true">
    <div class="transition-line"></div>
  </div>

  <ScreenFrame tagTopLeft={t('footer.eyebrow')} tagTopRight={t('footer.vol')} tagBottomLeft="GU" tagBottomRight={coords} />

  <!-- Ambient Effects -->
  <div class="ambient-grain" aria-hidden="true"></div>
  <div class="ambient-vignette" aria-hidden="true"></div>

  <!-- Decorative Grid Lines -->
  <div class="footer-grid-lines" aria-hidden="true">
    <div class="grid-line grid-line--v grid-line--vl"></div>
    <div class="grid-line grid-line--v grid-line--vr"></div>
    <div class="grid-line grid-line--h grid-line--hc"></div>
  </div>

  <!-- Top Ornament Bar -->
  <div class="top-ornament">
    <div class="orn-line orn-line--left"></div>
    <div class="orn-center">
      <span class="orn-diamond"></span>
      <span class="orn-star" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" width="14" height="14">
          <path d="M12 2 L13.2 8.8 L20 7 L15 12 L20 17 L13.2 15.2 L12 22 L10.8 15.2 L4 17 L9 12 L4 7 L10.8 8.8 Z"
                fill="var(--s-orange)" fill-opacity="0.5"/>
        </svg>
      </span>
      <span class="orn-diamond"></span>
    </div>
    <div class="orn-line orn-line--right"></div>
  </div>

  <!-- Main Footer Content -->
  <div class="footer-container">

    <!-- Masthead -->
    <div class="footer-masthead">
      <div class="masthead-eyebrow">
        <span class="eyebrow-bracket">[</span>
        <span class="eyebrow-text">{t('footer.eyebrow')}</span>
        <span class="eyebrow-bracket">]</span>
        <span class="eyebrow-divider">—</span>
        <span class="eyebrow-year">{t('footer.vol')}</span>
      </div>
    </div>

    <!-- Content Grid with Cell Separation -->
    <div class="footer-content">

      <!-- Brand Column -->
      <div class="footer-col brand-col">
        <div class="brand-logo-wrap">
          <img
            class="brand-logo"
            src="/logo.avif"
            alt="GRN URBAN"
            width="280"
            height="57"
            loading="lazy"
            decoding="async"
          />
        </div>
        <p class="brand-desc">{t('footer.brand.desc')}</p>
        <div class="brand-meta">
          <div class="meta-pill">
            <span class="meta-dot"></span>
            <span class="meta-text">{t('footer.meta.status')}</span>
          </div>
          <span class="meta-divider">·</span>
          <span class="meta-year">{t('footer.meta.founded')}</span>
        </div>
      </div>

      <!-- Links Column -->
      <div class="footer-col links-col">
        <div class="col-header">
          <span class="col-bracket">[</span>
          <span class="col-title">{t('footer.explore.title')}</span>
          <span class="col-bracket">]</span>
        </div>
        <nav class="footer-nav">
          {exploreLinks.map((link, i) => (
            <a href={link.href} class="nav-link" style={`--index: ${i}`} data-hover={link.label}>
              <span class="link-corner link-corner--tl"></span>
              <span class="link-corner link-corner--tr"></span>
              <span class="link-corner link-corner--bl"></span>
              <span class="link-corner link-corner--br"></span>
              <span class="link-glow"></span>
              <span class="link-num">{link.num}</span>
              <span class="link-label">{link.label}</span>
              <span class="link-arrow" aria-hidden="true">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M7 17L17 7M17 7H7M17 7V17" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </a>
          ))}
        </nav>
      </div>

      <!-- Legal & Contact Column -->
      <div class="footer-col legal-col">
        <div class="legal-section">
          <div class="col-header">
            <span class="col-bracket">[</span>
            <span class="col-title">{t('footer.legal.title')}</span>
            <span class="col-bracket">]</span>
          </div>
          <nav class="footer-nav footer-nav--compact">
            {legalLinks.map((link, i) => (
              <a href={link.href} class="nav-link nav-link--subtle" style={`--index: ${i}`}>
                <span class="link-num">{link.num}</span>
                <span class="link-label">{link.label}</span>
                <span class="link-indicator"></span>
              </a>
            ))}
          </nav>
        </div>

        <div class="collaborate-section">
          <div class="col-header">
            <span class="col-bracket">[</span>
            <span class="col-title">{t('collaborate.footerGroup')}</span>
            <span class="col-bracket">]</span>
          </div>
          <nav class="footer-nav footer-nav--compact">
            <a href={getRoute('collaborate', locale)} class="nav-link nav-link--subtle" style="--index: 0">
              <span class="link-num">03</span>
              <span class="link-label">{t('collaborate.footerGroup')}</span>
              <span class="link-indicator"></span>
            </a>
          </nav>
        </div>

        <div class="contact-section">
          <div class="col-header">
            <span class="col-bracket">[</span>
            <span class="col-title">{t('footer.contact.title')}</span>
            <span class="col-bracket">]</span>
          </div>
          <a href="mailto:info@granadaurban.com" class="contact-card">
            <div class="contact-card__bg"></div>
            <div class="contact-card__content">
              <span class="contact-card__icon" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke-linecap="round" stroke-linejoin="round"/>
                  <polyline points="22,6 12,13 2,6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <div class="contact-card__text">
                <span class="contact-card__label">{t('footer.contact.emailLabel')}</span>
                <span class="contact-card__value">info@granadaurban.com</span>
              </div>
              <span class="contact-card__arrow" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
          </a>
        </div>
      </div>

    </div>

    <!-- Large Wordmark Section -->
    <div class="wordmark-section">
      <div class="wordmark-grid" aria-hidden="true">
        <div class="wm-grid-line wm-grid-line--h"></div>
        <div class="wm-grid-line wm-grid-line--v"></div>
      </div>
      <div class="wordmark-display">
        {wordmarkChars.map((char, i) => (
          <span class="wordmark-char" style={`--char-index: ${i}`}>{char}</span>
        ))}
      </div>
      <div class="coordinates-display">
        <div class="coord-group">
          <span class="coord-label">LAT</span>
          <span class="coord-val">{coords}</span>
        </div>
        <div class="coord-divider" aria-hidden="true">
          <svg viewBox="0 0 10 10" width="10" height="10">
            <polygon points="5,0 10,5 5,10 0,5" fill="var(--s-ink-3)"/>
          </svg>
        </div>
        <div class="coord-group">
          <span class="coord-label">LNG</span>
          <span class="coord-val">{altCoords}</span>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <div class="bottom-content">
        <div class="bottom-left">
          <span class="copyright">{t('footer.copyright', { year: currentYear })}</span>
        </div>
        <div class="bottom-center">
          <a href="https://www.frnq.studio" target="_blank" rel="noopener noreferrer" class="developer-badge">
            <span class="dev-icon" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span class="dev-text">{t('footer.developedBy')}</span>
          </a>
        </div>
        <div class="bottom-right">
          <button class="back-to-top" id="back-to-top" aria-label={t('common.backToTop')}>
            <span class="top-line"></span>
            <span class="top-text">{t('common.backToTop')}</span>
            <span class="top-arrow" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 19V5M5 12l7-7 7 7" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </button>
        </div>
      </div>
    </div>

  </div>
</footer>


<script>
  const backToTopBtn = document.getElementById('back-to-top');
  if (backToTopBtn) {
    const launch = () => {
      backToTopBtn.classList.add('is-launching');
      window.scrollTo({ top: 0, behavior: 'smooth' });
      setTimeout(() => backToTopBtn.classList.remove('is-launching'), 800);
    };
    backToTopBtn.addEventListener('click', launch);
    backToTopBtn.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        launch();
      }
    });
  }

  const currentPath = window.location.pathname;
  document.querySelectorAll('.nav-link').forEach((link) => {
    const href = link.getAttribute('href');
    if (href && (currentPath === href || currentPath.startsWith(href + '/'))) {
      link.classList.add('is-active');
    }
  });
</script>

---
import { SITE_CONFIG } from '@config/site';

interface Props {
  class?: string;
  size?: 'sm' | 'md' | 'lg';
  variant?: 'default' | 'muted';
}

const { class: className = '', size = 'md', variant = 'default' } = Astro.props;

const socialLinks = [
  { name: 'Instagram', href: SITE_CONFIG.social.instagram ?? '#', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>' },
  { name: 'Twitter', href: SITE_CONFIG.social.twitter ?? '#', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/></svg>' },
  { name: 'Facebook', href: SITE_CONFIG.social.facebook ?? '#', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>' },
];

const iconSizes = { sm: '1rem', md: '1.25rem', lg: '1.5rem' };
const btnSizes = { sm: '2rem', md: '2.5rem', lg: '3rem' };
---

<div class:list={['flex items-center gap-3', className]}>
  {socialLinks.map((social) => (
    <a
      href={social.href}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`${social.name}`}
      class={`social-link social-link--${variant}`}
      style={`--btn-size: ${btnSizes[size]}; --icon-size: ${iconSizes[size]}`}
    >
      <div class="social-link__icon" set:html={social.icon} />
    </a>
  ))}
</div>

<style>
  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--btn-size);
    height: var(--btn-size);
    border-radius: var(--radius-lg);
    transition: all var(--duration-normal);
  }

  .social-link--default {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.6);
  }
  .social-link--default:hover {
    color: white;
    border-color: rgba(255, 255, 255, 0.4);
  }

  .social-link--muted {
    background: transparent;
    color: rgba(255, 255, 255, 0.4);
  }
  .social-link--muted:hover { color: white; }

  .social-link__icon {
    width: var(--icon-size);
    height: var(--icon-size);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .social-link__icon :global(svg) {
    width: 100%;
    height: 100%;
  }
</style>

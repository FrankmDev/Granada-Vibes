---
/**
 * SocialLinks - Componente reutilizable para enlaces de redes sociales
 * @param className - Clases CSS adicionales
 * @param size - Tamaño de los iconos ('sm' | 'md' | 'lg')
 * @param variant - Estilo visual ('default' | 'muted' | 'colored')
 */

interface Props {
  class?: string;
  size?: 'sm' | 'md' | 'lg';
  variant?: 'default' | 'muted' | 'colored';
}

const { 
  class: className = '', 
  size = 'md', 
  variant = 'default' 
} = Astro.props;

const socialLinks = [
  {
    name: 'Instagram',
    href: 'https://instagram.com/granadavibes',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
  },
  {
    name: 'Twitter',
    href: 'https://twitter.com/granadavibes',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/></svg>`,
  },
  {
    name: 'Facebook',
    href: 'https://facebook.com/granadavibes',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>`,
  },
];

const sizeClasses = {
  sm: 'w-8 h-8',
  md: 'w-10 h-10',
  lg: 'w-12 h-12',
};

const iconSizes = {
  sm: 'w-4 h-4',
  md: 'w-5 h-5',
  lg: 'w-6 h-6',
};

const variantClasses = {
  default: 'bg-base-card border border-edge text-surface-secondary hover:text-surface hover:border-surface/20',
  muted: 'bg-transparent text-surface-muted hover:text-surface',
  colored: 'bg-terra/10 border border-terra/30 text-terra hover:bg-terra hover:text-surface',
};
---

<div class:list={['flex items-center gap-3', className]}>
  {socialLinks.map((social) => (
    <a
      href={social.href}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`Síguenos en ${social.name}`}
      class:list={[
        'flex items-center justify-center rounded-xl transition-all duration-300',
        sizeClasses[size],
        variantClasses[variant],
      ]}
    >
      <div class:list={[iconSizes[size], 'flex items-center justify-center']}>
        <fragment set:html={social.icon} />
      </div>
    </a>
  ))}
</div>

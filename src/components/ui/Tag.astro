---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<span class:list={['inline-flex items-center px-3 py-1 text-xs font-medium text-text-muted bg-bg-elevated rounded-full border border-border hover:border-border-hover transition-colors', className]}>
  <slot />
</span>

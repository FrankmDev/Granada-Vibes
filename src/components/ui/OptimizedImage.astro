---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import { resolveImage, isLocalResolvable } from '../../utils/images';

interface Props {
  src: string | ImageMetadata;
  alt: string;
  width?: number;
  height?: number;
  sizes?: string;
  loading?: 'eager' | 'lazy';
  decoding?: 'async' | 'sync' | 'auto';
  fetchpriority?: 'high' | 'low' | 'auto';
  quality?: number;
  widths?: number[];
  class?: string;
}

const {
  src,
  alt,
  width,
  height,
  sizes,
  loading = 'lazy',
  decoding = 'async',
  fetchpriority,
  quality = 95,
  widths,
  class: className = '',
} = Astro.props;

const defaultSizes = '(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw';
const baseClasses = 'optimized-img';
const combinedClasses = className ? `${baseClasses} ${className}` : baseClasses;

// Only run Astro's image pipeline for stable image hosts. Wikimedia is kept as
// a runtime <img> source because it rate-limits build-time optimization bursts.
const OPTIMIZABLE_HOSTNAMES = [
];

let resolvedImage: ImageMetadata | null = null;
let remoteUrl: string | null = null;
let remoteOptimizable = false;

if (typeof src === 'string') {
  if (isLocalResolvable(src)) {
    const resolved = resolveImage(src);
    if (resolved && resolved.type === 'import') {
      resolvedImage = resolved.image;
    }
  } else if (src.startsWith('http://') || src.startsWith('https://')) {
    try {
      const hostname = new URL(src).hostname;
      remoteOptimizable = OPTIMIZABLE_HOSTNAMES.some(
        (h) => hostname === h || hostname.endsWith('.' + h)
      );
    } catch {
      remoteOptimizable = false;
    }
    remoteUrl = src;
  } else {
    remoteUrl = src;
  }
} else {
  resolvedImage = src;
}

const imgSizes = sizes || defaultSizes;
const fallbackWidth = width || 800;
const fallbackHeight = height || 600;
const responsiveWidths = widths ?? [360, 640, 960, 1280, 1600];
---

{resolvedImage ? (
  <Image
    src={resolvedImage}
    alt={alt}
    {...(width && height ? { width, height } : {})}
    sizes={imgSizes}
    quality={quality}
    widths={responsiveWidths}
    loading={loading}
    decoding={decoding}
    {...(fetchpriority ? { fetchpriority } : {})}
    class={combinedClasses}
    inferSize
  />
) : remoteOptimizable && remoteUrl ? (
  <Image
    src={remoteUrl}
    alt={alt}
    width={fallbackWidth}
    height={fallbackHeight}
    sizes={imgSizes}
    quality={quality}
    widths={responsiveWidths}
    loading={loading}
    decoding={decoding}
    {...(fetchpriority ? { fetchpriority } : {})}
    class={combinedClasses}
  />
) : (
  <img
    src={remoteUrl || '/'}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    decoding={decoding}
    {...(fetchpriority ? { fetchpriority } : {})}
    class={combinedClasses}
  />
)}

<style is:global>
  .optimized-img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
  }
</style>

---
/**
 * FooterLinkGroup - Grupo de enlaces para el footer con estilo consistente
 * @param title - Título de la sección
 * @param links - Array de enlaces { href, label, external? }
 * @param titleColor - Color del título ('terra' | 'sand' | 'coral' | 'surface' | 'primary' | 'secondary')
 */

interface Link {
  href: string;
  label: string;
  external?: boolean;
}

interface Props {
  title: string;
  links: Link[];
  titleColor?: 'terra' | 'sand' | 'coral' | 'surface' | 'primary' | 'secondary';
  class?: string;
}

const { title, links, titleColor = 'terra', class: className = '' } = Astro.props;

const titleColorClasses = {
  terra: 'text-terra',
  sand: 'text-sand',
  coral: 'text-coral',
  surface: 'text-surface',
  primary: 'text-primary',
  secondary: 'text-secondary',
};

const dotColors = ['bg-terra', 'bg-sand', 'bg-coral', 'bg-primary', 'bg-secondary'];
---

<div class={className}>
  <h3 
    class:list={[
      'text-xs font-bold uppercase tracking-[0.2em] mb-6',
      titleColorClasses[titleColor],
    ]}
  >
    {title}
  </h3>
  <ul class="space-y-4" role="list">
    {links.map((link, index) => (
      <li>
        <a 
          href={link.href}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
          class="group flex items-center gap-3 text-surface-secondary hover:text-surface transition-colors duration-300"
        >
          <span class:list={[
            'w-2 h-2 rounded-full bg-edge group-hover:scale-125 transition-transform duration-300',
            `group-hover:${dotColors[index % dotColors.length]}`,
          ]} />
          <span class="text-sm font-medium">{link.label}</span>
          {link.external && (
            <svg class="w-3 h-3 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          )}
        </a>
      </li>
    ))}
  </ul>
</div>

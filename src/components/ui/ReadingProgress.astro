---
/**
 * ReadingProgress — injects a top fixed bar that tracks scroll progress.
 * Uses CSS scroll-driven animation, avoiding scroll listeners and JS loops.
 */
---

<script>
  (function () {
    if (document.getElementById('read-progress')) return;

    const bar = document.createElement('div');
    bar.id = 'read-progress';
    bar.setAttribute('aria-hidden', 'true');
    document.body.appendChild(bar);
  })();
</script>

<style is:global>
  #read-progress {
    width: 100% !important;
    transform: scaleX(0);
    transform-origin: left center;
    transition: none !important;
  }

  @supports (animation-timeline: scroll()) {
    #read-progress {
      animation:
        read-progress-grow linear both,
        shimmer 2s linear infinite !important;
      animation-timeline: scroll(root), auto;
    }
  }

  @keyframes read-progress-grow {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }
</style>

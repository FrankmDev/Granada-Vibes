---
interface Props {
  title: string;
  url: string;
  label: string;
  copiedLabel?: string;
  class?: string;
  labelClass?: string;
}

const { title, url, label, copiedLabel = label, class: className = '', labelClass = '' } = Astro.props;
---

<button class={className} data-share-btn data-title={title} data-url={url} data-copied={copiedLabel}>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
    <path d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
  </svg>
  <span class={labelClass} aria-live="polite">{label}</span>
</button>

<script is:inline>
  (function () {
    if (window.__shareBtnsInitialized) return;
    window.__shareBtnsInitialized = true;

    document.addEventListener('click', async function (e) {
      const btn = e.target.closest('[data-share-btn]');
      if (!btn) return;

      const title = btn.dataset.title ?? '';
      const url   = btn.dataset.url ?? '';
      const copiedLabel = btn.dataset.copied ?? btn.querySelector('span')?.textContent ?? '';
      const labelSpan = btn.querySelector('span');

      if (navigator.share) {
        try {
          await navigator.share({ title, text: title, url });
          return;
        } catch (_) {}
      }

      try {
        await navigator.clipboard.writeText(url);
        if (labelSpan) {
          const orig = labelSpan.textContent;
          labelSpan.textContent = copiedLabel;
          setTimeout(() => { labelSpan.textContent = orig; }, 2000);
        }
      } catch (_) {}
    });
  })();
</script>

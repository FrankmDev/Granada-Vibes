---
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost' | 'accent';
  size?: 'sm' | 'md' | 'lg' | 'xl';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  fullWidth?: boolean;
  class?: string;
  icon?: boolean;
  iconPosition?: 'left' | 'right';
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  disabled = false,
  fullWidth = false,
  class: className = '',
  icon = false,
  iconPosition = 'right',
} = Astro.props;

const classes = [
  `btn-ui btn-ui--${variant} btn-ui--${size}`,
  fullWidth && 'w-full',
  className,
].filter(Boolean).join(' ');
---

{href ? (
  <a href={href} class={classes} role="button">
    {icon && iconPosition === 'left' && <span class="btn-ui__icon btn-ui__icon--left"><slot name="icon" /></span>}
    <span class="btn-ui__label"><slot /></span>
    {icon && iconPosition === 'right' && <span class="btn-ui__icon btn-ui__icon--right"><slot name="icon" /></span>}
    <span class="btn-ui__shine"></span>
  </a>
) : (
  <button type={type} disabled={disabled} class={classes}>
    {icon && iconPosition === 'left' && <span class="btn-ui__icon btn-ui__icon--left"><slot name="icon" /></span>}
    <span class="btn-ui__label"><slot /></span>
    {icon && iconPosition === 'right' && <span class="btn-ui__icon btn-ui__icon--right"><slot name="icon" /></span>}
    <span class="btn-ui__shine"></span>
  </button>
)}

<style>
  .btn-ui {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--duration-slow) var(--ease-out-expo);
    cursor: pointer;
    border: none;
  }

  .btn-ui:focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-accent) 50%, transparent);
  }

  .btn-ui:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* Sizes */
  .btn-ui--sm { padding: 0.625rem 1.25rem; font-size: 0.75rem; }
  .btn-ui--md { padding: 0.875rem 1.75rem; font-size: 0.875rem; }
  .btn-ui--lg { padding: 1rem 2rem; font-size: 0.875rem; }
  .btn-ui--xl { padding: 1.25rem 2.5rem; font-size: 1rem; }

  /* Variants */
  .btn-ui--primary {
    background: var(--color-accent);
    color: white;
    box-shadow: 0 8px 24px var(--color-accent-glow);
  }
  .btn-ui--primary:hover {
    background: var(--color-accent-hover);
    transform: scale(1.02);
    box-shadow: 0 10px 40px var(--color-accent-glow);
  }
  .btn-ui--primary:active { transform: scale(0.98); }

  .btn-ui--secondary {
    background: rgba(255, 255, 255, 0.05);
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  .btn-ui--secondary:hover {
    border-color: color-mix(in srgb, var(--color-accent) 40%, transparent);
    background: color-mix(in srgb, var(--color-accent) 5%, transparent);
    transform: translateY(-2px);
  }

  .btn-ui--ghost {
    background: transparent;
    color: rgba(255, 255, 255, 0.6);
  }
  .btn-ui--ghost:hover {
    color: white;
    background: rgba(255, 255, 255, 0.05);
  }

  .btn-ui--accent {
    background: rgba(255, 255, 255, 0.1);
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }
  .btn-ui--accent:hover {
    border-color: color-mix(in srgb, var(--color-secondary) 50%, transparent);
    color: var(--color-secondary);
    transform: translateY(-2px);
  }

  /* Sub-elements */
  .btn-ui__label {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .btn-ui__icon {
    transition: transform var(--duration-normal);
  }
  .btn-ui:hover .btn-ui__icon--left { transform: translateX(-2px); }
  .btn-ui:hover .btn-ui__icon--right { transform: translateX(2px); }

  .btn-ui__shine {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.2), transparent);
    transform: translateX(-100%);
    transition: transform 0.7s ease-out;
  }
  .btn-ui:hover .btn-ui__shine { transform: translateX(100%); }
</style>

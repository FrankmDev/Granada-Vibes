---
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost' | 'gold';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  fullWidth?: boolean;
  class?: string;
  icon?: boolean;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  disabled = false,
  fullWidth = false,
  class: className = '',
  icon = false,
} = Astro.props;

const baseClasses = 'group relative inline-flex items-center justify-center gap-2 font-semibold transition-all duration-300 rounded-xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/30 disabled:opacity-50 disabled:cursor-not-allowed overflow-hidden';

const variantClasses = {
  primary: 'bg-gradient-to-r from-accent to-coral text-white shadow-lg shadow-accent/15 hover:shadow-xl hover:shadow-accent/25 hover:-translate-y-0.5',
  secondary: 'bg-white text-text-primary border border-border hover:border-accent/50 hover:text-accent hover:-translate-y-0.5 shadow-soft',
  ghost: 'bg-transparent text-text-secondary hover:text-text-primary hover:bg-bg-raised',
  gold: 'bg-gradient-to-r from-gold to-gold-hover text-white font-semibold shadow-lg shadow-gold/15 hover:shadow-xl hover:shadow-gold/25 hover:-translate-y-0.5',
};

const sizeClasses = {
  sm: 'px-4 py-2.5 text-sm',
  md: 'px-6 py-3.5 text-[15px]',
  lg: 'px-8 py-4 text-base',
};

const classes = [
  baseClasses,
  variantClasses[variant],
  sizeClasses[size],
  fullWidth ? 'w-full' : '',
  className,
].join(' ');
---

{
  href ? (
    <a href={href} class={classes} role="button">
      <span class="relative z-10 flex items-center gap-2">
        <slot />
      </span>
      {variant !== 'ghost' && (
        <span class="absolute inset-0 bg-gradient-to-r from-white/0 via-white/15 to-white/0 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700"></span>
      )}
    </a>
  ) : (
    <button type={type} disabled={disabled} class={classes}>
      <span class="relative z-10 flex items-center gap-2">
        <slot />
      </span>
      {variant !== 'ghost' && (
        <span class="absolute inset-0 bg-gradient-to-r from-white/0 via-white/15 to-white/0 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700"></span>
      )}
    </button>
  )
}

---
/**
 * SectionHeader — unified editorial masthead for all sections.
 * Centered layout with eyebrow lines, split title (primary / secondary),
 * optional subtitle and CTA pill. Self-contained IntersectionObserver.
 */

interface Props {
  eyebrow: string;
  eyebrowYear?: string;
  title: string;
  titleSecondary?: string;
  subtitle?: string;
  animateTitle?: boolean;
  ctaHref?: string;
  ctaLabel?: string;
  theme?: 'cream' | 'dark' | 'transparent';
  size?: 'default' | 'compact';
  showDecoration?: boolean;
}

const {
  eyebrow,
  eyebrowYear,
  title,
  titleSecondary,
  subtitle,
  animateTitle = true,
  ctaHref,
  ctaLabel,
  theme = 'cream',
  size = 'default',
  showDecoration = false,
} = Astro.props;

const splitText = (text: string, baseDelay = 0) =>
  text.split('').map((char, i) => ({ char, delay: baseDelay + i * 0.03 }));

const primaryChars = splitText(title);
const secondaryChars = titleSecondary
  ? splitText(titleSecondary, title.length * 0.03)
  : [];
---

<header
  class:list={[
    'sh-editorial',
    `sh-theme--${theme}`,
    size === 'compact' && 'sh--compact',
  ]}
>
  <div class="sh-eyebrow-row">
    <span class="sh-eyebrow-line"></span>
    <span class="sh-eyebrow-medallion" aria-hidden="true">
      <span class="sh-eyebrow-medallion-dot"></span>
    </span>
    <span class="sh-eyebrow-text">{eyebrow}</span>
    {eyebrowYear && <span class="sh-eyebrow-year">{eyebrowYear}</span>}
    <span class="sh-eyebrow-line"></span>
  </div>

  <h2 class="sh-title" aria-label={titleSecondary ? `${title} ${titleSecondary}` : title}>
    <span class="sh-title-aura" aria-hidden="true"></span>
    <span class="sh-title-primary">
      {animateTitle
        ? primaryChars.map(({ char, delay }) => (
            <span class="sh-char sh-char--anim" style={`--delay: ${delay}s`}>
              {char === ' ' ? '\u00A0' : char}
            </span>
          ))
        : <span class="sh-char">{title}</span>
      }
    </span>
    {titleSecondary && (
      <>
        <span class="sh-divider" aria-hidden="true">/</span>
        <span class="sh-title-secondary">
          {animateTitle
            ? secondaryChars.map(({ char, delay }) => (
                <span class="sh-char sh-char--anim" style={`--delay: ${delay}s`}>
                  {char === ' ' ? '\u00A0' : char}
                </span>
              ))
            : <span class="sh-char">{titleSecondary}</span>
          }
        </span>
      </>
    )}
  </h2>

  {subtitle && (
    <>
      <span class="sh-subtitle-rule" aria-hidden="true"></span>
      <p class="sh-subtitle">{subtitle}</p>
    </>
  )}

  {ctaHref && ctaLabel && (
    <a href={ctaHref} class="sh-cta">
      <span class="sh-cta-tick" aria-hidden="true"></span>
      <span class="sh-cta-highlight" aria-hidden="true"></span>
      <span class="sh-cta-text">{ctaLabel}</span>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  )}

  {showDecoration && (
    <div class="sh-decoration">
      <div class="sh-decoration-line"></div>
      <div class="sh-decoration-dot"></div>
      <div class="sh-decoration-line"></div>
    </div>
  )}

  <slot />
</header>

<script>
  function initSectionHeaders() {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );

    document.querySelectorAll('.sh-editorial:not(.is-visible)').forEach((el) => {
      observer.observe(el);
    });
  }

  document.addEventListener('DOMContentLoaded', initSectionHeaders);
  document.addEventListener('astro:page-load', initSectionHeaders);
</script>

<style>
  /* ═══════════════════════════════════════════════════════════════
     BASE
     ═══════════════════════════════════════════════════════════════ */
  .sh-editorial {
    --sh-ink:        var(--color-text-inverse);
    --sh-ink-3:      var(--color-text-muted);
    --sh-cream:      var(--color-text-primary);
    --sh-orange:     var(--color-accent);
    --sh-border:     rgba(26, 22, 25, 0.08);

    position: relative;
    z-index: 10;
    text-align: center;
    margin-bottom: clamp(3rem, 4.5vw, 5rem);
    opacity: 0;
    transform: translateY(30px);
    transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .sh-editorial.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Dark theme ── */
  .sh-theme--dark {
    --sh-ink:        var(--color-text-primary);
    --sh-ink-3:      var(--color-text-secondary);
    --sh-cream:      var(--color-bg);
    --sh-orange:     var(--color-accent);
    --sh-border:     rgba(255, 255, 255, 0.08);
  }

  /* ── Transparent theme ── */
  .sh-theme--transparent {
    --sh-ink:        #f0ede8;
    --sh-ink-3:      #9a9490;
    --sh-border:     rgba(255, 255, 255, 0.08);
  }

  /* ═══════════════════════════════════════════════════════════════
     EYEBROW
     ═══════════════════════════════════════════════════════════════ */
  .sh-eyebrow-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(1rem, 2vw, 1.5rem);
    margin-bottom: clamp(1rem, 1.8vw, 1.5rem);
  }

  .sh-eyebrow-line {
    width: 80px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--sh-border) 30%, var(--sh-border) 70%, transparent);
  }

  .sh-eyebrow-text {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.3em;
    color: var(--sh-orange);
    text-transform: uppercase;
  }

  .sh-eyebrow-year {
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    color: var(--sh-ink-3);
    padding-left: 0.75rem;
    border-left: 1px solid var(--sh-border);
  }

  /* ── Eyebrow medallion — tiny central diamond ornament between the eyebrow lines ── */
  .sh-eyebrow-medallion {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 12px;
    height: 12px;
    flex-shrink: 0;
    transform: rotate(45deg);
    border: 1px solid var(--sh-orange);
    opacity: 0.45;
    transition: opacity 0.6s var(--ease-out-expo), transform 0.6s var(--ease-out-expo);
  }
  .sh-editorial.is-visible .sh-eyebrow-medallion {
    opacity: 0.85;
  }
  .sh-eyebrow-medallion:hover {
    transform: rotate(225deg);
    opacity: 1;
  }
  .sh-eyebrow-medallion-dot {
    display: block;
    width: 4px;
    height: 4px;
    background: var(--sh-orange);
    border-radius: 50%;
  }

  /* ═══════════════════════════════════════════════════════════════
     TITLE
     ═══════════════════════════════════════════════════════════════ */
  .sh-title {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(0.75rem, 2vw, 1.5rem);
    flex-wrap: wrap;
    margin: 0 0 clamp(1.25rem, 2vw, 1.75rem);
    text-wrap: balance;
    position: relative;
  }

  /* ── Title aura — faint radial behind the headline, very subtle ── */
  .sh-title-aura {
    position: absolute;
    inset: -0.4em -3em;
    z-index: -1;
    pointer-events: none;
    background:
      radial-gradient(ellipse 38% 60% at 50% 55%, rgba(232, 98, 42, 0.08) 0%, transparent 65%),
      radial-gradient(ellipse 28% 50% at 50% 45%, rgba(201, 168, 76, 0.07) 0%, transparent 65%);
    filter: blur(8px);
    opacity: 0;
    transition: opacity 1.2s var(--ease-out-expo) 0.3s;
  }
  .sh-editorial.is-visible .sh-title-aura {
    opacity: 1;
  }

  .sh-title-primary,
  .sh-title-secondary {
    display: flex;
    font-family: var(--font-body);
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 200;
    line-height: 0.95;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    overflow-wrap: anywhere;
    text-shadow: 0 1px 0 rgba(26,22,25,0.04);
  }

  .sh-title-primary {
    color: var(--sh-ink);
  }

  .sh-title-secondary {
    color: var(--sh-orange);
    text-shadow: 0 1px 0 rgba(232, 98, 42, 0.06);
  }

  .sh-char {
    display: inline-block;
  }

  .sh-char--anim {
    opacity: 0;
    transform: translateY(40px);
    animation: char-rise 1.2s cubic-bezier(0.16, 1, 0.3, 1) var(--delay) forwards;
    animation-play-state: paused;
  }

  .sh-editorial.is-visible .sh-char--anim {
    animation-play-state: running;
  }

  .sh-divider {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 300;
    color: var(--sh-border);
    opacity: 0;
    transform: translateY(40px);
    animation: char-rise 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.6s forwards;
    animation-play-state: paused;
  }

  .sh-editorial.is-visible .sh-divider {
    animation-play-state: running;
  }

  /* ═══════════════════════════════════════════════════════════════
     SUBTITLE
     ═══════════════════════════════════════════════════════════════ */
  .sh-subtitle {
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--sh-ink-3);
    max-width: min(68ch, 100%);
    margin: 0 auto;
    line-height: 1.7;
    text-wrap: pretty;
  }

  /* ── Tiny gold hairline above the subtitle (editorial center rule) ── */
  .sh-subtitle-rule {
    display: block;
    width: 28px;
    height: 1px;
    margin: 0 auto clamp(0.85rem, 1.3vw, 1.1rem);
    background: linear-gradient(90deg, transparent, rgba(201, 168, 76, 0.85), transparent);
    transform-origin: center;
    transform: scaleX(0);
    transition: transform 0.9s var(--ease-out-expo) 0.5s;
  }
  .sh-editorial.is-visible .sh-subtitle-rule {
    transform: scaleX(1);
  }

  /* ═══════════════════════════════════════════════════════════════
     CTA PILL
     ═══════════════════════════════════════════════════════════════ */
  .sh-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 2rem;
    padding: 0.875rem 2.25rem;
    background: var(--sh-ink);
    border-radius: 100px;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--sh-cream);
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 8px 24px rgba(26, 22, 25, 0.15);
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }

  /* Top hairline highlight on the CTA pill (very subtle, sells the material) */
  .sh-cta-highlight {
    position: absolute;
    top: 0;
    left: 1.25rem;
    right: 1.25rem;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.22) 50%, transparent 100%);
    z-index: 0;
    pointer-events: none;
  }

  /* Tiny gold tick on the left edge of the CTA pill */
  .sh-cta-tick {
    position: absolute;
    left: 0.6rem;
    top: 50%;
    width: 4px;
    height: 4px;
    background: var(--sh-orange);
    border-radius: 50%;
    transform: translateY(-50%);
    z-index: 0;
    opacity: 0.85;
    box-shadow: 0 0 0 2px rgba(232, 98, 42, 0.18);
    transition: opacity 0.4s ease, transform 0.4s var(--ease-out-expo);
  }
  .sh-cta:hover .sh-cta-tick {
    opacity: 1;
    transform: translateY(-50%) scale(1.2);
  }
  .sh-theme--dark .sh-cta-tick {
    background: var(--color-text-primary);
    box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.15);
  }

  .sh-cta-text {
    position: relative;
    z-index: 1;
  }
  .sh-cta svg {
    position: relative;
    z-index: 1;
    transition: transform 0.3s ease;
  }

  .sh-theme--dark .sh-cta {
    background: var(--sh-orange);
    color: var(--color-text-primary);
    box-shadow: 0 8px 24px rgba(232, 98, 42, 0.25);
  }

  .sh-cta:hover {
    background: var(--sh-orange);
    color: var(--color-text-primary);
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(232, 98, 42, 0.3);
  }

  .sh-theme--dark .sh-cta:hover {
    background: var(--sh-ink);
    box-shadow: 0 16px 40px rgba(26, 22, 25, 0.4);
  }

  .sh-cta:hover svg {
    transform: translateX(4px);
  }

  /* ═══════════════════════════════════════════════════════════════
     DECORATION
     ═══════════════════════════════════════════════════════════════ */
  .sh-decoration {
    display: flex;
    align-items: center;
    gap: 0;
    margin-top: 2.5rem;
  }

  .sh-decoration-line {
    flex: 1;
    height: 1px;
    background: var(--sh-border);
  }

  .sh-decoration-dot {
    width: 5px;
    height: 5px;
    background: var(--sh-orange);
    border-radius: 50%;
    margin: 0 1rem;
    flex-shrink: 0;
  }

  /* ═══════════════════════════════════════════════════════════════
     COMPACT SIZE
     ═══════════════════════════════════════════════════════════════ */
  .sh--compact {
    margin-bottom: clamp(2.5rem, 3.5vw, 3.5rem);
  }

  .sh--compact .sh-title-primary,
  .sh--compact .sh-title-secondary {
    font-size: clamp(2.5rem, 6vw, 5rem);
  }

  .sh--compact .sh-divider {
    font-size: clamp(1.5rem, 4vw, 3rem);
  }

  /* ═══════════════════════════════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════════════════════════════ */
  @media (max-width: 1024px) {
    .sh-title-primary,
    .sh-title-secondary {
      font-size: clamp(2.5rem, 9vw, 5rem);
    }
  }

  @media (max-width: 768px) {
    .sh-editorial {
      margin-bottom: 3rem;
    }

    .sh-title {
      gap: 0.75rem;
    }

    .sh-title-primary,
    .sh-title-secondary {
      font-size: clamp(2.25rem, 12vw, 4.5rem);
    }

    .sh-divider {
      display: none;
    }

    .sh-subtitle {
      font-size: 0.95rem;
    }

    .sh-cta {
      padding: 0.75rem 1.75rem;
      font-size: 0.7rem;
    }
  }

  @media (max-width: 480px) {
    .sh-eyebrow-text {
      font-size: 0.6rem;
      letter-spacing: 0.2em;
    }

    .sh-eyebrow-line {
      width: 40px;
    }

    .sh-eyebrow-medallion {
      width: 10px;
      height: 10px;
    }
    .sh-eyebrow-medallion-dot {
      width: 3px;
      height: 3px;
    }

    .sh-title-primary,
    .sh-title-secondary {
      font-size: clamp(2rem, 14vw, 3.5rem) !important;
    }

    .sh--compact .sh-title-primary,
    .sh--compact .sh-title-secondary {
      font-size: clamp(1.75rem, 13vw, 3rem) !important;
    }

    .sh-subtitle {
      font-size: 0.875rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sh-editorial {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .sh-char--anim {
      opacity: 1;
      transform: none;
      animation: none;
    }

    .sh-divider {
      opacity: 1;
      transform: none;
      animation: none;
    }

    .sh-eyebrow-medallion,
    .sh-title-aura,
    .sh-subtitle-rule {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

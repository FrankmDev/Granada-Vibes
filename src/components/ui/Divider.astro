---
interface Props {
  variant?: 'default' | 'gradient' | 'accent' | 'spacer';
  class?: string;
}

const { variant = 'default', class: className = '' } = Astro.props;
---

<div class:list={[`divider-ui divider-ui--${variant}`, className]} role="separator" />

<style>
  .divider-ui { width: 100%; }
  .divider-ui--default { border-top: 1px solid rgba(255, 255, 255, 0.06); }
  .divider-ui--gradient { height: 1px; background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent); }
  .divider-ui--accent { height: 1px; background: linear-gradient(90deg, transparent, var(--color-accent), transparent); }
  .divider-ui--spacer { height: 2rem; }
</style>

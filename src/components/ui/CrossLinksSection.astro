---
import OptimizedImage from './OptimizedImage.astro';

export interface CrossLink {
  url: string;
  title: string;
  meta: string;
  image?: string | null;
  tag?: string;
  plateNumber?: string;
}

interface Props {
  title: string;
  links: CrossLink[];
  showArrow?: boolean;
  showHeader?: boolean;
  /**
   * @deprecated Footer (PLATE Nº + coords) is no longer rendered.
   * Kept for backwards compatibility with existing callers.
   */
  showFooter?: boolean;
  viewAllHref?: string;
  viewAllLabel?: string;
}

const {
  title,
  links,
  showArrow: _showArrow = true,
  showHeader = true,
  viewAllHref,
  viewAllLabel,
} = Astro.props;
---

{links.length > 0 && (
  <div class="upg-related-bento">
    {showHeader && (
      <div class="upg-rb-header">
        <span class="upg-rb-bracket" aria-hidden="true">[</span>
        <span class="upg-rb-title">{title}</span>
        <span class="upg-rb-bracket" aria-hidden="true">]</span>
        <span class="upg-rb-rule" aria-hidden="true"></span>
        {viewAllHref && viewAllLabel && (
          <a class="upg-rb-viewall" href={viewAllHref}>
            <span>{viewAllLabel}</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        )}
      </div>
    )}

    <div class="upg-rb-list">
      {links.map((link, index) => (
        <a
          href={link.url}
          class="upg-rel-item"
          style={`--rd: ${index * 0.06}s`}
          aria-label={link.title}
        >
          <div class="uri-thumb">
            {link.image ? (
              <OptimizedImage
                src={link.image}
                alt={link.title}
                loading="lazy"
                sizes="(max-width: 640px) 100vw, 130px"
              />
            ) : (
              <div class="uri-thumb-fallback" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 16l4-4a3 3 0 0 1 4 0l8 8"></path>
                  <path d="M14 14l1.5-1.5a3 3 0 0 1 4 0L22 15"></path>
                  <circle cx="9" cy="9" r="2"></circle>
                </svg>
              </div>
            )}
          </div>

          <div class="uri-content">
            <h3 class="uri-title">
              <span class="uri-title-text">{link.title}</span>
            </h3>
            <p class="uri-meta">
              <span class="uri-meta-text">{link.meta}</span>
            </p>
          </div>

          <span class="uri-arrow" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
              <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
)}

<style>
  .upg-related-bento {
    position: relative;
    background: transparent;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .upg-related-bento.is-visible { opacity: 1; transform: translateY(0); }

  .upg-rb-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.95rem;
    padding-left: 0;
  }
  .upg-rb-bracket {
    font-family: var(--font-body);
    font-style: normal;
    font-size: 0.95rem;
    color: var(--s-ink-3);
    opacity: 0.55;
    line-height: 1;
  }
  .upg-rb-title {
    font-family: var(--font-display);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    color: var(--s-ink);
    text-transform: uppercase;
    white-space: nowrap;
  }
  .upg-rb-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--s-border) 0%, transparent 100%);
  }
  .upg-rb-viewall {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--s-orange);
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    transition: gap 0.25s ease, color 0.25s ease;
  }
  .upg-rb-viewall svg {
    width: 13px;
    height: 13px;
    transition: transform 0.25s ease;
  }
  .upg-rb-viewall:hover {
    color: var(--s-ink);
    gap: 0.6rem;
  }
  .upg-rb-viewall:hover svg { transform: translateX(2px); }

  .upg-rb-list {
    display: flex;
    flex-direction: column;
    gap: 0.48rem;
  }

  .upg-rel-item {
    position: relative;
    display: flex;
    flex-direction: row;
    align-items: stretch;
    gap: 0;
    min-height: 78px;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.46) 0%, rgba(255,255,255,0.18) 100%);
    border: 1px solid var(--s-border);
    border-radius: 13px;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.19, 1, 0.22, 1),
                border-color 0.4s ease,
                box-shadow 0.4s ease,
                background-color 0.4s ease;
    opacity: 0;
    transform: translateY(10px);
    animation: cell-reveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) calc(var(--rd, 0s) + 0.15s) forwards;
  }

  .uri-thumb {
    position: relative;
    flex: 0 0 76px;
    width: 76px;
    height: 76px;
    margin: 0.45rem 0 0.45rem 0.45rem;
    border-radius: 10px;
    background: rgba(26, 22, 25, 0.04);
    overflow: hidden;
  }
  .uri-thumb img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.19, 1, 0.22, 1),
                filter 0.5s ease;
    filter: grayscale(18%) contrast(1.02) brightness(0.94);
  }
  .upg-rel-item:hover .uri-thumb img {
    transform: scale(1.04);
    filter: grayscale(0%) contrast(1.05) brightness(1);
  }

  .uri-thumb-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(circle at top left, rgba(201, 168, 76, 0.18), transparent 58%),
      linear-gradient(135deg, rgba(232, 98, 42, 0.08), rgba(26, 22, 25, 0.035));
    color: rgba(26, 22, 25, 0.55);
  }
  .uri-thumb-fallback svg { width: 22px; height: 22px; }

  .uri-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.28rem;
    padding: 0.7rem 0.7rem 0.7rem 0.85rem;
    min-width: 0;
  }

  .uri-title {
    position: relative;
    margin: 0;
    font-family: var(--font-body);
    font-style: normal;
    font-weight: 300;
    font-size: clamp(0.98rem, 1.25vw, 1.12rem);
    line-height: 1.12;
    color: var(--s-ink);
    letter-spacing: -0.01em;
    transition: color 0.3s ease;
    display: block;
  }
  .uri-title-text {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .upg-rel-item:hover .uri-title { color: var(--s-orange); }

  .uri-meta {
    margin: 0;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--s-ink-3);
    line-height: 1.35;
    min-width: 0;
  }
  .uri-meta-text {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
    display: block;
  }

  .uri-arrow {
    width: 28px;
    height: 28px;
    align-self: center;
    margin-right: 0.55rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--s-ink-3);
    background: transparent;
    transition: background 0.35s cubic-bezier(0.19, 1, 0.22, 1),
                color 0.35s ease,
                transform 0.35s cubic-bezier(0.19, 1, 0.22, 1);
    flex-shrink: 0;
  }
  .uri-arrow svg { width: 14px; height: 14px; }
  .upg-rel-item:hover .uri-arrow {
    background: var(--s-orange);
    color: #fff;
    transform: translateX(3px);
  }

  .upg-rel-item:hover {
    transform: translateX(3px);
    border-color: rgba(201, 168, 76, 0.35);
    box-shadow:
      0 10px 24px -18px rgba(26, 22, 25, 0.22),
      0 2px 8px -6px rgba(26, 22, 25, 0.10);
  }

  :global(.upg-block--loose) .upg-related-bento {
    opacity: 1;
    transform: none;
  }

  :global(.upg-block--loose) .upg-rb-header {
    margin-bottom: 1rem;
  }
  :global(.upg-block--loose) .upg-rb-title {
    font-size: 0.64rem;
  }
  :global(.upg-block--loose) .upg-rb-bracket {
    font-size: 1rem;
  }

  :global(.upg-block--loose) .upg-rb-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.55rem;
  }

  :global(.upg-block--loose) .upg-rel-item {
    min-width: 0;
    min-height: 78px;
    flex-direction: row;
    align-items: stretch;
    border-radius: 13px;
  }

  :global(.upg-block--loose) .uri-thumb {
    flex: 0 0 76px;
    width: 76px;
    height: 76px;
    min-height: 0;
  }

  :global(.upg-block--loose) .uri-content {
    padding: 0.7rem 0.65rem 0.7rem 0.85rem;
    gap: 0.28rem;
  }

  :global(.upg-block--loose) .uri-title {
    font-size: clamp(0.98rem, 1.15vw, 1.08rem);
    line-height: 1.12;
  }

  :global(.upg-block--loose) .uri-meta {
    font-size: 0.7rem;
  }

  :global(.upg-block--loose) .uri-arrow {
    display: flex;
  }

  @media (max-width: 1024px) {
    :global(.upg-block--loose) .upg-rb-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    :global(.upg-block--loose) .upg-rb-list { grid-template-columns: 1fr; }
    .uri-thumb,
    :global(.upg-block--loose) .uri-thumb {
      flex-basis: 68px;
      width: 68px;
      height: 68px;
    }
  }

  /* ====================================================================
     REDUCED MOTION
     ==================================================================== */

  @media (prefers-reduced-motion: reduce) {
    .upg-rel-item,
    .uri-thumb img,
    .uri-arrow,
    .uri-title,
    .upg-rb-viewall,
    .upg-rb-viewall svg {
      transition: none !important;
      animation: none !important;
    }
  }
</style>

---
interface Props {
  href?: string;
  variant?: 'default' | 'terra' | 'amber' | 'mint' | 'glass' | 'elevated';
  class?: string;
  hover?: boolean;
  glow?: boolean;
}

const { href, variant = 'default', class: className = '', hover = true, glow = false } = Astro.props;

const variantClasses = {
  default: 'bg-base-card border-edge hover:border-edge-hover',
  terra: 'bg-base-card border-terra/20 hover:border-terra/40 hover:glow-terra',
  amber: 'bg-base-card border-amber/20 hover:border-amber/40 hover:glow-amber',
  mint: 'bg-base-card border-mint/20 hover:border-mint/40',
  glass: 'glass border-edge-hover',
  elevated: 'bg-base-elevated border-edge shadow-elevated hover:shadow-elevated-lg',
};

const baseClasses = [
  'relative rounded-3xl overflow-hidden transition-all duration-500',
  variantClasses[variant],
  hover && 'hover:-translate-y-2',
  glow && 'hover:shadow-lg',
  className,
].join(' ');
---

{
  href ? (
    <a href={href} class:list={[baseClasses, 'group block']}>
      <slot />
      {/* Hover gradient overlay */}
      <div class="absolute inset-0 bg-gradient-to-t from-terra/5 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
    </a>
  ) : (
    <div class:list={[baseClasses]}>
      <slot />
    </div>
  )
}

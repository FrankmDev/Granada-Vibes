---
interface Props {
  href?: string;
  variant?: 'default' | 'gold' | 'accent' | 'glass';
  class?: string;
  hover?: boolean;
}

const { href, variant = 'default', class: className = '', hover = true } = Astro.props;

const variantClasses = {
  default: 'bg-bg-card border-border hover:border-border-hover',
  gold: 'bg-bg-card border-gold/20 hover:border-gold/50',
  accent: 'bg-bg-card border-accent/20 hover:border-accent/50',
  glass: 'bg-bg-glass border-border/50 backdrop-blur-xl',
};

const baseClasses = [
  'relative rounded-2xl overflow-hidden transition-all duration-500',
  variantClasses[variant],
  hover && 'hover:-translate-y-1 hover:shadow-xl',
  className,
].join(' ');
---

{
  href ? (
    <a href={href} class:list={[baseClasses, 'group block']}>
      <slot />
    </a>
  ) : (
    <div class:list={[baseClasses]}>
      <slot />
    </div>
  )
}

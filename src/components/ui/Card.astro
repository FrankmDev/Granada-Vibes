---
interface Props {
  href?: string;
  variant?: 'default' | 'glass' | 'elevated' | 'accent';
  class?: string;
  hover?: boolean;
  glow?: boolean;
}

const { href, variant = 'default', class: className = '', hover = true, glow = false } = Astro.props;
---

{href ? (
  <a href={href} class:list={[`card-ui card-ui--${variant}`, hover && 'card-ui--hover', glow && 'card-ui--glow', 'group block', className]}>
    <div class="accent-bar"></div>
    <slot />
    <div class="hover-glow-overlay"></div>
  </a>
) : (
  <div class:list={[`card-ui card-ui--${variant}`, hover && 'card-ui--hover', glow && 'card-ui--glow', className]}>
    <slot />
  </div>
)}

<style>
  .card-ui {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: all var(--duration-slow) var(--ease-out-expo);
  }

  .card-ui--default {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .card-ui--glass {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .card-ui--elevated {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .card-ui--accent {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
  }

  .card-ui--hover:hover {
    transform: translateY(-4px);
    background: rgba(255, 255, 255, 0.06);
  }

  .card-ui--default.card-ui--hover:hover,
  .card-ui--glass.card-ui--hover:hover {
    border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
  }

  .card-ui--accent.card-ui--hover:hover {
    border-color: color-mix(in srgb, var(--color-accent) 50%, transparent);
  }

  .card-ui--glow:hover {
    box-shadow: 0 12px 40px color-mix(in srgb, var(--color-accent) 10%, transparent);
  }
</style>

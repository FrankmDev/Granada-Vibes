---
interface Props {
  href?: string;
  class?: string;
}

const { href, class: className = '' } = Astro.props;

const baseClasses = 'bg-bg-card border border-border rounded-2xl overflow-hidden transition-all duration-300 hover:border-border-hover hover:shadow-lg';
---

{
  href ? (
    <a href={href} class:list={[baseClasses, className]}>
      <slot />
    </a>
  ) : (
    <div class:list={[baseClasses, className]}>
      <slot />
    </div>
  )
}

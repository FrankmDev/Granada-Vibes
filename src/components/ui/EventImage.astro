---
import { Image } from 'astro:assets';
import type { Event } from '@types';

interface Props {
  event: Event;
  alt: string;
  class?: string;
  loading?: 'eager' | 'lazy';
  decoding?: 'async' | 'sync' | 'auto';
  fetchpriority?: 'high' | 'low' | 'auto';
  width?: number;
  height?: number;
  sizes?: string;
  quality?: number;
  widths?: number[];
}

const {
  event,
  alt,
  class: className = '',
  loading = 'lazy',
  decoding = 'async',
  fetchpriority,
  width,
  height,
  sizes,
  quality = 95,
  // Source images are capped at 1400px. 1600w is wasteful, so we generate
  // three tight breakpoints that cover mobile, tablet, and desktop retina.
  widths = [400, 800, 1400],
} = Astro.props;

// Load all event images from assets via Vite's import.meta.glob.
// This lets Astro's image pipeline (Sharp) optimize them at build time,
// generating responsive srcsets automatically.
const allImages = import.meta.glob('/src/assets/images/events/*.{webp,jpg,jpeg,png,avif}', { eager: true });

const filename = event.imageUrl ?? event.image;
const imagePath = filename ? `/src/assets/images/events/${filename}` : null;
const imageModule = imagePath ? allImages[imagePath] : null;
const imageMeta = imageModule ? (imageModule as { default: typeof Image.prototype.src }).default : null;
---

{imageMeta ? (
  <Image
    src={imageMeta}
    alt={alt}
    class={`optimized-img ${className}`}
    loading={loading}
    decoding={decoding}
    {...(fetchpriority ? { fetchpriority } : {})}
    {...(width ? { width } : {})}
    {...(height ? { height } : {})}
    {...(sizes ? { sizes } : {})}
    quality={quality}
    widths={widths}
  />
) : (
  <div class:list={['event-image-fallback', className]} aria-hidden="true" />
)}

<style is:global>
  .optimized-img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
  }

  .event-image-fallback {
    width: 100%;
    height: 100%;
    background:
      radial-gradient(circle at 1px 1px, rgba(255,255,255,0.15) 1px, transparent 0),
      linear-gradient(135deg, rgba(232,98,42,0.08), rgba(201,168,76,0.05));
    background-size: 20px 20px, 100% 100%;
  }
</style>

---
import type { ImageMetadata } from 'astro';
import type { Event } from '@types';

interface Props {
  event: Event;
  alt: string;
  class?: string;
  loading?: 'eager' | 'lazy';
  decoding?: 'async' | 'sync' | 'auto';
  fetchpriority?: 'high' | 'low' | 'auto';
  width?: number;
  height?: number;
  sizes?: string;
}

const {
  event,
  alt,
  class: className = '',
  loading = 'lazy',
  decoding = 'async',
  fetchpriority,
  width,
  height,
} = Astro.props;

// Event images are already normalized to WebP by scripts/optimize-event-images.ts.
// Importing them from src/assets gives us hashed URLs and dimensions without
// asking Astro to generate hundreds of duplicate derivatives per build.
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/events/*.{webp,jpg,jpeg,png,avif}',
  { eager: true }
);

const filename = event.imageUrl ?? event.image;
const imageName = filename ? filename.split('/').pop() : null;
const imagePath = imageName ? `/src/assets/images/events/${imageName}` : null;
const imageModule = imagePath ? allImages[imagePath] : null;
const imageMeta = imageModule?.default ?? null;
---

{imageMeta ? (
  <img
    src={imageMeta.src}
    alt={alt}
    class={`optimized-img ${className}`}
    loading={loading}
    decoding={decoding}
    {...(fetchpriority ? { fetchpriority } : {})}
    width={width ?? imageMeta.width}
    height={height ?? imageMeta.height}
  />
) : (
  <div class:list={['event-image-fallback', className]} aria-hidden="true" />
)}

<style is:global>
  .event-image-fallback {
    width: 100%;
    height: 100%;
    background:
      radial-gradient(circle at 1px 1px, rgba(255,255,255,0.15) 1px, transparent 0),
      linear-gradient(135deg, rgba(232,98,42,0.08), rgba(201,168,76,0.05));
    background-size: 20px 20px, 100% 100%;
  }
</style>

---
interface Props {
  variant?: 'default' | 'terra' | 'amber' | 'mint' | 'live' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { variant = 'default', size = 'md', class: className = '' } = Astro.props;

const variantClasses = {
  default: 'bg-base-elevated text-surface-secondary border-edge',
  terra: 'bg-terra/15 text-terra border-terra/30',
  amber: 'bg-amber/15 text-amber border-amber/30',
  mint: 'bg-mint/15 text-mint border-mint/30',
  live: 'bg-terra text-surface border-terra',
  outline: 'bg-transparent text-surface-secondary border-edge hover:border-surface-secondary',
};

const sizeClasses = {
  sm: 'px-2.5 py-1 text-[10px]',
  md: 'px-3.5 py-1.5 text-xs',
  lg: 'px-4 py-2 text-sm',
};

const classes = [
  'inline-flex items-center gap-1.5 font-bold uppercase tracking-[0.12em] rounded-full border transition-all duration-300',
  variantClasses[variant],
  sizeClasses[size],
  className,
].join(' ');
---

<span class={classes}>
  {variant === 'live' && (
    <span class="relative flex h-1.5 w-1.5">
      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-surface opacity-75"></span>
      <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-surface"></span>
    </span>
  )}
  <slot />
</span>

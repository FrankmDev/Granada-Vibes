---
interface Props {
  variant?: 'default' | 'primary' | 'secondary' | 'success' | 'live' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { variant = 'default', size = 'md', class: className = '' } = Astro.props;
---

<span class:list={[`badge-ui badge-ui--${variant} badge-ui--${size}`, className]}>
  {variant === 'live' && (
    <span class="badge-ui__pulse">
      <span class="badge-ui__ping"></span>
      <span class="badge-ui__dot"></span>
    </span>
  )}
  <slot />
</span>

<style>
  .badge-ui {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    border-radius: var(--radius-full);
    border: 1px solid transparent;
    transition: all var(--duration-normal);
  }

  /* Sizes */
  .badge-ui--sm { padding: 0.25rem 0.625rem; font-size: 0.625rem; }
  .badge-ui--md { padding: 0.375rem 0.875rem; font-size: 0.6875rem; }
  .badge-ui--lg { padding: 0.5rem 1rem; font-size: 0.75rem; }

  /* Variants */
  .badge-ui--default {
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.7);
    border-color: rgba(255, 255, 255, 0.08);
  }

  .badge-ui--primary {
    background: color-mix(in srgb, var(--color-accent) 15%, transparent);
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent) 25%, transparent);
  }

  .badge-ui--secondary {
    background: color-mix(in srgb, var(--color-secondary) 15%, transparent);
    color: var(--color-secondary);
    border-color: color-mix(in srgb, var(--color-secondary) 25%, transparent);
  }

  .badge-ui--success {
    background: color-mix(in srgb, var(--color-success) 15%, transparent);
    color: var(--color-success);
    border-color: color-mix(in srgb, var(--color-success) 25%, transparent);
  }

  .badge-ui--live {
    background: var(--color-accent);
    color: white;
    border-color: var(--color-accent);
    box-shadow: 0 8px 24px var(--color-accent-glow);
  }

  .badge-ui--outline {
    background: transparent;
    color: rgba(255, 255, 255, 0.5);
    border-color: rgba(255, 255, 255, 0.08);
  }

  .badge-ui--outline:hover {
    border-color: rgba(255, 255, 255, 0.2);
    color: white;
  }

  /* Live pulse */
  .badge-ui__pulse {
    position: relative;
    display: flex;
    width: 0.375rem;
    height: 0.375rem;
  }

  .badge-ui__ping {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: white;
    opacity: 0.75;
    animation: ping 1.5s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  .badge-ui__dot {
    position: relative;
    border-radius: 50%;
    width: 0.375rem;
    height: 0.375rem;
    background: white;
    box-shadow: 0 0 10px rgba(255, 255, 255, 0.8);
  }

  @keyframes ping {
    75%, 100% { transform: scale(2); opacity: 0; }
  }
</style>

---
import type { Event, Locale } from '@types';
import { formatDateShort } from '@utils/dates';

interface Props {
  event: Event;
  locale: Locale;
  dateLabel?: string;
  class?: string;
}

const { event, locale, dateLabel, class: className = '' } = Astro.props;
const href = locale === 'es' ? `/eventos/${event.slug}` : `/en/events/${event.slug}`;
const displayDate = dateLabel ?? formatDateShort(event.date, locale);
---

<a href={href} class:list={['mini-card group', className]}>
  <div class="flex items-start gap-3">
    <div class="mini-card__date">
      <span class="text-[10px] font-bold uppercase text-white/30 tracking-wider">
        {displayDate.split(' ')[0]?.substring(0, 3)}
      </span>
      <span class="text-sm font-display font-bold text-white">
        {displayDate.split(' ')[1]}
      </span>
    </div>

    <div class="flex-1 min-w-0">
      <p class="text-sm text-white group-hover:text-accent transition-colors duration-300 line-clamp-2 font-medium leading-snug">
        {event.title[locale]}
      </p>
      <p class="text-xs text-white/40 mt-1 truncate">{event.venue}</p>
      {event.price !== null ? (
        <p class="text-xs text-secondary font-semibold mt-1.5">{event.price}€</p>
      ) : (
        <p class="text-xs text-success font-semibold mt-1.5">
          {locale === 'es' ? 'Gratis' : 'Free'}
        </p>
      )}
    </div>
  </div>
</a>

<style>
  .mini-card {
    display: block;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-lg);
    transition: all var(--duration-normal);
  }

  .mini-card:hover {
    border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.05);
  }

  .mini-card__date {
    flex-shrink: 0;
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
</style>

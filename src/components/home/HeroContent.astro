---
/**
 * HeroContent — Left column: badge, headline, tagline, CTAs, and stats.
 */
import type { Locale } from '@types';
import { LOCALE_PATHS } from '@config/site';
import { useTranslations } from '@i18n/utils';

interface Props { locale: Locale; }

const { locale } = Astro.props;
const t = useTranslations(locale);
const localePath = LOCALE_PATHS[locale];
---

<div class="lg:col-span-7 relative z-30">
  <!-- Decorative accent line (desktop only) -->
  <div class="hero-content__side-line" aria-hidden="true">
    <div class="hero-content__side-line-gradient"></div>
    <div class="hero-content__side-line-dot"></div>
  </div>

  <!-- Live indicator badge -->
  <div class="hero-reveal flex items-center gap-4 mb-8" data-delay="0">
    <div class="hero-content__badge">
      <span class="hero-content__ping">
        <span class="hero-content__ping-wave"></span>
        <span class="hero-content__ping-dot"></span>
      </span>
      <span class="hero-content__badge-text">{t('home.hero.badge')}</span>
    </div>
  </div>

  <!-- Main headline -->
  <h1 id="hero-heading" class="mb-6">
    <span class="hero-reveal block overflow-hidden" data-delay="100">
      <span class="hero-content__word hero-content__word--main">GRANADA</span>
    </span>
    <span class="hero-reveal block overflow-hidden mt-1" data-delay="250">
      <span class="hero-content__word hero-content__word--accent">VIBES</span>
    </span>
  </h1>

  <!-- Tagline -->
  <p class="hero-reveal hero-content__tagline" data-delay="400">
    {t('home.hero.tagline')}
  </p>

  <!-- CTAs -->
  <div class="hero-reveal flex flex-wrap gap-4" data-delay="550">
    <a href={`${localePath}/eventos`} class="hero-content__cta-primary group">
      <span class="relative z-10">{t('home.hero.ctaEvents')}</span>
      <svg class="relative z-10 w-5 h-5 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
      </svg>
      <div class="hero-content__cta-shine"></div>
    </a>

    <a href={`${localePath}/rutas`} class="hero-content__cta-secondary group">
      <span>{t('home.hero.ctaRoutes')}</span>
      <svg class="w-5 h-5 opacity-40 group-hover:text-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.447-.894L15 7m0 13V7"/>
      </svg>
    </a>
  </div>

  <!-- Stats row -->
  <div class="hero-reveal hero-content__stats" data-delay="700">
    <div class="hero-content__stat group">
      <span class="hero-content__stat-value">50+</span>
      <span class="hero-content__stat-label">{t('home.hero.statEvents')}</span>
    </div>
    <div class="hero-content__stat-divider"></div>
    <div class="hero-content__stat group">
      <span class="hero-content__stat-value">12</span>
      <span class="hero-content__stat-label">{t('home.hero.statRoutes')}</span>
    </div>
    <div class="hero-content__stat-divider"></div>
    <div class="hero-content__stat group">
      <span class="hero-content__stat-value">8</span>
      <span class="hero-content__stat-label">{t('home.hero.statNeighborhoods')}</span>
    </div>
  </div>
</div>

<style>
  .hero-content__side-line { display: none; position: absolute; left: -2rem; top: 0; bottom: 0; width: 1px; }
  @media (min-width: 1024px) { .hero-content__side-line { display: block; } }
  .hero-content__side-line-gradient { height: 100%; background: linear-gradient(to bottom, transparent, color-mix(in srgb, var(--color-accent) 40%, transparent), transparent); }
  .hero-content__side-line-dot { position: absolute; top: 0; left: -3px; width: 8px; height: 8px; border-radius: 50%; background: var(--color-accent); box-shadow: 0 0 20px color-mix(in srgb, var(--color-accent) 80%, transparent); animation: hero-pulse-slow 3s ease-in-out infinite; }

  .hero-content__badge { display: inline-flex; align-items: center; gap: 0.75rem; padding: 0.5rem 1rem; background: var(--color-accent-muted); border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent); border-radius: var(--radius-full); overflow: hidden; transition: border-color var(--duration-slow); }
  .hero-content__badge:hover { border-color: color-mix(in srgb, var(--color-accent) 50%, transparent); }
  .hero-content__ping { position: relative; display: flex; width: 0.5rem; height: 0.5rem; }
  .hero-content__ping-wave { position: absolute; inset: 0; border-radius: 50%; background: var(--color-accent); opacity: 0.75; animation: hero-ping 1.5s cubic-bezier(0, 0, 0.2, 1) infinite; }
  .hero-content__ping-dot { position: relative; width: 0.5rem; height: 0.5rem; border-radius: 50%; background: var(--color-accent); box-shadow: 0 0 10px color-mix(in srgb, var(--color-accent) 80%, transparent); }
  .hero-content__badge-text { font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.25em; color: var(--color-accent); }

  .hero-content__word { display: block; animation: hero-slide-up 1s var(--ease-out-expo) forwards; }
  .hero-content__word--main { font-size: clamp(3.5rem, 12vw, 9rem); font-weight: 900; color: white; line-height: 0.85; letter-spacing: -0.04em; }
  .hero-content__word--accent { font-size: clamp(2.5rem, 7vw, 5.5rem); font-weight: 300; line-height: 0.9; letter-spacing: -0.02em; color: transparent; background: linear-gradient(to right, var(--color-accent), var(--color-secondary), var(--color-accent)); background-size: 200% auto; -webkit-background-clip: text; background-clip: text; animation: hero-slide-up 1s var(--ease-out-expo) forwards, hero-gradient-shift 6s ease infinite; }

  .hero-content__tagline { font-size: 1rem; line-height: 1.7; color: rgba(255, 255, 255, 0.5); max-width: 28rem; margin-bottom: 2.5rem; }
  @media (min-width: 1024px) { .hero-content__tagline { font-size: 1.125rem; } }

  .hero-content__cta-primary { position: relative; display: inline-flex; align-items: center; gap: 0.75rem; padding: 1rem 2rem; background: var(--color-accent); color: white; font-size: 0.875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; border-radius: var(--radius-lg); overflow: hidden; transition: all var(--duration-slow); }
  .hero-content__cta-primary:hover { box-shadow: 0 10px 40px var(--color-accent-glow); transform: scale(1.02); }
  .hero-content__cta-shine { position: absolute; inset: 0; transform: translateX(-100%); background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.2), transparent); transition: transform 0.7s; }
  .hero-content__cta-primary:hover .hero-content__cta-shine { transform: translateX(100%); }

  .hero-content__cta-secondary { display: inline-flex; align-items: center; gap: 0.75rem; padding: 1rem 2rem; background: rgba(255, 255, 255, 0.05); color: white; font-size: 0.875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; border-radius: var(--radius-lg); border: 1px solid rgba(255, 255, 255, 0.1); transition: all var(--duration-slow); }
  .hero-content__cta-secondary:hover { border-color: color-mix(in srgb, var(--color-accent) 40%, transparent); background: var(--color-accent-muted); }

  .hero-content__stats { display: none; align-items: baseline; gap: 2rem; margin-top: 4rem; padding-top: 2rem; border-top: 1px solid rgba(255, 255, 255, 0.06); }
  @media (min-width: 1024px) { .hero-content__stats { display: flex; } }
  .hero-content__stat { cursor: default; }
  .hero-content__stat-value { display: block; font-size: 1.875rem; font-weight: 900; color: white; transition: color var(--duration-normal); }
  .group:hover .hero-content__stat-value { color: var(--color-accent); }
  .hero-content__stat-label { display: block; font-size: 0.75rem; color: rgba(255, 255, 255, 0.3); text-transform: uppercase; letter-spacing: 0.08em; margin-top: 0.25rem; }
  .hero-content__stat-divider { width: 1px; height: 2rem; background: rgba(255, 255, 255, 0.1); align-self: center; }

  @keyframes hero-slide-up {
    from { transform: translateY(100%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  @keyframes hero-gradient-shift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
  @keyframes hero-pulse-slow {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.1); }
  }
  @keyframes hero-ping { 75%, 100% { transform: scale(2); opacity: 0; } }
</style>

---
import type { Event, Locale } from '../../types';
import { mockEvents } from '../../data/events/mock';

interface Props {
  events: Event[];
  locale: Locale;
}

const { events, locale } = Astro.props;

// Pool de imágenes de alta calidad de los mocks (Unsplash, fiables)
const fallbackPool = mockEvents
  .filter(e => e.image)
  .map(e => e.image!.replace('?w=800&h=600', '?w=1200&h=1600'));

function getFallback(index: number): string {
  return fallbackPool[index % fallbackPool.length]!;
}

function getEventImage(evt: Event, index: number): string {
  if (evt.image && !evt.image.includes('undefined')) return evt.image;
  if (evt.imageUrl) return evt.imageUrl;
  return getFallback(index);
}

const leftEvents = events.filter((_, i) => i % 2 === 0);
const rightEvents = events.filter((_, i) => i % 2 !== 0);
const currentYear = new Date().getFullYear();
---

<div class="sacrom-sticky-header">
  <h2 class="sacrom-section-title">01 // {locale === 'es' ? 'PROGRAMACIÓN MAMPARAS' : 'PROGRAMMING'}</h2>
  <span class="sacrom-section-meta">ARCHIVAL DATA {currentYear}</span>
</div>
<section class="sacrom-masonry-wrapper" aria-labelledby="events-heading">
  <!-- Columna Izquierda (40%) -->
  <div class="sacrom-masonry-col col-left">
    {leftEvents.map((evt, idx) => {
      // Escalado masivo progresivo para la caja, perdiendo el styling inline para el texto
      const heightVh = 50 + (idx * 15);
      const fallbackSrc = getFallback(idx);

      return (
        <article class="sacrom-masonry-item" style={`height: ${heightVh}vh;`}>
          <a href={`/eventos/${evt.slug}`} class="sacrom-card-link group">
            <img
              src={getEventImage(evt, idx)}
              onerror={`this.onerror=null;this.src='${fallbackSrc}'`}
              alt=""
              class="sacrom-card-img"
              loading="lazy"
              decoding="async"
            />
            <div class="sacrom-card-overlay active-always"></div>
            
            <div class="sacrom-badge-container">
              <span class="sacrom-cat-badge">{evt.category}</span>
            </div>

            <div class="sacrom-card-content p-heavy">
              <div class="sacrom-text-wrapper">
                <h3 class="sacrom-title">{evt.title[locale]}</h3>
                <div class="sacrom-meta-info">
                  <span class="sacrom-date">{evt.date || 'TBA'}</span>
                  <span class="sacrom-separator">//</span>
                  <span class="sacrom-venue">{evt.venue || 'Granada'}</span>
                </div>
              </div>
            </div>
          </a>
        </article>
      );
    })}
  </div>

  <!-- Columna Derecha (60%) -->
  <div class="sacrom-masonry-col col-right">
    {rightEvents.map((evt, idx) => {
      // Escalado masivo progresivo
      const heightVh = 70 + (idx * 20);
      const fallbackSrc = getFallback(idx);

      return (
        <article class="sacrom-masonry-item" style={`height: ${heightVh}vh;`}>
          <a href={`/eventos/${evt.slug}`} class="sacrom-card-link group">
            <img
              src={getEventImage(evt, idx)}
              onerror={`this.onerror=null;this.src='${fallbackSrc}'`}
              alt=""
              class="sacrom-card-img"
              loading="lazy"
              decoding="async"
            />
            <div class="sacrom-card-overlay active-always"></div>
            
            <div class="sacrom-badge-container">
              <span class="sacrom-cat-badge">{evt.category}</span>
            </div>

            <div class="sacrom-card-content p-heavy">
              <div class="sacrom-text-wrapper">
                <h3 class="sacrom-title">{evt.title[locale]}</h3>
                <div class="sacrom-meta-info">
                  <span class="sacrom-date">{evt.date || 'TBA'}</span>
                  <span class="sacrom-separator">//</span>
                  <span class="sacrom-venue">{evt.venue || 'Granada'}</span>
                </div>
              </div>
            </div>
          </a>
        </article>
      );
    })}
  </div>
</section>

<style>
  .sacrom-sticky-header {
    position: sticky;
    top: 72px; /* --header-height */
    z-index: 40;
    background-color: var(--color-bg);
    border-bottom: 2px solid var(--color-border);
    padding: 0.5rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .sacrom-section-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 900;
    letter-spacing: -0.08em;
    text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0;
  }

  .sacrom-section-meta {
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 900;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--color-text-primary);
    padding-bottom: 0.25rem;
  }

  @media (max-width: 640px) {
    .sacrom-sticky-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }

  /* Masonry Wrapper */
  .sacrom-masonry-wrapper {
    display: flex;
    width: 100%;
    background-color: var(--color-border);
    border-bottom: 2px solid var(--color-border);
  }

  .sacrom-masonry-col {
    display: flex;
    flex-direction: column;
    background-color: var(--color-bg);
  }

  .col-left {
    width: 40%;
    border-right: 2px solid var(--color-border);
  }

  .col-right {
    width: 60%;
  }

  /* Responsive: on mobile stack them */
  @media (max-width: 768px) {
    .sacrom-masonry-wrapper {
      flex-direction: column;
    }
    .col-left, .col-right {
      width: 100%;
      border-right: none;
    }
  }

  .sacrom-masonry-item {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-bottom: 2px solid var(--color-border);
  }
  
  .sacrom-card-link {
    display: block;
    width: 100%;
    height: 100%;
    color: var(--color-text-inverse);
    text-decoration: none;
    position: relative;
    cursor: pointer;
  }

  .sacrom-card-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s cubic-bezier(0.19, 1, 0.22, 1), filter 0.8s ease;
  }

  .sacrom-card-link:hover .sacrom-card-img {
    transform: scale(1.05);
  }

  .sacrom-card-overlay {
    position: absolute;
    inset: 0;
    transition: background-color 0.4s ease;
    z-index: 1;
  }

  .active-always {
    background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.8) 20%, rgba(0,0,0,0.4) 50%, transparent 80%);
  }
  .sacrom-card-link:hover .active-always {
    background: linear-gradient(to top, rgba(0,0,0,0.98) 0%, rgba(0,0,0,0.85) 25%, rgba(0,0,0,0.5) 55%, transparent 85%);
  }

  .sacrom-card-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    z-index: 2;
  }

  .p-heavy { padding: 3rem; }

  @media (max-width: 640px) {
    .p-heavy { padding: 1.5rem; }
  }

  .sacrom-badge-container {
    position: absolute;
    top: 2rem;
    right: 2rem;
    z-index: 3;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .sacrom-card-link:hover .sacrom-badge-container {
    transform: translateY(-5px);
  }

  @media (max-width: 640px) {
    .sacrom-badge-container { top: 1.5rem; right: 1.5rem; }
  }

  .sacrom-cat-badge {
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    background: #ffffff;
    color: #000000;
    padding: 0.4rem 0.8rem;
    border: 2px solid #000000;
    display: inline-block;
  }

  .sacrom-text-wrapper {
    max-width: 90%;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .sacrom-card-link:hover .sacrom-text-wrapper {
    transform: translateY(-8px);
  }

  .sacrom-title {
    font-family: var(--font-body); /* Lora serif for an elegant editorial look */
    font-size: clamp(2rem, 3.5vw, 4rem);
    font-weight: 400; /* Regular weight, premium feel */
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
    color: #ffffff;
    text-shadow: 0 4px 12px rgba(0,0,0,0.5); /* extra pop to guarantee legibility */
  }

  .sacrom-meta-info {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 1rem;
    color: rgba(255, 255, 255, 0.85);
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .sacrom-separator {
    color: rgba(255, 255, 255, 0.4);
    font-weight: 400;
  }

  .sacrom-venue {
    color: #ffffff;
  }
</style>
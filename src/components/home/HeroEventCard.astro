---
/**
 * HeroEventCard — Single event card used in the hero sidebar.
 */
import type { Locale, Event } from '@types';
import { eventCategoryStyles } from '@config/ui';
import { useTranslations } from '@i18n/utils';

interface Props {
  event: Event;
  locale: Locale;
  href: string;
  delay: number;
}

const { event, locale, href, delay } = Astro.props;
const t = useTranslations(locale);
const category = event.category ?? 'other';
const catStyle = eventCategoryStyles[category];
const title = event.title?.[locale] ?? '';
const eventImage = event.imageUrl ?? '';
const neighborhood = event.neighborhood ?? '';

const date = new Date(event.date);
const day = date.getDate();
const month = date.toLocaleDateString(locale, { month: 'short' }).toUpperCase();

// Urgency calculation
const today = new Date();
today.setHours(0, 0, 0, 0);
const eventDate = new Date(event.date);
eventDate.setHours(0, 0, 0, 0);
const diffDays = Math.ceil((eventDate.getTime() - today.getTime()) / (1000 * 60 * 60 * 24));

const urgency = diffDays === 0
  ? { label: t('home.hero.today'), variant: 'urgent', pulse: true }
  : diffDays === 1
    ? { label: t('home.hero.tomorrow'), variant: 'soon', pulse: false }
    : diffDays <= 3
      ? { label: t('home.hero.upcoming'), variant: 'near', pulse: false }
      : null;

const isFree = event.price === null || event.price === 0;
---

<a href={href} class="hero-reveal hero-ecard group" data-delay={delay}>
  <div class="hero-ecard__bar"></div>

  <div class="hero-ecard__date">
    <span class="hero-ecard__day">{day}</span>
    <span class="hero-ecard__month">{month}</span>
  </div>

  <div class="hero-ecard__thumb">
    {eventImage ? (
      <img src={eventImage} alt="" class="hero-ecard__img" loading="lazy" />
    ) : (
      <div class="hero-ecard__placeholder">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d={catStyle?.icon ?? ''} />
        </svg>
      </div>
    )}
    <div class="hero-ecard__thumb-fade"></div>
  </div>

  <div class="hero-ecard__body">
    <h3 class="hero-ecard__name">{title}</h3>
    <div class="hero-ecard__meta">
      <span class="hero-ecard__meta-item">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        <span class="truncate max-w-[80px]">{neighborhood ? t(`neighborhoods.${neighborhood}` as 'neighborhoods.centro') : ''}</span>
      </span>
      <span class="hero-ecard__sep"></span>
      <span class="truncate">{t(`categories.${category}` as 'categories.concert')}</span>
    </div>
  </div>

  <div class="hero-ecard__side">
    {urgency && (
      <span class:list={['hero-ecard__urgency', `hero-ecard__urgency--${urgency.variant}`, urgency.pulse && 'is-pulsing']}>
        <span class="hero-ecard__urgency-dot"></span>
        {urgency.label}
      </span>
    )}
    <span class:list={['hero-ecard__price', isFree && 'hero-ecard__price--free']}>
      {isFree ? t('home.hero.free') : `${event.price}\u20AC`}
    </span>
  </div>
</a>

<style>
  .hero-ecard {
    display: flex;
    align-items: stretch;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all var(--duration-normal);
  }

  .hero-ecard:hover {
    border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
    background: rgba(255, 255, 255, 0.06);
  }

  .hero-ecard__bar {
    width: 4px;
    background: linear-gradient(to bottom, var(--color-accent), var(--color-secondary));
    opacity: 0;
    transition: opacity var(--duration-normal);
  }

  .hero-ecard:hover .hero-ecard__bar { opacity: 1; }

  .hero-ecard__date {
    flex-shrink: 0;
    width: 3.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.03);
    border-right: 1px solid rgba(255, 255, 255, 0.05);
    padding: 0.75rem 0;
  }

  .hero-ecard__day { font-size: 1.25rem; font-weight: 900; color: white; line-height: 1; }
  .hero-ecard__month { font-size: 0.625rem; font-weight: 700; color: rgba(255, 255, 255, 0.3); }

  .hero-ecard__thumb { position: relative; flex-shrink: 0; width: 4rem; overflow: hidden; }

  .hero-ecard__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow);
  }

  .hero-ecard:hover .hero-ecard__img { transform: scale(1.1); }

  .hero-ecard__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, color-mix(in srgb, var(--color-accent) 20%, transparent), color-mix(in srgb, var(--color-secondary) 10%, transparent));
    color: rgba(255, 255, 255, 0.5);
  }

  .hero-ecard__thumb-fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent, rgba(0, 0, 0, 0.3));
  }

  .hero-ecard__body {
    flex: 1;
    min-width: 0;
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-ecard__name {
    font-size: 0.875rem;
    font-weight: 600;
    color: white;
    line-height: 1.3;
    margin-bottom: 0.375rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color var(--duration-normal);
  }

  .hero-ecard:hover .hero-ecard__name { color: var(--color-accent); }

  .hero-ecard__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.6875rem;
    color: rgba(255, 255, 255, 0.3);
  }

  .hero-ecard__meta-item { display: flex; align-items: center; gap: 0.25rem; }

  .hero-ecard__sep {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
  }

  .hero-ecard__side {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: space-between;
    padding: 0.75rem;
    border-left: 1px solid rgba(255, 255, 255, 0.05);
    background: rgba(255, 255, 255, 0.02);
  }

  .hero-ecard__urgency {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.125rem 0.5rem;
    border-radius: var(--radius-xs);
    font-size: 0.5625rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .hero-ecard__urgency--urgent { background: var(--color-accent-muted); color: var(--color-accent); }
  .hero-ecard__urgency--soon { background: var(--color-secondary-muted); color: var(--color-secondary); }
  .hero-ecard__urgency--near { background: var(--color-success-muted); color: var(--color-success); }
  .hero-ecard__urgency.is-pulsing { animation: hero-ecard-pulse 2s ease-in-out infinite; }

  .hero-ecard__urgency-dot { width: 4px; height: 4px; border-radius: 50%; background: currentColor; }

  .hero-ecard__price { font-size: 0.875rem; font-weight: 700; color: white; }
  .hero-ecard__price--free { color: var(--color-success); }

  @keyframes hero-ecard-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
  }
</style>

---
import type { BlogPost, BlogCategory, Locale } from '@types';
import ScreenFrame from '@components/ui/ScreenFrame.astro';
import OptimizedImage from '@components/ui/OptimizedImage.astro';
import { useTranslations } from '@i18n/utils';

interface Props {
  posts: BlogPost[];
  locale: Locale;
}

const { posts, locale } = Astro.props;
const t = useTranslations(locale);

// Get featured + 2 more posts
const featuredPost = posts.find(p => p.featured) || posts[0];
const otherPosts = posts.filter(p => p.id !== featuredPost?.id).slice(0, 2);
const displayPosts = [featuredPost, ...otherPosts].filter(Boolean);

const blogHref = locale === 'es' ? '/blog' : '/en/blog';

const categoryData: Record<BlogCategory, { icon: string; label: string; color: string; accentRgb: string }> = {
  guia: { icon: '◈', label: t('blog.categories.guia'), color: '#e8622a', accentRgb: '232, 98, 42' },
  cultura: { icon: '◎', label: t('blog.categories.cultura'), color: '#c9a84c', accentRgb: '201, 168, 76' },
  gastronomia: { icon: '◐', label: t('blog.categories.gastronomia'), color: '#d4873a', accentRgb: '212, 135, 58' },
  barrios: { icon: '○', label: t('blog.categories.barrios'), color: '#4a9e6b', accentRgb: '74, 158, 107' },
  consejos: { icon: '◆', label: t('blog.categories.consejos'), color: '#6b5a9e', accentRgb: '107, 90, 158' },
};

const BLOG_IMAGES: Record<string, string> = {
  'blog-002': 'https://images.unsplash.com/photo-1555396273-367ea4eb4db5?w=1200&h=800&fit=crop',
  'blog-003': 'https://images.unsplash.com/photo-1523531294919-4bcd7c65e216?w=1200&h=800&fit=crop',
  'blog-004': 'https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=1200&h=800&fit=crop',
  'blog-005': 'https://images.unsplash.com/photo-1548013146-72479768bada?w=1200&h=800&fit=crop',
  default: 'https://images.unsplash.com/photo-1548013146-72479768bada?w=1200&h=800&fit=crop',
};

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  return `${d.getDate()} ${d.toLocaleDateString('es-ES', { month: 'short' }).toUpperCase()}`;
}
---

<section class="journal-section" aria-label={t('blog.title')}>
  <!-- Decorative Elements -->
  <div class="deco-layer">
    <div class="deco-circle"></div>
    <div class="deco-line"></div>
    <div class="deco-dots"></div>
  </div>
  
  <ScreenFrame
    tagTopLeft="REVISTA"
    tagTopRight="04/25"
    tagBottomLeft="VOL. 1"
    tagBottomRight="ISSN"
  />

  <div class="journal-container">
    <!-- Masthead -->
    <header class="journal-masthead">
      <div class="masthead-kicker">
        <span class="kicker-line"></span>
        <span class="kicker-text">EDICIÓN ESPECIAL</span>
        <span class="kicker-line"></span>
      </div>
      <h2 class="masthead-title">
        <span class="title-main">Historias</span>
        <span class="title-sub">de una ciudad sin tiempo</span>
      </h2>
      <p class="masthead-lead">Relatos, guías y secretos de Granada escritos por quienes la habitan.</p>
    </header>

    <!-- Bento Grid Layout -->
    <div class="bento-grid">
      <!-- Main Feature - Large Card with Overlay Text -->
      {
        (() => {
          const post = displayPosts[0];
          if (!post) return null;
          const catData = categoryData[post.category];
          
          return (
            <article 
              class="bento-item item-feature" 
              style={`--accent: ${catData?.color ?? '#e8622a'}; --accent-rgb: ${catData?.accentRgb ?? '232, 98, 42'}`}
            >
              <a href={`/blog/${post.slug}`} class="feature-link">
                {/* Image Background */}
                <div class="feature-visual">
                  <OptimizedImage
                    src={post.image || BLOG_IMAGES[post.id] || BLOG_IMAGES.default}
                    alt={post.title[locale]}
                    class="feature-img"
                    loading="eager"
                    decoding="async"
                    sizes="(max-width: 768px) 100vw, 60vw"
                  />
                  <div class="feature-grad"></div>
                </div>

                {/* Content Overlay */}
                <div class="feature-content">
                  {/* Category Tag */}
                  <div class="feature-tag">
                    <span class="tag-icon">{catData?.icon ?? '◈'}</span>
                    <span class="tag-label">{catData?.label ?? 'Guía'}</span>
                  </div>

                  {/* Title */}
                  <h3 class="feature-title">{post.title[locale]}</h3>

                  {/* Excerpt */}
                  <p class="feature-excerpt">{post.description[locale]}</p>

                  {/* Meta Row */}
                  <div class="feature-meta">
                    <span class="meta-author">{post.author}</span>
                    <span class="meta-sep">—</span>
                    <time datetime={post.publishDate}>{formatDate(post.publishDate)}</time>
                  </div>
                </div>

                {/* Side Number */}
                <div class="feature-number">01</div>

                {/* Corner Accents */}
                <div class="corner-accent tl"></div>
                <div class="corner-accent br"></div>

                {/* Read Indicator */}
                <div class="read-indicator">
                  <span>Leer</span>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              </a>
            </article>
          );
        })()
      }

      {/* Side Articles - Expedition Style Cards from Routes */}
      {displayPosts.slice(1).map((post, idx) => {
        const catData = categoryData[post.category];
        const cardNum = String(idx + 2).padStart(2, '0');
        const postImage = post.image || BLOG_IMAGES[post.id] || BLOG_IMAGES.default;
        
        return (
          <article 
            class="bento-item item-side" 
            data-index={idx}
            style={`--card-index: ${idx}; --accent: ${catData?.color ?? '#e8622a'}; --accent-rgb: ${catData?.accentRgb ?? '232, 98, 42'}`}
          >
            <a href={`/blog/${post.slug}`} class="expedition-link">
              {/* Expedition Number Stamp */}
              <div class="expedition-stamp">
                <span class="stamp-prefix">ART.</span>
                <span class="stamp-number">{cardNum}</span>
              </div>

              {/* Main Visual */}
              <div class="expedition-visual">
                <div class="visual-frame">
                  <OptimizedImage
                    src={postImage}
                    alt={post.title[locale]}
                    class="expedition-img"
                    loading="lazy"
                    decoding="async"
                    sizes="(max-width: 640px) 100vw, 400px"
                  />
                  <div class="visual-vignette"></div>
                  
                  {/* Corner Markers */}
                  <div class="corner-marker tl"></div>
                  <div class="corner-marker tr"></div>
                  <div class="corner-marker bl"></div>
                  <div class="corner-marker br"></div>
                </div>
                
                {/* Category Tag */}
                <div class="legend-tag">
                  <span class="legend-symbol">{catData?.icon ?? '◈'}</span>
                  <span class="legend-text">{catData?.label ?? 'Artículo'}</span>
                </div>
                
                {/* Featured Badge */}
                {post.featured && (
                  <div class="featured-badge">
                    <span class="featured-star">★</span>
                    <span class="featured-text">{t('routes.featured')}</span>
                  </div>
                )}
              </div>

              {/* Content - Field Notes Style */}
              <div class="field-notes">
                {/* Top Row: Date */}
                <div class="notes-header">
                  <div class="time-badge">
                    <span class="time-icon">◎</span>
                    <span class="time-text">{formatDate(post.publishDate)}</span>
                  </div>
                </div>
                
                {/* Title */}
                <h3 class="expedition-title">
                  {post.title[locale]}
                </h3>
                
                {/* Description */}
                <p class="expedition-description">
                  {post.description[locale].length > 120 
                    ? post.description[locale].slice(0, 120) + '...' 
                    : post.description[locale]}
                </p>
                
                {/* Reading Progress Bar */}
                <div class="reading-bar">
                  <div class="reading-track">
                    <div class="reading-fill" style={`width: ${Math.min((post.readingTime / 15) * 100, 100)}%`}></div>
                  </div>
                  <span class="reading-text">{post.readingTime} min de lectura</span>
                </div>
              </div>
              
              {/* Hover Reveal - Compass */}
              <div class="compass-reveal" aria-hidden="true">
                <div class="compass-container">
                  <svg viewBox="0 0 100 100" class="compass-svg">
                    <circle cx="50" cy="50" r="45" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3"/>
                    <circle cx="50" cy="50" r="35" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.2"/>
                    <path d="M50 10 L55 45 L90 50 L55 55 L50 90 L45 55 L10 50 L45 45 Z" fill="currentColor" opacity="0.8"/>
                    <circle cx="50" cy="50" r="4" fill="currentColor"/>
                  </svg>
                  <span class="compass-text">LEER</span>
                </div>
              </div>
            </a>
          </article>
        );
      })}
    </div>

    {/* Footer Action */}
    <div class="journal-footer">
      <a href={blogHref} class="archive-link">
        <span class="archive-line"></span>
        <span class="archive-text">Explorar archivo completo</span>
        <span class="archive-count">{posts.length} artículos</span>
        <span class="archive-line"></span>
      </a>
    </div>
  </div>
</section>

<script>
  function initScrollAnimations() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

    document.querySelectorAll('.bento-item, .journal-masthead').forEach((el) => {
      observer.observe(el);
    });
  }

  document.addEventListener('DOMContentLoaded', initScrollAnimations);
  document.addEventListener('astro:page-load', initScrollAnimations);
</script>

<style>
  /* ═══════════════════════════════════════════════════════════════
     BASE
     ═══════════════════════════════════════════════════════════════ */
  .journal-section {
    --j-cream: #f5f0ea;
    --j-cream-2: #faf7f3;
    --j-ink: #1a1619;
    --j-ink-2: #3d3632;
    --j-ink-3: #6b6058;
    --j-orange: #e8622a;
    --j-gold: #c9a84c;
    --j-border: rgba(26, 22, 25, 0.08);
    --j-border-2: rgba(26, 22, 25, 0.12);

    position: relative;
    width: 100%;
    background: var(--j-cream);
    padding: 5rem 0 6rem;
    overflow: visible;
    margin-top: 3rem;
    z-index: 1;
  }

  .journal-section :global(.cin-screen-frame) { border-color: var(--j-border); }
  .journal-section :global(.cin-corner::before),
  .journal-section :global(.cin-corner::after) { background: var(--j-ink); opacity: 0.06; }
  .journal-section :global(.cin-frame-tag) { color: var(--j-ink-3); font-size: 0.6rem; letter-spacing: 0.15em; }

  /* Decorative Layer */
  .deco-layer { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
  .deco-circle { position: absolute; top: 10%; right: 5%; width: 300px; height: 300px; border: 1px solid var(--j-border); border-radius: 50%; opacity: 0.5; }
  .deco-line { position: absolute; top: 0; left: 30%; width: 1px; height: 100%; background: linear-gradient(to bottom, transparent, var(--j-border) 20%, var(--j-border) 80%, transparent); }
  .deco-dots { position: absolute; bottom: 15%; left: 8%; width: 120px; height: 120px; background-image: radial-gradient(circle, var(--j-border) 1px, transparent 1px); background-size: 12px 12px; opacity: 0.6; }

  /* Container */
  .journal-container { position: relative; z-index: 2; max-width: 1100px; margin: 0 auto; padding: 0 clamp(1.25rem, 4vw, 2.5rem); }

  /* ═══════════════════════════════════════════════════════════════
     MASTHEAD
     ═══════════════════════════════════════════════════════════════ */
  .journal-masthead { text-align: center; margin-bottom: 3rem; opacity: 0; transform: translateY(20px); transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1); }
  .journal-masthead.is-visible { opacity: 1; transform: translateY(0); }

  .masthead-kicker { display: flex; align-items: center; justify-content: center; gap: 1rem; margin-bottom: 1rem; }
  .kicker-line { width: 40px; height: 1px; background: var(--j-border); }
  .kicker-text { font-family: var(--font-display); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.3em; color: var(--j-orange); text-transform: uppercase; }

  .masthead-title { margin: 0 0 0.75rem; }
  .title-main { display: block; font-family: var(--font-body); font-size: clamp(2.5rem, 6vw, 4rem); font-weight: 300; line-height: 1; color: var(--j-ink); letter-spacing: -0.03em; }
  .title-sub { display: block; font-family: var(--font-display); font-size: clamp(0.9rem, 2vw, 1.1rem); font-weight: 400; letter-spacing: 0.15em; color: var(--j-ink-3); text-transform: uppercase; margin-top: 0.5rem; }

  .masthead-lead { font-family: var(--font-display); font-size: 1rem; color: var(--j-ink-2); max-width: 400px; margin: 0 auto; line-height: 1.6; }

  /* ═══════════════════════════════════════════════════════════════
     BENTO GRID
     ═══════════════════════════════════════════════════════════════ */
  .bento-grid { 
    display: grid; 
    grid-template-columns: 1.4fr 1fr; 
    grid-template-rows: 1fr 1fr; 
    gap: 1.25rem; 
    min-height: 600px;
    height: auto;
  }
  
  .bento-grid::after {
    content: '';
    display: block;
    clear: both;
  }

  /* ═══════════════════════════════════════════════════════════════
     FEATURE ITEM - Large Card (UNCHANGED)
     ═══════════════════════════════════════════════════════════════ */
  .item-feature { grid-row: span 2; opacity: 0; transform: translateY(30px); transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1); }
  .item-feature.is-visible { opacity: 1; transform: translateY(0); }

  .feature-link { display: block; position: relative; height: 100%; border-radius: 20px; overflow: hidden; text-decoration: none; color: inherit; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12); transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .feature-link:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(var(--accent-rgb), 0.2), 0 12px 32px rgba(0, 0, 0, 0.15); }

  .feature-visual { position: absolute; inset: 0; }
  .feature-img { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.75) saturate(0.9); transition: all 0.8s cubic-bezier(0.19, 1, 0.22, 1); }
  .feature-link:hover .feature-img { transform: scale(1.03); filter: brightness(0.8) saturate(1); }

  .feature-grad { position: absolute; inset: 0; background: linear-gradient(to top, rgba(26, 22, 25, 0.95) 0%, rgba(26, 22, 25, 0.5) 50%, rgba(26, 22, 25, 0.2) 100%); transition: opacity 0.5s ease; }
  .feature-link:hover .feature-grad { opacity: 0.9; }

  .feature-content { position: absolute; bottom: 0; left: 0; right: 0; padding: 2.5rem; z-index: 5; }

  .feature-tag { display: inline-flex; align-items: center; gap: 0.375rem; padding: 0.5rem 1rem; background: var(--accent); border-radius: 100px; margin-bottom: 1.25rem; transition: all 0.3s ease; }
  .feature-link:hover .feature-tag { transform: translateY(-2px); box-shadow: 0 4px 16px rgba(var(--accent-rgb), 0.4); }
  .tag-icon { font-size: 0.9rem; }
  .tag-label { font-family: var(--font-display); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: white; }

  .feature-title { font-family: var(--font-body); font-size: clamp(1.75rem, 3vw, 2.25rem); font-weight: 600; line-height: 1.15; color: white; margin: 0 0 1rem; letter-spacing: -0.02em; }

  .feature-excerpt { font-family: var(--font-display); font-size: 1rem; line-height: 1.7; color: rgba(255, 255, 255, 0.75); margin: 0 0 1.5rem; max-width: 90%; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

  .feature-meta { display: flex; align-items: center; gap: 0.75rem; font-family: var(--font-display); font-size: 0.85rem; color: rgba(255, 255, 255, 0.6); }
  .meta-author { color: rgba(255, 255, 255, 0.9); font-weight: 600; }
  .meta-sep { opacity: 0.5; }

  .feature-number { position: absolute; top: 1.5rem; right: 1.5rem; font-family: var(--font-display); font-size: 5rem; font-weight: 800; color: transparent; -webkit-text-stroke: 1px rgba(255, 255, 255, 0.2); line-height: 1; z-index: 3; transition: all 0.5s ease; }
  .feature-link:hover .feature-number { -webkit-text-stroke: 1px var(--accent); color: rgba(var(--accent-rgb), 0.1); }

  .corner-accent { position: absolute; width: 40px; height: 40px; border-color: rgba(255, 255, 255, 0.2); border-style: solid; border-width: 0; z-index: 4; transition: all 0.5s ease; }
  .corner-accent.tl { top: 1.5rem; left: 1.5rem; border-top-width: 2px; border-left-width: 2px; }
  .corner-accent.br { bottom: 1.5rem; right: 1.5rem; border-bottom-width: 2px; border-right-width: 2px; }
  .feature-link:hover .corner-accent { border-color: var(--accent); width: 60px; height: 60px; }

  .read-indicator { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) scale(0.9); display: flex; align-items: center; gap: 0.5rem; padding: 0.875rem 1.5rem; background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); border-radius: 100px; font-family: var(--font-display); font-size: 0.8rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--j-ink); opacity: 0; transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1); z-index: 10; }
  .feature-link:hover .read-indicator { opacity: 1; transform: translate(-50%, -50%) scale(1); }

  /* ═══════════════════════════════════════════════════════════════
     SIDE ITEMS - Expedition Style Cards (from Routes Page)
     ═══════════════════════════════════════════════════════════════ */
  .item-side { 
    opacity: 0; 
    transform: translateY(30px); 
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1); 
    transition-delay: calc(var(--card-index, 0) * 0.15s);
    min-height: 0;
  }
  .item-side.is-visible { opacity: 1; transform: translateY(0); }
  
  .item-side:nth-child(2) { grid-column: 2; grid-row: 1; }
  .item-side:nth-child(3) { grid-column: 2; grid-row: 2; }

  /* Card Link */
  .expedition-link {
    display: flex;
    flex-direction: column;
    position: relative;
    text-decoration: none;
    color: inherit;
    background: #ffffff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow:
      0 4px 6px rgba(26, 22, 25, 0.02),
      0 12px 24px rgba(26, 22, 25, 0.04);
    transition:
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    border: 1px solid rgba(26, 22, 25, 0.06);
    height: 100%;
    min-height: 0;
  }

  .expedition-link:hover {
    transform: translateY(-4px);
    box-shadow:
      0 16px 40px rgba(26, 22, 25, 0.1),
      0 6px 16px rgba(26, 22, 25, 0.06);
    border-color: rgba(26, 22, 25, 0.1);
  }

  /* Expedition Number Stamp */
  .expedition-stamp {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 0.5rem 0.875rem;
    background: var(--j-ink);
    border: 1.5px solid var(--j-gold);
    border-radius: 6px;
    transform: rotate(-1deg);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  }

  .expedition-link:hover .expedition-stamp {
    transform: rotate(0deg) scale(1.02);
  }

  .stamp-prefix {
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--j-gold);
  }

  .stamp-number {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--j-cream);
    line-height: 1;
  }

  /* Visual Container */
  .expedition-visual {
    position: relative;
    height: 180px;
    min-height: 180px;
    overflow: hidden;
    background: var(--j-ink);
    flex-shrink: 0;
  }

  .visual-frame {
    position: relative;
    width: 100%;
    height: 100%;
    padding: 0.75rem;
    box-sizing: border-box;
  }

  .expedition-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(20%) contrast(1.05) brightness(0.92);
    border-radius: 10px;
    transition:
      filter 0.6s cubic-bezier(0.19, 1, 0.22, 1),
      transform 0.6s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .expedition-link:hover .expedition-img {
    filter: grayscale(0%) contrast(1.02) brightness(1);
    transform: scale(1.03);
  }

  .visual-vignette {
    position: absolute;
    inset: 0.75rem;
    background:
      linear-gradient(
        to bottom,
        transparent 40%,
        rgba(26, 22, 25, 0.35) 100%
      );
    pointer-events: none;
    border-radius: 10px;
  }

  /* Corner Markers */
  .corner-marker {
    position: absolute;
    width: 18px;
    height: 18px;
    border-color: rgba(201, 168, 76, 0.45);
    border-style: solid;
    border-width: 0;
    transition: all 0.4s cubic-bezier(0.19, 1, 0.22, 1);
    pointer-events: none;
  }

  .expedition-link:hover .corner-marker {
    opacity: 1;
    border-color: var(--j-gold);
  }

  .corner-marker.tl { top: 0.5rem; left: 0.5rem; border-top-width: 2px; border-left-width: 2px; }
  .corner-marker.tr { top: 0.5rem; right: 0.5rem; border-top-width: 2px; border-right-width: 2px; }
  .corner-marker.bl { bottom: 0.5rem; left: 0.5rem; border-bottom-width: 2px; border-left-width: 2px; }
  .corner-marker.br { bottom: 0.5rem; right: 0.5rem; border-bottom-width: 2px; border-right-width: 2px; }

  /* Legend Tag (Category) */
  .legend-tag {
    position: absolute;
    bottom: 0.75rem;
    left: 0.75rem;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 0.5rem;

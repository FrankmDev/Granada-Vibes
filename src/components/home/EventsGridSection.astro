---
import type { Event, Locale, EventCategory } from '@types';
import { useTranslations } from '@i18n/utils';
import { getRoute, getEventDetailUrl } from '@utils/routes';
import SectionHeader from '@components/ui/SectionHeader.astro';
import EventImage from '@components/ui/EventImage.astro';
import { getEventDisplayTitle } from '@utils/event-seo';

interface Props {
  events: Event[];
  locale: Locale;
}

const { events, locale } = Astro.props;
const t = useTranslations(locale);

// Category labels sourced from i18n — no inline map needed
const categoryLabels: Record<EventCategory, string> = {
  concert:      t('categories.concert').toUpperCase(),
  exhibition:   t('categories.exhibition').toUpperCase(),
  festival:     t('categories.festival').toUpperCase(),
  market:       t('categories.market').toUpperCase(),
  theater:      t('categories.theater').toUpperCase(),
  workshop:     t('categories.workshop').toUpperCase(),
  'guided-tour':t('categories.guided-tour').toUpperCase(),
  cinema:       t('categories.cinema').toUpperCase(),
  other:        t('categories.other').toUpperCase(),
};

// Column height patterns for masonry alternation
const COL_HEIGHTS: [number[], number[], number[]] = [
  [58, 72, 58, 72], // left
  [72, 58, 72, 58], // center
  [58, 72, 58, 72], // right
];

// Distribute events into 3 columns, max 4 per column
const columns = [0, 1, 2].map((colIndex) =>
  events.filter((_, i) => i % 3 === colIndex).slice(0, 4)
);

// Dynamic container height: proportional to items so cards don't stretch to 260vh
const maxItemsPerColumn = Math.max(...columns.map((c) => c.length), 1);
const totalFlexUnits = COL_HEIGHTS[0]
  .slice(0, maxItemsPerColumn)
  .reduce((a, b) => a + b, 0);
const columnHeight = `${Math.max(totalFlexUnits, 120)}vh`;

function formatPrice(price: number | null): string {
  if (price === null) return t('events.free');
  return `${price}€`;
}

function formatDateParts(dateStr: string): { day: string; month: string } {
  const d = new Date(dateStr);
  const localeStr = locale === 'es' ? 'es-ES' : 'en-US';
  return {
    day: d.toLocaleDateString(localeStr, { day: 'numeric' }),
    month: d
      .toLocaleDateString(localeStr, { month: 'short' })
      .replace('.', '')
      .toUpperCase(),
  };
}

const eventsHref = getRoute('events', locale);
---

<section class="editorial-section" aria-label={t('home.sections.eventsAriaLabel')}>
  <div class="events-container">

    <!-- Cinematic Header -->
    <SectionHeader
      eyebrow={t('home.sections.eventsEyebrow')}
      title={t('nav.events').toUpperCase()}
      titleSecondary={t('home.sections.eventsTitleSecondary')}
      subtitle={t('home.sections.eventsSubtitle')}
      ctaHref={eventsHref}
      ctaLabel={t('actions.viewAll').toUpperCase()}
      animateTitle={false}
      theme="cream"
    />

    <!-- Masonry Grid — 3 columns -->
    <div class="masonry-wrapper" style={`--masonry-height: ${columnHeight}`}>
      {columns.map((colEvents, colIndex) => (
        <div class={`masonry-col col-${['left','center','right'][colIndex]}`} style={`--col-index: ${colIndex};`}>
          {colEvents.map((evt, idx) => {
            const heightVh = COL_HEIGHTS[colIndex]![idx] ?? 65;
            const category = categoryLabels[evt.category] ?? evt.category.toUpperCase();
            const href = getEventDetailUrl(evt.slug, locale);
            const displayTitle = getEventDisplayTitle(evt, locale);
            const dateParts = formatDateParts(evt.date);
            const priceFormatted = formatPrice(evt.price);
            const isFree = evt.price === null;

            return (
              <article class="masonry-item" style={`--item-flex: ${heightVh}; --item-index: ${idx}; --col-index: ${colIndex};`}>
                <a href={href} class="item-link">
                  <EventImage
                    event={evt}
                    alt={displayTitle}
                    class="item-image"
                    loading="lazy"
                    decoding="async"
                    sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw"
                    width={900}
                    height={1200}
                  />
                  <div class="item-overlay"></div>

                  <!-- Editorial corner brackets -->
                  <span class="cb cb-tl" aria-hidden="true"></span>
                  <span class="cb cb-tr" aria-hidden="true"></span>
                  <span class="cb cb-bl" aria-hidden="true"></span>
                  <span class="cb cb-br" aria-hidden="true"></span>

                  <!-- Expedition stamp (decorative, aria-hidden) -->
                  <div class="item-stamp" aria-hidden="true">
                    <span class="stamp-prefix">Nº</span>
                    <span class="stamp-num">{String(idx + 1).padStart(2, '0')}</span>
                  </div>

                  <!-- Stacked date badge: day (big) + month (small, orange) -->
                  <div class="date-badge">
                    <span class="date-day">{dateParts.day}</span>
                    <span class="date-month">{dateParts.month}</span>
                  </div>

                  <div class="item-content">
                    <div class="item-text">
                      <div class="item-category">{category}</div>
                      <h3 class="item-title">{displayTitle}</h3>
                      <div class="item-footer">
                        <span class="footer-venue">{evt.venue || 'Granada'}</span>
                        <span class={`price-badge${isFree ? ' price-badge--free' : ''}`}>
                          {priceFormatted}
                        </span>
                      </div>
                    </div>
                  </div>
                </a>
              </article>
            );
          })}
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* ─── Local palette: warm cream ─── */
  .editorial-section {
    --s-cream:    #f5f0ea;
    --s-ink:      #1a1619;
    --s-ink-2:    #5a4f47;
    --s-ink-3:    #8a7f77;
    --s-orange:   #e8622a;
    --s-border:   rgba(26, 22, 25, 0.10);
    --s-border-s: rgba(26, 22, 25, 0.06);
    --s-rail: 1560px;
    --s-gutter: clamp(2rem, 3vw, 3rem);
    --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
    --ease-out-quint: cubic-bezier(0.22, 1, 0.36, 1);

    position: relative;
    width: 100%;
    box-sizing: border-box;
    background: var(--s-cream);
    overflow: hidden;
    padding-top: clamp(5rem, 6vw, 6.5rem);
  }

  .events-container {
    width: 100%;
    margin: 0 auto;
    box-sizing: border-box;
  }

  .editorial-section :global(.sh-editorial) {
    width: 100%;
    max-width: var(--s-rail);
    margin-left: auto;
    margin-right: auto;
    padding-left: var(--s-gutter);
    padding-right: var(--s-gutter);
    box-sizing: border-box;
  }

  /* ─── Masonry Grid ─── */
  .masonry-wrapper {
    position: relative;
    display: flex;
    width: 100%;
    background: var(--s-border);
    border-bottom: 1px solid var(--s-border);
    overflow: hidden;
    isolation: isolate;
  }

  .masonry-wrapper::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none;
    background: linear-gradient(
      100deg,
      transparent 0%,
      rgba(245, 240, 234, 0.12) 32%,
      rgba(232, 98, 42, 0.34) 50%,
      rgba(245, 240, 234, 0.12) 68%,
      transparent 100%
    );
    opacity: 0;
    transform: translate3d(-110%, 0, 0);
  }

  .editorial-section.in-view .masonry-wrapper::before {
    animation: events-light-sweep 1200ms var(--ease-out-quint) 140ms both;
  }

  .masonry-col {
    display: flex;
    flex-direction: column;
    background: var(--s-cream);
    opacity: 1;
    transform: translate3d(0, 0, 0);
    clip-path: inset(0);
  }

  .editorial-section.in-view .masonry-col {
    animation: event-column-open 980ms var(--ease-out-expo) both;
    animation-delay: calc(var(--col-index, 0) * 130ms);
  }

  .col-left   { flex: 1; border-right: 1px solid var(--s-border); }
  .col-center { flex: 1; border-right: 1px solid var(--s-border); }
  .col-right  { flex: 1; }

  .masonry-item {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-bottom: 1px solid var(--s-border);
    background: var(--s-ink);
  }

  .masonry-item::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 6;
    pointer-events: none;
    background:
      linear-gradient(135deg, rgba(245, 240, 234, 0.92), rgba(245, 240, 234, 0.74)),
      linear-gradient(90deg, transparent, rgba(232, 98, 42, 0.18), transparent);
    opacity: 0;
    transform: translate3d(0, 0, 0);
    clip-path: inset(0 0 0 0);
  }

  .editorial-section.in-view .masonry-item {
    animation: event-card-settle 920ms var(--ease-out-expo) both;
    animation-delay: calc((var(--col-index, 0) * 120ms) + (var(--item-index, 0) * 70ms));
  }

  .editorial-section.in-view .masonry-item::before {
    animation: event-curtain-reveal 920ms var(--ease-out-expo) both;
    animation-delay: calc((var(--col-index, 0) * 120ms) + (var(--item-index, 0) * 70ms));
  }

  @media (min-width: 769px) {
    .masonry-col { height: var(--masonry-height, 260vh); }
    .masonry-item { flex: var(--item-flex, 1) 1 0%; min-height: 180px; }
  }

  .item-link {
    display: block;
    width: 100%; height: 100%;
    position: relative;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
  }

  .item-link::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 4;
    pointer-events: none;
    border: 1px solid rgba(245, 240, 234, 0);
    box-shadow: inset 0 0 0 0 rgba(245, 240, 234, 0);
    transition:
      border-color 280ms var(--ease-out-expo),
      box-shadow 280ms var(--ease-out-expo);
  }

  .item-link:focus-visible {
    outline: none;
  }

  .item-link:focus-visible::after {
    border-color: rgba(201, 168, 76, 0.95);
    box-shadow:
      inset 0 0 0 1px rgba(201, 168, 76, 0.55),
      inset 0 0 0 9px rgba(201, 168, 76, 0.05),
      inset 0 0 48px rgba(232, 98, 42, 0.18),
      0 0 0 1px rgba(201, 168, 76, 0.4);
  }

  .masonry-item:hover .item-link::after {
    border-color: rgba(245, 240, 234, 0.62);
    box-shadow:
      inset 0 0 0 8px rgba(245, 240, 234, 0.06),
      inset 0 0 42px rgba(232, 98, 42, 0.15);
  }

  /* Editorial corner brackets — gold, fade in on hover/focus */
  .cb {
    position: absolute;
    width: 18px;
    height: 18px;
    border-style: solid;
    border-color: rgba(201, 168, 76, 0.55);
    border-width: 0;
    z-index: 5;
    pointer-events: none;
    opacity: 0;
    transition: opacity 360ms var(--ease-out-expo), border-color 360ms var(--ease-out-expo);
  }
  .cb-tl { top: 0.85rem;    left: 0.85rem;    border-top-width: 1.5px; border-left-width: 1.5px; border-radius: 2px 0 0 0; }
  .cb-tr { top: 0.85rem;    right: 0.85rem;   border-top-width: 1.5px; border-right-width: 1.5px; border-radius: 0 2px 0 0; }
  .cb-bl { bottom: 0.85rem; left: 0.85rem;    border-bottom-width: 1.5px; border-left-width: 1.5px; }
  .cb-br { bottom: 0.85rem; right: 0.85rem;   border-bottom-width: 1.5px; border-right-width: 1.5px; }

  .masonry-item:hover .cb,
  .masonry-item:focus-within .cb {
    opacity: 1;
    border-color: rgba(201, 168, 76, 0.95);
  }

  /* Expedition stamp (Nº 01) — small gold-bordered black plate, top-left of card visual */
  .item-stamp {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 6;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 0.4rem 0.7rem;
    background: rgba(8, 8, 8, 0.78);
    border: 1px solid rgba(201, 168, 76, 0.55);
    border-radius: 3px;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.32);
    transform: rotate(-1.5deg);
    transition: transform 360ms var(--ease-out-expo);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .masonry-item:hover .item-stamp,
  .masonry-item:focus-within .item-stamp {
    transform: rotate(0deg) scale(1.04);
  }
  .stamp-prefix {
    font-family: var(--font-display);
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: rgba(201, 168, 76, 0.95);
    line-height: 1;
  }
  .stamp-num {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: rgba(245, 240, 234, 0.96);
    line-height: 1.1;
    margin-top: 0.1rem;
  }

  .item-image {
    position: absolute;
    inset: 0;
    filter: grayscale(25%) contrast(1.05) brightness(0.8);
    transform: scale(1.08);
    transition:
      transform 1.2s cubic-bezier(0.19, 1, 0.22, 1),
      filter 0.8s ease;
  }

  .masonry-item:hover .item-image,
  .masonry-item:focus-within .item-image {
    transform: scale(1.015);
    filter: grayscale(0%) contrast(1.06) brightness(0.92) saturate(1.08);
  }

  .item-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top,
      rgba(0,0,0,0.98) 0%,
      rgba(0,0,0,0.94) 8%,
      rgba(0,0,0,0.78) 22%,
      rgba(0,0,0,0.42) 48%,
      transparent      76%
    );
    z-index: 1;
  }

  .masonry-item:hover .item-overlay,
  .masonry-item:focus-within .item-overlay {
    background: linear-gradient(to top,
      rgba(0,0,0,0.99) 0%,
      rgba(0,0,0,0.96) 10%,
      rgba(0,0,0,0.86) 26%,
      rgba(0,0,0,0.52) 52%,
      transparent      82%
    );
  }

  .item-content {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 1.5rem;
    z-index: 2;
  }

  /* Date badge: stacked calendar (day big in Fraunces, month small in DM Sans orange) */
  .date-badge {
    position: absolute; top: 1rem; right: 1rem; z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    padding: 0.55rem 0.8rem 0.5rem;
    min-width: 52px;
    background: rgba(245, 240, 234, 0.97);
    border: 1px solid rgba(245, 240, 234, 0.55);
    border-radius: 8px;
    color: var(--s-ink);
    box-shadow: 0 6px 20px rgba(0,0,0,0.3);
    transition:
      transform 380ms var(--ease-out-expo),
      background 320ms var(--ease-out-expo),
      box-shadow 320ms var(--ease-out-expo);
  }
  @media (min-width: 769px) {
    .date-badge {
      backdrop-filter: blur(8px) saturate(120%);
      -webkit-backdrop-filter: blur(8px) saturate(120%);
    }
  }

  .date-day {
    font-family: var(--font-body);
    font-size: 1.35rem;
    font-weight: 400;
    line-height: 1;
    color: var(--s-ink);
    letter-spacing: -0.02em;
  }
  .date-month {
    font-family: var(--font-display);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--s-orange);
    line-height: 1;
    margin-top: 0.18rem;
  }

  .masonry-item:hover .date-badge,
  .masonry-item:focus-within .date-badge {
    transform: translateY(-5px) rotate(-1.5deg) scale(1.05);
    background: rgba(255, 255, 255, 0.99);
    box-shadow: 0 12px 28px rgba(0,0,0,0.38);
  }

  .item-text {
    max-width: 100%;
    transition:
      transform 0.6s cubic-bezier(0.19, 1, 0.22, 1),
      opacity 0.35s var(--ease-out-expo);
    display: flex; flex-direction: column; gap: 0.5rem;
  }

  .masonry-item:hover .item-text,
  .masonry-item:focus-within .item-text {
    transform: translateY(-8px);
  }

  .item-category {
    font-family: var(--font-display);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent-hover);
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  .item-category::before {
    content: '';
    width: 0.75rem;
    height: 1px;
    background: currentColor;
    transform: scaleX(0.55);
    transform-origin: left center;
    transition: transform 320ms var(--ease-out-expo);
  }

  .masonry-item:hover .item-category::before,
  .masonry-item:focus-within .item-category::before {
    transform: scaleX(1.55);
  }

  .item-title {
    font-family: var(--font-body);
    font-size: clamp(1.15rem, 1.7vw, 1.8rem);
    font-weight: 300;
    letter-spacing: -0.018em;
    line-height: 1.1;
    margin: 0;
    color: #faf8f3;
    text-shadow:
      0 1px 2px rgba(0,0,0,0.55),
      0 2px 16px rgba(0,0,0,0.4);
    position: relative;
    width: fit-content;
    max-width: 100%;
  }

  /* Editorial hairline under the title — gold, grows on hover */
  .item-title::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -7px;
    height: 1px;
    width: 1.5rem;
    background: rgba(201, 168, 76, 0.9);
    transform-origin: left center;
    transition: width 480ms var(--ease-out-expo), background 320ms var(--ease-out-expo);
  }
  .masonry-item:hover .item-title::after,
  .masonry-item:focus-within .item-title::after {
    width: 3.5rem;
    background: rgba(232, 98, 42, 0.98);
  }

  .item-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: 0.9rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(245, 240, 234, 0.12);
    font-family: var(--font-display);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.72);
  }

  .footer-venue {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-width: 0;
  }
  .footer-venue::before {
    content: '';
    width: 5px; height: 5px;
    border-radius: 50%;
    background: rgba(232, 98, 42, 0.95);
    box-shadow: 0 0 6px rgba(232, 98, 42, 0.6);
    flex-shrink: 0;
  }

  /* Price badge — pill, cream for paid, orange accent for free */
  .price-badge {
    display: inline-flex;
    align-items: baseline;
    padding: 0.38rem 0.72rem;
    background: rgba(245, 240, 234, 0.97);
    border: 1px solid rgba(245, 240, 234, 0.5);
    border-radius: 100px;
    font-family: var(--font-display);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--s-ink);
    box-shadow: 0 4px 14px rgba(0,0,0,0.28);
    white-space: nowrap;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
    transition:
      transform 360ms var(--ease-out-expo),
      background 320ms var(--ease-out-expo),
      box-shadow 320ms var(--ease-out-expo);
  }
  .price-badge--free {
    background: var(--s-orange);
    border-color: var(--s-orange);
    color: #fff;
    box-shadow: 0 4px 14px rgba(232, 98, 42, 0.4);
  }
  .masonry-item:hover .price-badge,
  .masonry-item:focus-within .price-badge {
    transform: translateY(-2px) scale(1.05);
    box-shadow: 0 8px 22px rgba(0,0,0,0.42);
  }
  .masonry-item:hover .price-badge--free,
  .masonry-item:focus-within .price-badge--free {
    box-shadow: 0 8px 22px rgba(232, 98, 42, 0.52);
  }

  @keyframes events-light-sweep {
    0% {
      opacity: 0;
      transform: translate3d(-110%, 0, 0);
    }
    20% {
      opacity: 1;
    }
    100% {
      opacity: 0;
      transform: translate3d(110%, 0, 0);
    }
  }

  @keyframes event-card-settle {
    0% {
      filter: saturate(0.75) brightness(0.7);
      transform: translate3d(0, 28px, 0) scale(0.985);
    }
    62% {
      filter: saturate(1.08) brightness(1.08);
    }
    100% {
      filter: saturate(1) brightness(1);
      transform: translate3d(0, 0, 0) scale(1);
    }
  }

  @keyframes event-curtain-reveal {
    0% {
      opacity: 1;
      clip-path: inset(0 0 0 0);
      transform: translate3d(0, 0, 0);
    }
    58% {
      opacity: 1;
    }
    100% {
      opacity: 0;
      clip-path: inset(0 0 100% 0);
      transform: translate3d(0, -12px, 0);
    }
  }

  @keyframes event-column-open {
    0% {
      opacity: 0.72;
      clip-path: inset(0 0 12% 0);
      transform: translate3d(0, 34px, 0);
    }
    100% {
      opacity: 1;
      clip-path: inset(0);
      transform: translate3d(0, 0, 0);
    }
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .editorial-section {
      --s-gutter: 1.5rem;
      padding-top: 4rem;
    }
    .masonry-wrapper { flex-direction: column; }
    .col-left, .col-center, .col-right { width: 100%; border-right: none; }
    .masonry-item { height: 50vh !important; }
  }

  @media (max-width: 480px) {
    .editorial-section {
      --s-gutter: 1.25rem;
      padding-top: 3.5rem;
    }
    .masonry-item { height: 60vh !important; }
    .item-title { font-size: 1.25rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .masonry-wrapper::before,
    .editorial-section.in-view .masonry-wrapper::before,
    .editorial-section.in-view .masonry-col,
    .editorial-section.in-view .masonry-item,
    .editorial-section.in-view .masonry-item::before {
      animation: none;
    }


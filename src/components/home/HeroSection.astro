---
import type { Locale } from '@types';
import ScreenFrame from '@components/ui/ScreenFrame.astro';
import { useTranslations } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const heroContent = {
  es: {
    supra: 'Patrimonio de la Humanidad',
    title: 'GRANADA',
    cta: t('home.hero.ctaEvents'),
    ctaLink: '/eventos',
    label: 'DESTINO PATRIMONIAL',
    ariaLabel: 'La Puerta a Granada',
  },
  en: {
    supra: 'World Heritage Site',
    title: 'GRANADA',
    cta: t('home.hero.ctaEvents'),
    ctaLink: '/en/events',
    label: 'HERITAGE DESTINATION',
    ariaLabel: 'The Gateway to Granada',
  },
};

const c = heroContent[locale];
---

<section class="portal-hero" aria-label={c.ariaLabel}>

  <!-- "Camera" Screen Frame -->
  <ScreenFrame />

  <!-- 1. The Living Canvas -->
  <div class="ambient-layer">
    <video class="ambient-video" autoplay muted loop playsinline preload="auto" poster="/images/hero-fallback.jpg">
      <source src="/heroVideo.mp4" type="video/mp4" />
    </video>
    <div class="ambient-filter"></div>
    <div class="ambient-gradient"></div>
  </div>

  <!-- 2. Colossal Monumental Lockup -->
  <div class="epic-title-layer">
    <span class="epic-subtitle" data-parallax="-0.04">{c.supra}</span>
    <h1 class="epic-title" data-parallax="-0.03" aria-label="Granada">
      {c.title.split('').map((letter, index) => (
        <span class="title-char" style={`--delay: ${index * 0.1}s`}>{letter}</span>
      ))}
    </h1>
  </div>

  <!-- 3. The Alhambra Portal -->
  <div class="portal-wrapper">

    <!-- Tourism Metadata floating horizontally beside the portal -->
    <div class="portal-meta meta-left">
      <span class="meta-text">{c.label}</span>
      <span class="meta-dot"></span>
    </div>

    <!-- The physical portal lens -->
    <div class="portal" data-parallax="0.05" aria-hidden="true">
      <div class="portal-inner-frame">
        <video class="sharp-video" autoplay muted loop playsinline preload="auto">
          <source src="/heroVideo.mp4" type="video/mp4" />
        </video>
        <div class="portal-shadows"></div>
        <div class="portal-glare"></div>
      </div>
    </div>

    <!-- Tourism Metadata floating horizontally beside the portal -->
    <div class="portal-meta meta-right">
      <span class="meta-dot"></span>
      <span class="meta-text">37°N · 3°W</span>
    </div>
  </div>

  <!-- 4. Minimal Glass Dock (Weather + Time + CTA) -->
  <div class="glass-dock-layer">
    <div class="glass-dock">

      <!-- Time & Weather -->
      <div class="dock-weather">
        <div class="time-display" id="live-time">--:--</div>
        <div class="weather-display">
          <span class="weather-temp" id="weather-today">--°</span>
          <span class="weather-icon" id="weather-icon-today">—</span>
        </div>
      </div>

      <!-- CTA -->
      <a href={c.ctaLink} class="dock-cta" aria-label={c.cta}>
        <span class="cta-text">{c.cta}</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="cta-arrow">
          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
        </svg>
      </a>

    </div>
  </div>

</section>

<style>
  .portal-hero {
    position: relative;
    width: 100%;
    height: 100dvh;
    min-height: 800px;
    background: var(--color-bg);
    overflow: hidden;
    color: var(--color-text-primary);
  }

  /*
   * MULTI-LAYERED AMBIENT CANVAS
   */
  .ambient-layer {
    position: absolute; inset: -5%; z-index: 1; pointer-events: none; opacity: 0;
    animation: cin-fade-in 2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .ambient-video {
    width: 100%; height: 100%; object-fit: cover;
    filter: blur(4px) saturate(1.1) brightness(0.85); transform: scale(1.02);
  }
  .ambient-filter {
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
    mix-blend-mode: soft-light;
    z-index: 2;
  }
  .ambient-filter::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 30%, rgba(0,0,0,0.4) 100%);
    pointer-events: none;
  }
  .ambient-gradient {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 40%, rgba(0,0,0,0.85) 100%); z-index: 3;
  }

  /*
   * COLOSSAL LOGO LOCKUP
   */
  .epic-title-layer {
    position: absolute;
    top: max(140px, 16vh);
    left: 0;
    width: 100%;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: none;
  }

  .epic-subtitle {
    font-family: var(--font-display);
    font-size: clamp(0.75rem, 1.2vw, 1.1rem);
    font-weight: 700;
    letter-spacing: 0.6em;
    text-transform: uppercase;
    color: var(--color-text-primary);
    margin-bottom: 1.5rem;
    text-shadow: 0 4px 15px rgba(0,0,0,0.8);
    opacity: 0;
    animation: cin-fade-in 2s forwards 1s;
  }

  .epic-title {
    font-family: var(--font-body);
    font-size: clamp(4.5rem, 12vw, 15rem);
    font-weight: 400;
    line-height: 1;
    margin: 0;
    display: flex;
    justify-content: center;
    gap: clamp(8px, 1vw, 20px);
    width: 100%;
    color: var(--color-text-primary);
    text-shadow: 0 10px 40px rgba(0,0,0,0.8), 0 0 120px rgba(0,0,0,0.9);
    letter-spacing: -0.01em;
  }

  .title-char {
    display: inline-block;
    opacity: 0;
    transform: translateY(40px);
    animation: char-rise 1.5s cubic-bezier(0.16, 1, 0.3, 1) var(--delay) forwards;
  }

  /*
   * ENLARGED ALHAMBRA PORTAL
   */
  .portal-wrapper {
    position: absolute;
    top: max(38vh, 320px);
    bottom: 22vh;
    left: 0;
    width: 100%;
    z-index: 4;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .portal {
    position: relative;
    width: clamp(340px, 35vw, 480px);
    height: 100%;
    max-height: 600px;
    border-radius: 40vw 40vw 0 0;
    box-shadow:
      0 40px 100px rgba(0,0,0,0.95),
      0 0 80px rgba(212,175,55,0.15),
      0 0 0 1px rgba(255,255,255,0.25);
    border-bottom: none;
    opacity: 0;
    animation: portal-reveal 2s cubic-bezier(0.16, 1, 0.3, 1) 0.5s forwards;
    padding: 0.5rem;
    background: rgba(255,255,255,0.02);
    backdrop-filter: blur(5px);
  }

  .portal-inner-frame {
    position: relative;
    width: 100%; height: 100%; border-radius: inherit; overflow: hidden;
    border: 1px solid rgba(255,255,255,0.2);
  }

  .sharp-video { width: 100%; height: 100%; object-fit: cover; object-position: center 25%; filter: saturate(1.2) contrast(1.15); }

  .portal-shadows {
    position: absolute; inset: 0; border-radius: inherit;
    box-shadow: inset 0 30px 60px rgba(0,0,0,0.5), inset 0 3px 0 rgba(255,220,150,0.5);
    background: linear-gradient(180deg, rgba(255,220,150,0.08) 0%, rgba(0,0,0,0.15) 100%);
  }

  .portal-glare {
    position: absolute; top: 50%; left: 50%; width: 200%; height: 200%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle at center, rgba(255,255,255,0.25) 0%, transparent 40%);
    mix-blend-mode: overlay; transition: transform 0.1s linear;
  }

  /* Portal Meta Data */
  .portal-meta {
    position: absolute;
    top: 40%;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.85rem;
    background: rgba(0,0,0,0.42);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 100px;
    opacity: 0;
    animation: cin-fade-in 2s cubic-bezier(0.16, 1, 0.3, 1) 1s forwards;
    pointer-events: none;
    max-width: calc(50% - clamp(170px, 17.5vw, 240px) - 3.5rem);
    overflow: hidden;
  }

  .meta-left {
    right: max(1.5rem, calc(50% + clamp(170px, 17.5vw, 240px) + 1.5rem));
  }
  .meta-right {
    left: max(1.5rem, calc(50% + clamp(170px, 17.5vw, 240px) + 1.5rem));
  }

  .meta-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--color-gold-text); flex-shrink: 0; }

  .meta-text {
    font-family: var(--font-display);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    color: rgba(255,255,255,0.88);
    white-space: nowrap;
    text-transform: uppercase;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /*
   * MINIMAL GLASS DOCK
   */
  .glass-dock-layer {
    position: absolute;
    bottom: 3rem;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 4rem);
    max-width: 480px;
    z-index: 10;
    opacity: 0;
    animation: dock-rise 1.5s cubic-bezier(0.16, 1, 0.3, 1) 1.2s forwards;
  }

  .glass-dock {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(40px) saturate(140%);
    -webkit-backdrop-filter: blur(40px) saturate(140%);
    border-radius: 100px;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow:
      0 25px 50px rgba(0, 0, 0, 0.4),
      0 10px 20px rgba(0, 0, 0, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  .dock-weather {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .time-display {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 300;
    font-variant-numeric: tabular-nums;
    color: var(--color-text-primary);
    letter-spacing: 0.05em;
    opacity: 0.95;
  }

  .weather-display {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding-left: 0.75rem;
    border-left: 1px solid rgba(255, 255, 255, 0.1);
  }

  .weather-temp {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--color-text-primary);
    opacity: 0.9;
  }

  .weather-icon {
    font-size: 1.3rem;
    line-height: 1;
    filter: drop-shadow(0 1px 2px rgba(0,0,0,0.3));
  }

  .dock-cta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.75rem;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 100px;
    text-decoration: none;
    color: var(--color-text-primary);
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    flex-shrink: 0;
  }

  .dock-cta:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-1px);
  }

  .cta-text {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .cta-arrow {
    opacity: 0.7;
    transition: transform 0.25s, opacity 0.25s;
  }

  .dock-cta:hover .cta-arrow {
    opacity: 1;
    transform: translateX(2px);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .epic-title { font-size: 14vw; gap: 5px; }
    .portal-meta { display: none; }
    .glass-dock { grid-template-columns: 1fr auto; }
  }

  @media (max-width: 768px) {
    .epic-title-layer { top: 11vh; }
    .epic-subtitle { font-size: 0.6rem; margin-bottom: 0.8rem; letter-spacing: 0.3em; }
    .epic-title { font-size: 18vw; gap: 2px; }
    .portal-wrapper { top: 26vh; bottom: 26vh; }
    .portal { width: 80vw; border-radius: 50vw 50vw 0 0; animation: cin-fade-in 2s forwards; }
    .glass-dock-layer { bottom: 1.5rem; width: calc(100% - 2rem); }
    .glass-dock {
      display: flex; flex-direction: column;
      border-radius: 16px; padding: 1.5rem 1.5rem; gap: 1.25rem; text-align: center;
    }
    .dock-cta { width: 100%; justify-content: space-between; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // 1. Live Time (Europe/Madrid)
    const timeEl = document.getElementById('live-time');
    if (timeEl) {
      const updateTime = () => {
        timeEl.textContent = new Intl.DateTimeFormat('es-ES', {
          timeZone: 'Europe/Madrid',
          hour: '2-digit',
          minute: '2-digit',
          second: '2-digit',
        }).format(new Date());
      };
      updateTime();
      setInterval(updateTime, 1000);
    }

    // 2. Live Weather — Open-Meteo (Granada lat/lon, no API key)
    const WMO_ICONS: Record<number, string> = {
      0: '☀️', 1: '🌤', 2: '⛅', 3: '☁️',
      45: '🌫', 48: '🌫',
      51: '🌦', 53: '🌦', 55: '🌦',
      61: '🌧', 63: '🌧', 65: '🌧',
      71: '❄️', 73: '❄️', 75: '❄️',
      80: '🌦', 81: '🌦', 82: '🌦',
      95: '⛈', 96: '⛈', 99: '⛈',
    };
    const wmoIcon = (code: number): string => {
      if (WMO_ICONS[code]) return WMO_ICONS[code];
      if (code <= 3) return '🌤';
      if (code <= 48) return '🌫';
      if (code <= 67) return '🌧';
      if (code <= 77) return '❄️';
      if (code <= 82) return '🌦';
      return '⛈';
    };

    fetch(
      'https://api.open-meteo.com/v1/forecast?latitude=37.18&longitude=-3.60&current=temperature_2m,weather_code&daily=temperature_2m_max,weather_code&timezone=Europe%2FMadrid&forecast_days=2'
    )
      .then((r) => r.json())
      .then((data) => {
        const todayTemp = document.getElementById('weather-today');
        const todayIcon = document.getElementById('weather-icon-today');

        const curTemp = Math.round(data.current.temperature_2m);
        const curCode = data.current.weather_code as number;

        if (todayTemp) todayTemp.textContent = `${curTemp}°`;
        if (todayIcon) todayIcon.textContent = wmoIcon(curCode);
      })
      .catch(() => {
        // silently degrade — dashes remain
      });

    // 3. Advanced Cinematic Glare and Parallax Physics
    if (window.matchMedia("(pointer: fine)").matches) {
      const section = document.querySelector('.portal-hero') as HTMLElement;
      const portal = document.querySelector('.portal') as HTMLElement;
      const glare = document.querySelector('.portal-glare') as HTMLElement;
      const titleLayer = document.querySelector('.epic-title-layer') as HTMLElement;

      section?.addEventListener('mousemove', (e) => {
        const { clientX, clientY, innerWidth, innerHeight } = window;
        const x = (clientX / innerWidth - 0.5);
        const y = (clientY / innerHeight - 0.5);

        requestAnimationFrame(() => {
          if (titleLayer) {
            titleLayer.style.transform = `translate(${x * -30}px, ${y * -20}px)`;
          }
          if (portal) {
            portal.style.transform = `translate(${x * 20}px, ${y * 15}px) rotateY(${x * 4}deg) rotateX(${-y * 4}deg)`;
          }
          if (glare) {
            glare.style.transform = `translate(calc(-50% + ${x * -100}px), calc(-50% + ${y * -100}px))`;
          }
        });
      });

      section?.addEventListener('mouseleave', () => {
        requestAnimationFrame(() => {
          if (titleLayer) titleLayer.style.transform = `translate(0, 0)`;
          if (portal) portal.style.transform = `translate(0, 0) rotateY(0deg) rotateX(0deg)`;
          if (glare) glare.style.transform = `translate(-50%, -50%)`;
        });
      });
    }
  });
</script>

---
import type { Locale } from '@types';
import ScreenFrame from '@components/ui/ScreenFrame.astro';
import { useTranslations } from '@i18n/utils';
import { getRoute } from '@utils/routes';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const c = {
  supra: t('home.hero.worldHeritage'),
  title: 'GRANADA',
  cta: t('home.hero.ctaEvents'),
  ctaLink: getRoute('events', locale),
  label: t('home.hero.heritageDestination'),
  ariaLabel: t('home.hero.gatewayLabel'),
};
---

<section class="portal-hero" aria-label={c.ariaLabel}>

  <!-- Cinematic Preloader -->
  <div class="hero-boot-screen" id="hero-boot-screen" aria-hidden="true">
    <!-- Completion flash -->
    <div class="boot-flash" id="boot-flash" aria-hidden="true"></div>

    <!-- Shockwave ripple on completion -->
    <div class="boot-shockwave" id="boot-shockwave" aria-hidden="true"></div>

    <!-- Entry spotlight sweep -->
    <div class="boot-spotlight" aria-hidden="true"></div>

    <!-- Data streams (subtle terminal rain) -->
    <div class="boot-data-stream ds-left" aria-hidden="true">
      <span></span><span></span><span></span><span></span><span></span>
      <span></span><span></span><span></span><span></span><span></span>
    </div>
    <div class="boot-data-stream ds-right" aria-hidden="true">
      <span></span><span></span><span></span><span></span><span></span>
      <span></span><span></span><span></span><span></span><span></span>
    </div>

    <!-- Grain texture -->
    <div class="boot-grain" aria-hidden="true"></div>

    <!-- Screen frame with animated corner brackets -->
    <div class="boot-frame" aria-hidden="true">
      <svg class="boot-corner boot-corner-tl" viewBox="0 0 40 40" aria-hidden="true">
        <path d="M0 40 L0 8 A8 8 0 0 1 8 0 L40 0" fill="none" stroke="currentColor" stroke-width="1"/>
      </svg>
      <svg class="boot-corner boot-corner-tr" viewBox="0 0 40 40" aria-hidden="true">
        <path d="M0 0 L32 0 A8 8 0 0 1 40 8 L40 40" fill="none" stroke="currentColor" stroke-width="1"/>
      </svg>
      <svg class="boot-corner boot-corner-bl" viewBox="0 0 40 40" aria-hidden="true">
        <path d="M0 0 L0 32 A8 8 0 0 0 8 40 L40 40" fill="none" stroke="currentColor" stroke-width="1"/>
      </svg>
      <svg class="boot-corner boot-corner-br" viewBox="0 0 40 40" aria-hidden="true">
        <path d="M40 0 L40 32 A8 8 0 0 1 32 40 L0 40" fill="none" stroke="currentColor" stroke-width="1"/>
      </svg>
      <span class="boot-corner-dot cd-tl" aria-hidden="true"></span>
      <span class="boot-corner-dot cd-tr" aria-hidden="true"></span>
      <span class="boot-corner-dot cd-bl" aria-hidden="true"></span>
      <span class="boot-corner-dot cd-br" aria-hidden="true"></span>
    </div>

    <!-- Filmstrip ticks -->
    <div class="boot-ticks" aria-hidden="true">
      <span class="b-tick"></span><span class="b-tick"></span><span class="b-tick"></span>
      <span class="b-tick b-tick-center"></span>
      <span class="b-tick"></span><span class="b-tick"></span><span class="b-tick"></span>
    </div>

    <!-- Corner tags -->
    <span class="boot-tag boot-tag-tl" aria-hidden="true">[00] INICIO</span>
    <span class="boot-tag boot-tag-tr" aria-hidden="true">GRN.V1</span>

    <!-- Vignette -->
    <div class="boot-vignette" aria-hidden="true"></div>

    <!-- CRT scanline -->
    <div class="boot-scanline" aria-hidden="true"></div>

    <!-- Light leak -->
    <div class="boot-light-leak" aria-hidden="true"></div>

    <!-- Floating boot particles -->
    <div class="boot-particle bp-1" aria-hidden="true"></div>
    <div class="boot-particle bp-2" aria-hidden="true"></div>
    <div class="boot-particle bp-3" aria-hidden="true"></div>
    <div class="boot-particle bp-4" aria-hidden="true"></div>
    <div class="boot-particle bp-5" aria-hidden="true"></div>
    <div class="boot-particle bp-6" aria-hidden="true"></div>
    <div class="boot-particle bp-7" aria-hidden="true"></div>
    <div class="boot-particle bp-8" aria-hidden="true"></div>
    <div class="boot-particle bp-9" aria-hidden="true"></div>
    <div class="boot-particle bp-10" aria-hidden="true"></div>

    <!-- Scanline grid -->
    <div class="boot-scanlines" aria-hidden="true"></div>

    <!-- Main brand wrap -->
    <div class="boot-brand-wrap">
      <!-- Orbital rings + star -->
      <div class="boot-logo-wrap">
        <div class="boot-crosshair" aria-hidden="true"></div>
        <svg class="boot-ring boot-ring-1" viewBox="0 0 200 200" aria-hidden="true">
          <circle cx="100" cy="100" r="90" fill="none" stroke="rgba(201,168,76,0.15)" stroke-width="0.5"/>
          <circle cx="100" cy="100" r="90" fill="none" stroke="rgba(201,168,76,0.6)" stroke-width="1" stroke-dasharray="12 8 30 8" stroke-linecap="round"/>
        </svg>
        <svg class="boot-ring boot-ring-2" viewBox="0 0 200 200" aria-hidden="true">
          <circle cx="100" cy="100" r="74" fill="none" stroke="rgba(201,168,76,0.1)" stroke-width="0.5"/>
          <circle cx="100" cy="100" r="74" fill="none" stroke="rgba(201,168,76,0.4)" stroke-width="1" stroke-dasharray="6 12 50 12" stroke-linecap="round"/>
        </svg>
        <svg class="boot-ring boot-ring-3" viewBox="0 0 200 200" aria-hidden="true">
          <circle cx="100" cy="100" r="58" fill="none" stroke="rgba(201,168,76,0.08)" stroke-width="0.5"/>
          <circle cx="100" cy="100" r="58" fill="none" stroke="rgba(201,168,76,0.3)" stroke-width="1" stroke-dasharray="40 20" stroke-linecap="round"/>
        </svg>
        <svg class="boot-star" viewBox="0 0 44 44" fill="none" aria-hidden="true">
          <path d="M22 3 L25.2 13.8 L36 8 L29.2 17.5 L38 22 L29.2 26.5 L36 36 L25.2 30.2 L22 41 L18.8 30.2 L8 36 L14.8 26.5 L6 22 L14.8 17.5 L8 8 L18.8 13.8 Z" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linejoin="round"/>
          <circle cx="22" cy="22" r="3.5" fill="currentColor"/>
        </svg>
        <div class="boot-star-glow" aria-hidden="true"></div>
        <div class="boot-lens-flare" aria-hidden="true"></div>
        <svg class="boot-geometry" viewBox="0 0 100 100" aria-hidden="true">
          <polygon points="50,3 85,15 97,50 85,85 50,97 15,85 3,50 15,15" fill="none" stroke="rgba(201,168,76,0.12)" stroke-width="0.5"/>
          <polygon points="50,12 78,22 88,50 78,78 50,88 22,78 12,50 22,22" fill="none" stroke="rgba(201,168,76,0.06)" stroke-width="0.5"/>
        </svg>
      </div>

      <!-- Radial glow behind lockup -->
      <div class="boot-lockup-glow" aria-hidden="true"></div>

      <!-- Side decorative rules -->
      <div class="boot-side-rule boot-side-rule-left" aria-hidden="true"></div>
      <div class="boot-side-rule boot-side-rule-right" aria-hidden="true"></div>

      <!-- Lockup -->
      <div class="boot-lockup" aria-hidden="true">
        <div class="boot-brand-name">
          <div class="boot-chromatic">
          {'GRANADA URBAN'.split('').map((char, i) => (
            <span class="boot-name-char" style={`--d: ${0.1 + i * 0.022}s`}>{char === ' ' ? '\u00A0' : char}</span>
          ))}
          </div>
        </div>
        <div class="boot-brand-tagline">Guía de la ciudad</div>
        <div class="boot-accent-line" aria-hidden="true"></div>
      </div>

      <!-- Status + Counter -->
      <div class="boot-readout" aria-hidden="true">
        <span class="boot-status" id="boot-status">Inicializando</span>
        <span class="boot-counter" id="boot-counter">000</span>
        <div class="boot-sub-status" id="boot-sub-status">
          <span>MEM</span><span class="sub-dot ok"></span>
          <span>NET</span><span class="sub-dot ok"></span>
          <span>SYS</span><span class="sub-dot ok"></span>
        </div>
      </div>
    </div>

    <!-- Progress area -->
    <div class="boot-rule-wrap" aria-hidden="true">
      <div class="boot-activity-track">
        <div class="boot-activity-fill" id="boot-activity-fill"></div>
      </div>
      <div class="boot-rule-track">
        <div class="boot-rule-track-bg"></div>
        <div class="boot-rule-fill" id="boot-rule-fill">
          <div class="boot-fill-shimmer"></div>
        </div>
        <div class="boot-rule-glow"></div>
      </div>
      <div class="boot-rule-percent" id="boot-rule-percent">0%</div>
    </div>

    <!-- Build info -->
    <div class="boot-build-info" aria-hidden="true">BUILD 2026.04.28 // GRN.V1.0.0</div>
  </div>

  <!-- Cinematic dust particles -->
  <div class="hero-particle dp-1" aria-hidden="true"></div>
  <div class="hero-particle dp-2" aria-hidden="true"></div>
  <div class="hero-particle dp-3" aria-hidden="true"></div>
  <div class="hero-particle dp-4" aria-hidden="true"></div>
  <div class="hero-particle dp-5" aria-hidden="true"></div>
  <div class="hero-particle dp-6" aria-hidden="true"></div>

  <!-- Camera Screen Frame -->
  <ScreenFrame />

  <!-- 1. The Living Canvas -->
  <div class="ambient-layer">
    <video class="ambient-video" autoplay muted loop playsinline preload="auto">
      <source src="/heroVideo.mp4" type="video/mp4" />
    </video>
    <div class="ambient-filter"></div>
    <div class="ambient-gradient"></div>
  </div>

  <!-- 2. Colossal Monumental Lockup -->
  <div class="epic-title-layer">
    <span class="epic-subtitle" data-parallax="-0.04">{c.supra}</span>
    <h1 class="epic-title" data-parallax="-0.03" aria-label="Granada">
      {c.title.split('').map((letter, index) => (
        <span class="title-char" style={`--delay: ${index * 0.1}s`}>{letter}</span>
      ))}
    </h1>
  </div>

  <!-- 3. The Alhambra Portal -->
  <div class="portal-wrapper">

    <!-- Tourism Metadata floating horizontally beside the portal -->
    <div class="portal-meta meta-left">
      <span class="meta-text">{c.label}</span>
      <span class="meta-dot"></span>
    </div>

    <!-- The physical portal lens -->
    <div class="portal" data-parallax="0.05" aria-hidden="true">
      <div class="portal-inner-frame">
        <video class="sharp-video" autoplay muted loop playsinline preload="auto">
          <source src="/heroVideo.mp4" type="video/mp4" />
        </video>
        <div class="portal-shadows"></div>
        <div class="portal-glare"></div>
      </div>
    </div>

    <!-- Tourism Metadata floating horizontally beside the portal -->
    <div class="portal-meta meta-right">
      <span class="meta-dot"></span>
      <span class="meta-text">37°N · 3°W</span>
    </div>
  </div>

  <!-- 4. Cinematic Glass Dock (Weather + Time + CTA) -->
  <div class="glass-dock-layer">
    <div class="glass-dock">

      <!-- Time & Weather -->
      <div class="dock-weather">
        <div class="time-block">
          <div class="live-dot" aria-hidden="true"></div>
          <div class="time-display" id="live-time">
            <span class="time-h">--</span><span class="time-sep">:</span><span class="time-m">--</span><span class="time-sep">:</span><span class="time-s">--</span>
          </div>
        </div>
        <div class="weather-display">
          <span class="weather-icon" id="weather-icon-today">—</span>
          <span class="weather-temp" id="weather-today">--°</span>
        </div>
      </div>

      <div class="dock-divider"></div>

      <!-- CTA -->
      <a href={c.ctaLink} class="dock-cta" aria-label={c.cta}>
        <span class="cta-text">{c.cta}</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="cta-arrow">
          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
        </svg>
      </a>

    </div>
  </div>

  <!-- 5. Scroll Hint -->
  <div class="scroll-hint">
    <span class="scroll-hint-line"></span>
    <span class="scroll-hint-text">SCROLL</span>
  </div>

  <!-- 6. Ambient Floating Orbs -->
  <div class="ambient-orb orb-1" aria-hidden="true"></div>
  <div class="ambient-orb orb-2" aria-hidden="true"></div>
  <div class="ambient-orb orb-3" aria-hidden="true"></div>

  <!-- 6b. Cinematic Light Leak -->
  <div class="light-leak" aria-hidden="true"></div>

  <!-- 6c. Corner Glows -->
  <div class="corner-glow glow-tl" aria-hidden="true"></div>
  <div class="corner-glow glow-tr" aria-hidden="true"></div>
  <div class="corner-glow glow-bl" aria-hidden="true"></div>
  <div class="corner-glow glow-br" aria-hidden="true"></div>

  <!-- 7. Bottom Editorial Ornament -->
  <div class="hero-ornament">
    <div class="ornament-line"></div>
    <div class="ornament-diamond">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2L22 12L12 22L2 12Z"/>
      </svg>
    </div>
    <div class="ornament-line"></div>
  </div>

</section>

<style>
  .portal-hero {
    position: relative;
    width: 100%;
    height: 100dvh;
    min-height: 800px;
    background: var(--color-bg);
    overflow: hidden;
    color: var(--color-text-primary);
  }

  /* ================================================================
     CINEMATIC PRELOADER — Alhambra Noir Boot Sequence
     ================================================================ */
  .hero-boot-screen {
    position: fixed;
    inset: 0;
    background: var(--color-bg);
    z-index: 9999;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;
    transform: scale(1);
    filter: blur(0px);
    overflow: hidden;
    transition:
      opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.08s,
      transform 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.08s,
      filter 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.08s;
  }
  .hero-boot-screen.is-hidden {
    opacity: 0;
    transform: scale(0.98);
    filter: blur(6px);
    pointer-events: none;
  }
  .hero-boot-screen.is-hidden .boot-brand-wrap {
    transform: scale(0.95);
    filter: blur(3px);
    opacity: 0;
    transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1),
                filter 0.55s cubic-bezier(0.22, 1, 0.36, 1),
                opacity 0.45s ease;
  }

  /* ── Shockwave on completion ── */
  .boot-shockwave {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 20px;
    height: 20px;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    border: 1px solid rgba(201,168,76,0.6);
    pointer-events: none;
    z-index: 49;
    opacity: 0;
  }
  .boot-shockwave.is-active {
    animation: shockwaveExpand 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes shockwaveExpand {
    0%   { width: 20px; height: 20px; opacity: 0.7; border-width: 2px; }
    100% { width: 120vmax; height: 120vmax; opacity: 0; border-width: 0px; }
  }

  /* ── Entry spotlight sweep ── */
  .boot-spotlight {
    position: absolute;
    inset: 0;
    z-index: 8;
    pointer-events: none;
    background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.03) 48%, rgba(201,168,76,0.06) 50%, rgba(255,255,255,0.03) 52%, transparent 60%);
    opacity: 0;
    animation: spotlightSweep 1s cubic-bezier(0.22, 1, 0.36, 1) 0.15s forwards;
  }
  @keyframes spotlightSweep {
    0%   { opacity: 0; transform: translateX(-100%); }
    25%  { opacity: 1; }
    75%  { opacity: 1; }
    100% { opacity: 0; transform: translateX(100%); }
  }

  /* ── Data streams (terminal rain) ── */
  .boot-data-stream {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 40px;
    z-index: 3;
    pointer-events: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-around;
    padding: 2rem 0;
    opacity: 0;
    animation: bootFadeIn 1s ease 0.25s forwards;
  }
  .ds-left { left: 2rem; }
  .ds-right { right: 2rem; }
  .boot-data-stream span {
    display: block;
    width: 1px;
    background: linear-gradient(to bottom, transparent, rgba(201,168,76,0.2), transparent);
    animation: dataStreamFall 2.2s ease-in-out infinite;
    opacity: 0.25;
  }
  .boot-data-stream span:nth-child(1) { height: 24px; animation-delay: 0s; }
  .boot-data-stream span:nth-child(2) { height: 40px; animation-delay: 0.3s; }
  .boot-data-stream span:nth-child(3) { height: 16px; animation-delay: 0.6s; }
  .boot-data-stream span:nth-child(4) { height: 32px; animation-delay: 0.9s; }
  .boot-data-stream span:nth-child(5) { height: 20px; animation-delay: 1.2s; }
  .boot-data-stream span:nth-child(6) { height: 36px; animation-delay: 1.5s; }
  .boot-data-stream span:nth-child(7) { height: 14px; animation-delay: 1.8s; }
  .boot-data-stream span:nth-child(8) { height: 28px; animation-delay: 2.1s; }
  .boot-data-stream span:nth-child(9) { height: 18px; animation-delay: 0.15s; }
  .boot-data-stream span:nth-child(10) { height: 44px; animation-delay: 0.45s; }
  @keyframes dataStreamFall {
    0%, 100% { transform: translateY(-8px); opacity: 0.1; }
    50% { transform: translateY(8px); opacity: 0.35; }
  }

  /* ── Grain overlay ── */
  .boot-grain {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0.04;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='4' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.5'/%3E%3C/svg%3E");
    mix-blend-mode: soft-light;
  }

  /* ── Screen frame with animated corner brackets ── */
  .boot-frame {
    position: absolute;
    inset: 2rem;
    z-index: 10;
    pointer-events: none;
  }
  .boot-corner {
    position: absolute;
    width: 64px;
    height: 64px;
    color: rgba(201,168,76,0.5);
  }
  .boot-corner path {
    stroke-dasharray: 150;
    stroke-dashoffset: 150;
    animation: cornerDraw 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .boot-corner-tl { top: 0; left: 0; }
  .boot-corner-tr { top: 0; right: 0; transform: rotate(90deg); }
  .boot-corner-bl { bottom: 0; left: 0; transform: rotate(-90deg); }
  .boot-corner-br { bottom: 0; right: 0; transform: rotate(180deg); }
  .boot-corner-tl path { animation-delay: 0.05s; }
  .boot-corner-tr path { animation-delay: 0.1s; }
  .boot-corner-bl path { animation-delay: 0.15s; }
  .boot-corner-br path { animation-delay: 0.2s; }
  @keyframes cornerDraw {
    to { stroke-dashoffset: 0; }
  }

  /* ── Filmstrip ticks ── */
  .boot-ticks {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    padding: 0 2.5rem;
    pointer-events: none;
    z-index: 11;
    opacity: 0;
    animation: bootFadeIn 0.45s ease 0.15s forwards;
  }
  .b-tick {
    display: block;
    width: 1px;
    height: 12px;
    background: rgba(201, 168, 76, 0.35);
  }
  .b-tick-center {
    height: 18px;
    background: rgba(201, 168, 76, 0.65);
    animation: tickShimmer 1.8s ease-in-out infinite;
  }
  @keyframes tickShimmer {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.2; }
  }

  /* ── Corner tags ── */
  .boot-tag {
    position: absolute;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(201,168,76,0.45);
    z-index: 11;
    opacity: 0;
    animation: bootFadeIn 0.45s ease 0.35s forwards;
  }
  .boot-tag-tl { top: 2.5rem; left: 2.5rem; }
  .boot-tag-tr { top: 2.5rem; right: 2.5rem; }

  /* ── Vignette ── */
  .boot-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 20%, rgba(0,0,0,0.65) 100%);
    pointer-events: none;
    z-index: 2;
  }

  /* ── CRT Scanline ── */
  .boot-scanline {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, rgba(201,168,76,0.2), transparent);
    box-shadow: 0 0 20px rgba(201,168,76,0.15);
    z-index: 12;
    pointer-events: none;
    opacity: 0;
    animation: scanlinePass 2.5s ease-in-out 0.6s infinite;
  }
  @keyframes scanlinePass {
    0% { top: 0%; opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { top: 100%; opacity: 0; }
  }

  /* ── Light leak ── */
  .boot-light-leak {
    position: absolute;
    top: -20%;
    right: -15%;
    width: 65%;
    height: 65%;
    background: radial-gradient(ellipse at center, rgba(201,168,76,0.1) 0%, transparent 55%);
    mix-blend-mode: screen;
    pointer-events: none;
    z-index: 3;
    filter: blur(70px);
    animation: lightLeakPulse 6s ease-in-out infinite alternate;
  }
  @keyframes lightLeakPulse {
    from { opacity: 0.3; transform: scale(0.85) rotate(0deg); }
    to   { opacity: 0.8; transform: scale(1.2) rotate(8deg); }
  }

  /* ── Main brand wrap ── */
  .boot-brand-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.4rem;
    z-index: 5;
    opacity: 0;
    transform: scale(0.94);
    filter: blur(6px);
    animation: bootWrapEnter 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.06s forwards;
  }
  @keyframes bootWrapEnter {
    to { opacity: 1; transform: scale(1); filter: blur(0px); }
  }

  /* ── Orbital rings + star ── */
  .boot-logo-wrap {
    position: relative;
    width: clamp(100px, 16vw, 160px);
    height: clamp(100px, 16vw, 160px);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .boot-crosshair {
    position: absolute;
    inset: -10%;
    z-index: 1;
    pointer-events: none;
    opacity: 0;
    animation: bootFadeIn 0.5s ease 0.2s forwards;
  }
  .boot-crosshair::before,
  .boot-crosshair::after {
    content: '';
    position: absolute;
    background: rgba(201,168,76,0.1);
  }
  .boot-crosshair::before {
    top: 50%; left: 0; right: 0; height: 1px;
    transform: translateY(-50%);
  }
  .boot-crosshair::after {
    left: 50%; top: 0; bottom: 0; width: 1px;
    transform: translateX(-50%);
  }
  .boot-logo-wrap.is-complete .boot-crosshair::before,
  .boot-logo-wrap.is-complete .boot-crosshair::after {
    animation: crosshairPulse 0.5s ease forwards;
  }
  @keyframes crosshairPulse {
    0% { background: rgba(201,168,76,0.1); }
    50% { background: rgba(201,168,76,0.45); }
    100% { background: rgba(201,168,76,0.1); }
  }
  .boot-ring {
    position: absolute;
    width: 240%;
    height: 240%;
    top: -70%;
    left: -70%;
    opacity: 0;
    animation: ringFadeIn 0.5s ease forwards, ringRotate var(--dur) linear infinite;
  }
  .boot-ring-1 { --dur: 10s; animation-delay: 0.1s, 0.1s; --rot: 360deg; }
  .boot-ring-2 { --dur: 15s; animation-delay: 0.2s, 0.2s; --rot: -360deg; }
  .boot-ring-3 { --dur: 20s; animation-delay: 0.3s, 0.3s; --rot: 360deg; }
  @keyframes ringFadeIn {
    to { opacity: 1; }
  }
  @keyframes ringRotate {
    from { transform: rotate(0deg); }
    to   { transform: rotate(var(--rot)); }
  }
  .boot-star {
    position: relative;
    width: 55%;
    height: 55%;
    color: var(--color-gold);
    filter: drop-shadow(0 0 28px rgba(201,168,76,0.55));
    opacity: 0;
    transform: scale(0.4) rotate(-45deg);
    animation: starEnter 0.65s cubic-bezier(0.22, 1, 0.36, 1) 0.15s forwards, starBreath 3s ease-in-out 0.8s infinite alternate;
  }
  .boot-star-glow {
    position: absolute;
    inset: -100%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(201,168,76,0.25) 0%, transparent 50%);
    filter: blur(28px);
    opacity: 0;
    animation: glowIn 0.5s ease 0.3s forwards;
  }
  @keyframes starEnter {
    to { opacity: 1; transform: scale(1) rotate(0deg); }
  }
  @keyframes starBreath {
    from { transform: scale(1); }
    to   { transform: scale(1.06); }
  }
  @keyframes glowIn {
    to { opacity: 1; }
  }

  /* ── Radial glow behind lockup ── */
  .boot-lockup-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -45%);
    width: 700px;
    height: 360px;
    background: radial-gradient(ellipse at center, rgba(201,168,76,0.05) 0%, transparent 60%);
    pointer-events: none;
    z-index: 4;
    opacity: 0;
    animation: bootFadeIn 1s ease 0.3s forwards;
  }

  /* ── Side decorative rules ── */
  .boot-side-rule {
    position: absolute;
    top: 50%;
    width: 1px;
    height: clamp(60px, 10vh, 100px);
    background: linear-gradient(to bottom, transparent, rgba(201,168,76,0.25), transparent);
    transform: translateY(-50%);
    z-index: 5;
    pointer-events: none;
    opacity: 0;
    animation: bootFadeIn 0.7s ease 0.45s forwards;
  }
  .boot-side-rule::before,
  .boot-side-rule::after {
    content: '';
    position: absolute;
    left: 50%;
    width: 5px;
    height: 1px;
    background: rgba(201,168,76,0.3);
    transform: translateX(-50%);
  }
  .boot-side-rule::before { top: 0; }
  .boot-side-rule::after { bottom: 0; }
  .boot-side-rule-left { left: -3.5rem; }
  .boot-side-rule-right { right: -3.5rem; }

  /* ── Brand lockup ── */
  .boot-lockup {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.7rem;
    opacity: 0;
    animation: bootFadeIn 0.01s linear 0.18s forwards;
    position: relative;
    z-index: 5;
  }
  .boot-brand-name {
    display: flex;
    font-family: var(--font-body);
    font-size: clamp(4.2rem, 13vw, 8.5rem);
    font-weight: 300;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--color-text-primary);
    line-height: 0.88;
    text-shadow: 0 8px 50px rgba(0,0,0,0.7), 0 0 100px rgba(201,168,76,0.1);
  }
  .boot-chromatic {
    position: relative;
    display: flex;
  }
  .boot-chromatic::before,
  .boot-chromatic::after {
    content: 'GRANADA URBAN';
    position: absolute;
    inset: 0;
    display: flex;
    justify-content: center;
    font-family: var(--font-body);
    font-size: inherit;
    font-weight: inherit;
    letter-spacing: inherit;
    text-transform: inherit;
    line-height: inherit;
    pointer-events: none;
    opacity: 0;
    animation: chromaticIn 1s ease 0.7s forwards;
  }
  .boot-chromatic::before {
    color: rgba(255,80,80,0.3);
    transform: translateX(-2px);
    mix-blend-mode: screen;
  }
  .boot-chromatic::after {
    color: rgba(80,150,255,0.25);
    transform: translateX(2px);
    mix-blend-mode: screen;
  }
  @keyframes chromaticIn {
    to { opacity: 1; }
  }
  .boot-name-char {
    display: inline-block;
    opacity: 0;
    transform: translateY(24px);
    animation: charPop 0.55s cubic-bezier(0.22, 1, 0.36, 1) var(--d) forwards;
  }
  .boot-brand-tagline {
    font-family: var(--font-display);
    font-size: clamp(0.8rem, 1.5vw, 1.1rem);
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(240,237,232,0.45);
    opacity: 0;
    animation: bootFadeIn 0.5s ease 0.55s forwards;
  }
  .boot-accent-line {
    width: 72px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-gold), transparent);
    margin-top: 0.5rem;
    opacity: 0;
    animation: bootFadeIn 0.45s ease 0.7s forwards, lineShimmer 2.5s ease-in-out 0.9s infinite alternate;
  }
  @keyframes charPop {
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes lineShimmer {
    from { opacity: 0.25; }
    to   { opacity: 0.9; }
  }

  /* ── Readout ── */
  .boot-readout {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.7rem;
    opacity: 0;
    animation: bootFadeIn 0.45s ease 0.5s forwards;
  }
  .boot-status {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(201,168,76,0.55);
    min-height: 1.2em;
    display: inline-flex;
    align-items: center;
    gap: 0.15em;
    transition: color 0.3s ease, text-shadow 0.3s ease;
  }
  .boot-status.is-changing {
    text-shadow: 0 0 12px rgba(201,168,76,0.5);
  }
  .boot-status::after {
    content: '';
    display: inline-block;
    width: 2px;
    height: 0.85em;
    background: rgba(201,168,76,0.6);
    margin-left: 0.1em;
    animation: cursorBlink 1s step-end infinite;
  }
  @keyframes cursorBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  .boot-counter {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4.5vw, 3.4rem);
    font-weight: 200;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.08em;
    line-height: 1;
    background: linear-gradient(180deg, var(--color-text-primary) 15%, rgba(201,168,76,0.95) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 40px rgba(201,168,76,0.3));
    transition: transform 0.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .boot-counter.milestone {
    animation: counterPulse 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .boot-counter.near-complete {
    filter: drop-shadow(0 0 60px rgba(201,168,76,0.6)) drop-shadow(0 0 20px rgba(255,255,255,0.2));
    transition: filter 0.4s ease;
  }
  @keyframes counterPulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.06); }
    100% { transform: scale(1); }
  }

  /* ── Bottom progress ── */
  .boot-rule-wrap {
    position: absolute;
    bottom: 3.2rem;
    left: 50%;
    transform: translateX(-50%);
    width: clamp(220px, 34vw, 380px);
    z-index: 11;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.7rem;
    opacity: 0;
    animation: bootFadeIn 0.4s ease 0.25s forwards;
  }
  .boot-activity-track {
    width: 100%;
    height: 1px;
    position: relative;
    overflow: hidden;
    border-radius: 1px;
    background: rgba(201,168,76,0.08);
    opacity: 0;
    animation: bootFadeIn 0.4s ease 0.3s forwards;
  }
  .boot-activity-fill {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 30%;
    background: linear-gradient(90deg, transparent, rgba(201,168,76,0.4), transparent);
    transform: translateX(-100%);
    animation: activitySlide 1.4s cubic-bezier(0.22, 1, 0.36, 1) infinite;
  }
  @keyframes activitySlide {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(400%); }
  }
  .boot-rule-track {
    width: 100%;
    height: 3px;
    position: relative;
    overflow: hidden;
    border-radius: 2px;
  }
  .boot-rule-track-bg {
    position: absolute;
    inset: 0;
    background: rgba(201,168,76,0.12);
  }
  .boot-rule-fill {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, var(--color-accent), var(--color-gold), var(--color-accent));
    background-size: 200% 100%;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.08s linear;
    overflow: hidden;
  }
  .boot-rule-fill::after {
    content: '';
    position: absolute;
    top: 50%;
    right: 0;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(255,255,255,0.8);
    box-shadow: 0 0 10px rgba(201,168,76,0.8), 0 0 20px rgba(201,168,76,0.4);
    transform: translate(50%, -50%);
    opacity: 0.9;
  }
  .boot-fill-shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent 30%, rgba(255,255,255,0.4) 50%, transparent 70%);
    transform: translateX(-100%);
    animation: fillShimmer 2s ease-in-out infinite;
  }
  @keyframes fillShimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(200%); }
  }
  .boot-rule-glow {
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    height: 14px;
    transform: translateY(-50%);
    background: linear-gradient(90deg, transparent, rgba(201,168,76,0.25), transparent);
    opacity: 0;
    animation: bootFadeIn 0.4s ease 0.4s forwards;
    pointer-events: none;
  }
  .boot-rule-percent {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    color: rgba(201,168,76,0.45);
    text-transform: uppercase;
    font-variant-numeric: tabular-nums;
  }

  /* ── Build info ── */
  .boot-build-info {
    position: absolute;
    bottom: 1.6rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-display);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(201,168,76,0.25);
    z-index: 11;
    opacity: 0;
    animation: bootFadeIn 0.5s ease 0.6s forwards;
    pointer-events: none;
  }

  /* ── Floating boot particles ── */
  .boot-particle {
    position: absolute;
    border-radius: 50%;
    background: var(--color-gold);
    pointer-events: none;
    z-index: 4;
    opacity: 0;
    animation: bootPartFade 1.5s ease forwards, bootPartFloat 8s ease-in-out infinite;
  }
  .bp-1 { width: 2px; height: 2px; top: 22%; left: 18%; animation-delay: 0.6s, 1.2s; box-shadow: 0 0 6px rgba(201,168,76,0.4); }
  .bp-2 { width: 3px; height: 3px; top: 65%; right: 22%; animation-delay: 0.9s, 1.5s; filter: blur(0.5px); opacity: 0.5; box-shadow: 0 0 8px rgba(201,168,76,0.35); }
  .bp-3 { width: 1.5px; height: 1.5px; bottom: 35%; left: 30%; animation-delay: 1.1s, 1.8s; }
  .bp-4 { width: 2.5px; height: 2.5px; top: 40%; right: 12%; animation-delay: 0.7s, 1.4s; filter: blur(0.5px); box-shadow: 0 0 6px rgba(201,168,76,0.3); }
  .bp-5 { width: 2px; height: 2px; bottom: 28%; right: 35%; animation-delay: 1.3s, 2s; box-shadow: 0 0 6px rgba(201,168,76,0.35); }
  .bp-6 { width: 2px; height: 2px; top: 15%; right: 28%; animation-delay: 0.5s, 1.1s; }
  .bp-7 { width: 1.5px; height: 1.5px; top: 55%; left: 14%; animation-delay: 0.8s, 1.6s; filter: blur(0.5px); }
  .bp-8 { width: 3px; height: 3px; bottom: 22%; left: 25%; animation-delay: 1.0s, 1.9s; box-shadow: 0 0 8px rgba(201,168,76,0.3); }
  .bp-9 { width: 2px; height: 2px; top: 35%; left: 8%; animation-delay: 0.65s, 1.3s; }
  .bp-10 { width: 2.5px; height: 2.5px; bottom: 40%; right: 18%; animation-delay: 1.15s, 2.1s; filter: blur(0.5px); box-shadow: 0 0 6px rgba(201,168,76,0.3); }
  @keyframes bootPartFade { to { opacity: 0.25; } }
  @keyframes bootPartFloat {
    0%, 100% { transform: translate(0, 0); }
    33% { transform: translate(10px, -16px); }
    66% { transform: translate(-8px, 10px); }
  }

  /* ── Scanline grid ── */
  .boot-scanlines {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.04) 2px,
      rgba(0,0,0,0.04) 4px
    );
    opacity: 0;
    animation: bootFadeIn 1s ease 0.3s forwards;
  }

  /* ── Frame breathing pulse ── */
  .boot-frame {
    animation: frameBreath 6s ease-in-out infinite alternate;
  }
  @keyframes frameBreath {
    from { opacity: 0.7; }
    to   { opacity: 1; }
  }

  /* ── Lens flare behind star ── */
  .boot-lens-flare {
    position: absolute;
    inset: -40%;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 50%, rgba(255,255,255,0.14) 0%, transparent 15%),
                radial-gradient(circle at 70% 50%, rgba(201,168,76,0.1) 0%, transparent 20%);
    filter: blur(8px);
    opacity: 0;
    animation: lensFlareIn 1s ease 0.5s forwards, lensFlareShift 5s ease-in-out 1.5s infinite alternate;
    pointer-events: none;
  }
  @keyframes lensFlareIn { to { opacity: 1; } }
  @keyframes lensFlareShift {
    from { transform: scale(1) rotate(0deg); }
    to   { transform: scale(1.15) rotate(8deg); }
  }

  /* ── Sacred geometry octagon behind star ── */
  .boot-geometry {
    position: absolute;
    width: 180%;
    height: 180%;
    top: -40%;
    left: -40%;
    opacity: 0;
    animation: geoFadeIn 1s ease 0.3s forwards, geoRotate 20s linear infinite;
    pointer-events: none;
    z-index: 0;
  }
  @keyframes geoFadeIn { to { opacity: 1; } }
  @keyframes geoRotate {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* ── Corner glow dots ── */
  .boot-corner-dot {
    position: absolute;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: rgba(201,168,76,0.35);
    box-shadow: 0 0 8px rgba(201,168,76,0.25);
    opacity: 0;
    animation: bootFadeIn 0.6s ease 0.5s forwards, cornerDotPulse 3s ease-in-out 1s infinite alternate;
    z-index: 12;
    pointer-events: none;
  }
  .cd-tl { top: -1px; left: -1px; }
  .cd-tr { top: -1px; right: -1px; }
  .cd-bl { bottom: -1px; left: -1px; }
  .cd-br { bottom: -1px; right: -1px; }
  @keyframes cornerDotPulse {
    from { opacity: 0.4; transform: scale(1); }
    to   { opacity: 0.9; transform: scale(1.4); }
  }

  /* ── Title subtle gold edge gradient ── */
  .boot-brand-name {
    position: relative;
  }
  .boot-brand-name::after {
    content: 'GRANADA URBAN';
    position: absolute;
    inset: 0;
    display: flex;
    justify-content: center;
    font-family: var(--font-body);
    font-size: inherit;
    font-weight: inherit;
    letter-spacing: inherit;
    text-transform: inherit;
    line-height: inherit;
    background: linear-gradient(180deg, rgba(255,255,255,0.3) 0%, transparent 40%, transparent 60%, rgba(201,168,76,0.18) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    pointer-events: none;
    mix-blend-mode: overlay;
    opacity: 0;
    animation: bootFadeIn 1.2s ease 0.8s forwards;
  }

  /* ── Sub-status (terminal style) ── */
  .boot-sub-status {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(201,168,76,0.38);
    opacity: 0;
    animation: bootFadeIn 0.6s ease 0.9s forwards;
    margin-top: -0.15rem;
  }
  .boot-sub-status span:not(.sub-dot) {
    opacity: 0.6;
  }
  .sub-dot {
    display: inline-block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(201,168,76,0.3);
    margin-right: 0.4rem;
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }
  .sub-dot.ok {
    background: rgba(201,168,76,0.6);
    box-shadow: 0 0 6px rgba(201,168,76,0.3);
  }
  .sub-dot.active {
    background: var(--color-accent);
    box-shadow: 0 0 8px rgba(232,98,42,0.5);
  }

  /* ── Completion flash ── */
  .boot-flash {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, rgba(255,255,255,0.06) 0%, transparent 60%);
    pointer-events: none;
    z-index: 50;
    opacity: 0;
  }
  .boot-flash.is-active {
    animation: bootFlash 0.35s ease-out forwards;
  }
  @keyframes bootFlash {
    0%   { opacity: 0; }
    30%  { opacity: 1; }
    100% { opacity: 0; }
  }

  @keyframes bootFadeIn { to { opacity: 1; } }

  /* ── Preloader responsive ── */
  @media (max-width: 768px) {
    .boot-frame { inset: 1rem; }
    .boot-corner { width: 44px; height: 44px; }
    .boot-brand-name { font-size: clamp(2.6rem, 12vw, 5rem); line-height: 0.9; }
    .boot-logo-wrap { width: clamp(70px, 22vw, 110px); height: clamp(70px, 22vw, 110px); }
    .boot-side-rule { display: none; }
    .boot-data-stream { display: none; }
    .boot-tag { font-size: 0.58rem; letter-spacing: 0.15em; }
    .boot-tag-tl { top: 1.2rem; left: 1.2rem; }
    .boot-tag-tr { top: 1.2rem; right: 1.2rem; }
    .boot-rule-wrap { width: clamp(160px, 72vw, 300px); bottom: 2.2rem; }
    .boot-build-info { display: none; }
    .boot-particle { display: none; }
    .boot-geometry { display: none; }
    .boot-readout { gap: 0.5rem; }
    .boot-counter { font-size: clamp(1.8rem, 6vw, 2.6rem); }
  }
  @media (max-width: 480px) {
    .boot-brand-name { font-size: clamp(2.2rem, 11vw, 3.6rem); }
    .boot-brand-tagline { font-size: 0.65rem; letter-spacing: 0.15em; }
    .boot-logo-wrap { width: clamp(55px, 18vw, 85px); height: clamp(55px, 18vw, 85px); }
    .boot-rule-wrap { bottom: 1.8rem; }
    .boot-tag { display: none; }
    .boot-ticks { padding: 0 1.2rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-boot-screen *, .hero-boot-screen *::before, .hero-boot-screen *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
    .hero-boot-screen { transition: opacity 0.3s ease; }
  }

  /* Cinematic dust particles */
  .hero-particle {
    position: absolute;
    border-radius: 50%;
    background: var(--color-gold);
    pointer-events: none;
    z-index: 3;
    opacity: 0;
    animation: dustFadeIn 2s ease forwards, dustFloat 10s ease-in-out infinite;
  }
  .dp-1 { width: 2px; height: 2px; top: 18%; left: 12%; animation-delay: 2.5s, 3s; }
  .dp-2 { width: 3px; height: 3px; top: 35%; right: 18%; animation-delay: 3s, 3.5s; filter: blur(1px); }
  .dp-3 { width: 2px; height: 2px; bottom: 30%; left: 22%; animation-delay: 2.8s, 3.2s; }
  .dp-4 { width: 1.5px; height: 1.5px; top: 55%; right: 28%; animation-delay: 3.2s, 3.8s; }
  .dp-5 { width: 2.5px; height: 2.5px; bottom: 45%; left: 8%; animation-delay: 3.5s, 4s; filter: blur(0.5px); }
  .dp-6 { width: 2px; height: 2px; top: 12%; right: 40%; animation-delay: 2.2s, 2.8s; }
  @keyframes dustFadeIn { to { opacity: 0.25; } }
  @keyframes dustFloat {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }

---
import type { Locale } from '@types';
import ScreenFrame from '@components/ui/ScreenFrame.astro';
import { useTranslations } from '@i18n/utils';
import { getRoute } from '@utils/routes';
import '../../styles/home/hero.css';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const c = {
  supra: t('home.hero.worldHeritage'),
  searchHeading: t('home.hero.searchHeading'),
  title: 'GRANADA',
  cta: t('home.hero.ctaEvents'),
  ctaLink: getRoute('events', locale),
  label: t('home.hero.heritageDestination'),
  ariaLabel: t('home.hero.gatewayLabel'),
};
---

<section class="portal-hero" aria-label={c.ariaLabel}>
  <h1 class="sr-only">{c.searchHeading}</h1>

  <!-- Cinematic Preloader — ultra light -->
  <div class="hero-boot-screen" id="hero-boot-screen" aria-hidden="true">
    <div class="boot-vignette" aria-hidden="true"></div>

    <div class="boot-frame" aria-hidden="true">
      <svg class="boot-corner boot-corner-tl" viewBox="0 0 40 40" aria-hidden="true">
        <path d="M0 40 L0 8 A8 8 0 0 1 8 0 L40 0" fill="none" stroke="currentColor" stroke-width="1"/>
      </svg>
      <svg class="boot-corner boot-corner-tr" viewBox="0 0 40 40" aria-hidden="true">
        <path d="M0 0 L32 0 A8 8 0 0 1 40 8 L40 40" fill="none" stroke="currentColor" stroke-width="1"/>
      </svg>
      <svg class="boot-corner boot-corner-bl" viewBox="0 0 40 40" aria-hidden="true">
        <path d="M0 0 L0 32 A8 8 0 0 0 8 40 L40 40" fill="none" stroke="currentColor" stroke-width="1"/>
      </svg>
      <svg class="boot-corner boot-corner-br" viewBox="0 0 40 40" aria-hidden="true">
        <path d="M40 0 L40 32 A8 8 0 0 1 32 40 L0 40" fill="none" stroke="currentColor" stroke-width="1"/>
      </svg>
    </div>

    <div class="boot-ticks" aria-hidden="true">
      <span class="b-tick"></span><span class="b-tick"></span><span class="b-tick"></span>
      <span class="b-tick b-tick-center"></span>
      <span class="b-tick"></span><span class="b-tick"></span><span class="b-tick"></span>
    </div>

    <span class="boot-tag boot-tag-tl" aria-hidden="true">[00] INICIO</span>
    <span class="boot-tag boot-tag-tr" aria-hidden="true">GRN.V1</span>

    <div class="boot-brand-wrap">
      <div class="boot-logo-wrap">
        <svg class="boot-star" viewBox="0 0 44 44" fill="none" aria-hidden="true">
          <path d="M22 3 L25.2 13.8 L36 8 L29.2 17.5 L38 22 L29.2 26.5 L36 36 L25.2 30.2 L22 41 L18.8 30.2 L8 36 L14.8 26.5 L6 22 L14.8 17.5 L8 8 L18.8 13.8 Z" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linejoin="round"/>
          <circle cx="22" cy="22" r="3.5" fill="currentColor"/>
        </svg>
        <div class="boot-star-glow" aria-hidden="true"></div>
      </div>

      <div class="boot-lockup">
        <div class="boot-brand-name">GRANADA URBAN</div>
        <div class="boot-brand-tagline">Guía de la ciudad</div>
        <div class="boot-accent-line" aria-hidden="true"></div>
      </div>

      <div class="boot-readout">
        <span class="boot-status" id="boot-status">Inicializando</span>
        <span class="boot-counter" id="boot-counter">000</span>
      </div>
    </div>

    <div class="boot-rule-wrap" aria-hidden="true">
      <div class="boot-rule-track">
        <div class="boot-rule-track-bg"></div>
        <div class="boot-rule-fill" id="boot-rule-fill"></div>
      </div>
      <div class="boot-rule-percent" id="boot-rule-percent">0%</div>
    </div>

    <div class="boot-build-info" aria-hidden="true">BUILD 2026.04.28 // GRN.V1.0.0</div>
  </div>

  <!-- Camera Screen Frame -->
  <ScreenFrame />

  <!-- 1. The Living Canvas -->
  <div class="ambient-layer">
    <picture class="ambient-picture">
      <source srcset="/hero-poster-1920-apex-20260526.jpg" media="(min-width: 900px)" />
      <img
        class="ambient-poster"
        src="/hero-poster-apex-20260526.jpg"
        alt=""
        width="1280"
        height="720"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </picture>
    <video
      class="ambient-video"
      muted
      loop
      playsinline
      preload="none"
      poster="/hero-poster-apex-20260526.jpg"
      data-src="/hero-video-ambient-apex-20260526.mp4"
      aria-hidden="true"
    >
    </video>
    <div class="ambient-grain" aria-hidden="true"></div>
    <div class="ambient-gradient"></div>
  </div>

  <!-- Ambient Orb -->
  <div class="ambient-orb orb-1" aria-hidden="true"></div>

  <!-- Light Leak -->
  <div class="light-leak" aria-hidden="true"></div>

  <!-- Corner Glows -->
  <div class="corner-glow glow-tl" aria-hidden="true"></div>
  <div class="corner-glow glow-tr" aria-hidden="true"></div>
  <div class="corner-glow glow-bl" aria-hidden="true"></div>
  <div class="corner-glow glow-br" aria-hidden="true"></div>

  <!-- 2. Monumental Lockup -->
  <div class="epic-title-layer">
    <span class="epic-subtitle" data-parallax="-0.04">{c.supra}</span>
    <div class="epic-title" data-parallax="-0.03" aria-hidden="true">
      {c.title.split('').map((letter, index) => (
        <span class="title-char" style={`--delay: ${index * 0.08}s`}>{letter}</span>
      ))}
    </div>
  </div>

  <!-- 3. The Alhambra Portal -->
  <div class="portal-wrapper">
    <div class="portal-meta meta-left">
      <span class="meta-text">{c.label}</span>
      <span class="meta-dot"></span>
    </div>

    <div class="portal" data-parallax="0.05" aria-hidden="true">
      <div class="portal-inner-frame">
        <video
          class="sharp-video"
          muted
          loop
          playsinline
          preload="none"
          poster="/hero-poster-1920-apex-20260526.jpg"
          data-src-mobile="/hero-video-1080-apex-20260526.mp4"
          data-src-desktop="/hero-video-1080-apex-20260526.mp4"
        >
        </video>
        <div class="portal-shadows"></div>
        <div class="portal-glare"></div>
      </div>
    </div>

    <div class="portal-meta meta-right">
      <span class="meta-dot"></span>
      <span class="meta-text">37°N · 3°W</span>
    </div>
  </div>

  <!-- 4. Cinematic Dock -->
  <div class="glass-dock-layer">
    <div class="glass-dock">
      <div class="dock-weather">
        <div class="time-block">
          <div class="live-dot" aria-hidden="true"></div>
          <div class="time-display" id="live-time">
            <span class="time-h">--</span><span class="time-sep">:</span><span class="time-m">--</span><span class="time-sep">:</span><span class="time-s">--</span>
          </div>
        </div>
        <div class="weather-display">
          <span class="weather-icon" id="weather-icon-today">—</span>
          <span class="weather-temp" id="weather-today">--°</span>
        </div>
      </div>

      <div class="dock-divider"></div>

      <a href={c.ctaLink} class="dock-cta" aria-label={c.cta}>
        <span class="cta-text">{c.cta}</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="cta-arrow" aria-hidden="true">
          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- 5. Scroll Hint -->
  <div class="scroll-hint">
    <span class="scroll-hint-line"></span>
    <span class="scroll-hint-text">SCROLL</span>
  </div>

  <!-- 6. Bottom Editorial Ornament -->
  <div class="hero-ornament">
    <div class="ornament-line"></div>
    <div class="ornament-diamond">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2L22 12L12 22L2 12Z"/>
      </svg>
    </div>
    <div class="ornament-line"></div>
  </div>

</section>

<script>
  (function initHero() {
    const section = document.querySelector('.portal-hero') as HTMLElement | null;
    const ambientVideo = document.querySelector('.ambient-video') as HTMLVideoElement | null;
    const sharpVideo = document.querySelector('.sharp-video') as HTMLVideoElement | null;
    const bootScreen = document.getElementById('hero-boot-screen');
    if (!section) return;

    // 1. Live Time
    const timeEl = document.getElementById('live-time');
    if (timeEl) {
      const hEl = timeEl.querySelector('.time-h');
      const mEl = timeEl.querySelector('.time-m');
      const sEl = timeEl.querySelector('.time-s');
      const updateTime = () => {
        const parts = new Intl.DateTimeFormat('es-ES', {
          timeZone: 'Europe/Madrid',
          hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false,
        }).formatToParts(new Date());
        const h = parts.find(p => p.type === 'hour')?.value ?? '--';
        const m = parts.find(p => p.type === 'minute')?.value ?? '--';
        const s = parts.find(p => p.type === 'second')?.value ?? '--';
        if (hEl) hEl.textContent = h;
        if (mEl) mEl.textContent = m;
        if (sEl) sEl.textContent = s;
      };
      updateTime();
      setInterval(updateTime, 1000);
    }

    // 2. Weather
    const WMO_ICONS: Record<number, string> = {
      0: '☀️', 1: '🌤', 2: '⛅', 3: '☁️',
      45: '🌫', 48: '🌫',
      51: '🌦', 53: '🌦', 55: '🌦',
      61: '🌧', 63: '🌧', 65: '🌧',
      71: '❄️', 73: '❄️', 75: '❄️',
      80: '🌦', 81: '🌦', 82: '🌦',
      95: '⛈', 96: '⛈', 99: '⛈',
    };
    const wmoIcon = (code: number): string => {
      if (WMO_ICONS[code]) return WMO_ICONS[code];
      if (code <= 3) return '🌤';
      if (code <= 48) return '🌫';
      if (code <= 67) return '🌧';
      if (code <= 77) return '❄️';
      if (code <= 82) return '🌦';
      return '⛈';
    };
    const fetchWeather = () => {
      fetch('https://api.open-meteo.com/v1/forecast?latitude=37.18&longitude=-3.60&current=temperature_2m,weather_code&timezone=Europe%2FMadrid')
        .then(r => r.json())
        .then(data => {
          const todayTemp = document.getElementById('weather-today');
          const todayIcon = document.getElementById('weather-icon-today');
          const curTemp = Math.round(data.current.temperature_2m);
          const curCode = data.current.weather_code as number;
          if (todayTemp) todayTemp.textContent = `${curTemp}°`;
          if (todayIcon) todayIcon.textContent = wmoIcon(curCode);
        })
        .catch(() => {});
    };
    // Defer weather fetch until after critical rendering
    if ('requestIdleCallback' in window) {
      requestIdleCallback(fetchWeather, { timeout: 3000 });
    } else {
      setTimeout(fetchWeather, 2000);
    }

    // 3. Lightweight Mouse Parallax
    const portal = document.querySelector('.portal') as HTMLElement;
    const glare = document.querySelector('.portal-glare') as HTMLElement;
    const titleLayer = document.querySelector('.epic-title-layer') as HTMLElement;
    const ambientLayer = document.querySelector('.ambient-layer') as HTMLElement;
    let parallaxRafId: number | null = null;
    let mouseX = 0, mouseY = 0, targetMouseX = 0, targetMouseY = 0;
    const lerp = (a: number, b: number, f: number) => a + (b - a) * f;

    const applyParallax = () => {
      mouseX = lerp(mouseX, targetMouseX, 0.06);
      mouseY = lerp(mouseY, targetMouseY, 0.06);
      titleLayer?.style.setProperty('transform',
        `translate3d(${mouseX * -30}px, ${mouseY * -20}px, 0)`);
      ambientLayer?.style.setProperty('transform',
        `translate3d(${mouseX * 10}px, ${mouseY * 10}px, 0) scale(1.04)`);
      portal?.style.setProperty('transform',
        `translate3d(${mouseX * 20}px, ${mouseY * 14}px, 0) rotateY(${mouseX * 4}deg) rotateX(${-mouseY * 4}deg)`);
      glare?.style.setProperty('transform',
        `translate(calc(-50% + ${mouseX * -80}px), calc(-50% + ${mouseY * -80}px))`);
    };
    const parallaxTick = () => { applyParallax(); parallaxRafId = requestAnimationFrame(parallaxTick); };

    if (section) {
      if (window.matchMedia('(pointer: fine)').matches) {
        section.addEventListener('mousemove', (e) => {
          targetMouseX = (e.clientX / window.innerWidth - 0.5);
          targetMouseY = (e.clientY / window.innerHeight - 0.5);
        });
        section.addEventListener('mouseleave', () => { targetMouseX = 0; targetMouseY = 0; });
      }
      const parallaxIo = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            if (!parallaxRafId) parallaxRafId = requestAnimationFrame(parallaxTick);
          } else {
            if (parallaxRafId) { cancelAnimationFrame(parallaxRafId); parallaxRafId = null; }
          }
        });
      }, { threshold: 0 });
      parallaxIo.observe(section);
    }

    // 4. Ultra-smooth Boot Sequence — fast, cinematic
    const bootCounter = document.getElementById('boot-counter');
    const bootStatus = document.getElementById('boot-status');
    const bootRuleFill = document.getElementById('boot-rule-fill');
    const bootPercent = document.getElementById('boot-rule-percent');
    const bootStart = performance.now();
    let hasRevealed = false;
    const MIN_BOOT_MS = 350;
    const MAX_BOOT_MS = 700;
    const easeOutCubic = (t: number) => 1 - Math.pow(1 - t, 3);
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const connection = 'connection' in navigator
      ? (navigator as Navigator & { connection?: { saveData?: boolean; effectiveType?: string } }).connection
      : undefined;
    const shouldSkipVideo = prefersReducedMotion || connection?.saveData === true || connection?.effectiveType === '2g';
    let portalVideoLoaded = false;

    const loadVideo = (video: HTMLVideoElement, src: string | undefined, playableClass: string) => {
      if (!src || video.src) return;

      const onCanPlay = () => video.classList.add(playableClass);
      video.addEventListener('canplay', onCanPlay, { once: true });
      video.addEventListener('error', onCanPlay, { once: true });
      video.src = src;
      video.load();
      video.play().catch(() => {});
      if (video.readyState >= 3) onCanPlay();
    };

    const loadPortalVideo = () => {
      if (!sharpVideo || portalVideoLoaded || shouldSkipVideo) return;
      const selectedSrc = window.matchMedia('(min-width: 900px)').matches
        ? sharpVideo.dataset.srcDesktop
        : sharpVideo.dataset.srcMobile;

      portalVideoLoaded = true;
      loadVideo(sharpVideo, selectedSrc, 'is-playable');
    };

    const loadAmbientVideo = () => {
      if (!ambientVideo || shouldSkipVideo || ambientVideo.src) return;
      loadVideo(ambientVideo, ambientVideo.dataset.src, 'is-playable');
    };

    const tick = setInterval(() => {
      if (hasRevealed) { clearInterval(tick); return; }
      const elapsed = performance.now() - bootStart;
      const progress = easeOutCubic(Math.min(elapsed / MIN_BOOT_MS, 1));
      const pct = Math.min(100, Math.floor(progress * 100));
      if (bootCounter) bootCounter.textContent = String(pct);
      if (bootRuleFill) bootRuleFill.style.transform = `scaleX(${progress})`;
      if (bootPercent) bootPercent.textContent = `${pct}%`;
      if (bootStatus) bootStatus.textContent = pct < 50 ? 'Cargando' : 'Listo';
    }, 40);

    const revealHero = () => {
      if (!bootScreen || hasRevealed) return;
      hasRevealed = true;
      clearInterval(tick);
      const elapsed = performance.now() - bootStart;
      const wait = Math.max(0, MIN_BOOT_MS - elapsed);

      setTimeout(() => {
        if (bootCounter) bootCounter.textContent = '100';
        if (bootRuleFill) bootRuleFill.style.transform = 'scaleX(1)';
        if (bootPercent) bootPercent.textContent = '100%';
        if (bootStatus) bootStatus.textContent = 'Listo';

        section?.classList.add('is-ready');
        loadPortalVideo();
        window.setTimeout(loadAmbientVideo, 180);

        // Boot fades out smoothly after a tiny delay
        setTimeout(() => {
          bootScreen.classList.add('is-hidden');
          setTimeout(() => { bootScreen.style.display = 'none'; }, 900);
        }, 80);
      }, wait);
    };

    setTimeout(revealHero, MAX_BOOT_MS);
  })();
</script>

    text-shadow:
      0 1px 1px rgba(0,0,0,0.3),
      0 4px 10px rgba(0,0,0,0.5),
      0 10px 40px rgba(0,0,0,0.8),
      0 0 80px rgba(0,0,0,0.6),
      0 0 120px rgba(201,168,76,0.04);

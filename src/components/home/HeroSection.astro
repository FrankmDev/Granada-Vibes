<script>
  document.addEventListener('DOMContentLoaded', () => {
    // 1. Live Time (Europe/Madrid)
    const timeEl = document.getElementById('live-time');
    if (timeEl) {
      const hEl = timeEl.querySelector('.time-h');
      const mEl = timeEl.querySelector('.time-m');
      const sEl = timeEl.querySelector('.time-s');

      const updateTime = () => {
        const parts = new Intl.DateTimeFormat('es-ES', {
          timeZone: 'Europe/Madrid',
          hour: '2-digit',
          minute: '2-digit',
          second: '2-digit',
          hour12: false,
        }).formatToParts(new Date());
        const h = parts.find(p => p.type === 'hour')?.value ?? '--';
        const m = parts.find(p => p.type === 'minute')?.value ?? '--';
        const s = parts.find(p => p.type === 'second')?.value ?? '--';

        if (hEl) hEl.textContent = h;
        if (mEl) mEl.textContent = m;
        if (sEl) sEl.textContent = s;
      };
      updateTime();
      setInterval(updateTime, 1000);
    }

    // 2. Live Weather — Open-Meteo (Granada lat/lon, no API key)
    const WMO_ICONS: Record<number, string> = {
      0: '☀️', 1: '🌤', 2: '⛅', 3: '☁️',
      45: '🌫', 48: '🌫',
      51: '🌦', 53: '🌦', 55: '🌦',
      61: '🌧', 63: '🌧', 65: '🌧',
      71: '❄️', 73: '❄️', 75: '❄️',
      80: '🌦', 81: '🌦', 82: '🌦',
      95: '⛈', 96: '⛈', 99: '⛈',
    };
    const wmoIcon = (code: number): string => {
      if (WMO_ICONS[code]) return WMO_ICONS[code];
      if (code <= 3) return '🌤';
      if (code <= 48) return '🌫';
      if (code <= 67) return '🌧';
      if (code <= 77) return '❄️';
      if (code <= 82) return '🌦';
      return '⛈';
    };

    fetch(
      'https://api.open-meteo.com/v1/forecast?latitude=37.18&longitude=-3.60&current=temperature_2m,weather_code&daily=temperature_2m_max,weather_code&timezone=Europe%2FMadrid&forecast_days=2'
    )
      .then((r) => r.json())
      .then((data) => {
        const todayTemp = document.getElementById('weather-today');
        const todayIcon = document.getElementById('weather-icon-today');

        const curTemp = Math.round(data.current.temperature_2m);
        const curCode = data.current.weather_code as number;

        if (todayTemp) todayTemp.textContent = `${curTemp}°`;
        if (todayIcon) todayIcon.textContent = wmoIcon(curCode);
      })
      .catch(() => {
        // silently degrade — dashes remain
      });

    // 3. Cinematic Mouse Parallax Engine
    const section = document.querySelector('.portal-hero') as HTMLElement;
    const portal = document.querySelector('.portal') as HTMLElement;
    const glare = document.querySelector('.portal-glare') as HTMLElement;
    const titleLayer = document.querySelector('.epic-title-layer') as HTMLElement;
    const ambientLayer = document.querySelector('.ambient-layer') as HTMLElement;

    let parallaxRafId: number | null = null;
    let mouseX = 0;
    let mouseY = 0;
    let targetMouseX = 0;
    let targetMouseY = 0;

    const lerp = (start: number, end: number, factor: number) => start + (end - start) * factor;

    const applyParallax = () => {
      mouseX = lerp(mouseX, targetMouseX, 0.08);
      mouseY = lerp(mouseY, targetMouseY, 0.08);

      const titleMouseX = mouseX * -35;
      const titleMouseY = mouseY * -24;
      titleLayer?.style.setProperty('transform',
        `translate(${titleMouseX}px, ${titleMouseY}px) rotateY(${mouseX * 3}deg) rotateX(${-mouseY * 3}deg)`
      );

      const ambientMouseX = mouseX * 12;
      const ambientMouseY = mouseY * 12;
      ambientLayer?.style.setProperty('transform',
        `translate(${ambientMouseX}px, ${ambientMouseY}px) scale(1.02)`
      );

      const portalMouseX = mouseX * 24;
      const portalMouseY = mouseY * 18;
      portal?.style.setProperty('transform',
        `translate(${portalMouseX}px, ${portalMouseY}px) rotateY(${mouseX * 5}deg) rotateX(${-mouseY * 5}deg)`
      );

      glare?.style.setProperty('transform',
        `translate(calc(-50% + ${mouseX * -100}px), calc(-50% + ${mouseY * -100}px))`
      );
    };

    const parallaxTick = () => {
      applyParallax();
      parallaxRafId = requestAnimationFrame(parallaxTick);
    };

    if (section) {
      if (window.matchMedia('(pointer: fine)').matches) {
        section.addEventListener('mousemove', () => {
          const { clientX, clientY, innerWidth, innerHeight } = window;
          targetMouseX = (clientX / innerWidth - 0.5);
          targetMouseY = (clientY / innerHeight - 0.5);
        });

        section.addEventListener('mouseleave', () => {
          targetMouseX = 0;
          targetMouseY = 0;
        });
      }

      const parallaxIo = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            if (!parallaxRafId) parallaxRafId = requestAnimationFrame(parallaxTick);
          } else {
            if (parallaxRafId) {
              cancelAnimationFrame(parallaxRafId);
              parallaxRafId = null;
            }
          }
        });
      }, { threshold: 0 });
      parallaxIo.observe(section);

      if (!parallaxRafId) parallaxRafId = requestAnimationFrame(parallaxTick);
    }

    // Boot reveal — smooth fade, bulletproof
    const ambientVideo = document.querySelector('.ambient-video') as HTMLVideoElement | null;
    const sharpVideo = document.querySelector('.sharp-video') as HTMLVideoElement | null;
    const bootScreen = document.getElementById('hero-boot-screen');
    const bootCounter = document.getElementById('boot-counter');
    const bootStatus = document.getElementById('boot-status');
    const bootRuleFill = document.getElementById('boot-rule-fill');
    const bootActivityFill = document.getElementById('boot-activity-fill');

    const MIN_BOOT_MS = 1200;
    const MAX_BOOT_MS = 2600;
    const bootStart = performance.now();
    let videosReady = 0;
    const totalVideos = 2;
    let hasRevealed = false;
    let counterRaf = 0;
    let lastMilestone = -1;

    const STATUS_MESSAGES = [
      { at: 0, text: 'Inicializando' },
      { at: 20, text: 'Cargando recursos' },
      { at: 45, text: 'Conectando servicios' },
      { at: 70, text: 'Sincronizando datos' },
      { at: 90, text: 'Preparando experiencia' },
      { at: 99, text: 'Listo' },
    ];

    const SCRAMBLE_CHARS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';

    const easeOutCubic = (t: number) => 1 - Math.pow(1 - t, 3);

    const subStatusDots = document.querySelectorAll('.sub-dot');
    const logoWrap = document.querySelector('.boot-logo-wrap') as HTMLElement | null;

    const scrambleText = (el: HTMLElement, finalText: string, duration = 200) => {
      if (!el) return;
      const start = performance.now();
      const orig = finalText;
      const tick = () => {
        const elapsed = performance.now() - start;
        const progress = Math.min(1, elapsed / duration);
        const revealed = Math.floor(progress * orig.length);
        let out = orig.slice(0, revealed);
        for (let i = revealed; i < orig.length; i++) {
          out += SCRAMBLE_CHARS[Math.floor(Math.random() * SCRAMBLE_CHARS.length)];
        }
        el.textContent = out;
        if (progress < 1) requestAnimationFrame(tick);
        else el.textContent = orig;
      };
      requestAnimationFrame(tick);
    };

    const triggerMilestone = (pct: number) => {
      const milestone = Math.floor(pct / 10) * 10;
      if (milestone > lastMilestone && milestone > 0 && milestone <= 100) {
        lastMilestone = milestone;
        if (bootCounter) {
          bootCounter.classList.remove('milestone');
          void bootCounter.offsetWidth; // force reflow
          bootCounter.classList.add('milestone');
          setTimeout(() => bootCounter.classList.remove('milestone'), 350);
        }
      }
    };

    const updateReadout = (rawProgress: number) => {
      const eased = easeOutCubic(Math.min(1, Math.max(0, rawProgress)));
      const pct = Math.min(100, Math.floor(eased * 100));
      const pctStr = String(pct).padStart(3, '0');
      if (bootCounter) bootCounter.textContent = pctStr;
      if (bootRuleFill) bootRuleFill.style.transform = `scaleX(${eased})`;

      const percentLabel = document.getElementById('boot-rule-percent');
      if (percentLabel) percentLabel.textContent = `${pct}%`;

      if (bootStatus) {
        const msg = STATUS_MESSAGES.slice().reverse().find(m => pct >= m.at);
        if (msg && bootStatus.textContent !== msg.text) {
          bootStatus.classList.add('is-changing');
          setTimeout(() => bootStatus.classList.remove('is-changing'), 350);
          scrambleText(bootStatus, msg.text, 180);
        }
      }

      if (bootCounter) {
        if (pct >= 90) bootCounter.classList.add('near-complete');
        else bootCounter.classList.remove('near-complete');
      }

      triggerMilestone(pct);

      // Sub-status terminal dots animation
      if (subStatusDots.length === 3) {
        if (pct >= 25) subStatusDots[0].classList.add('active');
        if (pct >= 55) subStatusDots[1].classList.add('active');
        if (pct >= 85) subStatusDots[2].classList.add('active');
      }

      // Activity bar speed increases with progress
      if (bootActivityFill) {
        const speed = 1.0 + eased * 1.0;
        bootActivityFill.style.animationDuration = `${1.8 - speed}s`;
      }
    };

    const animateCounter = () => {
      const tick = () => {
        if (hasRevealed) return;
        const elapsed = performance.now() - bootStart;
        const progress = Math.min(1, elapsed / MIN_BOOT_MS);
        updateReadout(progress);
        if (progress < 1) {
          counterRaf = requestAnimationFrame(tick);
        }
      };
      counterRaf = requestAnimationFrame(tick);
    };
    animateCounter();

    const revealHero = () => {
      if (!bootScreen || hasRevealed) return;
      hasRevealed = true;
      if (counterRaf) cancelAnimationFrame(counterRaf);

      const elapsed = performance.now() - bootStart;
      const remaining = Math.max(0, MIN_BOOT_MS - elapsed);

      setTimeout(() => {
        updateReadout(1);
        // Flash at 100%
        const flash = document.getElementById('boot-flash');
        if (flash) flash.classList.add('is-active');

        // Shockwave
        const shockwave = document.getElementById('boot-shockwave');
        if (shockwave) shockwave.classList.add('is-active');

        // Logo complete pulse
        if (logoWrap) logoWrap.classList.add('is-complete');

        setTimeout(() => {
          bootScreen.classList.add('is-hidden');
          setTimeout(() => {
            if (bootScreen.parentNode) {
              bootScreen.style.display = 'none';
            }
          }, 800);
        }, 100);
      }, remaining);
    };

    const onVideoReady = () => {
      videosReady++;
      if (videosReady >= totalVideos) {
        revealHero();
      }
    };

    const bindVideo = (video: HTMLVideoElement | null) => {
      if (!video) {
        onVideoReady();
        return;
      }
      if (video.readyState >= 2) {
        onVideoReady();
      } else {
        video.addEventListener('loadeddata', onVideoReady, { once: true });
        video.addEventListener('error', onVideoReady, { once: true });
      }
    };

    bindVideo(ambientVideo);
    bindVideo(sharpVideo);

    setTimeout(() => {
      revealHero();
    }, MAX_BOOT_MS);
  });
</script>

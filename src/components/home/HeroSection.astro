---
/**
 * HeroSection — Cinematic Video Hero
 * Full-bleed video background, editorial typography
 */
import type { Event } from '../../types';

interface Props {
  thisWeekEvents: Event[];
  locale: string;
}

const { thisWeekEvents, locale } = Astro.props;

const eyebrowLabel = locale === 'es' ? 'Guía Cultural' : 'Cultural Guide';
const tagline = locale === 'es'
  ? 'Eventos, rutas auténticas y los mejores planes de la ciudad.'
  : 'Events, authentic routes and the best plans in the city.';
const ctaLabel = locale === 'es' ? 'Ver programación' : 'View programme';
const eventsLabel = locale === 'es' ? 'Eventos' : 'Events';
const routesLabel = locale === 'es' ? 'Rutas' : 'Routes';
---

<section class="hero" aria-label={locale === 'es' ? 'Granada Vibes — Guía Cultural' : 'Granada Vibes — Cultural Guide'}>
  
  <!-- ── Video Background ── -->
  <div class="hero__video-container" aria-hidden="true">
    <video 
      class="hero__video" 
      autoplay 
      muted 
      loop 
      playsinline
      preload="auto"
      crossorigin="anonymous"
      poster="/images/hero-fallback.jpg"
    >
      <source src="/heroVideo.avi" type="video/x-msvideo" />
      <source src="/heroVideo.webm" type="video/webm" />
    </video>
    <div class="hero__video-overlay"></div>
    <div class="hero__grain" aria-hidden="true"></div>
  </div>

  <!-- ── Main Content ── -->
  <div class="hero__content">
    
    <!-- Top: Eyebrow and Navigation -->
    <div class="hero__top">
      <div class="hero__eyebrow">
        <span class="hero__eyebrow-bracket">[</span>
        <span class="hero__eyebrow-text">{eyebrowLabel}</span>
        <span class="hero__eyebrow-bracket">]</span>
        <span class="hero__year">2025 — 2026</span>
      </div>
      
      <nav class="hero__nav" aria-label={locale === 'es' ? 'Navegación principal' : 'Main navigation'}>
        <a href={locale === 'es' ? '/eventos' : '/en/events'} class="hero__nav-link">
          {eventsLabel}
        </a>
        <a href={locale === 'es' ? '/rutas' : '/en/routes'} class="hero__nav-link">
          {routesLabel}
        </a>
        <a href={locale === 'es' ? '/semana-santa' : '/en/easter'} class="hero__nav-link hero__nav-link--accent">
          Semana Santa
        </a>
      </nav>
    </div>
    
    <!-- Bottom: Title and CTA -->
    <div class="hero__bottom">
      <div class="hero__title-block">
        <h1 class="hero__title">
          <span class="hero__title-line hero__title-line--1">GRANADA</span>
          <span class="hero__title-line hero__title-line--2">VIBES</span>
        </h1>
        
        <p class="hero__tagline">{tagline}</p>
      </div>
      
      <a
        href={locale === 'es' ? '/eventos' : '/en/events'}
        class="hero__cta"
        aria-label={ctaLabel}
      >
        <span>{ctaLabel}</span>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- ── Stats Bar ── -->
  <div class="hero__stats" aria-label={locale === 'es' ? 'Datos de Granada' : 'Granada facts'}>
    <div class="hero__stat">
      <span class="hero__stat-num">
        <span class="hero__stat-value" data-count-target="48">0</span>
      </span>
      <span class="hero__stat-label">{locale === 'es' ? 'horas de tapeo' : 'hours of tapas'}</span>
    </div>
    <div class="hero__stat-divider"></div>
    <div class="hero__stat">
      <span class="hero__stat-num">
        <span class="hero__stat-value" data-count-target="800">0</span>
        <span class="hero__stat-suffix">+</span>
      </span>
      <span class="hero__stat-label">{locale === 'es' ? 'años de historia' : 'years of history'}</span>
    </div>
    <div class="hero__stat-divider"></div>
    <div class="hero__stat">
      <span class="hero__stat-num">
        <span class="hero__stat-value" data-count-target="2">0</span>
      </span>
      <span class="hero__stat-label">{locale === 'es' ? 'Patrimonios UNESCO' : 'UNESCO sites'}</span>
    </div>
    <div class="hero__stat-divider hero__stat-divider--hide"></div>
    <div class="hero__stat hero__stat--hide">
      <span class="hero__stat-num">
        <span class="hero__stat-value" data-count-target="40">0</span>
        <span class="hero__stat-suffix">+</span>
      </span>
      <span class="hero__stat-label">{locale === 'es' ? 'rutas curadas' : 'curated routes'}</span>
    </div>
  </div>

  <!-- ── Scroll Indicator ── -->
  <div class="hero__scroll-indicator" aria-hidden="true">
    <span class="hero__scroll-text">{locale === 'es' ? 'Descubrir' : 'Discover'}</span>
    <div class="hero__scroll-line"></div>
  </div>
</section>

<style>
  /* ── Base ── */
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* ── Video Background ── */
  .hero__video-container {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: 
      radial-gradient(ellipse at 30% 70%, rgba(232, 98, 42, 0.15) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 30%, rgba(201, 168, 76, 0.1) 0%, transparent 50%),
      linear-gradient(135deg, #0f0f0f 0%, #080808 50%, #0a0a0a 100%);
  }

  .hero__video {
    position: absolute;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .hero__video[data-loaded="true"] {
    opacity: 1;
  }

  .hero__video-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(8, 8, 8, 0.95) 0%,
      rgba(8, 8, 8, 0.7) 40%,
      rgba(8, 8, 8, 0.3) 70%,
      rgba(8, 8, 8, 0.5) 100%
    );
    pointer-events: none;
  }

  .hero__grain {
    position: absolute;
    inset: 0;
    opacity: 0.04;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    mix-blend-mode: overlay;
  }

  /* ── Content ── */
  .hero__content {
    position: relative;
    z-index: 10;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: clamp(1.5rem, 4vw, 3rem);
    padding-top: calc(var(--nav-height, 80px) + 1rem);
  }

  @media (min-width: 768px) {
    .hero__content {
      padding: clamp(2rem, 5vw, 4rem);
      padding-top: calc(var(--nav-height, 90px) + 1.5rem);
    }
  }

  /* ── Top Section ── */
  .hero__top {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .hero__top {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }
  }

  .hero__eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    animation: fadeIn 0.8s ease 0.2s both;
  }

  .hero__eyebrow-bracket {
    color: var(--color-accent);
    font-weight: 700;
  }

  .hero__eyebrow-text {
    color: var(--color-text-secondary);
  }

  .hero__year {
    margin-left: 1rem;
    color: var(--color-text-muted);
    font-weight: 400;
  }

  .hero__nav {
    display: flex;
    gap: 0;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(10px);
    animation: fadeIn 0.8s ease 0.3s both;
  }

  .hero__nav-link {
    display: block;
    padding: 0.75rem 1.25rem;
    font-family: var(--font-display);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-text-secondary);
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.25s ease;
  }

  .hero__nav-link:last-child {
    border-right: none;
  }

  .hero__nav-link:hover {
    color: var(--color-text-primary);
    background: rgba(255, 255, 255, 0.05);
  }

  .hero__nav-link--accent {
    color: var(--color-accent);
  }

  .hero__nav-link--accent:hover {
    color: var(--color-accent-hover);
    background: rgba(232, 98, 42, 0.1);
  }

  /* ── Bottom Section ── */
  .hero__bottom {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: flex-start;
    margin-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .hero__bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 0;
    }
  }

  .hero__title-block {
    max-width: 600px;
  }

  .hero__title {
    margin: 0 0 1rem;
    line-height: 0.9;
  }

  .hero__title-line {
    display: block;
    font-family: var(--font-display);
    font-weight: 900;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--color-text-primary);
  }

  .hero__title-line--1 {
    font-size: clamp(2.5rem, 8vw, 5rem);
    animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
  }

  .hero__title-line--2 {
    font-size: clamp(2rem, 6vw, 3.5rem);
    color: rgba(240, 237, 232, 0.8);
    animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero__tagline {
    font-size: clamp(0.875rem, 1.2vw, 1rem);
    font-weight: 400;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 400px;
    animation: fadeIn 0.8s ease 0.5s both;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── CTA ── */
  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-bg);
    background: var(--color-text-primary);
    text-decoration: none;
    padding: 1rem 1.75rem;
    border: 2px solid var(--color-text-primary);
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    animation: fadeIn 0.8s ease 0.6s both;
  }

  .hero__cta:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 rgba(255, 255, 255, 0.1);
  }

  .hero__cta:hover svg {
    transform: translateX(4px);
  }

  .hero__cta svg {
    transition: transform 0.25s ease;
  }

  /* ── Stats Bar ── */
  .hero__stats {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: stretch;
    background: rgba(8, 8, 8, 0.8);
    backdrop-filter: blur(20px);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0 clamp(1.5rem, 4vw, 4rem);
  }

  .hero__stat {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1.5rem clamp(1rem, 2.5vw, 2rem);
    border-right: 1px solid rgba(255, 255, 255, 0.05);
  }

  .hero__stat:last-child {
    border-right: none;
  }

  .hero__stat-num {
    display: flex;
    align-items: baseline;
    gap: 0.125rem;
    line-height: 1;
  }

  .hero__stat-value {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
  }

  .hero__stat-suffix {
    font-family: var(--font-display);
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .hero__stat-label {
    font-family: var(--font-display);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .hero__stat-divider {
    width: 1px;
    background: rgba(255, 255, 255, 0.1);
    flex-shrink: 0;
  }

  @media (max-width: 639px) {
    .hero__stat--hide,
    .hero__stat-divider--hide {
      display: none;
    }
  }

  /* ── Scroll Indicator ── */
  .hero__scroll-indicator {
    position: absolute;
    right: clamp(1.5rem, 4vw, 3rem);
    bottom: 120px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 10;
    animation: fadeIn 0.8s ease 1s both;
  }

  @media (max-width: 767px) {
    .hero__scroll-indicator {
      display: none;
    }
  }

  .hero__scroll-text {
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    writing-mode: vertical-rl;
    text-orientation: mixed;
    transform: rotate(180deg);
  }

  .hero__scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, var(--color-accent), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% {
      opacity: 0.3;
      transform: scaleY(0.8);
    }
    50% {
      opacity: 1;
      transform: scaleY(1);
    }
  }

  /* ── Responsive ── */
  @media (max-width: 767px) {
    .hero {
      min-height: 100svh;
    }

    .hero__nav {
      width: 100%;
      justify-content: center;
    }

    .hero__nav-link {
      flex: 1;
      text-align: center;
      padding: 0.75rem 0.5rem;
    }

    .hero__cta {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script>
  /* Video load handler */
  (function () {
    const video = document.querySelector('.hero__video');
    if (video) {
      video.addEventListener('loadeddata', function() {
        this.setAttribute('data-loaded', 'true');
      });
      // Fallback: if video fails, ensure content is still visible
      video.addEventListener('error', function() {
        console.warn('Hero video failed to load');
      });
    }
  })();

  /* Count-up on stats with IntersectionObserver */
  (function () {
    const stats = document.querySelectorAll('[data-count-target]');
    if (!stats.length || !('IntersectionObserver' in window)) {
      stats.forEach((el) => {
        const target = parseInt((el as HTMLElement).dataset.countTarget ?? '0', 10);
        el.textContent = String(target);
      });
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          const target = parseInt(el.dataset.countTarget ?? '0', 10);
          const duration = 1400;
          const start = performance.now();

          function step(now: number) {
            const progress = Math.min((now - start) / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            el.textContent = String(Math.round(eased * target));
            if (progress < 1) requestAnimationFrame(step);
          }

          requestAnimationFrame(step);
          observer.unobserve(el);
        });
      },
      { threshold: 0.4 }
    );

    stats.forEach((el) => observer.observe(el));
  })();
</script>

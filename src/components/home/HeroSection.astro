---
/**
 * HeroSection — Hero principal renovado
 * Diseño: Neo-brutalism limpio, Work Sans legible,
 *         elementos flotantes refinados, tipografía audaz
 */
import type { Event } from '@types';

interface Props {
  thisWeekEvents: Event[];
  locale: 'es' | 'en';
}

const { thisWeekEvents, locale } = Astro.props;

// Limit events for the hero
const heroEvents = thisWeekEvents.slice(0, 3);

// Función helper para formatear fecha
function formatHeroDate(dateStr: string) {
  const date = new Date(dateStr);
  return {
    day: date.getDate(),
    month: date.toLocaleDateString(locale, { month: 'short' })
  };
}
---

<section class="relative min-h-screen flex flex-col justify-center overflow-hidden pt-24 pb-20" aria-labelledby="hero-title">
  
  {/* Background gradient - Subtle depth */}
  <div class="absolute inset-0 bg-gradient-to-br from-base via-base to-base-elevated" aria-hidden="true"></div>
  
  {/* Animated gradient orbs - Refined positions */}
  <div class="absolute top-1/3 left-[10%] w-[500px] h-[500px] bg-terra/8 rounded-full blur-[120px] animate-float pointer-events-none" aria-hidden="true"></div>
  <div class="absolute bottom-1/4 right-[5%] w-[400px] h-[400px] bg-amber/8 rounded-full blur-[100px] animate-float-slow pointer-events-none" aria-hidden="true"></div>
  
  {/* Geometric decorative elements */}
  <div class="absolute top-[15%] right-[15%] w-24 h-24 border border-terra/15 rounded-2xl rotate-12 animate-float pointer-events-none" aria-hidden="true"></div>
  <div class="absolute bottom-[20%] left-[8%] w-16 h-16 border border-amber/15 rounded-full animate-float-slow pointer-events-none" aria-hidden="true"></div>
  <div class="absolute top-[60%] left-[5%] w-12 h-12 bg-terra/5 rounded-xl -rotate-6 animate-float-delayed pointer-events-none" aria-hidden="true"></div>
  <div class="absolute top-[20%] left-[20%] w-8 h-8 bg-amber/5 rounded-lg rotate-45 animate-float pointer-events-none" aria-hidden="true"></div>

  {/* Main content */}
  <div class="container relative z-10">
    <div class="max-w-5xl">
      
      {/* Eyebrow - Clean and minimal */}
      <div class="reveal mb-8">
        <div class="inline-flex items-center gap-3 px-4 py-2 bg-base-card border border-edge rounded-full">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-terra opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-terra"></span>
          </span>
          <span class="text-xs font-semibold uppercase tracking-[0.15em] text-surface-secondary">Guía Cultural Independiente</span>
          <span class="w-1 h-1 rounded-full bg-surface-disabled"></span>
          <span class="text-xs font-semibold uppercase tracking-[0.15em] text-terra">Granada 2026</span>
        </div>
      </div>

      {/* Main headline - BOLD new title */}
      <div class="reveal mb-8" style="transition-delay: 100ms;">
        <h1 id="hero-title" class="font-display font-bold text-surface leading-[0.9] tracking-[-0.04em]">
          <span class="block text-[clamp(3.5rem,11vw,9rem)]">
            Granada,
          </span>
          <span class="block text-[clamp(3.5rem,11vw,9rem)]">
            pero <em class="not-italic text-gradient-terra">de verdad</em>.
          </span>
        </h1>
      </div>

      {/* Subtitle - Clean Work Sans */}
      <div class="reveal max-w-2xl mb-10" style="transition-delay: 200ms;">
        <p class="text-lg md:text-xl text-surface-secondary leading-relaxed font-normal">
          Eventos que no salen en las guías. Rutas que solo conocen los locales. 
          <span class="text-surface font-medium">La Granada auténtica</span>, sin filtros ni colas de turistas.
        </p>
      </div>

      {/* CTA Buttons - Clean styling */}
      <div class="reveal flex flex-col sm:flex-row items-start gap-4 mb-16" style="transition-delay: 300ms;">
        <a 
          href="/eventos" 
          class="group relative inline-flex items-center gap-3 px-8 py-4 bg-terra text-surface font-semibold text-base rounded-2xl overflow-hidden transition-all duration-300 hover:shadow-xl hover:shadow-terra/30 hover:-translate-y-1"
        >
          <span class="relative z-10">Explorar eventos</span>
          <svg class="w-5 h-5 relative z-10 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
          <span class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700"></span>
        </a>
        
        <a 
          href="/rutas" 
          class="group inline-flex items-center gap-3 px-8 py-4 bg-base-card text-surface font-semibold text-base rounded-2xl border border-edge hover:border-amber/50 transition-all duration-300 hover:-translate-y-1"
        >
          <span>Ver rutas</span>
          <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1 group-hover:-translate-y-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
          </svg>
        </a>
      </div>

      {/* Stats row - Clean with Work Sans */}
      <div class="reveal" style="transition-delay: 400ms;">
        <div class="flex flex-wrap items-center gap-8 md:gap-12">
          <div class="flex items-center gap-4">
            <span class="font-display text-4xl md:text-5xl font-bold text-terra">800+</span>
            <span class="text-sm text-surface-muted font-medium leading-tight">años de<br/>historia</span>
          </div>
          <div class="hidden md:block w-px h-10 bg-edge"></div>
          <div class="flex items-center gap-4">
            <span class="font-display text-4xl md:text-5xl font-bold text-amber">2</span>
            <span class="text-sm text-surface-muted font-medium leading-tight">Patrimonios<br/>UNESCO</span>
          </div>
          <div class="hidden md:block w-px h-10 bg-edge"></div>
          <div class="flex items-center gap-4">
            <span class="font-display text-4xl md:text-5xl font-bold text-mint">0€</span>
            <span class="text-sm text-surface-muted font-medium leading-tight">tapa con<br/>cada bebida</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  {/* Bottom gradient fade */}
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-base to-transparent pointer-events-none" aria-hidden="true"></div>
  
  {/* Scroll indicator - Minimal */}
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 opacity-40">
    <div class="w-5 h-8 border border-surface-muted rounded-full flex justify-center pt-1.5">
      <div class="w-1 h-1.5 bg-terra rounded-full animate-bounce"></div>
    </div>
    <span class="text-[10px] uppercase tracking-[0.3em] text-surface-muted font-medium">Scroll</span>
  </div>
</section>

{/* Floating events bar - Only show if there are events */}
{heroEvents.length > 0 && (
  <div class="relative -mt-16 mb-20 z-20">
    <div class="container">
      <div class="reveal bg-base-card border border-edge rounded-3xl p-6 md:p-8 shadow-elevated">
        <div class="flex flex-col md:flex-row md:items-center gap-6 mb-6">
          <div class="flex items-center gap-3">
            <span class="relative flex h-2.5 w-2.5">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-terra opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-terra"></span>
            </span>
            <span class="text-xs font-semibold uppercase tracking-[0.15em] text-terra">Esta semana</span>
          </div>
          <div class="flex-1 h-px bg-edge hidden md:block"></div>
          <a href="/eventos" class="group inline-flex items-center gap-2 text-sm font-medium text-surface-secondary hover:text-terra transition-colors">
            Ver calendario completo
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {heroEvents.map((event, index) => (
            <a 
              href={`/eventos/${event.slug}`}
              class="group flex items-center gap-4 p-4 bg-base-elevated border border-edge rounded-2xl hover:border-terra/30 transition-all duration-300 hover:-translate-y-1"
            >
              <div class="flex-shrink-0 w-14 h-14 rounded-xl bg-base-card border border-edge flex flex-col items-center justify-center">
                <span class="text-lg font-display font-bold text-terra">{formatHeroDate(event.date).day}</span>
                <span class="text-[10px] uppercase tracking-wider text-surface-muted font-semibold">
                  {formatHeroDate(event.date).month}
                </span>
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="font-display font-semibold text-surface text-sm mb-1 truncate group-hover:text-terra transition-colors">
                  {event.title[locale]}
                </h3>
                <p class="text-xs text-surface-muted truncate">{event.venue}</p>
              </div>
              <svg class="w-5 h-5 text-surface-muted group-hover:text-terra transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
)}

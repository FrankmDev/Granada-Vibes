  }

  .title-char {
    display: inline-block;
    opacity: 0;
    transform: translateY(40px);
    animation: char-rise 1.5s cubic-bezier(0.16, 1, 0.3, 1) var(--delay) forwards;
  }

  /*
   * ENLARGED ALHAMBRA PORTAL
   */
  .portal-wrapper {
    position: absolute;
    top: max(36vh, 300px);

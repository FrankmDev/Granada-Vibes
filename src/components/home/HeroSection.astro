---
/**
 * HeroSection — Ultra Modern Granada Vibes
 * Bold typography, gradient mesh, floating elements, smooth animations
 */
import type { Event } from '@types';

interface Props {
  thisWeekEvents: Event[];
  locale: 'es' | 'en';
}

const { thisWeekEvents, locale } = Astro.props;

const heroEvents = thisWeekEvents.slice(0, 4);

function formatDate(dateStr: string) {
  const date = new Date(dateStr);
  return {
    day: date.getDate(),
    month: date.toLocaleDateString(locale, { month: 'short' })
  };
}

function getUrgency(dateStr: string) {
  const today = new Date();
  today.setHours(0, 0, 0, 0);
  const eventDate = new Date(dateStr);
  eventDate.setHours(0, 0, 0, 0);
  
  const diffDays = Math.ceil((eventDate.getTime() - today.getTime()) / (1000 * 60 * 60 * 24));
  
  if (diffDays <= 1) return { label: locale === 'es' ? 'HOY' : 'TODAY', class: 'urgent' };
  if (diffDays <= 3) return { label: locale === 'es' ? 'MAÑANA' : 'TOMORROW', class: 'soon' };
  if (diffDays <= 7) return { label: locale === 'es' ? 'ESTA SEMANA' : 'THIS WEEK', class: 'week' };
  return null;
}
---

<section class="relative min-h-screen flex flex-col overflow-hidden pt-20 pb-12" aria-labelledby="hero-title">
  
  <!-- Background - Gradient mesh + Pattern -->
  <div class="absolute inset-0 bg-gradient-to-br from-base via-base-100 to-base-200" aria-hidden="true"></div>
  <div class="absolute inset-0 bg-gradient-mesh opacity-80" aria-hidden="true"></div>
  <div class="absolute inset-0 pattern-dots opacity-50" aria-hidden="true"></div>
  
  <!-- Floating gradient orbs -->
  <div class="absolute top-0 right-0 w-[700px] h-[700px] bg-primary/5 rounded-full blur-[150px] pointer-events-none" aria-hidden="true"></div>
  <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-secondary/5 rounded-full blur-[120px] pointer-events-none" aria-hidden="true"></div>
  <div class="absolute top-1/3 left-1/4 w-[400px] h-[400px] bg-accent/3 rounded-full blur-[100px] pointer-events-none" aria-hidden="true"></div>

  <!-- Floating decorative shapes -->
  <div class="absolute top-32 left-[8%] w-3 h-3 bg-primary rounded-full float float-delay-1 opacity-60" aria-hidden="true"></div>
  <div class="absolute top-48 right-[12%] w-4 h-4 bg-secondary rounded-full float float-delay-2 opacity-50" aria-hidden="true"></div>
  <div class="absolute bottom-48 left-[15%] w-5 h-5 bg-accent rounded-full float float-delay-3 opacity-40" aria-hidden="true"></div>
  <div class="absolute top-1/2 right-[25%] w-2 h-2 bg-purple rounded-full float opacity-70" aria-hidden="true"></div>

  <div class="container relative z-10 flex-1 flex flex-col">
    
    <!-- Main Hero Content -->
    <div class="flex-1 flex items-center py-8 lg:py-12">
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-center w-full">
        
        <!-- Left: Text Content -->
        <div class="lg:col-span-6 lg:col-start-1">
          <div class="stagger-children">
            <!-- Eyebrow badge -->
            <div class="inline-flex items-center gap-2.5 px-4 py-2 bg-white/90 backdrop-blur-sm rounded-full shadow-soft-sm mb-8 border border-edge/50">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-60"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
              </span>
              <span class="text-xs font-semibold uppercase tracking-wider text-surface-secondary">
                {locale === 'es' ? 'Guía cultural de Granada' : 'Cultural guide of Granada'}
              </span>
            </div>
            
            <!-- H1 - Bold modern typography -->
            <h1 id="hero-title" class="mb-6">
              <span class="block font-display text-5xl md:text-6xl lg:text-7xl font-bold text-surface leading-[1.05] tracking-tight mb-2">
                {locale === 'es' ? 'Granada existe.' : 'Granada is real.'}
              </span>
              <span class="block font-display text-5xl md:text-6xl lg:text-7xl font-bold bg-gradient-to-r from-primary via-secondary to-accent bg-clip-text text-transparent leading-[1.05] tracking-tight">
                {locale === 'es' ? 'Vívela.' : 'Live it.'}
              </span>
            </h1>
            
            <!-- Description -->
            <p class="text-lg md:text-xl text-surface-secondary leading-relaxed max-w-lg mb-10 font-body">
              {locale === 'es' 
                ? 'Eventos culturales, rutas secretas y el mejor tapeo de España. La ciudad que las guías turísticas no te cuentan.'
                : 'Cultural events, secret routes, and the best tapas in Spain. The city tourist guides don\'t tell you about.'}
            </p>
            
            <!-- CTAs -->
            <div class="flex flex-wrap gap-4 mb-10">
              <a 
                href={locale === 'es' ? '/eventos' : '/en/events'}
                class="group inline-flex items-center gap-3 px-7 py-4 bg-primary text-white font-semibold text-base rounded-xl transition-all duration-200 hover:bg-primary-hover hover:shadow-glow-primary hover:-translate-y-1"
              >
                <span>{locale === 'es' ? 'Ver eventos' : 'View events'}</span>
                <svg class="w-5 h-5 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
              
              <a 
                href={locale === 'es' ? '/rutas' : '/en/routes'}
                class="group inline-flex items-center gap-3 px-7 py-4 bg-white text-surface font-semibold text-base rounded-xl border border-edge/50 shadow-soft-sm transition-all duration-200 hover:border-primary hover:text-primary hover:shadow-glow-primary hover:-translate-y-1"
              >
                <span>{locale === 'es' ? 'Ver rutas' : 'View routes'}</span>
                <svg class="w-5 h-5 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
                </svg>
              </a>
            </div>
            
            <!-- Stats -->
            <div class="flex items-center gap-6 md:gap-8">
              <div class="flex items-center gap-3">
                <span class="font-display text-3xl font-bold text-primary">+10</span>
                <span class="text-sm text-surface-muted font-medium">{locale === 'es' ? 'rutas' : 'routes'}</span>
              </div>
              <div class="w-px h-8 bg-edge"></div>
              <div class="flex items-center gap-3">
                <span class="font-display text-3xl font-bold text-secondary">+50</span>
                <span class="text-sm text-surface-muted font-medium">{locale === 'es' ? 'planes/mes' : 'plans/month'}</span>
              </div>
              <div class="w-px h-8 bg-edge"></div>
              <div class="flex items-center gap-3">
                <span class="font-display text-3xl font-bold text-accent">100%</span>
                <span class="text-sm text-surface-muted font-medium">{locale === 'es' ? 'local' : 'local'}</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Event Cards - Desktop -->
        <div class="hidden lg:block lg:col-span-5 lg:col-start-8">
          <div class="relative">
            <!-- Card container with glass effect -->
            <div class="bg-white/80 backdrop-blur-xl rounded-3xl border border-edge/50 shadow-soft-xl p-6">
              <!-- Header -->
              <div class="flex items-center justify-between mb-5">
                <div class="flex items-center gap-2">
                  <span class="w-2.5 h-2.5 bg-primary rounded-full animate-pulse"></span>
                  <span class="text-sm font-semibold text-surface uppercase tracking-wider">
                    {locale === 'es' ? 'Próximamente' : 'Coming up'}
                  </span>
                </div>
                <a href={locale === 'es' ? '/eventos' : '/en/events'} class="text-xs font-medium text-primary hover:underline">
                  {locale === 'es' ? 'Ver todos' : 'View all'} →
                </a>
              </div>
              
              <!-- Events list -->
              <div class="space-y-3">
                {heroEvents.map((event, i) => {
                  const urgency = getUrgency(event.date);
                  return (
                    <a 
                      href={`/${locale === 'es' ? 'eventos' : 'en/events'}/${event.slug}`}
                      class="group flex items-center gap-4 p-3 bg-base-50 rounded-2xl border border-edge/30 hover:border-primary/30 hover:shadow-soft transition-all duration-200 hover:-translate-x-1"
                      style={`animation-delay: ${i * 100}ms`}
                    >
                      <!-- Date -->
                      <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-gradient-to-br from-primary/10 to-secondary/10 flex flex-col items-center justify-center group-hover:from-primary/20 group-hover:to-secondary/20 transition-all duration-200">
                        <span class="text-base font-display font-bold text-primary leading-none">{formatDate(event.date).day}</span>
                        <span class="text-[9px] text-surface-muted uppercase font-medium">{formatDate(event.date).month}</span>
                      </div>
                      
                      <!-- Info -->
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 mb-0.5">
                          {urgency && (
                            <span class={`px-2 py-0.5 text-[9px] font-bold uppercase tracking-wider rounded-full ${
                              urgency.class === 'urgent' ? 'bg-primary text-white' 
                              : urgency.class === 'soon' ? 'bg-secondary/20 text-secondary'
                              : 'bg-base-200 text-surface-muted'
                            }`}>
                              {urgency.label}
                            </span>
                          )}
                        </div>
                        <h3 class="font-display text-sm font-medium text-surface truncate group-hover:text-primary transition-colors duration-200">
                          {event.title[locale]}
                        </h3>
                        <p class="text-xs text-surface-muted truncate">{event.venue}</p>
                      </div>
                      
                      <!-- Price -->
                      <div class="flex-shrink-0">
                        {event.price === 0 || event.price === null ? (
                          <span class="text-xs font-bold text-accent bg-accent/10 px-2 py-1 rounded-lg">GRATIS</span>
                        ) : (
                          <span class="text-xs font-semibold text-surface-secondary">{event.price}€</span>
                        )}
                      </div>
                    </a>
                  );
                })}
              </div>
            </div>
            
            <!-- Decorative elements -->
            <div class="absolute -top-3 -right-3 w-16 h-16 bg-secondary/20 rounded-full blur-xl" aria-hidden="true"></div>
            <div class="absolute -bottom-3 -left-3 w-12 h-12 bg-primary/20 rounded-full blur-xl" aria-hidden="true"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile: Horizontal scroll cards -->
    <div class="lg:hidden mt-6">
      <div class="flex items-center justify-center gap-2 mb-4 text-surface-muted">
        <svg class="w-4 h-4 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
        <span class="text-[10px] uppercase tracking-wider font-semibold">{locale === 'es' ? 'Desliza' : 'Swipe'}</span>
        <svg class="w-4 h-4 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </div>
      
      <div class="overflow-x-auto scrollbar-hide -mx-4 px-4">
        <div class="flex gap-3 pb-2">
          {heroEvents.map((event) => {
            const urgency = getUrgency(event.date);
            return (
              <a 
                href={`/${locale === 'es' ? 'eventos' : 'en/events'}/${event.slug}`}
                class="flex-shrink-0 w-72 p-4 bg-white/90 backdrop-blur-sm rounded-2xl border border-edge/50 shadow-soft-sm hover:border-primary/30 hover:shadow-glow-primary transition-all duration-200"
              >
                <div class="flex items-center gap-3 mb-3">
                  <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-primary/10 to-secondary/10 flex items-center justify-center flex-shrink-0">
                    <span class="text-sm font-display font-bold text-primary leading-none">{formatDate(event.date).day}</span>
                  </div>
                  <div class="flex-1 min-w-0">
                    {urgency && (
                      <span class={`px-2 py-0.5 text-[8px] font-bold uppercase tracking-wider rounded-full ${
                        urgency.class === 'urgent' ? 'bg-primary text-white' 
                        : urgency.class === 'soon' ? 'bg-secondary/20 text-secondary'
                        : 'bg-base-200 text-surface-muted'
                      }`}>
                        {urgency.label}
                      </span>
                    )}
                  </div>
                </div>
                <h3 class="font-display text-sm font-medium text-surface truncate mb-1">
                  {event.title[locale]}
                </h3>
                <p class="text-xs text-surface-muted truncate">
                  {event.venue}
                </p>
              </a>
            );
          })}
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="py-5 border-t border-edge/30 mt-auto">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="flex items-center gap-4 text-sm text-surface-muted">
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            </svg>
            {locale === 'es' ? 'Albaicín • Centro • Sacromonte' : 'Albaicín • Centro • Sacromonte'}
          </span>
        </div>
        
        <div class="flex items-center gap-5 text-sm">
          <a href={locale === 'es' ? '/eventos?cat=concierto' : '/en/events?cat=concert'} class="text-surface-secondary hover:text-primary font-medium transition-colors duration-200">
            {locale === 'es' ? 'Conciertos' : 'Concerts'}
          </a>
          <a href={locale === 'es' ? '/eventos?cat=exposicion' : '/en/events?cat=exhibition'} class="text-surface-secondary hover:text-primary font-medium transition-colors duration-200">
            {locale === 'es' ? 'Exposiciones' : 'Exhibitions'}
          </a>
          <a href={locale === 'es' ? '/eventos?cat=festival' : '/en/events?cat=festival'} class="text-surface-secondary hover:text-primary font-medium transition-colors duration-200">
            {locale === 'es' ? 'Festivales' : 'Festivals'}
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40">
    <div class="w-5 h-8 border-2 border-surface-muted/40 rounded-full flex justify-center pt-2">
      <div class="w-0.5 h-2 bg-primary rounded-full animate-bounce"></div>
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }
  
  .float {
    animation: float 5s ease-in-out infinite;
  }
  
  .float-delay-1 { animation-delay: 0s; }
  .float-delay-2 { animation-delay: 2s; }
  .float-delay-3 { animation-delay: 4s; }
  
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

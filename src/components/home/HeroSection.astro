---
/**
 * HeroSection — Orchestrator composing HeroBackground + HeroContent + HeroEventsList.
 * Contains section wrapper, scroll indicator, and client-side scripts.
 */
import type { Locale, Event } from '@types';
import { useTranslations } from '@i18n/utils';
import HeroBackground from './HeroBackground.astro';
import HeroContent from './HeroContent.astro';
import HeroEventsList from './HeroEventsList.astro';

interface Props {
  thisWeekEvents: Event[];
  locale: Locale;
}

const { thisWeekEvents, locale } = Astro.props;
const t = useTranslations(locale);
const heroEvents = thisWeekEvents.slice(0, 4);
---

<section class="hero-section" aria-labelledby="hero-heading">
  <HeroBackground />

  <div class="hero-section__content container">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
      <HeroContent locale={locale} />
      <div class="lg:col-span-5 relative z-30">
        <HeroEventsList events={heroEvents} locale={locale} />
      </div>
    </div>
  </div>

  <!-- Bottom scroll indicator -->
  <div class="hero-section__scroll" id="scroll-indicator">
    <span class="hero-section__scroll-text">{t('home.hero.scrollText')}</span>
    <div class="hero-section__scroll-bar">
      <div class="hero-section__scroll-bar-inner"></div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: 100vh;
    background: var(--color-bg);
    overflow: hidden;
  }

  .hero-section__content {
    position: relative;
    z-index: 20;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 6rem;
    padding-bottom: 5rem;
  }

  @media (min-width: 1024px) { .hero-section__content { padding-top: 7rem; } }

  .hero-section__scroll {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 50;
    opacity: 0;
    pointer-events: none;
    animation: hero-fade-in 0.8s ease-out 1.2s forwards;
  }

  .hero-section__scroll-text {
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: rgba(255, 255, 255, 0.3);
  }

  .hero-section__scroll-bar {
    width: 1px;
    height: 2.5rem;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0.3), transparent);
    position: relative;
    overflow: hidden;
  }

  .hero-section__scroll-bar-inner {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 50%;
    background: linear-gradient(to bottom, var(--color-accent), var(--color-secondary));
    animation: hero-scroll-line 2s ease-in-out infinite;
  }

  @keyframes hero-fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes hero-scroll-line {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(200%); }
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>

<script>
  // Reveal animations via IntersectionObserver
  (function() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const delay = entry.target.getAttribute('data-delay') || '0';
          setTimeout(() => {
            (entry.target as HTMLElement).style.opacity = '1';
            (entry.target as HTMLElement).style.transform = 'translateY(0)';
          }, parseInt(delay));
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

    document.querySelectorAll('.hero-reveal').forEach(el => {
      const htmlEl = el as HTMLElement;
      htmlEl.style.opacity = '0';
      htmlEl.style.transform = 'translateY(20px)';
      htmlEl.style.transition = 'opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1)';
      observer.observe(el);
    });
  })();

  // Parallax for hero background image + orbs (rAF-throttled scroll)
  (function() {
    const heroWrapper = document.getElementById('hero-image-wrapper');
    const orbs = document.querySelectorAll('.hero-bg__orb');
    let ticking = false;

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const y = window.scrollY;
          if (heroWrapper) heroWrapper.style.transform = `translateY(${y * 0.4}px) scale(1.1)`;
          orbs.forEach((orb) => {
            const speed = parseFloat(orb.getAttribute('data-speed') || '0.02');
            (orb as HTMLElement).style.transform = `translateY(${y * speed}px)`;
          });
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  })();

  // Cursor spotlight effect
  (function() {
    const section = document.querySelector('.hero-section') as HTMLElement | null;
    const spotlight = document.querySelector('.hero-spotlight') as HTMLElement | null;
    if (!section || !spotlight) return;

    setTimeout(() => { spotlight.style.opacity = '1'; }, 800);

    let mouseX = 50, mouseY = 50, currentX = 50, currentY = 50;

    section.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = section.getBoundingClientRect();
      mouseX = ((e.clientX - rect.left) / rect.width) * 100;
      mouseY = ((e.clientY - rect.top) / rect.height) * 100;
    });

    function animate() {
      currentX += (mouseX - currentX) * 0.08;
      currentY += (mouseY - currentY) * 0.08;
      section!.style.setProperty('--mouse-x', `${currentX}%`);
      section!.style.setProperty('--mouse-y', `${currentY}%`);
      requestAnimationFrame(animate);
    }
    animate();

    section.addEventListener('mouseleave', () => { spotlight.style.opacity = '0'; });
    section.addEventListener('mouseenter', () => { spotlight.style.opacity = '1'; });
  })();

  // Generate atmospheric particles
  (function() {
    const container = document.getElementById('particles-container');
    if (!container) return;

    for (let i = 0; i < 20; i++) {
      const p = document.createElement('div');
      const rand = Math.random();
      p.className = `hero-particle ${rand > 0.8 ? 'hero-particle--gold' : rand > 0.6 ? 'hero-particle--white' : ''}`;
      p.style.left = `${Math.random() * 100}%`;
      p.style.animationDelay = `${Math.random() * 15}s`;
      p.style.animationDuration = `${12 + Math.random() * 8}s`;
      container.appendChild(p);
    }
  })();

  // Hide scroll indicator on scroll
  (function() {
    const indicator = document.getElementById('scroll-indicator');
    if (!indicator) return;
    let hidden = false;

    window.addEventListener('scroll', () => {
      if (window.scrollY > 100 && !hidden) { indicator.style.opacity = '0'; hidden = true; }
      else if (window.scrollY <= 100 && hidden) { indicator.style.opacity = '1'; hidden = false; }
    }, { passive: true });
  })();
</script>

<!-- Particle styles (global scope for dynamically created elements) -->
<style is:global>
  .hero-particle {
    position: absolute;
    width: 2px;
    height: 2px;
    border-radius: 50%;
    pointer-events: none;
    background: radial-gradient(circle, color-mix(in srgb, var(--color-accent) 50%, transparent) 0%, transparent 70%);
    animation: hero-particle-float 15s linear infinite;
  }

  .hero-particle--gold {
    background: radial-gradient(circle, color-mix(in srgb, var(--color-gold) 40%, transparent) 0%, transparent 70%);
  }

  .hero-particle--white {
    background: radial-gradient(circle, rgba(255, 255, 255, 0.3) 0%, transparent 70%);
  }

  @keyframes hero-particle-float {
    0% { transform: translateY(100vh) translateX(0); opacity: 0; }
    10% { opacity: 0.5; }
    90% { opacity: 0.5; }
    100% { transform: translateY(-10vh) translateX(20px); opacity: 0; }
  }
</style>

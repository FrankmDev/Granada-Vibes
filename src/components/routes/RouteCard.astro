---
import type { Route, Locale } from '@types';
import RouteCardGrid from './RouteCardGrid.astro';
import RouteCardList from './RouteCardList.astro';

interface Props {
  route: Route;
  locale: Locale;
  t: (key: string, vars?: Record<string, string | number>) => string;
  index?: number;
  variant?: 'list' | 'grid';
}

const { route, locale, t, index = 0, variant = 'grid' } = Astro.props;
---

{variant === 'list' ? (
  <RouteCardList route={route} locale={locale} t={t} index={index} />
) : (
  <RouteCardGrid route={route} locale={locale} t={t} />
)}

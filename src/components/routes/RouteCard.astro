---
/**
 * RouteCard — Modern Teal Design
 * Distinct from EventCard with teal primary color and horizontal accents
 */
import type { Route, RouteDifficulty, Neighborhood } from '@types';
import { formatDuration, formatDistance } from '@utils/dates';

interface Props {
  route: Route;
  locale: 'es' | 'en';
  t: (key: string, vars?: Record<string, string | number>) => string;
  index?: number;
  variant?: 'list' | 'grid';
}

const { route, locale, t, index = 0, variant = 'list' } = Astro.props;
const href = locale === 'es' ? `/rutas/${route.slug}` : `/en/routes/${route.slug}`;

const difficultyConfig = (() => {
  switch (route.difficulty) {
    case 'easy':        return { bg: 'bg-emerald/10',   text: 'text-emerald',   bar: 'bg-emerald',   border: 'border-emerald/30',   dot: 'bg-emerald' };
    case 'moderate':    return { bg: 'bg-amber/10',     text: 'text-amber',     bar: 'bg-amber',     border: 'border-amber/30',     dot: 'bg-amber' };
    case 'challenging': return { bg: 'bg-rose/10',      text: 'text-rose',      bar: 'bg-rose',      border: 'border-rose/30',      dot: 'bg-rose' };
    default:            return { bg: 'bg-emerald/10',   text: 'text-emerald',   bar: 'bg-emerald',   border: 'border-emerald/30',   dot: 'bg-emerald' };
  }
})();

const difficultyLevel = route.difficulty === 'easy' ? 1 : route.difficulty === 'moderate' ? 2 : 3;

const bar1Class = 1 <= difficultyLevel ? difficultyConfig.bar : 'bg-base-200';
const bar2Class = 2 <= difficultyLevel ? difficultyConfig.bar : 'bg-base-200';
const bar3Class = 3 <= difficultyLevel ? difficultyConfig.bar : 'bg-base-200';

const timeIcons: Record<string, string> = {
  morning:   'M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707', // sun
  afternoon: 'M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707',
  sunset:    'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z',
  evening:   'M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z',
  any:       'M5 3l14 9-14 9V3z',
};
---

{variant === 'list' ? (
  <article class="group route-card-list">
    <a href={href} class="block">
      <div class:list={[
        'relative flex flex-col md:flex-row md:items-center gap-4 p-5 bg-white rounded-2xl border-2 border-transparent transition-all duration-300 hover:-translate-y-1 hover:shadow-soft-lg',
        'hover:border-primary/20'
      ]}>
        <!-- Accent bar -->
        <div class="absolute left-0 top-0 bottom-0 w-1 bg-gradient-to-b from-primary via-secondary to-primary/50 rounded-l-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        
        <!-- Index number -->
        <span class="hidden md:flex w-12 h-12 rounded-xl bg-gradient-to-br from-primary/10 to-secondary/10 items-center justify-center shrink-0 font-display text-xl font-bold text-primary/50">
          {String(index + 1).padStart(2, '0')}
        </span>
        
        <!-- Content -->
        <div class="flex-1 min-w-0">
          <!-- Meta row -->
          <div class="flex flex-wrap items-center gap-2 mb-2">
            <span class:list={['px-2.5 py-1 text-[9px] font-bold uppercase tracking-wider rounded-full border-2', difficultyConfig.bg, difficultyConfig.text, difficultyConfig.border]}>
              {t(`categories.${route.category}`)}
            </span>
            <span class="flex items-center gap-1 text-[10px] text-surface-muted">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {formatDuration(route.duration, locale)}
            </span>
            <span class="text-[10px] text-surface-muted">{formatDistance(route.distance, locale)}</span>
          </div>
          
          <!-- Title -->
          <h3 class="text-base font-display font-medium text-surface group-hover:text-primary transition-colors duration-200">
            {route.title[locale]}
          </h3>
        </div>
        
        <!-- Difficulty bars -->
        <div class="hidden md:flex items-center gap-2 px-4 py-2.5 bg-base-100 rounded-xl border border-edge/50">
          <span class="flex gap-1">
            <span class:list={['w-2 h-4 rounded-sm', bar1Class]}></span>
            <span class:list={['w-2 h-4 rounded-sm', bar2Class]}></span>
            <span class:list={['w-2 h-4 rounded-sm', bar3Class]}></span>
          </span>
        </div>
        
        <!-- Neighborhoods -->
        <div class="flex flex-wrap gap-1.5 md:justify-end">
          {route.neighborhoods.slice(0, 2).map((n: Neighborhood) => (
            <span class="px-2.5 py-1 text-[9px] text-surface-muted bg-base-100 rounded-full font-semibold border border-edge/50">
              {t(`neighborhoods.${n}`)}
            </span>
          ))}
        </div>
        
        <!-- Arrow -->
        <div class="hidden md:flex w-10 h-10 items-center justify-center rounded-xl bg-base-100 border-2 border-edge/50 group-hover:border-primary/30 group-hover:bg-primary/5 transition-all duration-200 shrink-0">
          <svg class="w-5 h-5 text-surface-muted group-hover:text-primary group-hover:translate-x-0.5 transition-all duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </div>
      </div>
    </a>
  </article>
) : (
  <article class="group route-card-grid">
    <a href={href} class="block h-full">
      <div class:list={[
        'relative h-full bg-white rounded-3xl overflow-hidden transition-all duration-500 ease-out',
        'border-2 border-transparent hover:border-secondary/20 hover:shadow-soft-xl hover:-translate-y-2',
        'route-card'
      ]}>
        <!-- Image with gradient overlay -->
        <div class="aspect-[16/10] bg-gradient-to-br from-base-200 to-base-300 relative overflow-hidden route-card-image">
          <!-- Decorative gradient -->
          <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-transparent to-secondary/10"></div>
          
          <!-- Top overlay for badges -->
          <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-transparent"></div>
          
          <!-- Decorative shapes -->
          <div class="absolute top-4 right-4 w-16 h-16 border-2 border-white/20 rounded-full transition-transform duration-500 group-hover:scale-110" aria-hidden="true"></div>
          <div class="absolute bottom-8 left-6 w-8 h-8 bg-secondary/20 rounded-full transition-all duration-500 group-hover:translate-x-2" aria-hidden="true"></div>
          
          <!-- Category badge -->
          <div class="absolute top-4 left-4 z-10">
            <span class:list={['px-3 py-1.5 text-[9px] font-bold uppercase tracking-wider rounded-full border-2 backdrop-blur-sm', difficultyConfig.bg, difficultyConfig.text, difficultyConfig.border]}>
              {t(`categories.${route.category}`)}
            </span>
          </div>
          
          <!-- Difficulty indicator (visual bars) -->
          <div class="absolute top-4 right-4 z-10">
            <div class="flex items-center gap-1.5 px-3 py-2 bg-white/90 backdrop-blur-sm rounded-full border-2 border-edge/50 shadow-soft">
              <span class="flex gap-0.5">
                <span class:list={['w-1.5 h-3 rounded-sm', bar1Class]}></span>
                <span class:list={['w-1.5 h-3 rounded-sm', bar2Class]}></span>
                <span class:list={['w-1.5 h-3 rounded-sm', bar3Class]}></span>
              </span>
            </div>
          </div>
          
          <!-- Time of day indicator -->
          <div class="absolute bottom-4 right-4 z-10">
            <span class="px-3 py-1.5 text-[10px] font-semibold bg-white/90 backdrop-blur-sm rounded-full border-2 border-edge/50 shadow-soft">
              <svg class="w-3 h-3 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {t(`timeOfDay.${route.timeOfDay}`)}
            </span>
          </div>
        </div>
        
        <!-- Content -->
        <div class="p-5">
          <!-- Meta info -->
          <div class="flex items-center gap-4 text-[11px] text-surface-muted mb-3">
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {formatDuration(route.duration, locale)}
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
              {formatDistance(route.distance, locale)}
            </span>
          </div>
          
          <!-- Title -->
          <h3 class="font-display text-lg font-medium text-surface mb-3 group-hover:text-primary transition-colors duration-200 line-clamp-2">
            {route.title[locale]}
          </h3>
          
          <!-- Description -->
          <p class="text-sm text-surface-muted line-clamp-2 mb-4 leading-relaxed">
            {route.description[locale]}
          </p>
          
          <!-- Neighborhoods and CTA -->
          <div class="flex items-center justify-between pt-3 border-t-2 border-edge/30">
            <div class="flex flex-wrap gap-1.5">
              {route.neighborhoods.slice(0, 2).map((n: Neighborhood) => (
                <span class="text-[10px] text-surface-muted bg-base-100 px-2 py-1 rounded-full font-semibold border border-edge/50">
                  {t(`neighborhoods.${n}`)}
                </span>
              ))}
            </div>
            
            <!-- Arrow -->
            <div class="w-8 h-8 rounded-full bg-base-100 flex items-center justify-center group-hover:bg-secondary group-hover:shadow-soft transition-all duration-300">
              <svg class="w-4 h-4 text-surface-muted group-hover:text-white group-hover:translate-x-0.5 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </div>
        </div>
      </div>
    </a>
  </article>
)}

---
import type { Route, RouteDifficulty } from '@types';
import { formatDuration, formatDistance } from '@utils/dates';

interface Props {
  route: Route;
  locale: 'es' | 'en';
  t: (key: string, vars?: Record<string, string | number>) => string;
  index?: number;
  variant?: 'list' | 'grid';
}

const { route, locale, t, index = 0, variant = 'list' } = Astro.props;
const href = locale === 'es' ? `/rutas/${route.slug}` : `/en/routes/${route.slug}`;

const difficultyColors: Record<RouteDifficulty, { bg: string; text: string; bar: string; border: string }> = {
  easy:        { bg: 'bg-mint/10',    text: 'text-mint',   bar: 'bg-mint',   border: 'border-mint/20' },
  moderate:    { bg: 'bg-amber/10',   text: 'text-amber',  bar: 'bg-amber',  border: 'border-amber/20' },
  challenging: { bg: 'bg-terra/10',   text: 'text-terra',  bar: 'bg-terra',  border: 'border-terra/20' },
};

const difficultyConfig = difficultyColors[route.difficulty];

const difficultyBars: Record<RouteDifficulty, number> = {
  easy:        1,
  moderate:    2,
  challenging: 3,
};

const bar1Class = 1 <= difficultyBars[route.difficulty] ? difficultyConfig.bar : 'bg-surface-disabled/30';
const bar2Class = 2 <= difficultyBars[route.difficulty] ? difficultyConfig.bar : 'bg-surface-disabled/30';
const bar3Class = 3 <= difficultyBars[route.difficulty] ? difficultyConfig.bar : 'bg-surface-disabled/30';
---

{variant === 'list' ? (
  <article class="group">
    <a href={href} class="block">
      <div class:list={[
        'relative flex flex-col md:flex-row md:items-center gap-4 p-4 bg-base-card/60 backdrop-blur-sm border border-edge rounded-xl transition-all duration-300 hover:-translate-y-0.5 hover:border-amber/20',
      ]}>
        {/* Index */}
        <span class="hidden md:block w-8 font-display text-2xl font-bold text-surface/[0.06] shrink-0 text-center">
          {String(index + 1).padStart(2, '0')}
        </span>
        
        {/* Content */}
        <div class="flex-1 min-w-0">
          {/* Meta */}
          <div class="flex flex-wrap items-center gap-2 mb-2">
            <span class:list={['px-2.5 py-1 text-[9px] font-bold uppercase tracking-wider rounded-full border', difficultyConfig.bg, difficultyConfig.text, difficultyConfig.border]}>
              {t(`categories.${route.category}`)}
            </span>
            <span class="flex items-center gap-1 text-[10px] text-surface-muted">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {formatDuration(route.duration, locale)}
            </span>
            <span class="text-[10px] text-surface-muted">{formatDistance(route.distance, locale)}</span>
          </div>
          
          {/* Title */}
          <h3 class="text-base font-display font-medium text-surface group-hover:text-amber transition-colors duration-200">
            {route.title[locale]}
          </h3>
        </div>
        
        {/* Difficulty bars */}
        <div class="hidden md:flex items-center gap-2">
          <span class="flex gap-0.5">
            <span class:list={['w-1.5 h-3 rounded-sm', bar1Class]}></span>
            <span class:list={['w-1.5 h-3 rounded-sm', bar2Class]}></span>
            <span class:list={['w-1.5 h-3 rounded-sm', bar3Class]}></span>
          </span>
        </div>
        
        {/* Neighborhoods */}
        <div class="flex flex-wrap gap-1.5 md:justify-end">
          {route.neighborhoods.slice(0, 2).map((n) => (
            <span class="px-2 py-1 text-[9px] text-surface-muted bg-base-elevated/50 rounded-full font-medium">
              {t(`neighborhoods.${n}`)}
            </span>
          ))}
        </div>
        
        {/* Arrow */}
        <div class="hidden md:flex w-8 h-8 items-center justify-center rounded-lg bg-base-elevated/50 border border-edge/50 group-hover:border-amber/20 group-hover:bg-amber/5 transition-all duration-200 shrink-0">
          <svg class="w-4 h-4 text-surface-muted group-hover:text-amber group-hover:translate-x-0.5 transition-all duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </div>
      </div>
    </a>
  </article>
) : (
  <article class="group">
    <a href={href} class="block h-full">
      <div class:list={[
        'relative h-full bg-base-card/60 backdrop-blur-sm border border-edge rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:border-amber/15 hover:shadow-[0_8px_30px_rgba(232,157,58,0.05)]',
      ]}>
        {/* Image */}
        <div class="aspect-[16/9] bg-base-elevated/50 relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-base-elevated to-base-card"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-base-card via-base-card/30 to-transparent"></div>
          <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/[0.02] to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000"></div>
          
          {/* Shapes */}
          <div class="absolute top-3 right-3 w-12 h-12 border border-white/[0.04] rounded-lg rotate-6" aria-hidden="true"></div>
          <div class="absolute bottom-6 left-3 w-6 h-6 bg-white/[0.02] rounded-full" aria-hidden="true"></div>
          
          {/* Category badge */}
          <div class="absolute top-3 left-3">
            <span class:list={['px-2.5 py-1 text-[9px] font-bold uppercase tracking-wider rounded-full border', difficultyConfig.bg, difficultyConfig.text, difficultyConfig.border]}>
              {t(`categories.${route.category}`)}
            </span>
          </div>
          
          {/* Difficulty */}
          <div class="absolute top-3 right-3">
            <div class="flex items-center gap-1 px-2 py-1.5 bg-base/60 backdrop-blur-sm rounded-full border border-white/[0.05]">
              <span class="flex gap-0.5">
                <span class:list={['w-1 h-1.5 rounded-sm', bar1Class]}></span>
                <span class:list={['w-1 h-1.5 rounded-sm', bar2Class]}></span>
                <span class:list={['w-1 h-1.5 rounded-sm', bar3Class]}></span>
              </span>
            </div>
          </div>
        </div>
        
        {/* Content */}
        <div class="p-4">
          {/* Meta */}
          <div class="flex items-center gap-2 text-[10px] text-surface-muted mb-2">
            <span class="flex items-center gap-1">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {formatDuration(route.duration, locale)}
            </span>
            <span class="w-0.5 h-0.5 rounded-full bg-surface-muted/30"></span>
            <span>{formatDistance(route.distance, locale)}</span>
          </div>
          
          {/* Title */}
          <h3 class="font-display text-base font-medium text-surface mb-2 group-hover:text-amber transition-colors duration-200 line-clamp-2">
            {route.title[locale]}
          </h3>
          
          {/* Neighborhoods */}
          <div class="flex flex-wrap gap-1.5 pt-2 border-t border-edge/50">
            {route.neighborhoods.slice(0, 2).map((n) => (
              <span class="text-[9px] text-surface-muted bg-base-elevated/50 px-2 py-1 rounded-full">
                {t(`neighborhoods.${n}`)}
              </span>
            ))}
          </div>
        </div>
      </div>
    </a>
  </article>
)}

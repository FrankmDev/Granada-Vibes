---
import OptimizedImage from '@components/ui/OptimizedImage.astro';
import ScreenFrame from '@components/ui/ScreenFrame.astro';
import type { MixedRoute, Locale } from '@types';
import { useTranslations } from '@i18n/utils';
import { getPlanDetailUrl } from '@utils/routes';

interface Props {
  locale: Locale;
  mixedRoutes: MixedRoute[];
  timePlansPath: string;
}

const { locale, mixedRoutes, timePlansPath } = Astro.props;
const t = useTranslations(locale);

const durationConfig: Record<string, { label: string; color: string; icon: string }> = {
  '2h': { label: 'Quick Tour', color: '#4a9e6b', icon: '◷' },
  '6h': { label: 'Half Day', color: '#d4873a', icon: '◐' },
  '12h': { label: 'Full Day', color: '#e8622a', icon: '◉' },
  '1day': { label: 'Adventure', color: '#c9a84c', icon: '◈' },
  '2days': { label: 'Weekend', color: '#6b5a9e', icon: '◆' },
  '3days': { label: 'Experience', color: '#c94a4a', icon: '✦' },
};

const planImages: Record<string, string> = {
  '2h': 'https://images.unsplash.com/photo-1523531294919-4bcd7c65e216?w=800&h=1000&fit=crop',
  '6h': 'https://images.unsplash.com/photo-1548013146-72479768bada?w=800&h=1000&fit=crop',
  '12h': 'https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=800&h=1000&fit=crop',
  '1day': 'https://images.unsplash.com/photo-1555396273-367ea4eb4db5?w=800&h=1000&fit=crop',
  '2days': 'https://images.unsplash.com/photo-1518105779142-d975f22f1b0a?w=800&h=1000&fit=crop',
  '3days': 'https://images.unsplash.com/photo-1504609813442-a8924e83f76e?w=800&h=1000&fit=crop',
};
---

<section class="rhythm-section" id="time-plans">
  <!-- Ambient Effects -->
  <div class="rhythm-grain" aria-hidden="true"></div>
  <div class="rhythm-gradient" aria-hidden="true"></div>
  
  <ScreenFrame
    tagTopLeft={t('mixedRoutes.frameTagTopLeft')}
    tagTopRight={t('mixedRoutes.frameTagTopRight')}
    tagBottomLeft={t('mixedRoutes.frameTagBottomLeft')}
    tagBottomRight="2025"
  />

  <div class="rhythm-container">
    <!-- Editorial Header -->
    <header class="rhythm-header">
      <div class="rhythm-eyebrow">
        <span class="eyebrow-line"></span>
        <span class="eyebrow-bracket">[</span>
        <span class="eyebrow-text">{t('routes.timePlansEyebrow')}</span>
        <span class="eyebrow-bracket">]</span>
        <span class="eyebrow-line"></span>
      </div>
      <h2 class="rhythm-title">
        <span class="title-line">
          {t('routes.timePlansTitle').split(' ')[0]?.split('').map((char, i) => (
            <span class="title-char title-char-muted" style={`--delay: ${i * 0.03}s`}>{char === ' ' ? '\u00A0' : char}</span>
          ))}
        </span>
        <span class="title-line">
          {t('routes.timePlansTitle').split(' ').slice(1).join(' ').split('').map((char, i) => (
            <span class="title-char title-char-accent" style={`--delay: ${0.2 + i * 0.03}s`}>{char === ' ' ? '\u00A0' : char}</span>
          ))}
        </span>
      </h2>
      <p class="rhythm-subtitle">{t('routes.timePlansSubtitle')}</p>
    </header>

    <!-- Cinematic Cards Grid -->
    <div class="rhythm-grid">
      {mixedRoutes.slice(0, 3).map((plan, idx) => {
        const href = getPlanDetailUrl(plan.slug, locale);
        const config = durationConfig[plan.duration] || { label: 'Quick Tour', color: '#4a9e6b', icon: '◷' };
        
        const totalStops = plan.days.reduce(
          (acc, day) => acc + day.blocks.reduce((bAcc, block) => bAcc + block.stops.length, 0),
          0
        );
        const totalHours = plan.totalHours || Math.floor(totalStops * 0.75);
        
        return (
          <article 
            class="rhythm-card animate-on-scroll"
            style={`--card-index: ${idx}; --accent-color: ${config.color}`}
          >
            <a href={href} class="card-link">
              {/* Visual Layer */}
              <div class="card-visual">
                <OptimizedImage
                  src={planImages[plan.duration] || planImages['2h']}
                  alt={plan.title[locale]}
                  class="visual-image"
                  loading={idx === 0 ? 'eager' : 'lazy'}
                  decoding="async"
                  sizes="(max-width: 640px) 100vw, 400px"
                />
                <div class="visual-overlay"></div>
                <div class="visual-vignette"></div>
                
                {/* Duration Badge */}
                <div class="duration-badge" style={`--badge-color: ${config.color}`}>
                  <span class="duration-icon">{config.icon}</span>
                  <span class="duration-text">{plan.duration}</span>
                </div>
                
                {/* Label */}
                <div class="type-label" style={`--label-color: ${config.color}`}>
                  {config.label}
                </div>
                
                {/* Corner Brackets */}
                <div class="corner-bracket tl"></div>
                <div class="corner-bracket tr"></div>
                <div class="corner-bracket bl"></div>
                <div class="corner-bracket br"></div>
              </div>

              {/* Content Layer */}
              <div class="card-body">
                <h3 class="card-headline">{plan.title[locale]}</h3>
                <p class="card-description">{plan.description[locale]}</p>
                
                {/* Meta Row */}
                <div class="card-meta">
                  <div class="meta-item">
                    <span class="meta-icon">◉</span>
                    <span class="meta-value">{totalStops}</span>
                    <span class="meta-label">{t('routes.stops')}</span>
                  </div>
                  <div class="meta-item">
                    <span class="meta-icon">◷</span>
                    <span class="meta-value">{totalHours}h</span>
                    <span class="meta-label">{t('mixedRoutes.totalHoursLabel')}</span>
                  </div>
                </div>
                
                {/* Neighborhoods */}
                <div class="card-neighborhoods">
                  {plan.neighborhoods.slice(0, 3).map((n: string) => (
                    <span class="nb-pill">{t(`neighborhoods.${n}`)}</span>
                  ))}
                </div>
                
                {/* CTA */}
                <div class="card-cta">
                  <span class="cta-text">{t('routes.explore')}</span>
                  <span class="cta-arrow">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </div>
              </div>
            </a>
          </article>
        );
      })}
    </div>
    
    <!-- View All Link -->
    <div class="rhythm-footer">
      <a href={timePlansPath} class="view-all-btn">
        <span class="btn-text">{t('actions.viewAll')}</span>
        <span class="btn-line"></span>
      </a>
    </div>
  </div>
</section>

---
/**
 * RouteDetailContent — route-specific CSS wrapper.
 * Shared layout CSS lives in DetailContent.astro (.det-* classes).
 * This component adds only route-specific styles.
 */
import DetailContent from '@components/shared/DetailContent.astro';
---
<DetailContent>
  <slot />
</DetailContent>

<style is:global>
  /* ── Route-specific styles ── */

  /* Metrics bar */
  .rut-metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    background: var(--s-border);
    margin-bottom: 0;
  }

  .rut-metric-cell {
    background: var(--s-bg-hi);
    padding: 1.5rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
  }

  .rut-metric-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(201,168,76,0.1);
    color: var(--s-gold);
    border-radius: 2px;
  }

  .rut-metric-icon svg { width: 18px; height: 18px; }

  .rut-metric-val {
    font-family: var(--font-body);
    font-size: clamp(1.1rem, 1.8vw, 1.4rem);
    font-weight: 400;
    color: var(--s-ink);
    letter-spacing: -0.01em;
  }

  .rut-metric-val.is-diff { font-weight: 600; color: var(--dc, var(--s-ink)); }

  .rut-metric-label {
    font-family: var(--font-display);
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--s-ink-3);
  }

  /* Difficulty bars */
  .rut-diff-bars { display: flex; gap: 3px; margin-top: 0.25rem; }

  .rut-diff-bar {
    width: 24px;
    height: 3px;
    background: var(--s-border);
    border-radius: 2px;
  }

  .rut-diff-bar.active { background: var(--dc, var(--s-ink)); }

  /* Neighborhood pills */
  .rut-neigh-flow { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.5rem; }

  .rut-neigh-pill {
    display: inline-flex;
    padding: 0.35rem 0.9rem;
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: rgba(201,168,76,0.1);
    border: 1px solid rgba(201,168,76,0.25);
    color: var(--s-gold);
    border-radius: 2px;
  }

  /* Timeline (highlights) */
  .rut-timeline {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
    padding-left: 2.5rem;
  }

  .rut-timeline::before {
    content: '';
    position: absolute;
    left: 0.75rem;
    top: 1rem;
    bottom: 1rem;
    width: 1px;
    background: linear-gradient(to bottom, var(--s-gold-dim), transparent);
  }

  .rut-tl-item {
    position: relative;
    padding: 1.25rem 0 1.25rem 1.25rem;
    border-bottom: 1px solid var(--s-border-s);
    opacity: 0;
    transform: translateX(-16px);
    transition: opacity 0.6s var(--ease-expo) calc(var(--ti, 0) * 0.1s),
                transform 0.6s var(--ease-expo) calc(var(--ti, 0) * 0.1s);
  }

  .det-block.is-visible .rut-tl-item { opacity: 1; transform: translateX(0); }
  .rut-tl-item:last-child { border-bottom: none; }

  .rut-tl-marker {
    position: absolute;
    left: -2rem;
    top: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .rut-tl-num {
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--s-orange);
    background: var(--s-bg);
    padding: 2px 0;
    line-height: 1;
  }

  .rut-tl-title {
    font-family: var(--font-display);
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--s-ink);
    margin-bottom: 0.4rem;
    line-height: 1.3;
  }

  .rut-tl-desc { font-family: var(--font-display); font-size: 0.88rem; line-height: 1.65; color: var(--s-ink-2); }

  /* Tips grid */
  .rut-tips-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2px; background: var(--s-border); }

  .rut-tip-card {
    background: var(--s-bg-hi);
    padding: 1.5rem;
    border-left: 2px solid var(--s-orange);
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s var(--ease-expo) calc(var(--tc, 0) * 0.08s),
                transform 0.5s var(--ease-expo) calc(var(--tc, 0) * 0.08s);
  }

  .det-block.is-visible .rut-tip-card { opacity: 1; transform: translateY(0); }

  .rut-tip-title { font-family: var(--font-display); font-size: 0.82rem; font-weight: 700; color: var(--s-ink); margin-bottom: 0.5rem; letter-spacing: 0.02em; }
  .rut-tip-text  { font-family: var(--font-display); font-size: 0.85rem; line-height: 1.65; color: var(--s-ink-2); }

  /* What to bring */
  .rut-bring-list { display: flex; flex-direction: column; gap: 0.75rem; list-style: none; padding: 0; margin: 0; }

  .rut-bring-item {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    font-family: var(--font-display);
    font-size: 0.95rem;
    color: var(--s-ink-2);
    line-height: 1.5;
  }

  .rut-bring-check { width: 18px; height: 18px; flex-shrink: 0; color: var(--s-gold); margin-top: 0.1rem; }
  .rut-bring-check svg { width: 18px; height: 18px; }

  /* Best months */
  .rut-months-flow { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.5rem; }

  .rut-month-tag {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--s-ink-2);
    padding: 0.25rem 0.6rem;
    background: var(--s-bg-hi);
    border: 1px solid var(--s-border);
    border-radius: 2px;
    text-transform: capitalize;
  }

  /* Sidebar difficulty bars */
  .rut-sb-diff { display: flex; align-items: center; gap: 0.75rem; justify-content: flex-end; }
  .rut-sb-bars { display: flex; gap: 3px; }

  .rut-sb-bar { width: 22px; height: 3px; background: var(--s-border); border-radius: 2px; }
  .rut-sb-bar.active { background: var(--dc, var(--s-ink)); }

  .rut-sb-diff-label { font-family: var(--font-display); font-size: 0.8rem; font-weight: 600; color: var(--dc, var(--s-ink)); }

  /* Share button */
  .rut-btn-share {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    width: 100%;
    padding: 0.875rem 1.5rem;
    background: transparent;
    color: var(--s-ink-2);
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: color 0.3s ease;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--s-border);
    border-left: none;
    border-right: none;
    border-bottom: none;
  }

  .rut-btn-share:hover { color: var(--s-ink); }
  .rut-btn-share svg { width: 16px; height: 16px; }

  /* Responsive */
  @media (max-width: 1024px) {
    .rut-metrics { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .rut-tips-grid { grid-template-columns: 1fr; }
    .rut-metrics   { grid-template-columns: repeat(2, 1fr); }
  }
</style>

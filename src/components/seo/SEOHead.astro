---
import { SITE_CONFIG, DEFAULT_OG_IMAGE } from '@config/site';
import { buildSeoTitle, clampMetaDescription } from '@utils/seo-text';
import { absoluteSiteUrl, getAlternateUrls, resolveOgImageUrl } from '@utils/seo';
import type { Locale } from '@types';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'article';
  canonical?: string;
  noindex?: boolean;
  path?: string;
  googleSiteVerification?: string;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleAuthor?: string;
  articleSection?: string;
  articleTags?: string[];
}

const { 
  locale, 
  title, 
  description,
  ogImage = DEFAULT_OG_IMAGE,
  ogImageAlt,
  ogType = 'website',
  canonical,
  noindex = false,
  path = '',
  googleSiteVerification,
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor,
  articleSection,
  articleTags,
} = Astro.props;

const siteUrl = SITE_CONFIG.url;
const currentPath = path || Astro.url.pathname;

const fullTitle = title
  ? buildSeoTitle(title, SITE_CONFIG.name)
  : `${SITE_CONFIG.name} - ${SITE_CONFIG.description[locale]}`;

const fullDescription = clampMetaDescription(description ?? SITE_CONFIG.description[locale]);
const fullCanonical = canonical ? absoluteSiteUrl(canonical) : absoluteSiteUrl(currentPath);
const fullOgImage = resolveOgImageUrl(ogImage);
const alternateUrls = getAlternateUrls(currentPath);
---

<!-- Primary Meta Tags -->
<title>{fullTitle}</title>
<meta name="description" content={fullDescription} />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
<meta name="googlebot" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="canonical" href={fullCanonical} />
{googleSiteVerification && (
  <meta name="google-site-verification" content={googleSiteVerification} />
)}

<!-- Hreflang -->
<link rel="alternate" hreflang="es" href={alternateUrls.es} />
<link rel="alternate" hreflang="en" href={alternateUrls.en} />
<link rel="alternate" hreflang="x-default" href={alternateUrls.es} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={SITE_CONFIG.name} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={fullDescription} />
<meta property="og:url" content={fullCanonical} />
<meta property="og:locale" content={locale === 'es' ? 'es_ES' : 'en_US'} />
<meta property="og:image" content={fullOgImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={ogImageAlt ?? fullTitle} />

{ogType === 'article' && articlePublishedTime && (
  <meta property="article:published_time" content={articlePublishedTime} />
)}
{ogType === 'article' && articleModifiedTime && (
  <meta property="article:modified_time" content={articleModifiedTime} />
)}
{ogType === 'article' && articleAuthor && (
  <meta property="article:author" content={articleAuthor} />
)}
{ogType === 'article' && articleSection && (
  <meta property="article:section" content={articleSection} />
)}
{ogType === 'article' && articleTags && articleTags.map((tag) => (
  <meta property="article:tag" content={tag} />
))}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:site" content="@granadaurban" />
<meta property="twitter:creator" content="@granadaurban" />
<meta property="twitter:url" content={fullCanonical} />
<meta property="twitter:title" content={fullTitle} />
<meta property="twitter:description" content={fullDescription} />
<meta property="twitter:image" content={fullOgImage} />

<!-- Additional SEO -->
<meta name="theme-color" content="#f5f0ea" />
<meta name="msapplication-TileColor" content="#f5f0ea" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content={SITE_CONFIG.name} />
<meta name="application-name" content={SITE_CONFIG.name} />
<meta name="format-detection" content="telephone=no" />

<!-- Icons -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="alternate icon" type="image/x-icon" href="/favicon.ico" />
<link rel="mask-icon" href="/favicon.svg" color="#c9a84c" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

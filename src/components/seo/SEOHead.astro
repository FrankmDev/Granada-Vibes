---
import { SITE_CONFIG, DEFAULT_OG_IMAGE } from '@config/site';
import type { Locale } from '@types';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  canonical?: string;
  noindex?: boolean;
  path?: string;
}

const { 
  locale, 
  title, 
  description,
  ogImage = DEFAULT_OG_IMAGE,
  ogType = 'website',
  canonical,
  noindex = false,
  path = '',
} = Astro.props;

const siteUrl = SITE_CONFIG.url;
const currentPath = path || Astro.url.pathname;

const fullTitle = title
  ? `${title} | ${SITE_CONFIG.name}`
  : `${SITE_CONFIG.name} - ${SITE_CONFIG.description[locale]}`;

const fullDescription = description ?? SITE_CONFIG.description[locale];
const fullCanonical = canonical ?? `${siteUrl}${currentPath}`;
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

// Path segment mapping between locales
const esToEnSegments: Record<string, string> = {
  'eventos': 'events',
  'rutas': 'routes',
  'blog': 'blog',
  'por-tiempo': 'by-time',
  'sobre': 'about',
  'privacidad': 'privacy',
  'aviso-legal': 'legal',
};
const enToEsSegments: Record<string, string> = Object.fromEntries(
  Object.entries(esToEnSegments).map(([k, v]) => [v, k])
);

function getEsPath(enPath: string): string {
  const withoutPrefix = enPath.replace(/^\/en/, '') || '/';
  return withoutPrefix.split('/').map(seg => enToEsSegments[seg] ?? seg).join('/');
}

function getEnPath(esPath: string): string {
  const translated = esPath.split('/').map(seg => esToEnSegments[seg] ?? seg).join('/');
  return `/en${translated === '/' ? '' : translated}` || '/en';
}

// Alternate URLs for hreflang
const isEnPath = currentPath.startsWith('/en');
const alternateUrls = {
  es: `${siteUrl}${isEnPath ? getEsPath(currentPath) : currentPath}`,
  en: `${siteUrl}${isEnPath ? currentPath : getEnPath(currentPath)}`,
};
---

<!-- Primary Meta Tags -->
<title>{fullTitle}</title>
<meta name="description" content={fullDescription} />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
<meta name="googlebot" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
<link rel="canonical" href={fullCanonical} />

<!-- Hreflang -->
<link rel="alternate" hreflang="es" href={alternateUrls.es} />
<link rel="alternate" hreflang="en" href={alternateUrls.en} />
<link rel="alternate" hreflang="x-default" href={alternateUrls.es} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={SITE_CONFIG.name} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={fullDescription} />
<meta property="og:url" content={fullCanonical} />
<meta property="og:locale" content={locale === 'es' ? 'es_ES' : 'en_US'} />
<meta property="og:image" content={fullOgImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={fullTitle} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={fullCanonical} />
<meta property="twitter:title" content={fullTitle} />
<meta property="twitter:description" content={fullDescription} />
<meta property="twitter:image" content={fullOgImage} />

<!-- Additional SEO -->
<meta name="theme-color" content="#FAF8F5" />
<meta name="msapplication-TileColor" content="#FAF8F5" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content={SITE_CONFIG.name} />
<meta name="application-name" content={SITE_CONFIG.name} />
<meta name="format-detection" content="telephone=no" />

<!-- Icons -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="alternate icon" type="image/x-icon" href="/favicon.ico" />
<link rel="mask-icon" href="/favicon.svg" color="#e07a5f" />
<link rel="apple-touch-icon" href="/favicon.svg" />

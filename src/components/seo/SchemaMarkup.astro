---
import { SITE_CONFIG } from '@config/site';
import type { Event, Route, BlogPost } from '@types';

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  type: 'website' | 'event' | 'route' | 'organization' | 'article';
  data?: Event | Route | BlogPost;
  locale: 'es' | 'en';
  path?: string;
  breadcrumb?: BreadcrumbItem[];
  faq?: FaqItem[];
}

const { type, data, locale, path = '', breadcrumb, faq } = Astro.props;

const siteUrl = SITE_CONFIG.url;

function resolveImageUrl(image: string | undefined): string {
  if (!image) return `${siteUrl}/og-default.jpg`;
  if (image.startsWith('http://') || image.startsWith('https://')) return image;
  return `${siteUrl}${image}`;
}

// Base organization schema
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE_CONFIG.name,
  description: SITE_CONFIG.description[locale],
  url: siteUrl,
  logo: `${siteUrl}/favicon.svg`,
  sameAs: [
    SITE_CONFIG.social.instagram,
    SITE_CONFIG.social.twitter,
    SITE_CONFIG.social.facebook,
  ].filter(Boolean),
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Granada',
    addressRegion: 'Andalucía',
    addressCountry: 'ES',
  },
};

// Website schema
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_CONFIG.name,
  description: SITE_CONFIG.description[locale],
  url: siteUrl,
  inLanguage: locale,
  publisher: {
    '@type': 'Organization',
    name: SITE_CONFIG.name,
  },
};

// BreadcrumbList schema
function buildBreadcrumbSchema(items: BreadcrumbItem[]) {
  return {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: items.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.name,
      item: item.url.startsWith('http') ? item.url : `${siteUrl}${item.url}`,
    })),
  };
}

// FAQPage schema
function buildFaqSchema(items: FaqItem[]) {
  return {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: items.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  };
}

// Generate schema based on type
let primarySchema = {};

switch (type) {
  case 'website':
    primarySchema = websiteSchema;
    break;

  case 'organization':
    primarySchema = organizationSchema;
    break;

  case 'event':
    if (data && 'date' in data) {
      const eventData = data as Event;
      primarySchema = {
        '@context': 'https://schema.org',
        '@type': 'Event',
        name: eventData.title[locale],
        description: eventData.description[locale],
        startDate: `${eventData.date}T${eventData.time}`,
        endDate: eventData.endDate ?? undefined,
        eventStatus: 'https://schema.org/EventScheduled',
        eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
        location: {
          '@type': 'Place',
          name: eventData.venue,
          address: {
            '@type': 'PostalAddress',
            addressLocality: 'Granada',
            addressRegion: 'Andalucía',
            addressCountry: 'ES',
          },
        },
        image: resolveImageUrl(eventData.image),
        url: `${siteUrl}${path}`,
        offers: eventData.price !== null ? {
          '@type': 'Offer',
          price: eventData.price,
          priceCurrency: eventData.currency,
          availability: 'https://schema.org/InStock',
          url: eventData.url || `${siteUrl}${path}`,
        } : {
          '@type': 'Offer',
          price: 0,
          priceCurrency: 'EUR',
          availability: 'https://schema.org/InStock',
        },
        organizer: {
          '@type': 'Organization',
          name: SITE_CONFIG.name,
          url: siteUrl,
        },
      };
    }
    break;

  case 'route':
    if (data && 'duration' in data) {
      const routeData = data as Route;
      primarySchema = {
        '@context': 'https://schema.org',
        '@type': 'TouristAttraction',
        name: routeData.title[locale],
        description: routeData.description[locale],
        image: resolveImageUrl(routeData.image),
        url: `${siteUrl}${path}`,
        touristType: [
          {
            '@type': 'Audience',
            audienceType: 'Cultural Tourists',
          },
          {
            '@type': 'Audience',
            audienceType: 'History Enthusiasts',
          },
        ],
        geo: {
          '@type': 'GeoCoordinates',
          latitude: 37.1773,
          longitude: -3.5986,
        },
        address: {
          '@type': 'PostalAddress',
            addressLocality: 'Granada',
            addressRegion: 'Andalucía',
            addressCountry: 'ES',
        },
        additionalProperty: [
          {
            '@type': 'PropertyValue',
            name: 'Duration',
            value: `${routeData.duration} minutes`,
          },
          {
            '@type': 'PropertyValue',
            name: 'Distance',
            value: `${routeData.distance} km`,
          },
          {
            '@type': 'PropertyValue',
            name: 'Difficulty',
            value: routeData.difficulty,
          },
        ],
      };
    }
    break;

  case 'article':
    if (data && 'publishDate' in data) {
      const postData = data as BlogPost;
      primarySchema = {
        '@context': 'https://schema.org',
        '@type': 'Article',
        headline: postData.title[locale],
        description: postData.description[locale],
        image: resolveImageUrl(postData.image),
        url: `${siteUrl}${path}`,
        datePublished: postData.publishDate,
        author: {
          '@type': 'Person',
          name: postData.author,
        },
        publisher: {
          '@type': 'Organization',
          name: SITE_CONFIG.name,
          url: siteUrl,
          logo: `${siteUrl}/favicon.svg`,
        },
        inLanguage: locale,
      };
    }
    break;
}

// Build final schema graph
const graph: unknown[] = [primarySchema];
if (breadcrumb && breadcrumb.length > 0) {
  graph.push(buildBreadcrumbSchema(breadcrumb));
}
if (faq && faq.length > 0) {
  graph.push(buildFaqSchema(faq));
}

const finalSchema = graph.length > 1
  ? { '@context': 'https://schema.org', '@graph': graph }
  : primarySchema;

const schemaString = JSON.stringify(finalSchema);
---

<script type="application/ld+json" set:html={schemaString} />

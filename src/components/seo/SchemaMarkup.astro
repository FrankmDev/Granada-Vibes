---
import { APPLE_TOUCH_ICON, SITE_CONFIG } from '@config/site';
import { resolveOgImageUrl } from '@utils/seo';
import { getPriceStatus } from '@utils/prices';
import type { Event, Route, BlogPost, MixedRoute } from '@types';
import type { VenueDirectoryEntry } from '@data/directories';

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  type: 'website' | 'event' | 'route' | 'timePlan' | 'article' | 'venue';
  data?: Event | Route | BlogPost | MixedRoute | VenueDirectoryEntry;
  locale: 'es' | 'en';
  path?: string;
  breadcrumb?: BreadcrumbItem[];
  faq?: FaqItem[];
}

const { type, data, locale, path = '', breadcrumb, faq } = Astro.props;

const siteUrl = SITE_CONFIG.url;
const madridDateFormatter = new Intl.DateTimeFormat('en-CA', {
  timeZone: 'Europe/Madrid',
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});

function resolveImageUrl(image: string | undefined): string | undefined {
  if (!image) return undefined;
  if (!image.startsWith('http://') && !image.startsWith('https://') && !image.startsWith('/')) {
    return undefined;
  }
  return resolveOgImageUrl(image);
}

function todayInMadrid(): string {
  return madridDateFormatter.format(new Date());
}

// Base organization schema
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${siteUrl}/#organization`,
  name: SITE_CONFIG.name,
  description: SITE_CONFIG.description[locale],
  url: siteUrl,
  logo: `${siteUrl}${APPLE_TOUCH_ICON}`,
  email: SITE_CONFIG.email,
  sameAs: [
    SITE_CONFIG.social.instagram,
    SITE_CONFIG.social.twitter,
    SITE_CONFIG.social.facebook,
  ].filter(Boolean),
  contactPoint: {
    '@type': 'ContactPoint',
    email: SITE_CONFIG.email,
    contactType: 'customer support',
    areaServed: 'ES',
    availableLanguage: ['es', 'en'],
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Granada',
    addressRegion: 'Andalucía',
    addressCountry: 'ES',
  },
  areaServed: {
    '@type': 'City',
    name: 'Granada',
    address: {
      '@type': 'PostalAddress',
      addressRegion: 'Andalucía',
      addressCountry: 'ES',
    },
  },
  knowsAbout: [
    'Granada events',
    'Granada cultural agenda',
    'Granada routes',
    'Alhambra',
    'Albaicín',
    'Sacromonte',
    'Granada tapas',
    'Flamenco in Granada',
  ],
};

// Website schema
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${siteUrl}/#website`,
  name: SITE_CONFIG.name,
  description: SITE_CONFIG.description[locale],
  url: siteUrl,
  inLanguage: locale,
  about: {
    '@type': 'City',
    name: 'Granada',
    address: {
      '@type': 'PostalAddress',
      addressRegion: 'Andalucía',
      addressCountry: 'ES',
    },
  },
  hasPart: [
    {
      '@type': 'DataFeed',
      name: 'Granada Urban Events Feed',
      encodingFormat: 'application/json',
      url: `${siteUrl}/ai/events.json`,
    },
    {
      '@type': 'DataFeed',
      name: 'Granada Urban Routes Feed',
      encodingFormat: 'application/json',
      url: `${siteUrl}/ai/routes.json`,
    },
    {
      '@type': 'DataFeed',
      name: 'Granada Urban Guides Feed',
      encodingFormat: 'application/json',
      url: `${siteUrl}/ai/guides.json`,
    },
  ],
  publisher: {
    '@type': 'Organization',
    '@id': `${siteUrl}/#organization`,
    name: SITE_CONFIG.name,
  },
};

// BreadcrumbList schema
function buildBreadcrumbSchema(items: BreadcrumbItem[]) {
  return {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: items.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.name,
      item: item.url.startsWith('http') ? item.url : `${siteUrl}${item.url}`,
    })),
  };
}

// FAQPage schema
function buildFaqSchema(items: FaqItem[]) {
  return {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: items.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  };
}

// Generate schema based on type
let primarySchema = {};

switch (type) {
  case 'website':
    primarySchema = websiteSchema;
    break;

  case 'event':
    if (data && 'date' in data) {
      const eventData = data as Event;
      const eventImages = [
        resolveImageUrl(eventData.remoteImageUrl),
        resolveImageUrl(eventData.image),
        resolveImageUrl(eventData.imageUrl),
      ].filter((img, i, arr) => img && arr.indexOf(img) === i);

      // Build a valid startDate (date-only when time is invalid)
      const isValidTime = /^\d{2}:\d{2}$/.test(eventData.time);
      const startDate = isValidTime ? `${eventData.date}T${eventData.time}` : eventData.date;

      // Fallback description when curated one is empty
      const rawDescription = eventData.description?.[locale]?.trim();
      const safeDescription = rawDescription && rawDescription.length > 0
        ? rawDescription
        : `${eventData.title[locale]} — ${eventData.venue}, ${eventData.date}. ${eventData.category} en Granada.`;

      // Determine performer
      let performerSchema: Record<string, unknown> | undefined;
      if (eventData.performer) {
        performerSchema = {
          '@type': 'PerformingGroup',
          name: eventData.performer[locale],
        };
      } else if (eventData.category === 'concert' || eventData.category === 'theater') {
        // For concerts, the title is usually the artist / show name
        performerSchema = {
          '@type': eventData.category === 'concert' ? 'MusicGroup' : 'PerformingGroup',
          name: eventData.title[locale],
        };
      }

      // Build offer object (always include url + validFrom to satisfy GSC)
      const offerUrl = eventData.url || eventData.ticketsUrl || eventData.sourceUrl || `${siteUrl}${path}`;
      const priceStatus = getPriceStatus(eventData);
      const offerBase = {
        '@type': 'Offer' as const,
        url: offerUrl,
        validFrom: eventData.date,
        availability: 'https://schema.org/InStock',
      };
      const offerSchema = priceStatus === 'paid'
        ? { ...offerBase, price: eventData.price, priceCurrency: eventData.currency }
        : priceStatus === 'free'
          ? { ...offerBase, price: 0, priceCurrency: 'EUR' }
          : { ...offerBase, priceCurrency: 'EUR' };

      // Normalize endDate to match startDate format (datetime when startDate is datetime)
      const rawEndDate = eventData.endDate || eventData.date;
      const endDate = isValidTime && /^\d{4}-\d{2}-\d{2}$/.test(rawEndDate)
        ? `${rawEndDate}T${eventData.time}`
        : rawEndDate;
      const eventStatus = /^\d{4}-\d{2}-\d{2}$/.test(rawEndDate) && rawEndDate < todayInMadrid()
        ? 'https://schema.org/EventCompleted'
        : 'https://schema.org/EventScheduled';

      const schemaParts: Record<string, unknown> = {
        '@context': 'https://schema.org',
        '@type': 'Event',
        name: eventData.title[locale],
        description: safeDescription,
        startDate,
        endDate,
        eventStatus,
        eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
        location: {
          '@type': 'Place',
          name: eventData.venue,
          address: {
            '@type': 'PostalAddress',
            streetAddress: eventData.address,
            addressLocality: 'Granada',
            addressRegion: 'Andalucía',
            addressCountry: 'ES',
          },
        },
        image: eventImages.length > 1 ? eventImages : eventImages[0],
        url: `${siteUrl}${path}`,
        isAccessibleForFree: priceStatus === 'free',
        offers: offerSchema,
        organizer: {
          '@type': 'Organization',
          name: SITE_CONFIG.name,
          url: siteUrl,
          logo: `${siteUrl}${APPLE_TOUCH_ICON}`,
        },
        about: {
          '@type': 'Thing',
          name: eventData.category,
        },
      };

      if (performerSchema) {
        schemaParts.performer = performerSchema;
      }

      if (eventData.tags && eventData.tags.length > 0) {
        schemaParts.keywords = eventData.tags.join(', ');
      }

      primarySchema = schemaParts;
    }
    break;

  case 'route':
    if (data && 'duration' in data) {
      const routeData = data as Route;
      const routeImages = [resolveImageUrl(routeData.image)].filter(Boolean);
      const routeProps: Record<string, unknown>[] = [
        {
          '@type': 'PropertyValue',
          name: 'Duration',
          value: `${routeData.duration} minutes`,
        },
        {
          '@type': 'PropertyValue',
          name: 'Distance',
          value: `${routeData.distance} km`,
        },
        {
          '@type': 'PropertyValue',
          name: 'Difficulty',
          value: routeData.difficulty,
        },
        {
          '@type': 'PropertyValue',
          name: 'Best time of day',
          value: routeData.timeOfDay,
        },
        {
          '@type': 'PropertyValue',
          name: 'Category',
          value: routeData.category,
        },
      ];
      if (routeData.bestTimeToVisit) {
        routeProps.push({
          '@type': 'PropertyValue',
          name: 'Best time to visit',
          value: routeData.bestTimeToVisit[locale],
        });
      }
      if (routeData.startingPoint) {
        routeProps.push({
          '@type': 'PropertyValue',
          name: 'Starting point',
          value: routeData.startingPoint[locale],
        });
      }
      if (routeData.accessibility) {
        routeProps.push({
          '@type': 'PropertyValue',
          name: 'Accessibility',
          value: routeData.accessibility[locale],
        });
      }
      primarySchema = {
        '@context': 'https://schema.org',
        '@type': 'TouristAttraction',
        name: routeData.title[locale],
        description: routeData.description[locale],
        image: routeImages.length > 0 ? routeImages : undefined,
        url: `${siteUrl}${path}`,
        isAccessibleForFree: true,
        touristType: [
          {
            '@type': 'Audience',
            audienceType: 'Cultural Tourists',
          },
          {
            '@type': 'Audience',
            audienceType: 'History Enthusiasts',
          },
        ],
        geo: {
          '@type': 'GeoCoordinates',
          latitude: 37.1773,
          longitude: -3.5986,
        },
        address: {
          '@type': 'PostalAddress',
          addressLocality: 'Granada',
          addressRegion: 'Andalucía',
          addressCountry: 'ES',
        },
        additionalProperty: routeProps,
        hasMap: 'https://www.google.com/maps/search/?api=1&query=Granada,+Spain',
      };
    }
    break;

  case 'timePlan':
    if (data && 'days' in data) {
      const planData = data as import('@types').MixedRoute;
      const planImages = [resolveImageUrl(planData.image)].filter(Boolean);
      const itemListElements: unknown[] = [];
      planData.days.forEach((day) => {
        day.blocks.forEach((block) => {
          block.stops.forEach((stop) => {
            itemListElements.push({
              '@type': 'ListItem',
              position: itemListElements.length + 1,
              item: {
                '@type': 'TouristAttraction',
                name: stop.name[locale],
                description: stop.description[locale],
                additionalProperty: [
                  { '@type': 'PropertyValue', name: 'Category', value: stop.category },
                  { '@type': 'PropertyValue', name: 'Duration', value: `${stop.duration} minutes` },
                ],
              },
            });
          });
        });
      });
      primarySchema = {
        '@context': 'https://schema.org',
        '@type': 'TouristAttraction',
        name: planData.title[locale],
        description: planData.description[locale],
        image: planImages.length > 0 ? planImages : undefined,
        url: `${siteUrl}${path}`,
        isAccessibleForFree: true,
        touristType: [
          {
            '@type': 'Audience',
            audienceType: 'Cultural Tourists',
          },
          {
            '@type': 'Audience',
            audienceType: 'History Enthusiasts',
          },
        ],
        geo: {
          '@type': 'GeoCoordinates',
          latitude: 37.1773,
          longitude: -3.5986,
        },
        address: {
          '@type': 'PostalAddress',
          addressLocality: 'Granada',
          addressRegion: 'Andalucía',
          addressCountry: 'ES',
        },
        additionalProperty: [
          {
            '@type': 'PropertyValue',
            name: 'Duration',
            value: planData.duration,
          },
          {
            '@type': 'PropertyValue',
            name: 'Neighborhoods',
            value: planData.neighborhoods.join(', '),
          },
        ],
        hasMap: 'https://www.google.com/maps/search/?api=1&query=Granada,+Spain',
      };
      if (itemListElements.length > 0) {
        (primarySchema as Record<string, unknown>).itinerary = {
          '@type': 'ItemList',
          itemListElement: itemListElements,
        };
      }
    }
    break;

  case 'article':
    if (data && 'publishDate' in data) {
      const postData = data as BlogPost;
      const postImages = [resolveImageUrl(postData.image)].filter(Boolean);
      const articleText = postData.content[locale].replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
      const articleWordCount = articleText ? articleText.split(' ').length : Math.round(postData.readingTime * 200);
      primarySchema = {
        '@context': 'https://schema.org',
        '@type': 'Article',
        headline: postData.title[locale],
        description: postData.description[locale],
        image: postImages.length > 0 ? postImages : undefined,
        url: `${siteUrl}${path}`,
        mainEntityOfPage: {
          '@type': 'WebPage',
          '@id': `${siteUrl}${path}`,
        },
        datePublished: postData.publishDate,
        dateModified: postData.publishDate,
        articleSection: postData.category,
        wordCount: articleWordCount,
        keywords: postData.tags.join(', '),
        publisher: {
          '@type': 'Organization',
          name: SITE_CONFIG.name,
          url: siteUrl,
          logo: `${siteUrl}${APPLE_TOUCH_ICON}`,
        },
        inLanguage: locale,
      };
    }
    break;

  case 'venue':
    if (data && 'upcomingEvents' in data && 'name' in data) {
      const venueData = data as VenueDirectoryEntry;
      primarySchema = {
        '@context': 'https://schema.org',
        '@type': 'Place',
        '@id': `${siteUrl}${path}#place`,
        name: venueData.name,
        description: venueData.description[locale],
        url: `${siteUrl}${path}`,
        address: {
          '@type': 'PostalAddress',
          addressLocality: 'Granada',
          addressRegion: 'Andalucía',
          addressCountry: 'ES',
        },
        containedInPlace: {
          '@type': 'City',
          name: 'Granada',
        },
        subjectOf: {
          '@type': 'ItemList',
          name: locale === 'en' ? `Upcoming events at ${venueData.name}` : `Próximos eventos en ${venueData.name}`,
          itemListElement: venueData.upcomingEvents.slice(0, 8).map((event, index) => ({
            '@type': 'ListItem',
            position: index + 1,
            item: {
              '@type': 'Event',
              name: event.title[locale],
              startDate: event.date,
              url: `${siteUrl}${locale === 'en' ? '/en/events/' : '/eventos/'}${event.slug}/`,
            },
          })),
        },
      };
    }
    break;
}

// Build final schema graph
const graph: unknown[] = type === 'website'
  ? [organizationSchema, primarySchema]
  : [primarySchema];
if (breadcrumb && breadcrumb.length > 0) {
  graph.push(buildBreadcrumbSchema(breadcrumb));
}
if (faq && faq.length > 0) {
  graph.push(buildFaqSchema(faq));
}

const finalSchema = graph.length > 1
  ? { '@context': 'https://schema.org', '@graph': graph }
  : primarySchema;

const schemaString = JSON.stringify(finalSchema);
---

<script type="application/ld+json" set:html={schemaString} />

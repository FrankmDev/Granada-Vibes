---
import BaseLayout from '@layouts/BaseLayout.astro';
import NavBar from '@components/layout/NavBar.astro';
import Footer from '@components/layout/Footer.astro';
import VenueMap from '@components/ui/VenueMap.astro';
import EventImage from '@components/ui/EventImage.astro';
import EventDetailHero from '@components/events/EventDetailHero.astro';
import ShareButton from '@components/ui/ShareButton.astro';
import ButtonCTA from '@components/ui/ButtonCTA.astro';
import InstagramIcon from '@components/icons/InstagramIcon.astro';
import WhatsAppIcon from '@components/icons/WhatsAppIcon.astro';
import { getDirectoryHref, getIndexableEvents } from '@data/index.js';
import { getVenueCoordinates } from '@data/venues/coordinates.js';
import { useTranslations } from '@i18n/utils';
import { getEventDetailUrl, getRoute } from '@utils/routes';
import { formatFullDate, formatTime } from '@utils/dates';
import { getNeighborhoodLink } from '@utils/cross-links';
import RelatedGuides from '@components/related/RelatedGuides.astro';
import RelatedEvents from '@components/related/RelatedEvents.astro';
import RelatedRoutes from '@components/related/RelatedRoutes.astro';
import RelatedVenues from '@components/related/RelatedVenues.astro';
import ContinueExploring from '@components/related/ContinueExploring.astro';
import CollaborateCTA from '@components/shared/CollaborateCTA.astro';
import {
  getRelatedEventsForEvent,
  getRelatedGuidesForEvent,
  getRelatedRoutesForEvent,
  getRelatedVenuesForEvent,
} from '@utils/related-content';
import {
  formatPriceLabel,
  getEventDisplayTitle,
  getEventSeoDescription,
  getEventSeoTitle,
  getPriceStatus,
  isPastEvent,
  isNearDuplicateOf,
  shouldIndexEventDetail,
} from '@utils';
import type { Event, Locale } from '@types';
import '@styles/pages/event-detail.css';

interface Props {
  locale: Locale;
  event: Event;
}

const { locale, event } = Astro.props;
const t = useTranslations(locale);
const isEnglish = locale === 'en';

function normalizeLocalizedSeoText(value: string | undefined): string {
  return (value ?? '')
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/\s+/g, ' ')
    .trim();
}

function hasDistinctEnglishEventCopy(currentEvent: Event): boolean {
  const comparisons = [
    [currentEvent.title.es, currentEvent.title.en],
    [currentEvent.description.es, currentEvent.description.en],
    [currentEvent.longDescription?.es, currentEvent.longDescription?.en],
    [currentEvent.tips?.es, currentEvent.tips?.en],
  ];

  return comparisons.some(([spanishCopy, englishCopy]) => {
    const spanish = normalizeLocalizedSeoText(spanishCopy);
    const english = normalizeLocalizedSeoText(englishCopy);
    return english.length > 0 && english !== spanish;
  });
}

const categoryUrl = `${getRoute('events', locale)}#archive`;
const byTimeLink = {
  url: getRoute('byTime', locale),
  title: t('nav.byTime'),
  meta: t('mixedRoutes.heroSubtitle'),
  image: null,
};
const plannerLink = {
  url: getRoute('planner', locale),
  title: t('nav.planner'),
  meta: t('planner.heroDescription'),
  image: null,
};

const copy = isEnglish
  ? {
      priceText:
        getPriceStatus(event) === 'paid'
          ? `From ${event.price}€.`
          : getPriceStatus(event) === 'free'
            ? 'Free entry.'
            : 'Check price.',
      breadcrumb: {
        home: 'Home',
        listing: 'Events',
      },
      sections: {
        aboutEyebrow: '[ About the event ]',
        aboutTitle: 'About the Event',
        locationEyebrow: '[ Location ]',
        locationTitle: 'Where',
        experienceEyebrow: '[ Experience ]',
        experienceTitle: 'What to expect',
        tipsEyebrow: '[ Practical tips ]',
        tipsTitle: 'Good to know',
        tags: '[ Tags ]',
      },
      faq: {
        tipsQuestion: `What should I know before going to ${event.title[locale]}?`,
        dateQuestion: `When is ${event.title[locale]} in Granada?`,
        dateAnswer: `${event.title[locale]} is scheduled for ${formatFullDate(event.date, locale)} at ${formatTime(event.time, locale)}.`,
        priceQuestion: 'How much are the tickets?',
        priceFree: 'Entry is free.',
        pricePaid: `Tickets are ${event.price}€.`,
        priceUnknown: 'Please check the official event website for pricing information.',
        venueQuestion: 'Where is the event held?',
        venueAnswer: `The event is held at ${event.venue}, located in the ${t(`neighborhoods.${event.neighborhood}`)} neighborhood in Granada.`,
        ticketsQuestion: `Where can I get tickets for ${event.title[locale]}?`,
        ticketsAnswer: event.ticketsUrl || event.sourceUrl
          ? `Use the official ticket or event source linked from this page and confirm the latest price before buying.`
          : `No official ticket link is available yet on GRN URBAN. Check the event source and confirm price and access conditions before going.`,
        nearbyQuestion: `What can I do near ${event.venue}?`,
        nearbyAnswer: `Check related routes, guides and other upcoming events linked from this page to build a plan before or after the event.`,
      },
      status: {
        past: 'This event has already taken place. Use this page as a reference and browse related upcoming events in Granada.',
      },
      share: {
        label: 'Share',
        copied: 'Copied!',
        intro: 'Send this listing to whoever is planning time in Granada.',
        whatsappLabel: 'WhatsApp',
        whatsappAria: 'Share this event on WhatsApp',
        instagramLabel: 'Instagram',
        instagramAria: 'Copy link to share on Instagram',
        facebookLabel: 'Facebook',
        facebookAria: 'Share this event on Facebook',
      },
      seoSuffix: 'Discover all the details on GRN URBAN.',
      nav: {
        prev: 'Previous event',
        next: 'Next event',
      },
    }
  : {
      priceText:
        getPriceStatus(event) === 'paid'
          ? `Desde ${event.price}€.`
          : getPriceStatus(event) === 'free'
            ? 'Entrada libre.'
            : 'Consultar precio.',
      breadcrumb: {
        home: 'Inicio',
        listing: 'Eventos',
      },
      sections: {
        aboutEyebrow: '[ Sobre el evento ]',
        aboutTitle: 'Sobre el Evento',
        locationEyebrow: '[ Ubicación ]',
        locationTitle: 'Dónde',
        experienceEyebrow: '[ Experiencia ]',
        experienceTitle: 'Qué esperar',
        tipsEyebrow: '[ Recomendación ]',
        tipsTitle: 'Consejos prácticos',
        tags: '[ Etiquetas ]',
      },
      faq: {
        tipsQuestion: `¿Qué debo saber antes de ir a ${event.title[locale]}?`,
        dateQuestion: `¿Cuándo es ${event.title[locale]} en Granada?`,
        dateAnswer: `${event.title[locale]} está programado para el ${formatFullDate(event.date, locale)} a las ${formatTime(event.time, locale)}.`,
        priceQuestion: '¿Cuál es el precio de la entrada?',
        priceFree: 'La entrada es gratuita.',
        pricePaid: `El precio es de ${event.price}€.`,
        priceUnknown: 'Consulta la web oficial del evento para información sobre precios.',
        venueQuestion: '¿Dónde se celebra el evento?',
        venueAnswer: `El evento se celebra en ${event.venue}, situado en el barrio de ${t(`neighborhoods.${event.neighborhood}`)} en Granada.`,
        ticketsQuestion: `¿Dónde comprar entradas para ${event.title[locale]}?`,
        ticketsAnswer: event.ticketsUrl || event.sourceUrl
          ? `Usa el enlace oficial de entradas o fuente del evento que aparece en esta página y confirma el precio actualizado antes de comprar.`
          : `GRN URBAN todavía no tiene enlace oficial de entradas para este evento. Consulta la fuente del evento y confirma precio y condiciones de acceso antes de ir.`,
        nearbyQuestion: `¿Qué hacer cerca de ${event.venue}?`,
        nearbyAnswer: `Revisa las rutas, guías y próximos eventos relacionados enlazados en esta página para montar un plan antes o después del evento.`,
      },
      status: {
        past: 'Este evento ya se celebró. Usa esta ficha como referencia y consulta otros próximos eventos relacionados en Granada.',
      },
      share: {
        label: 'Compartir',
        copied: '¡Copiado!',
        intro: 'Envía esta ficha a quien esté organizando un plan por Granada.',
        whatsappLabel: 'WhatsApp',
        whatsappAria: 'Compartir este evento por WhatsApp',
        instagramLabel: 'Instagram',
        instagramAria: 'Copiar enlace para compartir en Instagram',
        facebookLabel: 'Facebook',
        facebookAria: 'Compartir este evento en Facebook',
      },
      seoSuffix: 'Descubre todos los detalles en GRN URBAN.',
      nav: {
        prev: 'Evento anterior',
        next: 'Evento siguiente',
      },
    };

const venueCoords = getVenueCoordinates(event.venue, event.neighborhood);
const allEvents = getIndexableEvents().sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());
const eventIndex = allEvents.findIndex((e) => e.id === event.id);
const prevEvent = eventIndex > 0 ? allEvents[eventIndex - 1] : null;
const nextEvent = eventIndex < allEvents.length - 1 ? allEvents[eventIndex + 1] : null;
const today = new Date();
today.setHours(0, 0, 0, 0);

const neighborhoodLink = getNeighborhoodLink(event.neighborhood, locale);
const hasPassed = isPastEvent(event);
const displayTitle = getEventDisplayTitle(event, locale);

const eventImage = event.remoteImageUrl || event.imageUrl || event.image;
const ogImage = eventImage || 'https://upload.wikimedia.org/wikipedia/commons/0/0a/Granada_-_Teatro_Isabel_la_Cat%C3%B3lica_8.jpg';
const priceLabel = formatPriceLabel(event, t);
const seoTitle = getEventSeoTitle(event, locale);
const seoDescription = getEventSeoDescription(event, locale, t);
const shouldIndexEvent = shouldIndexEventDetail(event);
const needsEnglishGeneratedCopy = isEnglish && !hasDistinctEnglishEventCopy(event);
const englishPriceContext = getPriceStatus(event) === 'free'
  ? 'free entry'
  : getPriceStatus(event) === 'paid'
    ? `tickets from ${priceLabel}`
    : 'price details to confirm';
const localizedDescription = event.description[locale]?.trim();
const eventDescription = needsEnglishGeneratedCopy
  ? `${event.title.en} is scheduled in Granada on ${formatFullDate(event.date, locale)} at ${formatTime(event.time, locale)}. The event takes place at ${event.venue}, in the ${t(`neighborhoods.${event.neighborhood}`)} area, with ${englishPriceContext}. This page brings together the practical details, venue context and related plans so you can decide if it fits your time in the city.`
  : localizedDescription || seoDescription;
const eventLongDescription = needsEnglishGeneratedCopy
  ? [
      `Use this listing as the working plan for ${event.title.en}: check the date, time, venue and ticket context first, then use the related routes and guides on this page to build something useful before or after the event.`,
      `For visitors, the important thing is not only the event itself but how it sits inside the day. GRN URBAN keeps this page connected to nearby plans, cultural routes and current events so the listing is useful beyond a single title and address.`,
    ]
  : event.longDescription?.[locale]?.split('\n\n') ?? [];

// Prevent rendering a first long-description paragraph that near-duplicates the lead
const filteredLongDescription: string[] = eventLongDescription.filter((p, i) => {
  if (!p) return false;
  if (i === 0 && isNearDuplicateOf(p, eventDescription)) return false;
  return true;
});

const breadcrumb = [
  { name: copy.breadcrumb.home, url: getRoute('home', locale) },
  { name: copy.breadcrumb.listing, url: getRoute('events', locale) },
  { name: event.title[locale], url: getEventDetailUrl(event.slug, locale) },
];

const faq = [];

if (event.tips?.[locale]) {
  faq.push({
    question: copy.faq.tipsQuestion,
    answer: event.tips[locale],
  });
}

faq.push({
  question: copy.faq.dateQuestion,
  answer: copy.faq.dateAnswer,
});

faq.push({
  question: copy.faq.priceQuestion,
  answer:
    event.price !== null
      ? event.price === 0
        ? copy.faq.priceFree
        : copy.faq.pricePaid
      : copy.faq.priceUnknown,
});

if (event.venue) {
  faq.push({
    question: copy.faq.venueQuestion,
    answer: copy.faq.venueAnswer,
  });
}

faq.push({
  question: copy.faq.ticketsQuestion,
  answer: copy.faq.ticketsAnswer,
});

faq.push({
  question: copy.faq.nearbyQuestion,
  answer: copy.faq.nearbyAnswer,
});

// Key facts for sidebar — date, time, price, neighborhood only
const eventFacts: Array<{ label: string; value: string }> = [
  { label: t('detail.date'), value: formatFullDate(event.date, locale) },
  { label: t('detail.time'), value: formatTime(event.time, locale) },
  { label: t('detail.price'), value: priceLabel },
  { label: t('detail.zones'), value: t(`neighborhoods.${event.neighborhood}`) },
];

const relatedVenuesList = getRelatedVenuesForEvent(event, 2);
const relatedEventsList = getRelatedEventsForEvent(event, 3);
const relatedRoutesList = getRelatedRoutesForEvent(event, 3);
const relatedGuidesList = getRelatedGuidesForEvent(event, 3);
const hasRelatedContent =
  relatedVenuesList.length > 0 ||
  relatedEventsList.length > 0 ||
  relatedRoutesList.length > 0 ||
  relatedGuidesList.length > 0;

const shareUrl = Astro.url.href;
const encodedShareUrl = encodeURIComponent(shareUrl);
const encodedShareText = encodeURIComponent(`${displayTitle} · GRN URBAN`);
---

<BaseLayout
  locale={locale}
  title={seoTitle}
  description={seoDescription}
  ogImage={ogImage}
  noindex={!shouldIndexEvent}
  ogType="article"
  schemaType="event"
  schemaData={event}
  breadcrumb={breadcrumb}
  faq={faq.length > 0 ? faq : undefined}
>
  <NavBar slot="header" locale={locale} currentPath={Astro.url.pathname} />

  <EventDetailHero event={event} locale={locale} />

  <div class="det-page">
    <div class="det-content-wrap">
      <div class="upgraded-layout">
        <main id="main-content" class="upgraded-main">
          <article class="upg-block event-article-card" id="event-content" data-reveal>
            <!-- 01 — Description -->
            <section class="event-entry-section event-entry-section--intro" id="event-intro">
              <header class="upg-header">
                <span class="upg-num">01</span>
                <div class="upg-line"></div>
                <span class="upg-eyebrow">{copy.sections.aboutEyebrow}</span>
              </header>
              <h2 class="upg-title">{copy.sections.aboutTitle}</h2>

              <div class="upg-body content-rich">
                <p class="upg-lead">{eventDescription}</p>
                {filteredLongDescription.length > 0 && (
                  <div class="upg-long-desc">
                    {filteredLongDescription.map((paragraph) => (
                      <p>{paragraph}</p>
                    ))}
                  </div>
                )}
              </div>

              <div class="upg-meta-links">
                <a href={categoryUrl} class="upg-badge ghost">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
                  {t(`categories.${event.category}`)}
                </a>
                <a href={byTimeLink.url} class="upg-badge ghost">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  {byTimeLink.title}
                </a>
                <a href={plannerLink.url} class="upg-badge ghost">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6h11M9 12h11M9 18h11M5 6h.01M5 12h.01M5 18h.01"/></svg>
                  {plannerLink.title}
                </a>
                {neighborhoodLink && (
                  <a href={neighborhoodLink.url} class="upg-badge ghost">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    {neighborhoodLink.label}
                  </a>
                )}
              </div>

              {hasPassed && (
                <div class="upg-past-notice">
                  <strong>{copy.status.past}</strong>
                  <a href={getRoute('events', locale)}>{t('detail.allEvents')}</a>
                </div>
              )}
            </section>

            <!-- 02 — Location -->
            <section class="event-entry-section" id="event-location">
              <header class="upg-header">
                <span class="upg-num">02</span>
                <div class="upg-line"></div>
                <span class="upg-eyebrow">{copy.sections.locationEyebrow}</span>
              </header>
              <h2 class="upg-title">{copy.sections.locationTitle}</h2>

              <div class="upg-venue-block">
                <div class="upg-venue-grid">
                  <div class="upg-venue-info">
                    <h3 class="upg-venue-title">{event.venue}</h3>
                    <address class="upg-venue-badges">
                      <span class="upg-badge">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        {t(`neighborhoods.${event.neighborhood}`)}
                      </span>
                      {event.address && (
                        <span class="upg-badge ghost">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                          {event.address}
                        </span>
                      )}
                    </address>
                    {event.venueDescription && (
                      <p class="upg-venue-desc">{event.venueDescription[locale]}</p>
                    )}
                  </div>

                  <div class="upg-venue-map-wrapper">
                    <div class="upg-map-glass-overlay"></div>
                    {venueCoords ? (
                      <VenueMap lat={venueCoords.lat} lng={venueCoords.lng} venueName={event.venue} theme="light" locale={locale} />
                    ) : (
                      <div class="upg-map-placeholder">
                        <span>{t('detail.mapComingSoon')}</span>
                      </div>
                    )}
                  </div>
                </div>
              </div>
            </section>

            <!-- 03 — Experience / Highlights -->
            {event.highlights?.[locale] && event.highlights[locale].length > 0 && (
              <section class="event-entry-section" id="event-experience">
                <header class="upg-header">
                  <span class="upg-num">03</span>
                  <div class="upg-line"></div>
                  <span class="upg-eyebrow">{copy.sections.experienceEyebrow}</span>
                </header>
                <h2 class="upg-title">{copy.sections.experienceTitle}</h2>

                <div class="upg-highlights">
                  {event.highlights[locale].map((item, index) => (
                    <div class="upg-hl-item" style={`--hl-delay: ${index * 0.1}s`}>
                      <div class="upg-hl-num-wrap">
                        <span class="upg-hl-num">{(index + 1).toString().padStart(2, '0')}</span>
                      </div>
                      <p class="upg-hl-text">{item}</p>
                    </div>
                  ))}
                </div>
              </section>
            )}

            <!-- 04 — Tips -->
            {event.tips?.[locale] && (
              <section class="event-entry-section block-tips" id="event-tips">
                <header class="upg-header">
                  <span class="upg-num">04</span>
                  <div class="upg-line"></div>
                  <span class="upg-eyebrow">{copy.sections.tipsEyebrow}</span>
                </header>
                <h2 class="upg-title">{copy.sections.tipsTitle}</h2>

                <div class="upg-tips-content">
                  <div class="upg-tips-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  </div>
                  <p class="upg-tips-text">{event.tips[locale]}</p>
                </div>
              </section>
            )}

            <!-- 05 — Tags -->
            {event.tags.length > 0 && (
              <section class="event-entry-section" id="event-tags">
                <div class="upg-tags">
                  <span class="upg-tags-title">{copy.sections.tags}</span>
                  <div class="upg-tags-list">
                    {event.tags.map((tag) => (
                      <span class="upg-tag">#{tag}</span>
                    ))}
                  </div>
                </div>
              </section>
            )}
          </article>

          <!-- Prev/Next event navigation -->
          {(prevEvent || nextEvent) && (
            <nav class="upg-block upg-nav-block" data-reveal aria-label={isEnglish ? 'Event navigation' : 'Navegación de eventos'}>
              <div class="upg-nav-flex">
                {prevEvent ? (
                  <a href={getEventDetailUrl(prevEvent.slug, locale)} class="upg-nav-link">
                    <span class="upg-nav-arrow" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M15 18l-6-6 6-6"></path>
                      </svg>
                    </span>
                    <span class="upg-nav-copy">
                      <span class="upg-nav-label">{copy.nav.prev}</span>
                      <span class="upg-nav-title">{getEventDisplayTitle(prevEvent, locale)}</span>
                      <time class="upg-nav-meta" datetime={`${prevEvent.date}T${prevEvent.time}`}>{formatFullDate(prevEvent.date, locale)}</time>
                    </span>
                  </a>
                ) : <span />}
                {nextEvent ? (
                  <a href={getEventDetailUrl(nextEvent.slug, locale)} class="upg-nav-link upg-nav-link--end">
                    <span class="upg-nav-copy">
                      <span class="upg-nav-label">{copy.nav.next}</span>
                      <span class="upg-nav-title">{getEventDisplayTitle(nextEvent, locale)}</span>
                      <time class="upg-nav-meta" datetime={`${nextEvent.date}T${nextEvent.time}`}>{formatFullDate(nextEvent.date, locale)}</time>
                    </span>
                    <span class="upg-nav-arrow" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 18l6-6-6-6"></path>
                      </svg>
                    </span>
                  </a>
                ) : <span />}
              </div>
            </nav>
          )}
        </main>

        <aside class="upg-sidebar" aria-label={isEnglish ? 'Event details sidebar' : 'Barra lateral de detalles del evento'}>
          <div class="upg-sidebar-sticky">
            <!-- 01 — Key facts -->
            <section class="event-side-card event-keyfacts-card" aria-labelledby="event-keyfacts-title" data-reveal>
              <header class="event-side-head event-side-head--plain">
                <h2 id="event-keyfacts-title" class="event-side-title">{t('detail.keyFacts')}</h2>
                <span class="event-side-rule" aria-hidden="true"></span>
              </header>

              <dl class="event-facts-grid">
                {eventFacts.map((fact) => (
                  <div class="event-fact">
                    <dt>{fact.label}</dt>
                    <dd>{fact.value}</dd>
                  </div>
                ))}
              </dl>

              {event.ticketsUrl && (
                <ButtonCTA
                  href={event.ticketsUrl}
                  variant="primary"
                  size="md"
                  fullWidth
                  target="_blank"
                  rel="noopener noreferrer"
                  data-track="click_ticket"
                  class="upg-tickets-btn"
                >
                  {t('detail.getTickets')}
                </ButtonCTA>
              )}
            </section>

            <!-- 02 — Share (ticket-shaped) -->
            <section class="event-side-card event-share-card" data-reveal aria-labelledby="event-share-title">
              <div class="event-share-card-top">
                <header class="event-side-head event-side-head--plain">
                  <h2 id="event-share-title" class="event-side-title event-side-title--light">{copy.share.label}</h2>
                  <span class="event-side-rule event-side-rule--gold" aria-hidden="true"></span>
                </header>
                <p class="event-share-intro">{copy.share.intro}</p>
                <span class="event-share-stamp">{priceLabel}</span>
              </div>

              <div class="event-share-card-divider" aria-hidden="true">
                <span class="ticket-notch ticket-notch--left"></span>
                <span class="ticket-dashed"></span>
                <span class="ticket-notch ticket-notch--right"></span>
              </div>

              <div class="event-share-card-bottom">
                <ShareButton
                  title={event.title[locale]}
                  url={shareUrl}
                  label={copy.share.label}
                  copiedLabel={copy.share.copied}
                  variant="primary"
                  fullWidth
                  class="event-share-btn"
                />

                <div class="event-share-channels" aria-label={copy.share.label}>
                  <a
                    class="event-share-channel event-share-channel--whatsapp"
                    href={`https://wa.me/?text=${encodedShareText}%20${encodedShareUrl}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={copy.share.whatsappAria}
                    title={copy.share.whatsappAria}
                  >
                    <span class="event-share-icon" aria-hidden="true">
                      <WhatsAppIcon />
                    </span>
                    <span class="event-share-label">{copy.share.whatsappLabel}</span>
                  </a>
                  <button
                    type="button"
                    class="event-share-channel event-share-channel--instagram"
                    data-share-copy
                    data-share-url={shareUrl}
                    data-share-method="instagram"
                    aria-label={copy.share.instagramAria}
                    title={copy.share.instagramAria}
                  >
                    <span class="event-share-icon" aria-hidden="true">
                      <InstagramIcon />
                    </span>
                    <span class="event-share-label">{copy.share.instagramLabel}</span>
                  </button>
                  <a
                    class="event-share-channel event-share-channel--facebook"
                    href={`https://www.facebook.com/sharer/sharer.php?u=${encodedShareUrl}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={copy.share.facebookAria}
                    title={copy.share.facebookAria}
                  >
                    <span class="event-share-icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M22 12.06C22 6.48 17.52 2 11.94 2S2 6.48 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.91h2.54V9.84c0-2.52 1.5-3.91 3.8-3.91 1.1 0 2.25.2 2.25.2v2.47h-1.27c-1.25 0-1.64.78-1.64 1.57v1.89h2.8l-.45 2.91h-2.35V22A10 10 0 0 0 22 12.06Z"/>
                      </svg>
                    </span>
                    <span class="event-share-label">{copy.share.facebookLabel}</span>
                  </a>
                </div>
              </div>

              <span class="event-share-panel-bracket event-share-panel-bracket--tl" aria-hidden="true"></span>
              <span class="event-share-panel-bracket event-share-panel-bracket--tr" aria-hidden="true"></span>
              <span class="event-share-panel-bracket event-share-panel-bracket--bl" aria-hidden="true"></span>
              <span class="event-share-panel-bracket event-share-panel-bracket--br" aria-hidden="true"></span>
            </section>
          </div>
        </aside>
      </div>

      {hasRelatedContent && (
        <section class="event-related-full upg-block upg-block--loose" id="event-related" data-reveal>
          <div class="upg-block-bg"></div>
          <header class="upg-header event-related-header">
            <span class="upg-num">05</span>
            <div class="upg-line"></div>
            <span class="upg-eyebrow">[ {t('detail.completePlan')} ]</span>
          </header>
          <div class="upg-related-stack">
            <RelatedVenues type="event" event={event} locale={locale} title={t('detail.relatedVenues')} limit={2} />
            <RelatedEvents type="event" event={event} locale={locale} title={t('detail.relatedEvents')} limit={3} />
            <RelatedRoutes type="event" event={event} locale={locale} title={t('detail.relatedRoutes')} limit={3} />
            <RelatedGuides type="event" event={event} locale={locale} title={t('detail.relatedGuides')} limit={3} />
          </div>
        </section>
      )}
    </div>

    <div style="padding: 0 clamp(1.25rem, 4vw, 4rem);">
      <CollaborateCTA locale={locale} variant="event" />
    </div>

    <ContinueExploring locale={locale} />

    <div class="det-footer-orn" aria-hidden="true">
      <span class="det-orn-line"></span>
      <span class="det-orn-star" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17.2l-6.2 4.1 2.4-7.4L2 9.4h7.6z"/></svg></span>
      <span class="det-orn-line"></span>
    </div>
  </div>

  <Footer slot="footer" locale={locale} />
</BaseLayout>

<script is:inline>
  (function () {
    if (window.__eventShareCopyInitialized) return;
    window.__eventShareCopyInitialized = true;

    document.addEventListener('click', async function (event) {
      const button = event.target.closest('[data-share-copy]');
      if (!button) return;

      const url = button.dataset.shareUrl ?? window.location.href;
      const method = button.dataset.shareMethod ?? 'copy';

      try {
        await navigator.clipboard.writeText(url);
        button.classList.add('is-copied');
        window.setTimeout(function () {
          button.classList.remove('is-copied');
        }, 1600);

        if (typeof window.grnTrackEvent === 'function') {
          window.grnTrackEvent('share', {
            method,
            content_id: window.location.pathname,
          });
        }
      } catch (_) {}
    });
  })();
</script>

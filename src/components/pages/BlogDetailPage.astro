---
import BaseLayout from '@layouts/BaseLayout.astro';
import NavBar from '@components/layout/NavBar.astro';
import Footer from '@components/layout/Footer.astro';
import BlogDetailHero from '@components/blog/BlogDetailHero.astro';
import InstagramIcon from '@components/icons/InstagramIcon.astro';
import WhatsAppIcon from '@components/icons/WhatsAppIcon.astro';
import ShareButton from '@components/ui/ShareButton.astro';
import ReadingProgress from '@components/ui/ReadingProgress.astro';
import { useTranslations } from '@i18n/utils';
import { getBlogDetailUrl, getRoute } from '@utils/routes';
import RelatedGuides from '@components/related/RelatedGuides.astro';
import RelatedEvents from '@components/related/RelatedEvents.astro';
import RelatedRoutes from '@components/related/RelatedRoutes.astro';
import RelatedVenues from '@components/related/RelatedVenues.astro';
import ContinueExploring from '@components/related/ContinueExploring.astro';
import { clampMetaDescription } from '@utils/seo-text';
import { getBlogDisplayTitle, getBlogSeoDescription } from '@utils/content-seo';
import { editorialMediaByBlogSlug } from '@data/editorial-media';
import {
  getRelatedEventsForPost,
  getRelatedGuidesForPost,
  getRelatedRoutesForPost,
  getRelatedVenuesForPost,
} from '@utils/related-content';
import type { BlogPost, Locale } from '@types';
import '@styles/pages/blog-detail.css';

interface Props {
  locale: Locale;
  post: BlogPost;
}

interface TocItem {
  text: string;
  id: string;
}

interface GuideFact {
  label: string;
  value: string;
}

interface ShareAction {
  id: 'whatsapp' | 'instagram' | 'facebook';
  label: string;
  ariaLabel: string;
  href?: string;
  copyOnly?: boolean;
}

const { locale, post } = Astro.props as Props;
const t = useTranslations(locale);
const isEnglish = locale === 'en';
const displayTitle = getBlogDisplayTitle(post, locale);

const publishedDate = new Date(post.publishDate);
const dateLocale = isEnglish ? 'en-GB' : 'es-ES';
const formattedDate = publishedDate.toLocaleDateString(dateLocale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const categoryLabel = t(`blog.categories.${post.category}`);
const categoryUrl = `${getRoute('blog', locale)}#content`;
const ogImage = post.image ?? 'https://upload.wikimedia.org/wikipedia/commons/c/c6/Carrera_del_Darro_de_Granada.jpg';

function stripHtml(value: string): string {
  return value.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
}

function slugifyHeading(value: string, fallbackIndex: number): string {
  const slug = value
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/&/g, ' y ')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');

  return slug || `seccion-${fallbackIndex + 1}`;
}

function getUniqueHeadingId(baseId: string, usedIds: Map<string, number>): string {
  const count = usedIds.get(baseId) ?? 0;
  usedIds.set(baseId, count + 1);
  return count === 0 ? baseId : `${baseId}-${count + 1}`;
}

function pushFact(facts: GuideFact[], fact: GuideFact | null, maxFacts: number): void {
  if (!fact || !fact.label.trim() || !fact.value.trim() || facts.length >= maxFacts) return;
  const key = `${fact.label}::${fact.value}`.toLowerCase();
  const exists = facts.some((item) => `${item.label}::${item.value}`.toLowerCase() === key);
  if (!exists) facts.push(fact);
}

function isHiddenGuideFact(fact: GuideFact): boolean {
  const label = fact.label
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '');

  return ['tipo', 'type', 'zona', 'zonas', 'area', 'areas'].includes(label);
}

const rawContent = post.content[locale];
const plainText = stripHtml(rawContent);
const wordCount = plainText ? plainText.split(' ').length : 0;
const calculatedReadingTime = Math.max(1, Math.ceil(wordCount / 220));

let headingCounter = 0;
const tocItems: TocItem[] = [];
const usedHeadingIds = new Map<string, number>();
const mediaBlock = editorialMediaByBlogSlug[post.slug]?.[locale] ?? '';
const contentWithMedia = mediaBlock
  ? rawContent.replace(/<\/p>/i, (match) => `${match}${mediaBlock}`)
  : rawContent;

const processedContent = contentWithMedia.replace(
  /<h2([^>]*)>([\s\S]*?)<\/h2>/gi,
  (_fullMatch: string, attrs: string, innerHtml: string) => {
    const text = stripHtml(innerHtml);
    const id = getUniqueHeadingId(slugifyHeading(text, headingCounter), usedHeadingIds);
    headingCounter += 1;
    tocItems.push({ text, id });
    const cleanedAttrs = attrs.replace(/\s+id=(["']).*?\1/i, '');
    return `<h2${cleanedAttrs} id="${id}">${innerHtml}</h2>`;
  }
);

const keyFacts: GuideFact[] = [];
const maxKeyFacts = 4;
const guideFacts = post.guideFacts?.map((fact) => ({
  label: fact.label[locale],
  value: fact.value[locale],
})).filter((fact) => !isHiddenGuideFact(fact)) ?? [];

for (const fact of guideFacts) {
  pushFact(keyFacts, fact, maxKeyFacts);
}

pushFact(keyFacts, { label: t('detail.readingTime'), value: t('blog.readingTime', { minutes: calculatedReadingTime }) }, maxKeyFacts);
pushFact(keyFacts, { label: t('detail.publishDate'), value: formattedDate }, maxKeyFacts);
const sidebarTocItems = tocItems.slice(0, 4);

const shareUrl = Astro.url.href;
const encodedShareUrl = encodeURIComponent(shareUrl);
const encodedShareText = encodeURIComponent(`${displayTitle} · GRN URBAN`);
const shareActions: ShareAction[] = [
  {
    id: 'whatsapp',
    label: t('detail.shareWhatsApp'),
    ariaLabel: t('detail.shareOnWhatsApp'),
    href: `https://wa.me/?text=${encodedShareText}%20${encodedShareUrl}`,
  },
  {
    id: 'instagram',
    label: t('detail.shareInstagram'),
    ariaLabel: t('detail.copyForInstagram'),
    copyOnly: true,
  },
  {
    id: 'facebook',
    label: t('detail.shareFacebook'),
    ariaLabel: t('detail.shareOnFacebook'),
    href: `https://www.facebook.com/sharer/sharer.php?u=${encodedShareUrl}`,
  },
];

const relatedGuides = getRelatedGuidesForPost(post, 3);
const relatedEvents = getRelatedEventsForPost(post, 3);
const relatedRoutes = getRelatedRoutesForPost(post, 3);
const relatedVenues = getRelatedVenuesForPost(post, 3);
const hasRelatedContent =
  relatedGuides.length > 0 ||
  relatedEvents.length > 0 ||
  relatedRoutes.length > 0 ||
  relatedVenues.length > 0;

const copy = {
  breadcrumb: {
    home: t('nav.home'),
    listing: t('blog.title'),
  },
  section: {
    article: t('detail.navArticle'),
    keyFacts: t('detail.keyFacts'),
    tocLabel: t('detail.inThisGuide'),
    shareTitle: t('detail.shareGuideTitle'),
    shareIntro: t('detail.shareGuideIntro'),
    shareLabel: t('detail.share'),
    shareCopied: t('detail.copied'),
    tags: t('detail.tags'),
  },
  seoDescription: clampMetaDescription(getBlogSeoDescription(post, locale)),
  relatedTitle: t('detail.alsoInteresting'),
};

const breadcrumb = [
  { name: copy.breadcrumb.home, url: getRoute('home', locale) },
  { name: copy.breadcrumb.listing, url: getRoute('blog', locale) },
  { name: post.title[locale], url: getBlogDetailUrl(post.slug, locale) },
];
---

<BaseLayout
  locale={locale}
  title={post.title[locale]}
  description={copy.seoDescription}
  ogImage={ogImage}
  ogImageAlt={post.title[locale]}
  ogType="article"
  schemaType="article"
  schemaData={post}
  breadcrumb={breadcrumb}
  articlePublishedTime={post.publishDate}
  articleModifiedTime={post.publishDate}
  articleSection={categoryLabel}
  articleTags={post.tags}
>
  <NavBar slot="header" locale={locale} currentPath={Astro.url.pathname} />

  <BlogDetailHero
    post={post}
    locale={locale}
    readingMinutes={calculatedReadingTime}
    sectionCount={tocItems.length}
    displayTitle={displayTitle}
  />

  <div class="det-page blog-page-override">
    <div class="det-content-wrap">
      <div class="guide-meta-row">
        <main class="upgraded-main" aria-label={displayTitle}>
          <article class="upg-block guide-article-card" id="article-content" data-reveal>
            <header class="upg-header">
              <span class="upg-num">03</span>
              <span class="upg-line" aria-hidden="true"></span>
              <span class="upg-eyebrow">[ {copy.section.article} ]</span>
            </header>

            <div class="blg-prose content-rich" set:html={processedContent} />

            {(post.tags.length > 0 || categoryLabel) && (
              <footer class="guide-article-footer" id="tags">
                <a href={categoryUrl} class="guide-pill-link">{categoryLabel}</a>
                {post.tags.slice(0, 8).map((tag) => (
                  <span class="guide-tag">#{tag}</span>
                ))}
              </footer>
            )}
          </article>
        </main>

        <aside class="flex flex-col gap-4 lg:sticky lg:top-24 lg:self-start" aria-label={copy.section.keyFacts}>
          <section class="guide-keyfacts-card" aria-labelledby="guide-keyfacts-title" data-reveal>
            <header class="guide-section-head">
              <span class="guide-section-num">01</span>
              <span class="guide-section-line" aria-hidden="true"></span>
              <h2 id="guide-keyfacts-title" class="guide-section-title">{copy.section.keyFacts}</h2>
            </header>

            <dl class="guide-facts-grid">
              {keyFacts.map((fact) => (
                <div class="guide-fact">
                  <dt>{fact.label}</dt>
                  <dd>{fact.value}</dd>
                </div>
              ))}
            </dl>
          </section>

          {sidebarTocItems.length > 0 && (
            <nav class="guide-toc-card" data-reveal aria-labelledby="guide-toc-title">
              <header class="guide-section-head">
                <span class="guide-section-num">02</span>
                <span class="guide-section-line" aria-hidden="true"></span>
                <h2 id="guide-toc-title" class="guide-section-title">{copy.section.tocLabel}</h2>
              </header>

              <ol class="guide-toc-list">
                {sidebarTocItems.map((item, index) => (
                  <li>
                    <a href={`#${item.id}`} class="guide-toc-link">
                      <span>{(index + 1).toString().padStart(2, '0')}</span>
                      <strong>{item.text}</strong>
                    </a>
                  </li>
                ))}
              </ol>
            </nav>
          )}

          <section class="blg-share-card" data-reveal aria-labelledby="guide-share-title">
            <header class="guide-section-head">
              <span class="guide-section-num">03</span>
              <span class="guide-section-line" aria-hidden="true"></span>
              <h2 id="guide-share-title" class="guide-section-title">{copy.section.shareTitle}</h2>
            </header>

            <p class="blg-share-intro">{copy.section.shareIntro}</p>

            <ShareButton
              title={post.title[locale]}
              url={shareUrl}
              label={copy.section.shareLabel}
              copiedLabel={copy.section.shareCopied}
              class="blg-share-btn"
            />

            <div class="blg-share-channels" aria-label={copy.section.shareTitle}>
              {shareActions.map((action) => (
                action.copyOnly ? (
                  <button
                    type="button"
                    class={`blg-share-channel blg-share-channel--${action.id}`}
                    data-share-copy
                    data-share-url={shareUrl}
                    data-share-method={action.id}
                    aria-label={action.ariaLabel}
                    title={action.ariaLabel}
                  >
                    <span class="blg-share-icon" aria-hidden="true">
                      {action.id === 'instagram' && (
                        <InstagramIcon />
                      )}
                    </span>
                    <span class="blg-share-label">{action.label}</span>
                  </button>
                ) : (
                  <a
                    class={`blg-share-channel blg-share-channel--${action.id}`}
                    href={action.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={action.ariaLabel}
                    title={action.ariaLabel}
                  >
                    <span class="blg-share-icon" aria-hidden="true">
                      {action.id === 'whatsapp' && (
                        <WhatsAppIcon />
                      )}
                      {action.id === 'facebook' && (
                        <svg viewBox="0 0 24 24" fill="currentColor">
                          <path d="M22 12.06C22 6.48 17.52 2 11.94 2S2 6.48 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.91h2.54V9.84c0-2.52 1.5-3.91 3.8-3.91 1.1 0 2.25.2 2.25.2v2.47h-1.27c-1.25 0-1.64.78-1.64 1.57v1.89h2.8l-.45 2.91h-2.35V22A10 10 0 0 0 22 12.06Z"/>
                        </svg>
                      )}
                    </span>
                    <span class="blg-share-label">{action.label}</span>
                  </a>
                )
              ))}
            </div>
          </section>
        </aside>
      </div>

      {hasRelatedContent && (
        <section class="upg-block upg-block--loose guide-related-full" id="also-interesting" data-reveal aria-labelledby="guide-related-title">
          <header class="upg-header">
            <span class="upg-num">04</span>
            <span class="upg-line" aria-hidden="true"></span>
            <h2 id="guide-related-title" class="upg-eyebrow">[ {copy.relatedTitle} ]</h2>
          </header>
          <div class="upg-related-stack">
            <RelatedGuides type="post" post={post} locale={locale} title={t('detail.relatedGuides')} limit={3} />
            <RelatedEvents type="post" post={post} locale={locale} title={t('detail.relatedEvents')} limit={3} />
            <RelatedRoutes type="post" post={post} locale={locale} title={t('detail.relatedRoutes')} limit={3} />
            <RelatedVenues type="post" post={post} locale={locale} title={t('detail.relatedVenues')} limit={3} />
          </div>
        </section>
      )}
    </div>

    <ContinueExploring locale={locale} />

    <div class="det-footer-orn" aria-hidden="true">
      <span></span>
      <i></i>
      <b>
        <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
          <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17.2l-6.2 4.1 2.4-7.4L2 9.4h7.6z"/>
        </svg>
      </b>
      <i></i>
      <span></span>
    </div>
  </div>

  <Footer slot="footer" locale={locale} />
</BaseLayout>

<ReadingProgress />

<script is:inline>
  (function () {
    if (window.__guideShareCopyInitialized) return;
    window.__guideShareCopyInitialized = true;

    document.addEventListener('click', async function (event) {
      const button = event.target.closest('[data-share-copy]');
      if (!button) return;

      const url = button.dataset.shareUrl ?? window.location.href;
      const method = button.dataset.shareMethod ?? 'copy';

      try {
        await navigator.clipboard.writeText(url);
        button.classList.add('is-copied');
        window.setTimeout(function () {
          button.classList.remove('is-copied');
        }, 1600);

        if (typeof window.grnTrackEvent === 'function') {
          window.grnTrackEvent('share', {
            method,
            content_id: window.location.pathname,
          });
        }
      } catch (_) {}
    });
  })();
</script>

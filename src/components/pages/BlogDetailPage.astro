---
import BaseLayout from '@layouts/BaseLayout.astro';
import NavBar from '@components/layout/NavBar.astro';
import Footer from '@components/layout/Footer.astro';
import BlogDetailHero from '@components/blog/BlogDetailHero.astro';
import OptimizedImage from '@components/ui/OptimizedImage.astro';
import ShareButton from '@components/ui/ShareButton.astro';
import ReadingProgress from '@components/ui/ReadingProgress.astro';
import { getRelatedPosts, getAllPosts } from '@data/index.js';
import { useTranslations } from '@i18n/utils';
import { getBlogDetailUrl, getRoute, getRouteDetailUrl, getEventDetailUrl } from '@utils/routes';
import { getRelatedRoutesForBlogPost, getRelatedEventsForBlogPost } from '@utils/cross-links';
import CrossLinksSection from '@components/ui/CrossLinksSection.astro';
import { formatDuration, formatFullDate } from '@utils/dates';
import type { BlogPost, Locale } from '@types';
import '@styles/pages/blog-detail.css';

interface Props {
  locale: Locale;
  post: BlogPost;
}

const { locale, post } = Astro.props as Props;
const t = useTranslations(locale);
const isEnglish = locale === 'en';
const allPosts = getAllPosts();
const postIndex = allPosts.findIndex((p) => p.id === post.id);
const prevPost = postIndex > 0 ? allPosts[postIndex - 1] : null;
const nextPost = postIndex < allPosts.length - 1 ? allPosts[postIndex + 1] : null;
const relatedPosts = getRelatedPosts(post, 3);
const relatedRoutes = getRelatedRoutesForBlogPost(post, 2);
const relatedEvents = getRelatedEventsForBlogPost(post, 2);

const crossLinks = [
  ...relatedRoutes.map((r) => ({
    url: getRouteDetailUrl(r.slug, locale),
    title: r.title[locale],
    meta: `${formatDuration(r.duration, locale)} · ${t(`categories.${r.category}`)}`,
    image: r.image,
  })),
  ...relatedEvents.map((e) => ({
    url: getEventDetailUrl(e.slug, locale),
    title: e.title[locale],
    meta: `${formatFullDate(e.date, locale)} · ${t(`categories.${e.category}`)}`,
    image: e.imageUrl || e.image,
  })),
].slice(0, 4);

const publishedDate = new Date(post.publishDate);
const dateLocale = isEnglish ? 'en-GB' : 'es-ES';
const formattedDate = publishedDate.toLocaleDateString(dateLocale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const dayNum = publishedDate.getDate().toString().padStart(2, '0');
const monthShort = publishedDate.toLocaleDateString(dateLocale, { month: 'short' }).toUpperCase();
const categoryLabel = t(`blog.categories.${post.category}`);
const categoryUrl = `${getRoute('blog', locale)}?category=${post.category}`;
const ogImage = post.image ?? 'https://images.unsplash.com/photo-1548013146-72479768bada?w=1200&h=630&fit=crop&q=80';

const copy = isEnglish
  ? {
      breadcrumb: {
        home: 'Home',
        listing: t('blog.title'),
      },
      section: {
        article: '[ Article ]',
        authorByline: 'Written by',
        authorBio: 'GRN URBAN contributor specialising in local culture and experiential travel.',
        infoLabel: 'INFORMATION',
        shareLabel: 'Share article',
        shareCopied: 'Link copied!',
        tags: '[ Tags ]',
      },
      seoDescription: `${post.description[locale]} — ${categoryLabel}. By ${post.author}. ${t('blog.readingTime', { minutes: post.readingTime })}.`,
      nav: {
        prev: 'Previous article',
        next: 'Next article',
      },
    }
  : {
      breadcrumb: {
        home: 'Inicio',
        listing: t('blog.title'),
      },
      section: {
        article: '[ Artículo ]',
        authorByline: 'Escrito por',
        authorBio: 'Colaborador de GRN URBAN especializado en cultura local y turismo experiencial.',
        infoLabel: 'INFORMACIÓN',
        shareLabel: 'Compartir artículo',
        shareCopied: '¡Enlace copiado!',
        tags: '[ Etiquetas ]',
      },
      seoDescription: `${post.description[locale]} — ${categoryLabel}. Por ${post.author}. ${t('blog.readingTime', { minutes: post.readingTime })}.`,
      nav: {
        prev: 'Artículo anterior',
        next: 'Artículo siguiente',
      },
    };

const breadcrumb = [
  { name: copy.breadcrumb.home, url: getRoute('home', locale) },
  { name: copy.breadcrumb.listing, url: getRoute('blog', locale) },
  { name: post.title[locale], url: getBlogDetailUrl(post.slug, locale) },
];
---

<BaseLayout
  locale={locale}
  title={post.title[locale]}
  description={copy.seoDescription}
  ogImage={ogImage}
  ogImageAlt={post.title[locale]}
  ogType="article"
  schemaType="article"
  schemaData={post}
  breadcrumb={breadcrumb}
  articlePublishedTime={post.publishDate}
  articleModifiedTime={post.publishDate}
  articleAuthor={post.author}
  articleSection={categoryLabel}
  articleTags={post.tags}
>
  <NavBar slot="header" locale={locale} currentPath={Astro.url.pathname} />

  <BlogDetailHero post={post} locale={locale} formattedDate={formattedDate} />

  <div class="det-page blog-page-override">
    <div class="det-content-wrap">
      <div class="upgraded-layout">
        <main id="main-content" class="upgraded-main">
          <article class="upg-block" id="article-content" data-reveal aria-label={post.title[locale]}>
            <div class="upg-block-bg"></div>
            <header class="upg-header">
              <span class="upg-num">01</span>
              <div class="upg-line"></div>
              <span class="upg-eyebrow">{copy.section.article}</span>
            </header>

            <div class="blg-prose content-rich" set:html={post.content[locale]} />

            <div class="upg-meta-links" style="display:flex; flex-wrap:wrap; gap:0.75rem; margin-top:2rem;">
              <a href={categoryUrl} class="upg-badge ghost" style="text-decoration:none;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
                {categoryLabel}
              </a>
            </div>
          </article>

          <article class="upg-block" id="author" data-reveal style="padding: 2.5rem 3rem;">
            <div class="upg-block-bg"></div>
            <div style="display:flex; gap: 1.5rem; align-items: center;">
              <div class="upg-author-avatar">
                <span class="upg-author-initial">{post.author.charAt(0)}</span>
              </div>
              <div>
                <span style="font-family: var(--font-display); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; color: var(--s-ink-3); text-transform: uppercase; display: block; margin-bottom: 0.2rem;">{copy.section.authorByline}</span>
                <span style="font-family: var(--font-body); font-size: 1.5rem; font-weight: 600; color: var(--s-ink); display: block; margin-bottom: 0.4rem;">{post.author}</span>
                <span style="font-family: var(--font-display); font-size: 0.9rem; color: var(--s-ink-2); line-height: 1.5; display: block;">{copy.section.authorBio}</span>
              </div>
            </div>
          </article>

          {post.tags.length > 0 && (
            <div class="upg-tags" id="tags" data-reveal>
              <span class="upg-tags-title">{copy.section.tags}</span>
              <div class="upg-tags-list">
                {post.tags.map((tag: string) => (
                  <span class="upg-tag">#{tag}</span>
                ))}
              </div>
            </div>
          )}

          {(prevPost || nextPost) && (
            <nav class="upg-block" data-reveal aria-label={isEnglish ? 'Article navigation' : 'Navegación de artículos'} style="padding: 2rem 3rem;">
              <div class="upg-block-bg"></div>
              <div style="display:flex; justify-content:space-between; align-items:center; gap:1rem;">
                {prevPost ? (
                  <a href={getBlogDetailUrl(prevPost.slug, locale)} style="display:flex; flex-direction:column; align-items:flex-start; text-decoration:none; max-width:45%;">
                    <span style="font-family:var(--font-display); font-size:0.7rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--s-ink-3); margin-bottom:0.35rem;">{copy.nav.prev}</span>
                    <span style="font-family:var(--font-body); font-size:1.1rem; font-weight:600; color:var(--s-ink); line-height:1.3;">{prevPost.title[locale]}</span>
                    <time datetime={prevPost.publishDate} style="font-family:var(--font-display); font-size:0.8rem; color:var(--s-ink-2); margin-top:0.25rem;">{prevPost.publishDate}</time>
                  </a>
                ) : <span />}
                {nextPost ? (
                  <a href={getBlogDetailUrl(nextPost.slug, locale)} style="display:flex; flex-direction:column; align-items:flex-end; text-decoration:none; max-width:45%;">
                    <span style="font-family:var(--font-display); font-size:0.7rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--s-ink-3); margin-bottom:0.35rem;">{copy.nav.next}</span>
                    <span style="font-family:var(--font-body); font-size:1.1rem; font-weight:600; color:var(--s-ink); line-height:1.3; text-align:right;">{nextPost.title[locale]}</span>
                    <time datetime={nextPost.publishDate} style="font-family:var(--font-display); font-size:0.8rem; color:var(--s-ink-2); margin-top:0.25rem;">{nextPost.publishDate}</time>
                  </a>
                ) : <span />}
              </div>
            </nav>
          )}

          {crossLinks.length > 0 && (
            <div class="upg-block" data-reveal style="padding: 2.5rem 3rem;">
              <div class="upg-block-bg"></div>
              <header class="upg-header">
                <span class="upg-num">02</span>
                <div class="upg-line"></div>
                <span class="upg-eyebrow">[ {t('detail.discoverMore')} ]</span>
              </header>
              <CrossLinksSection title={t('detail.discoverMore')} links={crossLinks} />
            </div>
          )}
        </main>

        <aside class="upg-sidebar" aria-label={isEnglish ? 'Article sidebar' : 'Barra lateral del artículo'}>
          <div class="upg-sidebar-sticky">
            <nav class="upg-toc" data-reveal aria-label={isEnglish ? 'Table of contents' : 'Tabla de contenidos'} style="margin-bottom:1.5rem; background:#fff; border-radius:20px; border:1px solid var(--s-border); padding:1.5rem 2rem;">
              <span style="font-family:var(--font-display); font-size:0.7rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--s-ink-3); display:block; margin-bottom:1rem;">{isEnglish ? 'On this page' : 'En esta página'}</span>
              <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0.6rem;">
                <li><a href="#article-content" style="font-family:var(--font-display); font-size:0.85rem; color:var(--s-ink-2); text-decoration:none; display:flex; align-items:center; gap:0.5rem;"><span style="color:var(--s-orange);">01</span> {isEnglish ? 'Article' : 'Artículo'}</a></li>
                <li><a href="#author" style="font-family:var(--font-display); font-size:0.85rem; color:var(--s-ink-2); text-decoration:none; display:flex; align-items:center; gap:0.5rem;"><span style="color:var(--s-orange);">02</span> {isEnglish ? 'Author' : 'Autor'}</a></li>
                {post.tags.length > 0 && (
                  <li><a href="#tags" style="font-family:var(--font-display); font-size:0.85rem; color:var(--s-ink-2); text-decoration:none; display:flex; align-items:center; gap:0.5rem;"><span style="color:var(--s-orange);">03</span> {isEnglish ? 'Tags' : 'Etiquetas'}</a></li>
                )}
              </ul>
            </nav>

            <div class="upg-ticket-card" data-reveal>
              <div class="upg-ticket-glass"></div>

              <div class="upg-tc-header">
                <div class="upg-tc-date-box">
                  <time datetime={post.publishDate} class="tc-day" style="font-size: 1.4rem;">{dayNum}</time>
                  <span class="tc-month">{monthShort}</span>
                </div>
                <div class="upg-tc-info">
                  <span class="tc-time" style="color:var(--s-ink);">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                    {t('blog.readingTime', { minutes: post.readingTime })}
                  </span>
                  <span class="tc-category">{categoryLabel}</span>
                </div>
              </div>

              <div style="padding: 0 2.5rem 1rem;">
                <span class="tc-price-label" style="display:block; margin-bottom:1rem;">{copy.section.infoLabel}</span>
                <div style="display:flex; flex-direction:column; gap:0.75rem;">
                  <div style="display:flex; align-items:center; gap:0.6rem;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:16px;height:16px;color:var(--s-orange);"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    <span style="font-family:var(--font-display); font-size:0.85rem; font-weight:600; color:var(--s-ink);">{post.author}</span>
                  </div>
                  <div style="display:flex; align-items:center; gap:0.6rem;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:16px;height:16px;color:var(--s-orange);"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    <time datetime={post.publishDate} style="font-family:var(--font-display); font-size:0.85rem; color:var(--s-ink-2);">{formattedDate}</time>
                  </div>
                </div>
              </div>

              <div class="upg-tc-divider">
                <span class="tcd-hole left"></span>
                <div class="tcd-dashed"></div>
                <span class="tcd-hole right"></span>
              </div>

              <div class="upg-tc-actions">
                <ShareButton
                  title={post.title[locale]}
                  url={Astro.url.href}
                  label={copy.section.shareLabel}
                  copiedLabel={copy.section.shareCopied}
                  class="upg-btn-primary"
                />
              </div>
            </div>

            {relatedPosts.length > 0 && (
              <div class="upg-related-bento" data-reveal>
                <div class="upg-rb-header">
                  <span class="upg-rb-title">[ {t('detail.relatedPosts')} ]</span>
                  <a href={getRoute('blog', locale)} class="upg-rb-all">{t('detail.allPosts')} →</a>
                </div>

                <div class="upg-rb-list">
                  {relatedPosts.map((relatedPost, index) => (
                    <a href={getBlogDetailUrl(relatedPost.slug, locale)} class="upg-rel-item" style={`--rd: ${index * 0.15}s`}>
                      <div class="uri-thumb">
                        {relatedPost.image ? (
                          <OptimizedImage src={relatedPost.image} alt={relatedPost.title[locale]} loading="lazy" sizes="(max-width: 640px) 100vw, 280px" />
                        ) : (
                          <div class="uri-thumb-fallback"></div>
                        )}
                      </div>
                      <div class="uri-content">
                        <span class="uri-title">{relatedPost.title[locale]}</span>
                        <span class="uri-meta">{t('blog.readingTime', { minutes: relatedPost.readingTime })}</span>
                      </div>
                      <div class="uri-arrow">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        </aside>
      </div>
    </div>

    <div class="det-footer-orn" aria-hidden="true" style="display: flex; align-items: center; justify-content: center; gap: 1rem; padding: 3rem clamp(1.5rem, 5vw, 4rem) 4rem; opacity: 0.3;">
      <span style="flex: 1; max-width: 120px; height: 1px; background: var(--s-border);"></span>
      <span style="width: 6px; height: 6px; background: var(--s-gold); transform: rotate(45deg);"></span>
      <span style="color: var(--s-gold); margin: 0 0.5rem;"><svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17.2l-6.2 4.1 2.4-7.4L2 9.4h7.6z"/></svg></span>
      <span style="width: 6px; height: 6px; background: var(--s-gold); transform: rotate(45deg);"></span>
      <span style="flex: 1; max-width: 120px; height: 1px; background: var(--s-border);"></span>
    </div>
  </div>

  <Footer slot="footer" locale={locale} />
</BaseLayout>

<ReadingProgress />

---
import BaseLayout from '@layouts/BaseLayout.astro';
import PlanHero from '@components/shared/PlanHero.astro';
import CrossLinksSection from '@components/ui/CrossLinksSection.astro';
import CollaborateCTA from '@components/shared/CollaborateCTA.astro';
import RelatedGuides from '@components/related/RelatedGuides.astro';
import RelatedEvents from '@components/related/RelatedEvents.astro';
import RelatedRoutes from '@components/related/RelatedRoutes.astro';
import RelatedPlans from '@components/related/RelatedPlans.astro';
import { getAllMixedRoutes, getAllPosts } from '@data';
import { useTranslations } from '@i18n/utils';
import { getBlogDisplayTitle } from '@utils/content-seo';
import { getRoute, getPlanDetailUrl, getBlogDetailUrl, getRouteDetailUrl } from '@utils/routes';
import { formatDuration } from '@utils/dates';
import { formatDistance } from '@utils/dates';
import { getRelatedMixedRoutesForMixedRoute } from '@utils/related-content';
import type { MixedRoute, MixedRouteStop, Locale } from '@types';
import ShareButton from '@components/ui/ShareButton.astro';
import ReadingProgress from '@components/ui/ReadingProgress.astro';
import '@styles/pages/mixed-route-detail.css';

interface Props {
  locale: Locale;
  plan: MixedRoute;
}

const { locale, plan } = Astro.props;
const t = useTranslations(locale);
const isEnglish = locale === 'en';

const allPlans = getAllMixedRoutes();
const allPosts = getAllPosts();
const planIndex = allPlans.findIndex((p) => p.id === plan.id);
const prevPlan = planIndex > 0 ? allPlans[planIndex - 1] : null;
const nextPlan = planIndex < allPlans.length - 1 ? allPlans[planIndex + 1] : null;
const beforeTravelPost = allPosts.find((item) => item.slug === 'antes-de-llegar-granada');
const tapasPost = allPosts.find((item) => item.slug === 'tapas-gratis-granada');
const oneDayPost = allPosts.find((item) => item.slug === 'granada-en-un-dia-itinerario');

const ogImage = plan.image || 'https://upload.wikimedia.org/wikipedia/commons/3/32/Alhambra_view_1102.jpg';

const breadcrumb = [
  { name: isEnglish ? 'Home' : 'Inicio', url: getRoute('home', locale) },
  { name: t('nav.routes'), url: getRoute('routes', locale) },
  { name: plan.title[locale], url: getPlanDetailUrl(plan.slug, locale) },
];

const totalStops = plan.days.reduce(
  (acc, day) => acc + day.blocks.reduce((bAcc, block) => bAcc + block.stops.length, 0),
  0
);

const stopCategoryConfig: Record<string, { color: string; bg: string; border: string; icon: string; label: string }> = {
  mirador: { color: '#d4873a', bg: 'rgba(212, 135, 58, 0.12)', border: 'rgba(212, 135, 58, 0.3)', icon: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z', label: t('mixedRoutes.stopCategories.mirador') },
  tapas: { color: '#c94a4a', bg: 'rgba(201, 74, 74, 0.12)', border: 'rgba(201, 74, 74, 0.3)', icon: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z', label: t('mixedRoutes.stopCategories.tapas') },
  monumento: { color: '#4a9e6b', bg: 'rgba(74, 158, 107, 0.12)', border: 'rgba(74, 158, 107, 0.3)', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4', label: t('mixedRoutes.stopCategories.monumento') },
  cultura: { color: '#d4873a', bg: 'rgba(212, 135, 58, 0.12)', border: 'rgba(212, 135, 58, 0.3)', icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z', label: t('mixedRoutes.stopCategories.cultura') },
  paseo: { color: '#4a9e6b', bg: 'rgba(74, 158, 107, 0.12)', border: 'rgba(74, 158, 107, 0.3)', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6', label: t('mixedRoutes.stopCategories.paseo') },
  compras: { color: '#d4873a', bg: 'rgba(212, 135, 58, 0.12)', border: 'rgba(212, 135, 58, 0.3)', icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z', label: t('mixedRoutes.stopCategories.compras') },
  naturaleza: { color: '#4a9e6b', bg: 'rgba(74, 158, 107, 0.12)', border: 'rgba(74, 158, 107, 0.3)', icon: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z', label: t('mixedRoutes.stopCategories.naturaleza') },
  flamenco: { color: '#c94a4a', bg: 'rgba(201, 74, 74, 0.12)', border: 'rgba(201, 74, 74, 0.3)', icon: 'M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3', label: t('mixedRoutes.stopCategories.flamenco') },
};

const slugDurationLabels: Record<string, string> = {
  '30min': t('mixedRoutes.slugDurationLabels.30min'),
  '1h': t('mixedRoutes.slugDurationLabels.1h'),
  '2h': t('mixedRoutes.slugDurationLabels.2h'),
  '6h': t('mixedRoutes.slugDurationLabels.6h'),
  '12h': t('mixedRoutes.slugDurationLabels.12h'),
  'half-day': t('mixedRoutes.slugDurationLabels.half-day'),
  'full-day': t('mixedRoutes.slugDurationLabels.full-day'),
  '1day': t('mixedRoutes.slugDurationLabels.1day'),
  '2days': t('mixedRoutes.slugDurationLabels.2days'),
  '3days': t('mixedRoutes.slugDurationLabels.3days'),
};
const getDurationLabel = (dur: string) => slugDurationLabels[dur] ?? dur;

const refNum = plan.id.replace(/^mr-/, '').padStart(3, '0');
const refCode = `PLN / ${refNum} · ${new Date().getFullYear()}`;
const backHref = getRoute('byTime', locale);
const backLabel = t('mixedRoutes.title');
const eyebrowText = getDurationLabel(plan.duration).toUpperCase();
const onwardLinks = Array.from(new Map([
  {
    url: getRoute('planner', locale),
    title: t('nav.planner'),
    meta: t('planner.heroDescription'),
    image: null,
  },
  {
    url: getRoute('routes', locale),
    title: t('nav.routes'),
    meta: t('routes.heroSubtitle'),
    image: null,
  },
  ...(beforeTravelPost
    ? [{
        url: getBlogDetailUrl(beforeTravelPost.slug, locale),
        title: getBlogDisplayTitle(beforeTravelPost, locale),
        meta: `${t('blog.readingTime', { minutes: beforeTravelPost.readingTime })} · ${t(`blog.categories.${beforeTravelPost.category}`)}`,
        image: beforeTravelPost.image,
      }]
    : []),
  ...(plan.duration === '2h' || plan.duration === '6h'
    ? oneDayPost
      ? [{
          url: getBlogDetailUrl(oneDayPost.slug, locale),
          title: getBlogDisplayTitle(oneDayPost, locale),
          meta: `${t('blog.readingTime', { minutes: oneDayPost.readingTime })} · ${t(`blog.categories.${oneDayPost.category}`)}`,
          image: oneDayPost.image,
        }]
      : []
    : []),
  ...(tapasPost
    ? [{
        url: getBlogDetailUrl(tapasPost.slug, locale),
        title: getBlogDisplayTitle(tapasPost, locale),
        meta: `${t('blog.readingTime', { minutes: tapasPost.readingTime })} · ${t(`blog.categories.${tapasPost.category}`)}`,
        image: tapasPost.image,
      }]
    : []),
].map((link) => [link.url, link])).values()).slice(0, 4);

const copy = isEnglish
  ? {
      nav: {
        prev: 'Previous plan',
        next: 'Next plan',
      },
      toc: 'On this page',
    }
  : {
      nav: {
        prev: 'Plan anterior',
        next: 'Plan siguiente',
      },
      toc: 'En esta página',
    };

// Key facts for the sidebar (compact 2x2 grid)
const planFacts = [
  { label: t('mixedRoutes.dockDuration'), value: getDurationLabel(plan.duration) },
  { label: t('mixedRoutes.dockStops'), value: totalStops.toString() },
  { label: t('mixedRoutes.dockZones'), value: plan.neighborhoods.length.toString() },
  { label: t('detail.pointsOfInterest'), value: plan.totalHours.toString() },
];

// Other plans (mixed routes) for bottom recommendations
const otherPlans = getRelatedMixedRoutesForMixedRoute(plan, 3);

const otherPlanLinks = otherPlans.map((p) => ({
  url: getPlanDetailUrl(p.slug, locale),
  title: p.title[locale],
  meta: getDurationLabel(p.duration),
  image: p.image || null,
}));

// Build the compact TOC: max 4 day items + optional essential tips
const tocItems: Array<{ id: string; label: string; index: number | null }> = plan.days
  .slice(0, 4)
  .map((day, i) => ({
    id: `day-${i + 1}`,
    label: day.label ? day.label[locale] : t('mixedRoutes.day', { number: i + 1 }),
    index: i + 1,
  }));

if (plan.essentialTips && plan.essentialTips.length > 0 && tocItems.length < 4) {
  tocItems.push({ id: 'essential-tips', label: t('mixedRoutes.essentialTips'), index: null });
}
---

<BaseLayout
  locale={locale}
  title={plan.title[locale]}
  description={plan.description[locale]}
  ogImage={ogImage}
  ogImageAlt={plan.title[locale]}
  schemaType="timePlan"
  schemaData={plan}
  breadcrumb={breadcrumb}
>
  <PlanHero
    locale={locale}
    backHref={backHref}
    backLabel={backLabel}
    refCode={refCode}
    title={plan.title[locale]}
    eyebrowText={eyebrowText}
    description={plan.description[locale]}
    duration={plan.duration}
    totalStops={totalStops}
    neighborhoods={plan.neighborhoods}
    bestFor={plan.bestFor ? plan.bestFor[locale] : undefined}
    {...(plan.image ? { image: plan.image } : {})}
  />

  <div class="det-page mx-page-override">
    <div class="det-content-wrap mt-pull">
      <div class="upgraded-layout">

        <main id="main-content" class="upgraded-main">
            {plan.days.map((day, dayIndex) => (
              <article class="upg-block mx-day-section" id={`day-${dayIndex + 1}`} data-reveal style={`--day-delay: ${dayIndex * 0.15}s`}>
                <div class="upg-block-bg"></div>

                <header class="upg-header mx-day-header">
                  <span class="upg-num">{(dayIndex + 1).toString().padStart(2, '0')}</span>
                  <div class="upg-line"></div>
                  <span class="upg-eyebrow">
                    [ {day.label ? day.label[locale] : t('detail.planDay', { number: dayIndex + 1 })} ]
                  </span>
                </header>

                {day.blocks.map((block, blockIndex) => (
                  <div class="mx-block" data-reveal-inner style={`--block-delay: ${(blockIndex + 1) * 0.1}s;`}>
                    <div class="mx-block-header">
                      <div class="mx-block-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                          <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </div>
                      <h3 class="mx-block-title">{block.label[locale]}</h3>
                      <div class="mx-block-divider"></div>
                    </div>

                    <ol class="mx-stops-list">
                      {block.stops.map((stop: MixedRouteStop, stopIndex: number) => {
                        const catConfig = stopCategoryConfig[stop.category] || stopCategoryConfig.paseo;
                        return (
                          <li class="mx-stop" data-reveal-inner style={`--stop-delay: ${stopIndex * 0.08}s`}>
                            <div class="mx-stop-marker" aria-hidden="true">
                              <div class="mx-stop-dot" style={`--dot-color: ${catConfig.color}`}></div>
                              <div class="mx-stop-line"></div>
                            </div>
                            <article class="mx-stop-card" style={`--card-accent: ${catConfig.color}`}>
                              <header class="mx-stop-header">
                                <span class="mx-stop-category" style={`color: ${catConfig.color}; background: ${catConfig.bg}; border-color: ${catConfig.border};`}>
                                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                                    <path d={catConfig.icon} stroke-linecap="round" stroke-linejoin="round"/>
                                  </svg>
                                  {catConfig.label}
                                </span>
                                {stop.neighborhood && (
                                  <span class="mx-stop-zone">{t(`neighborhoods.${stop.neighborhood}`)}</span>
                                )}
                                <span class="mx-stop-duration">~{stop.duration} min</span>
                              </header>
                              <h4 class="mx-stop-name">{stop.name[locale]}</h4>
                              <p class="mx-stop-desc">{stop.description[locale]}</p>
                              {stop.tip && (
                                <div class="mx-stop-tip" style={`--tip-color: ${catConfig.color}`}>
                                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                                    <path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/>
                                  </svg>
                                  <span>{stop.tip[locale]}</span>
                                </div>
                              )}
                            </article>
                          </li>
                        );
                      })}
                    </ol>
                  </div>
                ))}
              </article>
            ))}

            {plan.essentialTips && plan.essentialTips.length > 0 && (
              <article class="upg-block block-tips" id="essential-tips" data-reveal>
                <div class="upg-block-bg"></div>
                <header class="upg-header">
                  <span class="upg-num">E</span>
                  <div class="upg-line"></div>
                  <span class="upg-eyebrow">[ {t('mixedRoutes.planTipsLabel')} ]</span>
                </header>
                <h2 class="upg-title">{t('mixedRoutes.essentialTips')}</h2>

                <div class="mx-tips-grid">
                  {plan.essentialTips.map((tip, i) => (
                    <article class="mx-tip-card" style={`--tip-delay: ${i * 0.08}s`}>
                      <span class="mx-tip-rule" aria-hidden="true"></span>
                      <header class="mx-tip-head">
                        <span class="mx-tip-num">{(i + 1).toString().padStart(2, '0')}</span>
                        <span class="mx-tip-kicker">{t('mixedRoutes.planTipsLabel')}</span>
                      </header>
                      <p class="mx-tip-text">{tip[locale]}</p>
                    </article>
                  ))}
                </div>
              </article>
            )}

            {onwardLinks.length > 0 && (
              <div class="upg-block upg-block--loose" data-reveal>
                <div class="upg-block-bg"></div>
                <header class="upg-header">
                  <span class="upg-num">08</span>
                  <div class="upg-line"></div>
                  <span class="upg-eyebrow">[ {t('detail.discoverMore')} ]</span>
                </header>
                <CrossLinksSection title={t('detail.discoverMore')} links={onwardLinks} />
              </div>
            )}

            {(prevPlan || nextPlan) && (
              <nav class="upg-block mx-plan-nav" data-reveal aria-label={t('detail.onThisPlan')}>
                <div class="upg-block-bg"></div>
                <div class="mx-plan-nav-flex">
                  {prevPlan ? (
                    <a href={getPlanDetailUrl(prevPlan.slug, locale)} class="mx-plan-nav-link">
                      <span class="mx-plan-nav-arrow" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M15 18l-6-6 6-6"></path>
                        </svg>
                      </span>
                      <span class="mx-plan-nav-copy">
                        <span class="mx-plan-nav-label">{copy.nav.prev}</span>
                        <span class="mx-plan-nav-title">{prevPlan.title[locale]}</span>
                        <span class="mx-plan-nav-meta">{getDurationLabel(prevPlan.duration)}</span>
                      </span>
                    </a>
                  ) : <span />}
                  {nextPlan ? (
                    <a href={getPlanDetailUrl(nextPlan.slug, locale)} class="mx-plan-nav-link mx-plan-nav-link--end">
                      <span class="mx-plan-nav-copy">
                        <span class="mx-plan-nav-label">{copy.nav.next}</span>
                        <span class="mx-plan-nav-title">{nextPlan.title[locale]}</span>
                        <span class="mx-plan-nav-meta">{getDurationLabel(nextPlan.duration)}</span>
                      </span>
                      <span class="mx-plan-nav-arrow" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M9 18l6-6-6-6"></path>
                        </svg>
                      </span>
                    </a>
                  ) : <span />}
                </div>
              </nav>
            )}
          </main>

          <aside class="upg-sidebar mx-sidebar" aria-label={isEnglish ? 'Plan details sidebar' : 'Barra lateral de detalles del plan'}>
            <div class="upg-sidebar-sticky">

              <section class="route-side-card mx-keyfacts-card" aria-labelledby="mx-keyfacts-title" data-reveal>
                <header class="route-side-head">
                  <span class="route-side-num">01</span>
                  <span class="route-side-line" aria-hidden="true"></span>
                  <h2 id="mx-keyfacts-title" class="route-side-title">{t('detail.keyFacts')}</h2>
                </header>
                <dl class="route-facts-grid">
                  {planFacts.map((fact) => (
                    <div class="route-fact">
                      <dt>{fact.label}</dt>
                      <dd>{fact.value}</dd>
                    </div>
                  ))}
                </dl>
                {plan.bestFor && (
                  <p class="mx-bestfor">{t('mixedRoutes.bestFor')}: {plan.bestFor[locale]}</p>
                )}
              </section>

              {tocItems.length > 0 && (
                <nav class="route-side-card route-toc-card mx-toc-card" aria-labelledby="mx-toc-title" data-reveal>
                  <header class="route-side-head">
                    <span class="route-side-num">02</span>
                    <span class="route-side-line" aria-hidden="true"></span>
                    <h2 id="mx-toc-title" class="route-side-title">{copy.toc}</h2>
                  </header>
                  <ol class="route-toc-list">
                    {tocItems.map((item) => (
                      <li>
                        <a href={`#${item.id}`} class="route-toc-link">
                          <span>{item.index !== null ? item.index.toString().padStart(2, '0') : 'X'}</span>
                          <strong>{item.label}</strong>
                        </a>
                      </li>
                    ))}
                  </ol>
                </nav>
              )}

              <section class="route-side-card mx-share-card" aria-labelledby="mx-share-title" data-reveal>
                <header class="route-side-head">
                  <span class="route-side-num">03</span>
                  <span class="route-side-line" aria-hidden="true"></span>
                  <h2 id="mx-share-title" class="route-side-title">{t('detail.shareRoute')}</h2>
                </header>
                <div class="route-share-actions">
                  <ShareButton
                    title={plan.title[locale]}
                    url={Astro.url.href}
                    label={t('detail.shareRoute')}
                    copiedLabel={t('detail.copied')}
                    class="upg-btn-primary"
                  />
                  <a href={getRoute('byTime', locale)} class="upg-btn-secondary mx-back-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span class="upg-share-label">{t('detail.backToTimeRoutes')}</span>
                  </a>
                </div>
              </section>

            </div>
          </aside>

        </div>
      </div>

      <div class="mx-collab-section">
        <CollaborateCTA locale={locale} variant="timePlan" />
      </div>

      <section class="upg-block upg-block--loose mx-recommend" id="also-plans" data-reveal aria-labelledby="mx-plans-title">
        <header class="upg-header">
          <span class="upg-num">07</span>
          <span class="upg-line" aria-hidden="true"></span>
          <h2 id="mx-plans-title" class="upg-eyebrow">[ {t('detail.relatedPlans')} ]</h2>
        </header>
        <RelatedPlans
          locale={locale}
          plan={plan}
          title={t('detail.relatedPlans')}
          limit={3}
        />
      </section>

      <section class="upg-block upg-block--loose mx-recommend" id="also-interesting" data-reveal aria-labelledby="mx-related-title">
        <header class="upg-header">
          <span class="upg-num">08</span>
          <span class="upg-line" aria-hidden="true"></span>
          <h2 id="mx-related-title" class="upg-eyebrow">[ {t('detail.alsoInteresting')} ]</h2>
        </header>
        <div class="upg-related-stack">
          <RelatedRoutes type="mixedRoute" plan={plan} locale={locale} title={t('detail.relatedRoutes')} limit={3} />
          <RelatedGuides type="mixedRoute" plan={plan} locale={locale} title={t('detail.relatedGuides')} limit={3} />
          <RelatedEvents type="mixedRoute" plan={plan} locale={locale} title={t('detail.relatedEvents')} limit={3} />
        </div>
      </section>

      <div class="det-footer-orn" aria-hidden="true">
        <span></span>
        <i></i>
        <b>
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
            <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17.2l-6.2 4.1 2.4-7.4L2 9.4h7.6z"></path>
          </svg>
        </b>
        <i></i>
        <span></span>
      </div>

    </div>

</BaseLayout>

<script>
  import '@/scripts/pages/timeRouteDetail.ts';
</script>

<ReadingProgress />

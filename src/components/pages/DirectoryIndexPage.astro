---
import '@styles/pages/directory.css';
import BaseLayout from '@layouts/BaseLayout.astro';
import SubpageHero from '@components/shared/SubpageHero.astro';
import ScreenFrame from '@components/ui/ScreenFrame.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import { SITE_CONFIG } from '@config/site';
import { useTranslations } from '@i18n/utils';
import { getRoute } from '@utils/routes';
import type { VenueDirectoryEntry } from '@data/directories';
import type { Locale } from '@types';

interface Props {
  locale: Locale;
  entries: VenueDirectoryEntry[];
}

const { locale, entries } = Astro.props;
const t = useTranslations(locale);
const currentYear = new Date().getFullYear();
const basePath = locale === 'en' ? '/en/venues/' : '/salas/';
const title = t('directory.venuesTitle');
const description = t('directory.venuesDescription');
const h1 = t('directory.venuesH1');
const displayH1 = t('directory.venuesDisplayH1');
const intro = t('directory.venuesIntro');
const totalLabel = t('directory.totalVenues');
const metaLabel = t('directory.venueMeta');

const topEntries = entries.slice(0, 48);
const totalUpcoming = entries.reduce((sum, entry) => sum + entry.upcomingEvents.length, 0);

const breadcrumb = [
  { name: locale === 'en' ? 'Home' : 'Inicio', url: getRoute('home', locale) },
  { name: h1, url: basePath },
];

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: h1,
  itemListElement: topEntries.map((entry, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: entry.name,
    url: `${SITE_CONFIG.url}${basePath}${entry.slug}/`,
  })),
};

const heroMetadata = [
  { label: totalLabel, value: entries.length.toString(), icon: 'layers' },
  { label: t('directory.upcomingDates'), value: totalUpcoming.toString(), icon: 'calendar' },
  { label: t('directory.listedEvents'), value: topEntries.reduce((sum, entry) => sum + entry.events.length, 0).toString(), icon: 'clock' },
];
---

<BaseLayout locale={locale} title={title} description={description} breadcrumb={breadcrumb}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <SubpageHero
    locale={locale}
    title={displayH1}
    subtitle={t('directory.indexEyebrow')}
    eyebrow="GRN URBAN"
    eyebrowRight={`ED. ${currentYear}`}
    description={intro}
    ctaText={t('directory.browseEvents')}
    ctaLink={getRoute('events', locale)}
    secondaryCtaText={t('detail.allEvents')}
    secondaryCtaLink={getRoute('events', locale)}
    pageNumber="04"
    coordinates="37°10′N 3°36′W"
    metadata={heroMetadata}
    variant="compact"
  />

  <section class="dir-archive" aria-label={h1}>
    <div class="cin-grain" aria-hidden="true"></div>
    <ScreenFrame
      tagTopLeft={t('events.archiveFrameTagTopLeft')}
      tagTopRight={t('events.archiveFrameTagTopRight')}
      tagBottomLeft={t('events.archiveFrameTagBottomLeft')}
      tagBottomRight={t('events.archiveFrameTagBottomRight')}
    />

    <div class="dir-wrap">
      <SectionHeader
        eyebrow={t('directory.featuredList')}
        eyebrowYear={`${currentYear - 1} — ${currentYear}`}
        title={displayH1}
        size="compact"
        animateTitle={true}
        theme="cream"
      />

      <div class="dir-grid">
        {topEntries.map((entry, idx) => (
          <article class="dir-card" style={`--card-index: ${idx};`}>
            <a href={`${basePath}${entry.slug}/`}>
              <span class="dir-card__meta">{metaLabel}</span>
              <h3>{entry.name}</h3>
              <p>{entry.description[locale]}</p>
              <div class="dir-card__footer">
                <span>{entry.upcomingEvents.length} {t('directory.upcomingDates')}</span>
                <span>{entry.events.length} {t('directory.listedEvents')}</span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <script is:inline>
    (function() {
      const sectionHeaders = document.querySelectorAll('.dir-archive .section-header');
      if (sectionHeaders.length === 0) return;
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('in-view');
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 }
      );
      sectionHeaders.forEach(sh => io.observe(sh));
    })();
  </script>
</BaseLayout>

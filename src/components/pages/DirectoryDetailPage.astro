---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/layout/Breadcrumbs.astro';
import EventImage from '@components/ui/EventImage.astro';
import { SITE_CONFIG } from '@config/site';
import { useTranslations } from '@i18n/utils';
import { getEventDetailUrl, getRoute } from '@utils/routes';
import { formatFullDate, formatTime } from '@utils/dates';
import { formatPriceLabel } from '@utils/prices';
import type { ArtistDirectoryEntry, VenueDirectoryEntry } from '@data/directories';
import type { Locale } from '@types';

interface Props {
  locale: Locale;
  kind: 'artist' | 'venue';
  entry: ArtistDirectoryEntry | VenueDirectoryEntry;
}

const { locale, kind, entry } = Astro.props;
const t = useTranslations(locale);
const isArtist = kind === 'artist';
const indexPath = isArtist
  ? locale === 'en' ? '/en/artists/' : '/artistas/'
  : locale === 'en' ? '/en/venues/' : '/salas/';
const indexLabel = isArtist ? t('directory.allArtists') : t('directory.allVenues');
const detailMeta = isArtist ? t('directory.artistMeta') : t('directory.venueMeta');
const faq = [
  {
    question: isArtist ? t('directory.artistFaqQuestion') : t('directory.venueFaqQuestion'),
    answer: isArtist ? t('directory.artistFaqAnswer') : t('directory.venueFaqAnswer'),
  },
];
const primaryFaq = faq[0]!;
const breadcrumb = [
  { name: locale === 'en' ? 'Home' : 'Inicio', url: getRoute('home', locale) },
  { name: indexLabel, url: indexPath },
  { name: entry.name, url: `${indexPath}${entry.slug}/` },
];
const eventsToShow = entry.upcomingEvents.length > 0 ? entry.upcomingEvents : entry.events;
const eventListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: entry.title[locale],
  itemListElement: eventsToShow.slice(0, 12).map((event, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: event.title[locale],
    url: `${SITE_CONFIG.url}${getEventDetailUrl(event.slug, locale)}`,
  })),
};
---

<BaseLayout
  locale={locale}
  title={entry.title[locale]}
  description={entry.description[locale]}
  breadcrumb={breadcrumb}
  faq={faq}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(eventListSchema)} />

  <section class="dir-detail-hero">
    <div class="dir-detail-wrap">
      <Breadcrumbs variant="light" items={[
        { label: locale === 'en' ? 'Home' : 'Inicio', href: getRoute('home', locale) },
        { label: indexLabel, href: indexPath },
        { label: entry.name },
      ]} />
      <p class="dd-eyebrow">{detailMeta}</p>
      <h1>{entry.name}</h1>
      <p class="dd-intro">{entry.intro[locale]}</p>
      <div class="dd-stats">
        <span><strong>{entry.upcomingEvents.length}</strong>{t('directory.upcomingDates')}</span>
        <span><strong>{entry.events.length}</strong>{t('directory.listedEvents')}</span>
      </div>
    </div>
  </section>

  <main class="dir-detail-wrap dd-main">
    <section class="dd-events" aria-labelledby="dd-events-title">
      <header class="dd-section-head">
        <p>{entry.upcomingEvents.length > 0 ? t('directory.upcomingEvents') : t('directory.eventHistory')}</p>
        <h2 id="dd-events-title">{entry.upcomingEvents.length > 0 ? t('directory.upcomingEvents') : t('directory.pastEvents')}</h2>
      </header>

      {eventsToShow.length > 0 ? (
        <div class="dd-event-grid">
          {eventsToShow.slice(0, 12).map((event) => (
            <article class="dd-event-card">
              <a href={getEventDetailUrl(event.slug, locale)}>
                <div class="dd-event-card__media">
                  {(event.imageUrl || event.image) ? (
                    <EventImage event={event} alt={event.title[locale]} loading="lazy" sizes="(max-width: 768px) 100vw, 33vw" width={700} height={460} />
                  ) : (
                    <div class="dd-event-card__fallback"></div>
                  )}
                </div>
                <div class="dd-event-card__body">
                  <div class="dd-event-card__meta">
                    <time datetime={`${event.date}T${event.time}`}>{formatFullDate(event.date, locale)}</time>
                    <span>{formatTime(event.time, locale)}</span>
                  </div>
                  <h3>{event.title[locale]}</h3>
                  <p>{event.description[locale]}</p>
                  <div class="dd-event-card__footer">
                    <span>{event.venue}</span>
                    <strong>{formatPriceLabel(event, t)}</strong>
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="dd-empty">
          <p>{t('directory.noUpcoming')}</p>
          <a href={getRoute('events', locale)}>{t('directory.browseEvents')}</a>
        </div>
      )}
    </section>

    <section class="dd-faq" aria-labelledby="dd-faq-title">
      <header class="dd-section-head">
        <p>{t('directory.faqTitle')}</p>
        <h2 id="dd-faq-title">{t('directory.faqTitle')}</h2>
      </header>
      <article>
        <h3>{primaryFaq.question}</h3>
        <p>{primaryFaq.answer}</p>
      </article>
    </section>
  </main>
</BaseLayout>

<style>
  .dir-detail-hero {
    background: var(--color-bg);
    color: var(--color-text-primary);
    padding: 7rem 1.5rem 4rem;
  }

  .dir-detail-wrap {
    width: min(1180px, 100%);
    margin: 0 auto;
  }

  .dd-eyebrow,
  .dd-section-head p {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .dir-detail-hero h1 {
    font-family: var(--font-body);
    font-size: clamp(3rem, 8vw, 7rem);
    line-height: 0.92;
    margin: 0.8rem 0 1.2rem;
  }

  .dd-intro {
    max-width: 800px;
    color: var(--color-text-secondary);
    line-height: 1.7;
    font-size: 1.05rem;
  }

  .dd-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .dd-stats span {
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 999px;
    padding: 0.8rem 1rem;
    background: rgba(255,255,255,0.05);
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .dd-stats strong {
    color: var(--color-gold);
    margin-right: 0.45rem;
  }

  .dd-main {
    color: var(--s-ink);
    padding: 4rem 1.5rem 5rem;
  }

  .dd-events,
  .dd-faq {
    margin-bottom: 4rem;
  }

  .dd-section-head {
    border-bottom: 1px solid var(--s-border);
    padding-bottom: 1rem;
    margin-bottom: 1.5rem;
  }

  .dd-section-head h2 {
    font-family: var(--font-body);
    font-size: clamp(2rem, 4vw, 3.4rem);
    margin: 0;
  }

  .dd-event-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: var(--s-border);
    border: 1px solid var(--s-border);
  }

  .dd-event-card {
    background: var(--s-bg);
  }

  .dd-event-card a {
    color: inherit;
    text-decoration: none;
    min-height: 100%;
    display: grid;
  }

  .dd-event-card__media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--color-bg-card);
  }

  .dd-event-card__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(20%) contrast(1.05) brightness(0.84);
  }

  .dd-event-card__fallback {
    width: 100%;
    height: 100%;
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--color-accent) 26%, transparent), transparent),
      var(--color-bg-card);
  }

  .dd-event-card__body {
    padding: 1.25rem;
    display: grid;
    gap: 0.85rem;
  }

  .dd-event-card__meta,
  .dd-event-card__footer {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--s-ink) 58%, transparent);
  }

  .dd-event-card h3 {
    font-family: var(--font-body);
    font-size: 1.45rem;
    line-height: 1.08;
    margin: 0;
  }

  .dd-event-card p {
    margin: 0;
    color: color-mix(in srgb, var(--s-ink) 68%, transparent);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .dd-event-card__footer {
    border-top: 1px solid var(--s-border);
    padding-top: 0.85rem;
  }

  .dd-event-card__footer strong {
    color: var(--s-orange);
  }

  .dd-empty,
  .dd-faq article {
    border: 1px solid var(--s-border);
    background: var(--s-bg);
    padding: 1.5rem;
  }

  .dd-empty a {
    color: var(--s-orange);
    font-weight: 800;
  }

  .dd-faq h3 {
    font-family: var(--font-body);
    font-size: 1.4rem;
    margin: 0 0 0.8rem;
  }

  .dd-faq p {
    margin: 0;
    color: color-mix(in srgb, var(--s-ink) 68%, transparent);
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .dd-event-grid { grid-template-columns: 1fr; }
  }
</style>

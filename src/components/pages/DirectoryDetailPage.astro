---
import '@styles/pages/directory.css';
import BaseLayout from '@layouts/BaseLayout.astro';
import SubpageHero from '@components/shared/SubpageHero.astro';
import ScreenFrame from '@components/ui/ScreenFrame.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import EventArchiveCard from '@components/events/EventArchiveCard.astro';
import { SITE_CONFIG } from '@config/site';
import { useTranslations } from '@i18n/utils';
import { getEventDetailUrl, getRoute } from '@utils/routes';
import { venueDisplayTitle } from '@utils/page-display-title';
import type { VenueDirectoryEntry } from '@data/directories';
import type { Locale, EventCategory } from '@types';

interface Props {
  locale: Locale;
  entry: VenueDirectoryEntry;
}

const { locale, entry } = Astro.props;
const t = useTranslations(locale);
const currentYear = new Date().getFullYear();
const indexPath = locale === 'en' ? '/en/venues/' : '/salas/';
const indexLabel = t('directory.allVenues');
const detailMeta = t('directory.venueMeta');
const heroTitle = venueDisplayTitle(entry.name);

const faq = [
  {
    question: t('directory.venueFaqQuestion'),
    answer: t('directory.venueFaqAnswer'),
  },
];

const breadcrumb = [
  { name: locale === 'en' ? 'Home' : 'Inicio', url: getRoute('home', locale) },
  { name: indexLabel, url: indexPath },
  { name: entry.name, url: `${indexPath}${entry.slug}/` },
];

const eventsToShow = entry.upcomingEvents.length > 0 ? entry.upcomingEvents : entry.events;
const shouldIndexDirectoryEntry = entry.events.length >= 2;

const eventListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: entry.title[locale],
  itemListElement: eventsToShow.slice(0, 12).map((event, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: event.title[locale],
    url: `${SITE_CONFIG.url}${getEventDetailUrl(event.slug, locale)}`,
  })),
};

const categoryLabels: Record<EventCategory, string> = {
  concert: t('categories.concert').toUpperCase(),
  exhibition: t('categories.exhibition').toUpperCase(),
  festival: t('categories.festival').toUpperCase(),
  market: t('categories.market').toUpperCase(),
  theater: t('categories.theater').toUpperCase(),
  workshop: t('categories.workshop').toUpperCase(),
  'guided-tour': t('categories.guided-tour').toUpperCase(),
  cinema: t('categories.cinema').toUpperCase(),
  other: t('categories.other').toUpperCase(),
};

const heroMetadata = [
  { label: t('directory.upcomingDates'), value: entry.upcomingEvents.length.toString(), icon: 'calendar' },
  { label: t('directory.listedEvents'), value: entry.events.length.toString(), icon: 'layers' },
  { label: detailMeta, value: entry.name, icon: 'map-pin' },
];
---

<BaseLayout
  locale={locale}
  title={entry.title[locale]}
  description={entry.description[locale]}
  noindex={!shouldIndexDirectoryEntry}
  schemaType="venue"
  schemaData={entry}
  breadcrumb={breadcrumb}
  faq={faq}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(eventListSchema)} />

  <SubpageHero
    locale={locale}
    title={heroTitle}
    subtitle={detailMeta}
    eyebrow="GRN URBAN"
    eyebrowRight={`ED. ${currentYear}`}
    description={entry.intro[locale]}
    ctaText={indexLabel}
    ctaLink={indexPath}
    secondaryCtaText={t('detail.allEvents')}
    secondaryCtaLink={getRoute('events', locale)}
    pageNumber="05"
    coordinates="37°10′N 3°36′W"
    metadata={heroMetadata}
    variant="compact"
  />

  <section class="dir-archive" aria-label={entry.name}>
    <div class="cin-grain" aria-hidden="true"></div>
    <ScreenFrame
      tagTopLeft={t('events.archiveFrameTagTopLeft')}
      tagTopRight={t('events.archiveFrameTagTopRight')}
      tagBottomLeft={t('events.archiveFrameTagBottomLeft')}
      tagBottomRight={t('events.archiveFrameTagBottomRight')}
    />

    <div class="dir-wrap">
      <SectionHeader
        eyebrow={entry.upcomingEvents.length > 0 ? t('directory.upcomingEvents') : t('directory.eventHistory')}
        eyebrowYear={`${currentYear - 1} — ${currentYear}`}
        title={heroTitle}
        size="compact"
        animateTitle={true}
        theme="cream"
      />

      {eventsToShow.length > 0 ? (
        <div class="dir-grid">
          {eventsToShow.slice(0, 12).map((event, idx) => (
            <EventArchiveCard
              event={event}
              locale={locale}
              href={getEventDetailUrl(event.slug, locale)}
              categoryLabel={categoryLabels[event.category] ?? event.category.toUpperCase()}
              cardIndex={idx}
              loading={idx < 3 ? 'eager' : 'lazy'}
              sizes="(max-width: 768px) 100vw, 33vw"
            />
          ))}
        </div>
      ) : (
        <div class="dir-empty">
          <p>{t('directory.noUpcoming')}</p>
          <a href={getRoute('events', locale)}>{t('directory.browseEvents')}</a>
        </div>
      )}
    </div>
  </section>

  <section class="dir-archive" aria-label={t('directory.faqTitle')}>
    <div class="dir-wrap">
      <SectionHeader
        eyebrow={t('directory.faqTitle')}
        eyebrowYear={`${currentYear - 1} — ${currentYear}`}
        title={t('directory.faqTitle')}
        theme="cream"
      />
      <div class="dir-meta-list">
        {faq.map((item) => (
          <article>
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <script is:inline>
    (function() {
      const sectionHeaders = document.querySelectorAll('.dir-archive .section-header');
      if (sectionHeaders.length === 0) return;
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('in-view');
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 }
      );
      sectionHeaders.forEach(sh => io.observe(sh));
    })();
  </script>
</BaseLayout>

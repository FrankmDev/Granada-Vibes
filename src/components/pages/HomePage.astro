---
import { getIndexableEvents, getFeaturedRoutes, getAllPosts, getAllMixedRoutes } from '@data/index.js';
import BaseLayout from '@layouts/BaseLayout.astro';
import NavBar from '@components/layout/NavBar.astro';
import Footer from '@components/layout/Footer.astro';
import HeroSection from '@components/home/HeroSection.astro';
import EventsGridSection from '@components/home/EventsGridSection.astro';
import RoutesGridSection from '@components/home/RoutesGridSection.astro';
import BlogSection from '@components/home/BlogSection.astro';
import TimeRoutesSection from '@components/home/TimeRoutesSection.astro';
import HomeCTA from '@components/home/HomeCTA.astro';
import PlannerSection from '@components/home/PlannerSection.astro';
import type { Event, Locale } from '@types';

interface Props {
  locale: Locale;
}

const madridDateFormatter = new Intl.DateTimeFormat('en-CA', {
  timeZone: 'Europe/Madrid',
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});

const { locale } = Astro.props;
const currentPath = Astro.url.pathname;
const todayStr = madridDateFormatter.format(new Date());
const allEvents = getIndexableEvents();
const featuredRoutes = getFeaturedRoutes();
const allPosts = getAllPosts();
const allMixedRoutes = getAllMixedRoutes();
const featuredGuideSlugs = [
  'antes-de-llegar-granada',
  'granada-en-un-dia-itinerario',
  'tapas-gratis-granada',
];

const upcoming = allEvents
  .filter((event: Event) => event.date >= todayStr)
  .sort((left: Event, right: Event) => left.date.localeCompare(right.date));

const gridEvents = upcoming.slice(0, 6);
const displayRoutes = featuredRoutes.slice(0, 7);

const seo = locale === 'es'
  ? {
      title: 'GranadaUrban | Guía cultural de Granada',
      description:
        'Eventos, rutas, guías y planes en Granada. Descubre qué hacer hoy, este fin de semana y durante todo el año con una mirada local.',
    }
  : {
      title: 'GranadaUrban | Granada cultural guide',
      description:
        'Events, routes, guides and plans in Granada. Discover what to do today, this weekend and year-round with a local editorial view.',
    };

const ogImage = 'https://upload.wikimedia.org/wikipedia/commons/3/32/Alhambra_view_1102.jpg';
---

<BaseLayout
  locale={locale}
  title={seo.title}
  description={seo.description}
  ogImage={ogImage}
  schemaType="website"
>
  <NavBar slot="header" locale={locale} currentPath={currentPath} />

  <HeroSection locale={locale} />
  <TimeRoutesSection plans={allMixedRoutes} locale={locale} />
  <RoutesGridSection routes={displayRoutes} locale={locale} />
  <PlannerSection locale={locale} />
  <EventsGridSection events={gridEvents} locale={locale} />
  <BlogSection posts={allPosts} locale={locale} featuredSlugs={featuredGuideSlugs} />
  <HomeCTA locale={locale} />

  <Footer slot="footer" locale={locale} />
</BaseLayout>

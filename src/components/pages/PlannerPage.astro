---
import BaseLayout from '@layouts/BaseLayout.astro';
import SubpageHero from '@components/shared/SubpageHero.astro';
import PlanificadorForm from '@components/PlanificadorForm.astro';
import { lugares } from '@data/lugares';
import { useTranslations } from '@i18n/utils';
import { getRoute } from '@utils/routes';
import type { Locale } from '@types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const heroMetadata = [
  { label: t('planner.heroMetaPlaces'), value: `${lugares.length}+` },
  { label: t('planner.heroMetaCategories'), value: '8' },
  { label: t('planner.heroMetaPrice'), value: t('planner.heroMetaPriceValue') },
];

const ogImage = 'https://upload.wikimedia.org/wikipedia/commons/6/65/Granada%2C_Mirador_Ojo_de_Granada%2C_Sierra_Nevada.jpg';
const byTimePath = getRoute('byTime', locale);
---

<BaseLayout
  locale={locale}
  title={t('planner.seoTitle')}
  description={t('planner.seoDescription')}
  ogImage={ogImage}
  schemaType="planner"
  schemaData={{
    name: t('planner.schemaName'),
    description: t('planner.schemaDescription'),
    applicationCategory: 'TravelApplication',
    operatingSystem: 'Web',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
  }}
>
  <SubpageHero
    locale={locale}
    title={t('planner.heroTitle')}
    subtitle={t('planner.heroSubtitle')}
    eyebrow={t('planner.heroEyebrow')}
    eyebrowRight={t('planner.heroEyebrowRight')}
    description={t('planner.heroDescription')}
    ctaText={t('planner.heroCta')}
    ctaLink="#planner-app"
    secondaryCtaText={t('nav.byTime')}
    secondaryCtaLink={byTimePath}
    pageNumber="05"
    coordinates="37°10′N · 3°35′W"
    metadata={heroMetadata}
    variant="compact"
  />

  <PlanificadorForm locale={locale} />
</BaseLayout>

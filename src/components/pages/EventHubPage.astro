---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/layout/Breadcrumbs.astro';
import EventImage from '@components/ui/EventImage.astro';
import { getAllEvents } from '@data/index.js';
import { eventHubs, type EventHubConfig } from '@data/seo/event-hubs.js';
import { useTranslations } from '@i18n/utils';
import { getEventDetailUrl, getRoute } from '@utils/routes';
import { formatFullDate, formatTime } from '@utils/dates';
import { formatPriceLabel, getPriceStatus } from '@utils/prices';
import type { Event, Locale } from '@types';

interface Props {
  locale: Locale;
  config: EventHubConfig;
}

const { locale, config } = Astro.props;
const t = useTranslations(locale);
const isEnglish = locale === 'en';

const today = new Date();
today.setHours(0, 0, 0, 0);

function eventDate(event: Event): Date {
  const date = new Date(event.date);
  date.setHours(0, 0, 0, 0);
  return date;
}

function isUpcoming(event: Event): boolean {
  return eventDate(event) >= today;
}

function isToday(event: Event): boolean {
  return eventDate(event).getTime() === today.getTime();
}

function getWeekendWindow(): { start: Date; end: Date } {
  const day = today.getDay();
  const daysUntilFriday = day <= 5 ? 5 - day : 6;
  const start = new Date(today);
  start.setDate(today.getDate() + daysUntilFriday);
  const end = new Date(start);
  end.setDate(start.getDate() + 2);
  return { start, end };
}

function isThisWeekend(event: Event): boolean {
  const { start, end } = getWeekendWindow();
  const date = eventDate(event);
  return date >= start && date <= end;
}

function matchesHub(event: Event): boolean {
  if (!isUpcoming(event)) return false;
  if (config.kind === 'today') return isToday(event);
  if (config.kind === 'weekend') return isThisWeekend(event);
  if (config.category && event.category !== config.category) return false;
  if (config.freeOnly && getPriceStatus(event) !== 'free') return false;
  if (config.venueIncludes) {
    const venue = event.venue.toLowerCase();
    return config.venueIncludes.some((needle) => venue.includes(needle));
  }
  return true;
}

const events = getAllEvents()
  .filter(matchesHub)
  .sort((a, b) => a.date.localeCompare(b.date) || a.time.localeCompare(b.time));

const featuredEvents = events.slice(0, 6);
const nearbyEvents = getAllEvents()
  .filter((event) => isUpcoming(event) && !events.some((item) => item.id === event.id))
  .sort((a, b) => a.date.localeCompare(b.date) || a.time.localeCompare(b.time))
  .slice(0, 4);

const breadcrumb = [
  { name: isEnglish ? 'Home' : 'Inicio', url: getRoute('home', locale) },
  { name: isEnglish ? 'Events' : 'Eventos', url: getRoute('events', locale) },
  { name: config.h1[locale], url: locale === 'en' ? config.englishPath : config.spanishPath },
];

const hubLinks = eventHubs
  .filter((hub) => hub.id !== config.id)
  .slice(0, 5)
  .map((hub) => ({
    href: locale === 'en' ? hub.englishPath : hub.spanishPath,
    label: hub.h1[locale],
  }));

const faq = config.faqs.map((item) => ({
  question: item.question[locale],
  answer: item.answer[locale],
}));
---

<BaseLayout
  locale={locale}
  title={config.title[locale]}
  description={config.description[locale]}
  breadcrumb={breadcrumb}
  faq={faq}
>
  <section class="hub-hero">
    <div class="hub-hero__inner">
      <Breadcrumbs variant="light" items={[
        { label: isEnglish ? 'Home' : 'Inicio', href: getRoute('home', locale) },
        { label: isEnglish ? 'Events' : 'Eventos', href: getRoute('events', locale) },
        { label: config.h1[locale] },
      ]} />

      <div class="hub-hero__grid">
        <div class="hub-hero__copy">
          <p class="hub-eyebrow">{config.eyebrow[locale]}</p>
          <h1>{config.h1[locale]}</h1>
          <p class="hub-intro">{config.intro[locale]}</p>
          <div class="hub-stats" aria-label={t('seoHub.statsLabel')}>
            <span><strong>{events.length}</strong>{t('seoHub.eventsCount')}</span>
            <span><strong>{nearbyEvents.length}</strong>{t('seoHub.alternativesCount')}</span>
          </div>
        </div>
        <aside class="hub-actions" aria-label={t('seoHub.quickLinks')}>
          <a class="hub-primary-link" href={getRoute('events', locale)}>{config.ctaLabel[locale]}</a>
          <div class="hub-link-list">
            {hubLinks.map((link) => (
              <a href={link.href}>{link.label}</a>
            ))}
          </div>
        </aside>
      </div>
    </div>
  </section>

  <main class="hub-main">
    <section class="hub-events" aria-labelledby="hub-events-title">
      <div class="hub-section-head">
        <p>{t('seoHub.upcomingEyebrow')}</p>
        <h2 id="hub-events-title">{t('seoHub.upcomingTitle')}</h2>
      </div>

      {featuredEvents.length > 0 ? (
        <div class="hub-card-grid">
          {featuredEvents.map((event) => (
            <article class="hub-event-card">
              <a href={getEventDetailUrl(event.slug, locale)}>
                <div class="hub-event-card__media">
                  {(event.imageUrl || event.image) ? (
                    <EventImage event={event} alt={event.title[locale]} loading="lazy" sizes="(max-width: 768px) 100vw, 33vw" width={700} height={480} />
                  ) : (
                    <div class="hub-event-card__fallback"></div>
                  )}
                </div>
                <div class="hub-event-card__body">
                  <div class="hub-event-card__meta">
                    <time datetime={`${event.date}T${event.time}`}>{formatFullDate(event.date, locale)}</time>
                    <span>{formatTime(event.time, locale)}</span>
                  </div>
                  <h3>{event.title[locale]}</h3>
                  <p>{event.description[locale]}</p>
                  <div class="hub-event-card__footer">
                    <span>{event.venue}</span>
                    <strong>{formatPriceLabel(event, t)}</strong>
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="hub-empty">
          <h2>{config.emptyTitle[locale]}</h2>
          <p>{config.emptyText[locale]}</p>
          <a href={getRoute('events', locale)}>{t('detail.allEvents')}</a>
        </div>
      )}
    </section>

    {nearbyEvents.length > 0 && (
      <section class="hub-more" aria-labelledby="hub-more-title">
        <div class="hub-section-head">
          <p>{t('seoHub.moreEyebrow')}</p>
          <h2 id="hub-more-title">{t('seoHub.moreTitle')}</h2>
        </div>
        <div class="hub-more-list">
          {nearbyEvents.map((event) => (
            <a href={getEventDetailUrl(event.slug, locale)}>
              <span>{event.title[locale]}</span>
              <small>{formatFullDate(event.date, locale)} · {event.venue}</small>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="hub-faq" aria-labelledby="hub-faq-title">
      <div class="hub-section-head">
        <p>{t('seoHub.faqEyebrow')}</p>
        <h2 id="hub-faq-title">{t('seoHub.faqTitle')}</h2>
      </div>
      <div class="hub-faq-list">
        {config.faqs.map((item) => (
          <article>
            <h3>{item.question[locale]}</h3>
            <p>{item.answer[locale]}</p>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .hub-hero {
    background: var(--color-bg);
    color: var(--color-text-primary);
    padding: 7rem 1.5rem 4rem;
    position: relative;
    overflow: hidden;
  }

  .hub-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(120deg, color-mix(in srgb, var(--color-accent) 18%, transparent), transparent 38%),
      radial-gradient(circle at 85% 10%, color-mix(in srgb, var(--color-gold) 18%, transparent), transparent 28%);
    opacity: 0.65;
    pointer-events: none;
  }

  .hub-hero__inner,
  .hub-main {
    width: min(1180px, 100%);
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hub-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 3rem;
    align-items: end;
    margin-top: 3rem;
  }

  .hub-eyebrow,
  .hub-section-head p {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin: 0 0 0.9rem;
  }

  .hub-hero h1 {
    font-family: var(--font-body);
    font-size: clamp(3rem, 8vw, 7.5rem);
    line-height: 0.92;
    max-width: 900px;
    margin: 0;
  }

  .hub-intro {
    max-width: 720px;
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin: 1.6rem 0 0;
  }

  .hub-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .hub-stats span,
  .hub-primary-link,
  .hub-link-list a {
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.05);
    color: var(--color-text-primary);
    border-radius: 999px;
    padding: 0.8rem 1rem;
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .hub-stats strong {
    color: var(--color-gold);
    margin-right: 0.45rem;
  }

  .hub-actions {
    display: grid;
    gap: 1rem;
  }

  .hub-primary-link {
    background: var(--color-accent);
    color: var(--color-bg);
    text-align: center;
    border-color: var(--color-accent);
  }

  .hub-link-list {
    display: grid;
    gap: 0.65rem;
  }

  .hub-link-list a {
    border-radius: 8px;
  }

  .hub-main {
    color: var(--s-ink);
    padding: 4rem 1.5rem 5rem;
  }

  .hub-events,
  .hub-more,
  .hub-faq {
    margin-bottom: 4.5rem;
  }

  .hub-section-head {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    align-items: end;
    border-bottom: 1px solid var(--s-border);
    padding-bottom: 1rem;
    margin-bottom: 1.5rem;
  }

  .hub-section-head h2 {
    font-family: var(--font-body);
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1;
    margin: 0;
  }

  .hub-card-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: var(--s-border);
    border: 1px solid var(--s-border);
  }

  .hub-event-card {
    background: var(--s-bg);
  }

  .hub-event-card a {
    color: inherit;
    text-decoration: none;
    display: grid;
    min-height: 100%;
  }

  .hub-event-card__media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--color-bg-card);
  }

  .hub-event-card__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(20%) contrast(1.05) brightness(0.82);
    transform: scale(1.04);
    transition: 1s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .hub-event-card:hover .hub-event-card__media :global(img) {
    filter: grayscale(0%) brightness(0.9);
    transform: scale(1);
  }

  .hub-event-card__fallback {
    width: 100%;
    height: 100%;
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--color-accent) 26%, transparent), transparent),
      var(--color-bg-card);
  }

  .hub-event-card__body {
    padding: 1.35rem;
    display: grid;
    gap: 0.9rem;
  }

  .hub-event-card__meta,
  .hub-event-card__footer {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--s-ink) 58%, transparent);
  }

  .hub-event-card h3 {
    font-family: var(--font-body);
    font-size: 1.45rem;
    line-height: 1.08;
    margin: 0;
  }

  .hub-event-card p {
    margin: 0;
    color: color-mix(in srgb, var(--s-ink) 68%, transparent);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .hub-event-card__footer {
    border-top: 1px solid var(--s-border);
    padding-top: 0.9rem;
  }

  .hub-event-card__footer strong {
    color: var(--s-orange);
  }

  .hub-empty {
    border: 1px solid var(--s-border);
    padding: 2rem;
    background: color-mix(in srgb, var(--s-bg) 84%, white);
  }

  .hub-empty h2 {
    font-family: var(--font-body);
    margin: 0 0 0.7rem;
  }

  .hub-empty p {
    color: color-mix(in srgb, var(--s-ink) 68%, transparent);
    margin: 0 0 1rem;
  }

  .hub-empty a {
    color: var(--s-orange);
    font-weight: 800;
  }

  .hub-more-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    background: var(--s-border);
    border: 1px solid var(--s-border);
  }

  .hub-more-list a {
    background: var(--s-bg);
    color: inherit;
    text-decoration: none;
    padding: 1.2rem;
    display: grid;
    gap: 0.35rem;
  }

  .hub-more-list span {
    font-family: var(--font-body);
    font-size: 1.2rem;
    line-height: 1.15;
  }

  .hub-more-list small {
    font-family: var(--font-display);
    color: color-mix(in srgb, var(--s-ink) 58%, transparent);
  }

  .hub-faq-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    background: var(--s-border);
    border: 1px solid var(--s-border);
  }

  .hub-faq-list article {
    background: var(--s-bg);
    padding: 1.5rem;
  }

  .hub-faq-list h3 {
    font-family: var(--font-body);
    font-size: 1.3rem;
    line-height: 1.15;
    margin: 0 0 0.8rem;
  }

  .hub-faq-list p {
    color: color-mix(in srgb, var(--s-ink) 68%, transparent);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 880px) {
    .hub-hero__grid,
    .hub-card-grid,
    .hub-more-list,
    .hub-faq-list {
      grid-template-columns: 1fr;
    }

    .hub-hero {
      padding-top: 6rem;
    }

    .hub-section-head {
      display: block;
    }
  }
</style>

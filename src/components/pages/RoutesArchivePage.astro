---
import '@styles/pages/routes-archive.css';
import BaseLayout from '@layouts/BaseLayout.astro';
import SubpageHero from '@components/shared/SubpageHero.astro';
import RoutesGridSection from '@components/home/RoutesGridSection.astro';
import CinematicCTA from '@components/shared/CinematicCTA.astro';
import RoutesArchiveFilter from '@components/routes/RoutesArchiveFilter.astro';
import RoutesArchiveGrid from '@components/routes/RoutesArchiveGrid.astro';
import MixedRoutesFullGrid from '@components/routes/MixedRoutesFullGrid.astro';
import { getAllRoutes } from '@data/index';
import { useTranslations } from '@i18n/utils';
import { getRoute } from '@utils/routes';
import type { RouteCategory, RouteDifficulty, Locale } from '@types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const allRoutes = getAllRoutes();

const categories: RouteCategory[] = ['viewpoint', 'tapas', 'monuments', 'hiking', 'photography', 'secrets', 'history', 'flamenco'];
const difficulties: RouteDifficulty[] = ['easy', 'moderate', 'challenging'];

const difficultyLabels: Record<RouteDifficulty, string> = {
  easy:        t('difficulty.easy'),
  moderate:    t('difficulty.moderate'),
  challenging: t('difficulty.challenging'),
};

const difficultyColors: Record<RouteDifficulty, string> = {
  easy:        '#4a9e6b',
  moderate:    '#d4873a',
  challenging: '#c94a4a',
};

const categoryLabels: Record<RouteCategory, string> = {
  viewpoint:   t('categories.viewpoint'),
  tapas:       t('categories.tapas'),
  monuments:   t('categories.monuments'),
  hiking:      t('categories.hiking'),
  photography: t('categories.photography'),
  secrets:     t('categories.secrets'),
  history:     t('categories.history'),
  flamenco:    t('categories.flamenco'),
};

const categoryIcons: Record<RouteCategory, string> = {
  viewpoint:   '○',
  tapas:       '◐',
  monuments:   '◈',
  hiking:      '△',
  photography: '◉',
  secrets:     '◆',
  history:     '◫',
  flamenco:    '◎',
};

const ROUTE_FALLBACKS: Partial<Record<RouteCategory, string>> & { default: string } = {
  tapas:       'https://upload.wikimedia.org/wikipedia/commons/a/a0/Granada%2C_La_Fontana%2C_tapas.jpg',
  monuments:   'https://upload.wikimedia.org/wikipedia/commons/0/0c/Cathedral_%26_Capilla_Real_Granada_Spain.jpg',
  hiking:      'https://upload.wikimedia.org/wikipedia/commons/c/c6/Carrera_del_Darro_de_Granada.jpg',
  photography: 'https://upload.wikimedia.org/wikipedia/commons/f/f0/Aa_view_from_sacromonte_2016_at_granada_in_spain.jpg',
  viewpoint:   'https://upload.wikimedia.org/wikipedia/commons/3/32/Alhambra_view_1102.jpg',
  secrets:     'https://upload.wikimedia.org/wikipedia/commons/0/00/Realejo-San_Matias%2C_Granada%2C_Spain_-_panoramio_-_georama_%289%29.jpg',
  history:     'https://upload.wikimedia.org/wikipedia/commons/f/f0/Corral_del_Carbon_de_Granada_01.jpg',
  flamenco:    'https://upload.wikimedia.org/wikipedia/commons/a/a3/Granada_Spain_Tablao-flamenca-Albaic%C3%ADn-01.jpg',
  default:     'https://upload.wikimedia.org/wikipedia/commons/3/32/Alhambra_view_1102.jpg',
};

const ogImage = 'https://upload.wikimedia.org/wikipedia/commons/3/32/Alhambra_view_1102.jpg';

const heroMetadata = [
  { label: t('routes.heroMetaTotalLabel'), value: allRoutes.length.toString() },
  { label: t('routes.heroMetaCategoriesLabel'), value: categories.length.toString() },
  { label: t('routes.heroMetaDifficultiesLabel'), value: difficulties.length.toString() },
];

const eventsPath = getRoute('events', locale);
---

<BaseLayout 
  locale={locale} 
  title={t('routes.title')}
  description={t('routes.pageDescription')}
  ogImage={ogImage}
>
  <!-- CINEMATIC HERO -->
  <SubpageHero
    locale={locale}
    title={t('routes.heroTitle')}
    subtitle={t('routes.heroSubtitle')}
    eyebrow={t('routes.heroEyebrow')}
    eyebrowRight={t('routes.heroEyebrowRight')}
    description={t('routes.heroDescription')}
    ctaText={t('routes.heroCta')}
    ctaLink="#featured-routes"
    secondaryCtaText={t('routes.heroSecondaryCta')}
    secondaryCtaLink="#time-plans"
    pageNumber="02"
    coordinates="37°11′N 3°36′W"
    metadata={heroMetadata}
    variant="compact"
  />

  <!-- CINEMATIC ACCORDION SECTION -->
  <div id="featured-routes" class="routes-accordion-wrap">
    <RoutesGridSection routes={allRoutes} locale={locale} />
  </div>

  <!-- FILTER + GRID SECTION -->
  <section class="filter-section" id="routes-grid">
    <div class="filter-backdrop">
      <div class="backdrop-pattern"></div>
    </div>

    <RoutesArchiveFilter
      locale={locale}
      categories={categories}
      categoryLabels={categoryLabels}
      categoryIcons={categoryIcons}
      allRoutes={allRoutes}
    />

    <div class="filter-container">
      <RoutesArchiveGrid
        locale={locale}
        routes={allRoutes}
        categoryLabels={categoryLabels}
        categoryIcons={categoryIcons}
        difficultyLabels={difficultyLabels}
        difficultyColors={difficultyColors}
        routeFallbacks={ROUTE_FALLBACKS}
      />
    </div>
  </section>

  <!-- TIME PLANS SECTION -->
  <MixedRoutesFullGrid locale={locale} />

  <!-- CTA SECTION -->
  <CinematicCTA 
    locale={locale}
    ctaPrimaryText={t('routes.ctaBtn')}
    ctaPrimaryLink={eventsPath}
    ctaSecondaryText={t('routes.heroSecondaryCta')}
    ctaSecondaryLink="#time-plans"
  />

  <script>
    import '../../scripts/pages/routesArchive.ts';
  </script>
</BaseLayout>

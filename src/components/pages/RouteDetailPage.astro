---
import BaseLayout from '@layouts/BaseLayout.astro';
import RouteDetailHero from '@components/routes/RouteDetailHero.astro';
import Footer from '@components/layout/Footer.astro';
import OptimizedImage from '@components/ui/OptimizedImage.astro';
import ShareButton from '@components/ui/ShareButton.astro';
import { getAllRoutes } from '@data/index.js';
import { useTranslations } from '@i18n/utils';
import { getRoute, getRouteDetailUrl, getBlogDetailUrl, getEventDetailUrl } from '@utils/routes';
import { formatDistance, formatDuration } from '@utils/dates';
import { formatFullDate } from '@utils/dates';
import { getRelatedPostsForRoute, getRelatedEventsForRoute } from '@utils/cross-links';
import CrossLinksSection from '@components/ui/CrossLinksSection.astro';
import type { Locale, Neighborhood, Route, RouteHighlight, RouteTip } from '@types';
import '@styles/pages/route-detail.css';

interface Props {
  locale: Locale;
  route: Route;
}

const { locale, route } = Astro.props;
const t = useTranslations(locale);
const isEnglish = locale === 'en';

const categoryUrl = `${getRoute('routes', locale)}?type=${route.category}`;

const copy = isEnglish
  ? {
      breadcrumb: {
        home: 'Home',
        listing: 'Routes',
      },
      sections: {
        aboutEyebrow: '[ About the route ]',
        aboutTitle: 'Description',
        neighborhoods: 'Neighbourhoods:',
        itineraryEyebrow: '[ ITINERARY ]',
        itineraryTitle: 'The itinerary',
        tipsEyebrow: '[ Recommendation ]',
        tipsTitle: 'Local tips',
        tags: '[ Tags ]',
        timeLabel: 'TIME',
        bringLabel: 'WHAT TO BRING',
      },
      faq: {
        durationQuestion: 'How long does this route take?',
        durationAnswer: `The route takes approximately ${formatDuration(route.duration, locale)}.`,
        difficultyQuestion: 'What is the difficulty level?',
        difficultyAnswer: `The difficulty level is ${t(`difficulty.${route.difficulty}`)}.`,
      },
      share: {
        label: 'Share route',
        copied: 'Copied!',
      },
      seo:
        `Route "${route.title[locale]}" through ${route.neighborhoods.map((neighborhood: Neighborhood) => t(`neighborhoods.${neighborhood}`)).join(', ')} in Granada — ${formatDuration(route.duration, locale)} of ${t(`categories.${route.category}`).toLowerCase()}, ${formatDistance(route.distance, locale)}. Difficulty: ${t(`difficulty.${route.difficulty}`).toLowerCase()}. Discover practical tips, must-see spots and how to prepare the perfect itinerary.`,
      nav: {
        prev: 'Previous route',
        next: 'Next route',
      },
    }
  : {
      breadcrumb: {
        home: 'Inicio',
        listing: 'Rutas',
      },
      sections: {
        aboutEyebrow: '[ Sobre la ruta ]',
        aboutTitle: 'Descripción',
        neighborhoods: 'Barrios:',
        itineraryEyebrow: '[ RECORRIDO ]',
        itineraryTitle: 'El itinerario',
        tipsEyebrow: '[ Recomendación ]',
        tipsTitle: 'Tips de local',
        tags: '[ Etiquetas ]',
        timeLabel: 'HORARIO',
        bringLabel: 'QUÉ LLEVAR',
      },
      faq: {
        durationQuestion: '¿Cuánto dura esta ruta?',
        durationAnswer: `La ruta tiene una duración aproximada de ${formatDuration(route.duration, locale)}.`,
        difficultyQuestion: '¿Qué nivel de dificultad tiene?',
        difficultyAnswer: `La dificultad es ${t(`difficulty.${route.difficulty}`).toLowerCase()}.`,
      },
      share: {
        label: 'Compartir ruta',
        copied: '¡Copiado!',
      },
      seo:
        `Ruta "${route.title[locale]}" por ${route.neighborhoods.map((neighborhood: Neighborhood) => t(`neighborhoods.${neighborhood}`)).join(', ')} en Granada — ${formatDuration(route.duration, locale)} de ${t(`categories.${route.category}`).toLowerCase()}, ${formatDistance(route.distance, locale)}. Dificultad ${t(`difficulty.${route.difficulty}`).toLowerCase()}. Descubre consejos prácticos, puntos imprescindibles y cómo preparar el itinerario perfecto.`,
      nav: {
        prev: 'Ruta anterior',
        next: 'Ruta siguiente',
      },
    };

const allRoutes = getAllRoutes();
const routeIndex = allRoutes.findIndex((r) => r.id === route.id);
const prevRoute = routeIndex > 0 ? allRoutes[routeIndex - 1] : null;
const nextRoute = routeIndex < allRoutes.length - 1 ? allRoutes[routeIndex + 1] : null;

const relatedRoutes = allRoutes
  .filter((candidate) => candidate.category === route.category && candidate.id !== route.id)
  .slice(0, 3);

if (relatedRoutes.length < 3) {
  const moreRoutes = allRoutes
    .filter(
      (candidate) =>
        candidate.difficulty === route.difficulty &&
        candidate.id !== route.id &&
        !relatedRoutes.some((related) => related.id === candidate.id)
    )
    .slice(0, 3 - relatedRoutes.length);

  relatedRoutes.push(...moreRoutes);
}

const relatedPosts = getRelatedPostsForRoute(route, 2);
const relatedEventsForRoute = getRelatedEventsForRoute(route, 2);

const crossLinks = [
  ...relatedPosts.map((p) => ({
    url: getBlogDetailUrl(p.slug, locale),
    title: p.title[locale],
    meta: `${t('blog.readingTime', { minutes: p.readingTime })} · ${t(`blog.categories.${p.category}`)}`,
    image: p.image,
  })),
  ...relatedEventsForRoute.map((e) => ({
    url: getEventDetailUrl(e.slug, locale),
    title: e.title[locale],
    meta: `${formatFullDate(e.date, locale)} · ${t(`categories.${e.category}`)}`,
    image: e.imageUrl || e.image,
  })),
].slice(0, 4);

const ogImage = route.image || 'https://images.unsplash.com/photo-1523531294919-4bcd7c65e216?w=1200&h=630&fit=crop&q=80';
const breadcrumb = [
  { name: copy.breadcrumb.home, url: getRoute('home', locale) },
  { name: copy.breadcrumb.listing, url: getRoute('routes', locale) },
  { name: route.title[locale], url: getRouteDetailUrl(route.slug, locale) },
];

const faq = route.tips.slice(0, 2).map((tip: RouteTip) => ({
  question: tip.title[locale],
  answer: tip.content[locale],
}));

faq.push(
  { question: copy.faq.durationQuestion, answer: copy.faq.durationAnswer },
  { question: copy.faq.difficultyQuestion, answer: copy.faq.difficultyAnswer },
);

const distString = formatDistance(route.distance, locale);
const distValue = distString.replace(/[^\d.,]/g, '').trim();
const distUnit = distString.replace(/[\d.,]/g, '').trim();
---

<BaseLayout
  locale={locale}
  title={route.title[locale]}
  description={copy.seo}
  ogImage={ogImage}
  schemaType="route"
  schemaData={route}
  breadcrumb={breadcrumb}
  faq={faq.length > 0 ? faq : undefined}
>
  <RouteDetailHero route={route} locale={locale} />

  <div class="det-page route-page-override">
    <div class="det-content-wrap">
      <div class="upgraded-layout">
        <main id="main-content" class="upgraded-main">
          <article class="upg-block" data-reveal>
            <div class="upg-block-bg"></div>
            <header class="upg-header">
              <span class="upg-num">01</span>
              <div class="upg-line"></div>
              <span class="upg-eyebrow">{copy.sections.aboutEyebrow}</span>
            </header>

            <h2 class="upg-title">{copy.sections.aboutTitle}</h2>

            <div class="upg-body content-rich">
              <p class="upg-lead">{route.description[locale]}</p>
              {route.longDescription && <p class="upg-text-secondary">{route.longDescription[locale]}</p>}
            </div>

            {route.neighborhoods.length > 0 && (
              <div class="upg-route-neighs">
                <span class="upg-rn-label">{copy.sections.neighborhoods}</span>
                <div class="upg-tags-list">
                  {route.neighborhoods.map((neighborhood: Neighborhood) => (
                    <a href={`${getRoute('routes', locale)}?neighborhood=${neighborhood}`} class="upg-badge ghost" style="text-decoration:none;">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                      {t(`neighborhoods.${neighborhood}`)}
                    </a>
                  ))}
                </div>
              </div>
            )}

            <div class="upg-meta-links" style="display:flex; flex-wrap:wrap; gap:0.75rem; margin-top:2rem;">
              <a href={categoryUrl} class="upg-badge ghost" style="text-decoration:none;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
                {t(`categories.${route.category}`)}
              </a>
            </div>
          </article>

          {route.highlights.length > 0 && (
            <article class="upg-block" id="itinerary" data-reveal>
              <div class="upg-block-bg"></div>
              <header class="upg-header">
                <span class="upg-num">02</span>
                <div class="upg-line"></div>
                <span class="upg-eyebrow">{copy.sections.itineraryEyebrow}</span>
              </header>
              <h2 class="upg-title">{copy.sections.itineraryTitle}</h2>

              <div class="upg-highlights">
                {route.highlights.map((highlight: RouteHighlight, index: number) => (
                  <div class="upg-hl-item" style={`--hl-delay: ${index * 0.1}s`}>
                    <div class="upg-hl-num-wrap">
                      <span class="upg-hl-num">{(index + 1).toString().padStart(2, '0')}</span>
                    </div>
                    <div class="upg-hl-content">
                      <h3 class="tl-title" style="margin-bottom:0.4rem; font-family: var(--font-display); font-size:1.1rem; color:var(--s-ink);">{highlight.title[locale]}</h3>
                      <p class="upg-hl-text" style="padding-top:0;">{highlight.description[locale]}</p>
                      {(highlight.address || highlight.price || highlight.hours || highlight.duration || highlight.tip) && (
                        <div class="upg-hl-meta" style="margin-top: 1rem; padding: 1rem; background: rgba(26,22,25,0.03); border-radius: 12px; border: 1px solid var(--s-border);">
                          <div style="font-family: var(--font-display); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; color: var(--s-ink-3); text-transform: uppercase; margin-bottom: 0.5rem;">{t('detail.stopInfo')}</div>
                          <div style="display: flex; flex-direction: column; gap: 0.35rem;">
                            {highlight.address && (
                              <div style="display: flex; align-items: flex-start; gap: 0.5rem; font-family: var(--font-display); font-size: 0.8rem; color: var(--s-ink-2);">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" style="flex-shrink: 0; margin-top: 2px; color: var(--s-orange);"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                <span>{highlight.address[locale]}</span>
                              </div>
                            )}
                            {highlight.duration && (
                              <div style="display: flex; align-items: center; gap: 0.5rem; font-family: var(--font-display); font-size: 0.8rem; color: var(--s-ink-2);">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" style="flex-shrink: 0; color: var(--s-orange);"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                                <span>{formatDuration(highlight.duration, locale)}</span>
                              </div>
                            )}
                            {highlight.price && (
                              <div style="display: flex; align-items: center; gap: 0.5rem; font-family: var(--font-display); font-size: 0.8rem; color: var(--s-ink-2);">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" style="flex-shrink: 0; color: var(--s-orange);"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                <span>{highlight.price[locale]}</span>
                              </div>
                            )}
                            {highlight.hours && (
                              <div style="display: flex; align-items: center; gap: 0.5rem; font-family: var(--font-display); font-size: 0.8rem; color: var(--s-ink-2);">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" style="flex-shrink: 0; color: var(--s-orange);"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                <span>{highlight.hours[locale]}</span>
                              </div>
                            )}
                            {highlight.tip && (
                              <div style="display: flex; align-items: flex-start; gap: 0.5rem; font-family: var(--font-display); font-size: 0.8rem; color: var(--s-ink-2); margin-top: 0.25rem; padding-top: 0.35rem; border-top: 1px dashed var(--s-border);">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" style="flex-shrink: 0; margin-top: 2px; color: var(--s-gold);"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                <span>{highlight.tip[locale]}</span>
                              </div>
                            )}
                          </div>
                        </div>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </article>
          )}

          {route.tips.length > 0 && (
            <article class="upg-block block-tips" id="tips" data-reveal>
              <div class="upg-block-bg"></div>
              <header class="upg-header">
                <span class="upg-num">03</span>
                <div class="upg-line"></div>
                <span class="upg-eyebrow">{copy.sections.tipsEyebrow}</span>
              </header>
              <h2 class="upg-title">{copy.sections.tipsTitle}</h2>

              <div class="upg-tips-content" style="flex-direction: column;">
                {route.tips.map((tip: RouteTip) => (
                  <div style="display: flex; gap: 1.5rem; align-items: flex-start; margin-bottom: 2rem;">
                    <div class="upg-tips-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </div>
                    <div>
                      <h3 style="font-family: var(--font-display); font-size: 1.05rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--s-ink);">{tip.title[locale]}</h3>
                      <p class="upg-tips-text" style="font-style: normal;">{tip.content[locale]}</p>
                    </div>
                  </div>
                ))}
              </div>
            </article>
          )}

          {(route.startingPoint || route.endingPoint || route.howToGetThere || route.estimatedBudget || route.whoIsItFor || route.accessibility || route.bestTimeToVisit) && (
            <article class="upg-block" id="practical-info" data-reveal>
              <div class="upg-block-bg"></div>
              <header class="upg-header">
                <span class="upg-num">04</span>
                <div class="upg-line"></div>
                <span class="upg-eyebrow">[ {t('detail.practicalInfo')} ]</span>
              </header>
              <h2 class="upg-title">{t('detail.routeInfo')}</h2>

              <div class="upg-body content-rich" style="display: flex; flex-direction: column; gap: 1.5rem;">
                {route.startingPoint && (
                  <div>
                    <h4 style="font-family: var(--font-display); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--s-ink-3); margin-bottom: 0.35rem;">{t('detail.startingPoint')}</h4>
                    <p class="upg-text-secondary" style="margin-top: 0;">{route.startingPoint[locale]}</p>
                  </div>
                )}
                {route.endingPoint && (
                  <div>
                    <h4 style="font-family: var(--font-display); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--s-ink-3); margin-bottom: 0.35rem;">{t('detail.endingPoint')}</h4>
                    <p class="upg-text-secondary" style="margin-top: 0;">{route.endingPoint[locale]}</p>
                  </div>
                )}
                {route.howToGetThere && (
                  <div>
                    <h4 style="font-family: var(--font-display); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--s-ink-3); margin-bottom: 0.35rem;">{t('detail.howToGetThere')}</h4>
                    <p class="upg-text-secondary" style="margin-top: 0;">{route.howToGetThere[locale]}</p>
                  </div>
                )}
                {route.estimatedBudget && (
                  <div>
                    <h4 style="font-family: var(--font-display); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--s-ink-3); margin-bottom: 0.35rem;">{t('detail.estimatedBudget')}</h4>
                    <p class="upg-text-secondary" style="margin-top: 0;">{route.estimatedBudget[locale]}</p>
                  </div>
                )}
                {route.whoIsItFor && (
                  <div>
                    <h4 style="font-family: var(--font-display); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--s-ink-3); margin-bottom: 0.35rem;">{t('detail.whoIsItFor')}</h4>
                    <p class="upg-text-secondary" style="margin-top: 0;">{route.whoIsItFor[locale]}</p>
                  </div>
                )}
                {route.accessibility && (
                  <div>
                    <h4 style="font-family: var(--font-display); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--s-ink-3); margin-bottom: 0.35rem;">{t('detail.accessibility')}</h4>
                    <p class="upg-text-secondary" style="margin-top: 0;">{route.accessibility[locale]}</p>
                  </div>
                )}
                {route.bestTimeToVisit && (
                  <div>
                    <h4 style="font-family: var(--font-display); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--s-ink-3); margin-bottom: 0.35rem;">{t('detail.bestTimeToVisit')}</h4>
                    <p class="upg-text-secondary" style="margin-top: 0;">{route.bestTimeToVisit[locale]}</p>
                  </div>
                )}
              </div>
            </article>
          )}

          {route.tags.length > 0 && (
            <div class="upg-tags" data-reveal>
              <span class="upg-tags-title">{copy.sections.tags}</span>
              <div class="upg-tags-list">
                {route.tags.map((tag: string) => (
                  <span class="upg-tag">#{tag}</span>
                ))}
              </div>
            </div>
          )}

          {(prevRoute || nextRoute) && (
            <nav class="upg-block" data-reveal aria-label={isEnglish ? 'Route navigation' : 'Navegación de rutas'} style="padding: 2rem 3rem;">
              <div class="upg-block-bg"></div>
              <div style="display:flex; justify-content:space-between; align-items:center; gap:1rem;">
                {prevRoute ? (
                  <a href={getRouteDetailUrl(prevRoute.slug, locale)} style="display:flex; flex-direction:column; align-items:flex-start; text-decoration:none; max-width:45%;">
                    <span style="font-family:var(--font-display); font-size:0.7rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--s-ink-3); margin-bottom:0.35rem;">{copy.nav.prev}</span>
                    <span style="font-family:var(--font-body); font-size:1.1rem; font-weight:600; color:var(--s-ink); line-height:1.3;">{prevRoute.title[locale]}</span>
                    <span style="font-family:var(--font-display); font-size:0.8rem; color:var(--s-ink-2); margin-top:0.25rem;">{formatDuration(prevRoute.duration, locale)} · {t(`difficulty.${prevRoute.difficulty}`)}</span>
                  </a>
                ) : <span />}
                {nextRoute ? (
                  <a href={getRouteDetailUrl(nextRoute.slug, locale)} style="display:flex; flex-direction:column; align-items:flex-end; text-decoration:none; max-width:45%;">
                    <span style="font-family:var(--font-display); font-size:0.7rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--s-ink-3); margin-bottom:0.35rem;">{copy.nav.next}</span>
                    <span style="font-family:var(--font-body); font-size:1.1rem; font-weight:600; color:var(--s-ink); line-height:1.3; text-align:right;">{nextRoute.title[locale]}</span>
                    <span style="font-family:var(--font-display); font-size:0.8rem; color:var(--s-ink-2); margin-top:0.25rem;">{formatDuration(nextRoute.duration, locale)} · {t(`difficulty.${nextRoute.difficulty}`)}</span>
                  </a>
                ) : <span />}
              </div>
            </nav>
          )}

          {crossLinks.length > 0 && (
            <div class="upg-block" data-reveal style="padding: 2.5rem 3rem;">
              <div class="upg-block-bg"></div>
              <header class="upg-header">
                <span class="upg-num">05</span>
                <div class="upg-line"></div>
                <span class="upg-eyebrow">[ {t('detail.discoverMore')} ]</span>
              </header>
              <CrossLinksSection title={t('detail.discoverMore')} links={crossLinks} />
            </div>
          )}
        </main>

        <aside class="upg-sidebar" aria-label={isEnglish ? 'Route details sidebar' : 'Barra lateral de detalles de ruta'}>
          <div class="upg-sidebar-sticky">
            {(route.highlights.length > 0 || route.tips.length > 0 || route.startingPoint || route.endingPoint) && (
              <nav class="upg-toc" data-reveal aria-label={isEnglish ? 'Table of contents' : 'Tabla de contenidos'} style="margin-bottom:1.5rem; background:#fff; border-radius:20px; border:1px solid var(--s-border); padding:1.5rem 2rem;">
                <span style="font-family:var(--font-display); font-size:0.7rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--s-ink-3); display:block; margin-bottom:1rem;">{isEnglish ? 'On this page' : 'En esta página'}</span>
                <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0.6rem;">
                  {route.highlights.length > 0 && (
                    <li><a href="#itinerary" style="font-family:var(--font-display); font-size:0.85rem; color:var(--s-ink-2); text-decoration:none; display:flex; align-items:center; gap:0.5rem;"><span style="color:var(--s-orange);">01</span> {copy.sections.itineraryTitle}</a></li>
                  )}
                  {route.tips.length > 0 && (
                    <li><a href="#tips" style="font-family:var(--font-display); font-size:0.85rem; color:var(--s-ink-2); text-decoration:none; display:flex; align-items:center; gap:0.5rem;"><span style="color:var(--s-orange);">02</span> {copy.sections.tipsTitle}</a></li>
                  )}
                  {(route.startingPoint || route.endingPoint || route.howToGetThere || route.estimatedBudget || route.whoIsItFor || route.accessibility || route.bestTimeToVisit) && (
                    <li><a href="#practical-info" style="font-family:var(--font-display); font-size:0.85rem; color:var(--s-ink-2); text-decoration:none; display:flex; align-items:center; gap:0.5rem;"><span style="color:var(--s-orange);">03</span> {t('detail.routeInfo')}</a></li>
                  )}
                </ul>
              </nav>
            )}
            <div class="upg-ticket-card" data-reveal>
              <div class="upg-ticket-glass"></div>

              <div class="upg-tc-header">
                <div class="upg-tc-date-box">
                  <span class="tc-day" style="font-size: 1rem; font-weight:600; font-family:var(--font-display);">{t(`timeOfDay.${route.timeOfDay}`).slice(0, 3).toUpperCase()}</span>
                  <span class="tc-month">{copy.sections.timeLabel}</span>
                </div>
                <div class="upg-tc-info">
                  <span class="tc-time" style="color:var(--s-ink);">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                    {formatDuration(route.duration, locale)}
                  </span>
                  <span class="tc-category">{t(`categories.${route.category}`)}</span>
                </div>
              </div>

              <div class="upg-tc-price-wrap">
                <span class="tc-price-label">{t('detail.distance')}</span>
                <span class="tc-price-val">
                  {distValue}<span style="font-size:1.5rem; margin-left:5px;">{distUnit}</span>
                </span>
              </div>

              <div style="padding: 0 2.5rem 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
                <span style="font-family: var(--font-display); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: var(--s-orange);">{t(`difficulty.${route.difficulty}`)}</span>
                <div style="flex:1; height: 1px; background: var(--s-border);"></div>
              </div>

              {route.whatToBring && (
                <div style="padding: 0 2.5rem 1rem;">
                  <span class="tc-price-label" style="display:block; margin-bottom:0.75rem;">{copy.sections.bringLabel}</span>
                  <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0.5rem;">
                    {route.whatToBring[locale].map((item: string) => (
                      <li style="display:flex; align-items:flex-start; gap:0.5rem; font-family:var(--font-display); font-size:0.8rem; color:var(--s-ink-2);">
                        <span style="color:#d4873a; margin-top:-2px;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M5 13l4 4L19 7"/></svg></span>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              <div class="upg-tc-divider">
                <span class="tcd-hole left"></span>
                <div class="tcd-dashed"></div>
                <span class="tcd-hole right"></span>
              </div>

              <div class="upg-tc-actions">
                <ShareButton
                  title={route.title[locale]}
                  url={Astro.url.href}
                  label={copy.share.label}
                  copiedLabel={copy.share.copied}
                  class="upg-btn-primary"
                />
              </div>
            </div>

            {relatedRoutes.length > 0 && (
              <div class="upg-related-bento" data-reveal>
                <div class="upg-rb-header">
                  <span class="upg-rb-title">[ {t('detail.similarRoutes')} ]</span>
                  <a href={getRoute('routes', locale)} class="upg-rb-all">{t('detail.allRoutes')} →</a>
                </div>

                <div class="upg-rb-list">
                  {relatedRoutes.map((related, index) => (
                    <a href={getRouteDetailUrl(related.slug, locale)} class="upg-rel-item" style={`--rd: ${index * 0.15}s`}>
                      <div class="uri-thumb">
                        {related.image ? (
                          <OptimizedImage src={related.image} alt={related.title[locale]} loading="lazy" sizes="(max-width: 640px) 100vw, 280px" />
                        ) : (
                          <div class="uri-thumb-fallback"></div>
                        )}
                      </div>
                      <div class="uri-content">
                        <span class="uri-title">{related.title[locale]}</span>
                        <span class="uri-meta">{formatDuration(related.duration, locale)}</span>
                      </div>
                      <div class="uri-arrow">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        </aside>
      </div>
    </div>

    <div class="det-footer-orn" aria-hidden="true" style="display: flex; align-items: center; justify-content: center; gap: 1rem; padding: 3rem clamp(1.5rem, 5vw, 4rem) 4rem; opacity: 0.3;">
      <span style="flex: 1; max-width: 120px; height: 1px; background: var(--s-border);"></span>
      <span style="color: var(--s-gold);"><svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17.2l-6.2 4.1 2.4-7.4L2 9.4h7.6z"/></svg></span>
      <span style="flex: 1; max-width: 120px; height: 1px; background: var(--s-border);"></span>
    </div>
  </div>

  <Footer slot="footer" locale={locale} />
</BaseLayout>

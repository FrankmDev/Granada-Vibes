---
import BaseLayout from '@layouts/BaseLayout.astro';
import RouteDetailHero from '@components/routes/RouteDetailHero.astro';
import Footer from '@components/layout/Footer.astro';
import ShareButton from '@components/ui/ShareButton.astro';
import ButtonCTA from '@components/ui/ButtonCTA.astro';
import InstagramIcon from '@components/icons/InstagramIcon.astro';
import WhatsAppIcon from '@components/icons/WhatsAppIcon.astro';
import { getAllRoutes } from '@data/index.js';
import { useTranslations } from '@i18n/utils';
import { getRoute, getRouteDetailUrl } from '@utils/routes';
import { formatDistance, formatDuration } from '@utils/dates';
import RelatedGuides from '@components/related/RelatedGuides.astro';
import RelatedEvents from '@components/related/RelatedEvents.astro';
import RelatedRoutes from '@components/related/RelatedRoutes.astro';
import RelatedVenues from '@components/related/RelatedVenues.astro';
import {
  getRelatedGuidesForRoute,
  getRelatedEventsForRoute,
  getRelatedRoutesForRoute,
  getRelatedVenuesForRoute,
} from '@utils/related-content';
import ContinueExploring from '@components/related/ContinueExploring.astro';
import CollaborateCTA from '@components/shared/CollaborateCTA.astro';
import { getRouteDisplayTitle, getRouteSeoDescription, getRouteSeoTitle } from '@utils/content-seo';
import type { Locale, Neighborhood, Route, RouteHighlight, RouteTip } from '@types';
import '@styles/pages/route-detail.css';

interface Props {
  locale: Locale;
  route: Route;
}

const { locale, route } = Astro.props;
const t = useTranslations(locale);
const isEnglish = locale === 'en';
const neighborhoodsLabel = route.neighborhoods
  .map((neighborhood: Neighborhood) => t(`neighborhoods.${neighborhood}`))
  .join(', ');
const routeSeoTitle = getRouteSeoTitle(route, locale);
const displayTitle = getRouteDisplayTitle(route, locale);
const routeSeoDescription = getRouteSeoDescription({
  route,
  locale,
  neighborhoods: neighborhoodsLabel,
  difficulty: t(`difficulty.${route.difficulty}`).toLowerCase(),
});

const categoryUrl = `${getRoute('routes', locale)}#routes-grid`;
const byTimeLink = {
  url: getRoute('byTime', locale),
  title: t('nav.byTime'),
  meta: t('mixedRoutes.heroSubtitle'),
  image: null,
};
const plannerLink = {
  url: getRoute('planner', locale),
  title: t('nav.planner'),
  meta: t('planner.heroDescription'),
  image: null,
};

const copy = isEnglish
  ? {
      breadcrumb: {
        home: 'Home',
        listing: 'Routes',
      },
      sections: {
        aboutEyebrow: '[ About the route ]',
        aboutTitle: 'Description',
        neighborhoods: 'Neighbourhoods:',
        itineraryEyebrow: '[ ITINERARY ]',
        itineraryTitle: 'The itinerary',
        tipsEyebrow: '[ Recommendation ]',
        tipsTitle: 'Local tips',
        tags: '[ Tags ]',
        timeLabel: 'TIME',
        bringLabel: 'WHAT TO BRING',
      },
      faq: {
        durationQuestion: 'How long does this route take?',
        durationAnswer: `The route takes approximately ${formatDuration(route.duration, locale)}.`,
        difficultyQuestion: 'What is the difficulty level?',
        difficultyAnswer: `The difficulty level is ${t(`difficulty.${route.difficulty}`)}.`,
      },
      share: {
        label: 'Share route',
        copied: 'Copied!',
        whatsappLabel: 'WhatsApp',
        whatsappAria: 'Share this route on WhatsApp',
        instagramLabel: 'Instagram',
        instagramAria: 'Copy link to share on Instagram',
        facebookLabel: 'Facebook',
        facebookAria: 'Share this route on Facebook',
      },
      seo: routeSeoDescription,
      nav: {
        prev: 'Previous route',
        next: 'Next route',
      },
    }
  : {
      breadcrumb: {
        home: 'Inicio',
        listing: 'Rutas',
      },
      sections: {
        aboutEyebrow: '[ Sobre la ruta ]',
        aboutTitle: 'Descripción',
        neighborhoods: 'Barrios:',
        itineraryEyebrow: '[ RECORRIDO ]',
        itineraryTitle: 'El itinerario',
        tipsEyebrow: '[ Recomendación ]',
        tipsTitle: 'Tips de local',
        tags: '[ Etiquetas ]',
        timeLabel: 'HORARIO',
        bringLabel: 'QUÉ LLEVAR',
      },
      faq: {
        durationQuestion: '¿Cuánto dura esta ruta?',
        durationAnswer: `La ruta tiene una duración aproximada de ${formatDuration(route.duration, locale)}.`,
        difficultyQuestion: '¿Qué nivel de dificultad tiene?',
        difficultyAnswer: `La dificultad es ${t(`difficulty.${route.difficulty}`).toLowerCase()}.`,
      },
      share: {
        label: 'Compartir ruta',
        copied: '¡Copiado!',
        whatsappLabel: 'WhatsApp',
        whatsappAria: 'Compartir esta ruta por WhatsApp',
        instagramLabel: 'Instagram',
        instagramAria: 'Copiar enlace para compartir en Instagram',
        facebookLabel: 'Facebook',
        facebookAria: 'Compartir esta ruta en Facebook',
      },
      seo: routeSeoDescription,
      nav: {
        prev: 'Ruta anterior',
        next: 'Ruta siguiente',
      },
    };

const allRoutes = getAllRoutes();
const routeIndex = allRoutes.findIndex((r) => r.id === route.id);
const prevRoute = routeIndex > 0 ? allRoutes[routeIndex - 1] : null;
const nextRoute = routeIndex < allRoutes.length - 1 ? allRoutes[routeIndex + 1] : null;

const relatedGuidesList = getRelatedGuidesForRoute(route, 3);
const relatedEventsList = getRelatedEventsForRoute(route, 3);
const relatedRoutesList = getRelatedRoutesForRoute(route, 3);
const relatedVenuesList = getRelatedVenuesForRoute(route, 3);
const hasRelatedContent =
  relatedGuidesList.length > 0 ||
  relatedEventsList.length > 0 ||
  relatedRoutesList.length > 0 ||
  relatedVenuesList.length > 0;

const ogImage = route.image || 'https://upload.wikimedia.org/wikipedia/commons/3/32/Alhambra_view_1102.jpg';
const breadcrumb = [
  { name: copy.breadcrumb.home, url: getRoute('home', locale) },
  { name: copy.breadcrumb.listing, url: getRoute('routes', locale) },
  { name: route.title[locale], url: getRouteDetailUrl(route.slug, locale) },
];

const faq = route.tips.slice(0, 2).map((tip: RouteTip) => ({
  question: tip.title[locale],
  answer: tip.content[locale],
}));

faq.push(
  { question: copy.faq.durationQuestion, answer: copy.faq.durationAnswer },
  { question: copy.faq.difficultyQuestion, answer: copy.faq.difficultyAnswer },
);

const distString = formatDistance(route.distance, locale);
const routeFacts = [
  { label: t('detail.duration'), value: formatDuration(route.duration, locale) },
  { label: t('detail.distance'), value: distString },
  { label: t('detail.difficulty'), value: t(`difficulty.${route.difficulty}`) },
  { label: t('detail.bestTimeToVisit'), value: t(`timeOfDay.${route.timeOfDay}`) },
];
---

<BaseLayout
  locale={locale}
  title={routeSeoTitle}
  description={copy.seo}
  ogImage={ogImage}
  ogType="article"
  schemaType="route"
  schemaData={route}
  breadcrumb={breadcrumb}
  faq={faq.length > 0 ? faq : undefined}
>
  <RouteDetailHero route={route} locale={locale} displayTitle={displayTitle} />

  <div class="det-page route-page-override">
    <div class="det-content-wrap">
      <div class="route-meta-row">
        <main id="main-content" class="upgraded-main" aria-label={displayTitle}>
          <article class="upg-block route-article-card" id="route-content" data-reveal>
            <section class="route-entry-section route-entry-section--intro">
            <header class="upg-header">
              <span class="upg-num">01</span>
              <div class="upg-line"></div>
              <span class="upg-eyebrow">{copy.sections.aboutEyebrow}</span>
            </header>
            <h2 class="upg-title">{copy.sections.aboutTitle}</h2>

            <div class="upg-body content-rich">
              <p class="upg-lead">{route.description[locale]}</p>
              {route.longDescription && <p class="upg-text-secondary">{route.longDescription[locale]}</p>}
            </div>

            {route.neighborhoods.length > 0 && (
              <div class="upg-route-neighs">
                <span class="upg-rn-label">{copy.sections.neighborhoods}</span>
                <div class="upg-tags-list">
                  {route.neighborhoods.map((neighborhood: Neighborhood) => (
                    <a href={`${getRoute('routes', locale)}#routes-grid`} class="upg-badge ghost">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                      {t(`neighborhoods.${neighborhood}`)}
                    </a>
                  ))}
                </div>
              </div>
            )}

            <div class="upg-meta-links">
              <a href={categoryUrl} class="upg-badge ghost">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
                {t(`categories.${route.category}`)}
              </a>
              <a href={byTimeLink.url} class="upg-badge ghost">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                {byTimeLink.title}
              </a>
              <a href={plannerLink.url} class="upg-badge ghost">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6h11M9 12h11M9 18h11M5 6h.01M5 12h.01M5 18h.01"/></svg>
                {plannerLink.title}
              </a>
            </div>
            </section>

          {route.highlights.length > 0 && (
            <section class="route-entry-section" id="itinerary">
              <header class="upg-header">
                <span class="upg-num">02</span>
                <div class="upg-line"></div>
                <span class="upg-eyebrow">{copy.sections.itineraryEyebrow}</span>
              </header>
              <h2 class="upg-title">{copy.sections.itineraryTitle}</h2>

              <div class="upg-highlights">
                {route.highlights.map((highlight: RouteHighlight, index: number) => (
                  <div class="upg-hl-item" style={`--hl-delay: ${index * 0.1}s`}>
                    <div class="upg-hl-num-wrap">
                      <span class="upg-hl-num">{(index + 1).toString().padStart(2, '0')}</span>
                    </div>
                    <div class="upg-hl-content">
                      <h3 class="tl-title">{highlight.title[locale]}</h3>
                      <p class="upg-hl-text upg-hl-text--flush">{highlight.description[locale]}</p>
                      {(highlight.address || highlight.price || highlight.hours || highlight.duration || highlight.tip) && (
                        <div class="upg-hl-meta">
                          <div class="upg-hl-meta-title">{t('detail.stopInfo')}</div>
                          <div class="upg-hl-meta-list">
                            {highlight.address && (
                              <div class="upg-hl-meta-row upg-hl-meta-row--start">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                <span>{highlight.address[locale]}</span>
                              </div>
                            )}
                            {highlight.duration && (
                              <div class="upg-hl-meta-row">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                                <span>{formatDuration(highlight.duration, locale)}</span>
                              </div>
                            )}
                            {highlight.price && (
                              <div class="upg-hl-meta-row">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                <span>{highlight.price[locale]}</span>
                              </div>
                            )}
                            {highlight.hours && (
                              <div class="upg-hl-meta-row">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                <span>{highlight.hours[locale]}</span>
                              </div>
                            )}
                            {highlight.tip && (
                              <div class="upg-hl-meta-row upg-hl-meta-row--tip upg-hl-meta-row--start">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                <span>{highlight.tip[locale]}</span>
                              </div>
                            )}
                          </div>
                        </div>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </section>
          )}

          {route.tips.length > 0 && (
            <section class="route-entry-section block-tips" id="tips">
              <header class="upg-header">
                <span class="upg-num">03</span>
                <div class="upg-line"></div>
                <span class="upg-eyebrow">{copy.sections.tipsEyebrow}</span>
              </header>
              <h2 class="upg-title">{copy.sections.tipsTitle}</h2>

              <div class="upg-tips-grid">
                {route.tips.map((tip: RouteTip, index: number) => (
                  <article class="upg-tip-card" style={`--tip-delay: ${index * 0.08}s`}>
                    <span class="upg-tip-rule" aria-hidden="true"></span>
                    <header class="upg-tip-head">
                      <span class="upg-tip-num">{(index + 1).toString().padStart(2, '0')}</span>
                      <span class="upg-tip-kicker">{copy.sections.tipsTitle}</span>
                    </header>
                    <h3 class="upg-tip-title">{tip.title[locale]}</h3>
                    <p class="upg-tip-text">{tip.content[locale]}</p>
                    <footer class="upg-tip-foot">
                      <span class="upg-tip-tag">{copy.sections.tipsEyebrow.replace(/[\[\]]/g, '').trim()}</span>
                      <span class="upg-tip-coord">37°10′N · 3°35′W</span>
                    </footer>
                  </article>
                ))}
              </div>
            </section>
          )}

          {(route.startingPoint || route.endingPoint || route.howToGetThere || route.estimatedBudget || route.whoIsItFor || route.accessibility || route.bestTimeToVisit) && (
            <section class="route-entry-section" id="practical-info">
              <header class="upg-header">
                <span class="upg-num">04</span>
                <div class="upg-line"></div>
                <span class="upg-eyebrow">[ {t('detail.practicalInfo')} ]</span>
              </header>
              <h2 class="upg-title">{t('detail.routeInfo')}</h2>

              <div class="upg-body content-rich upg-practical-list">
                {route.startingPoint && (
                  <div class="upg-practical-item">
                    <h4 class="upg-practical-label">{t('detail.startingPoint')}</h4>
                    <p class="upg-text-secondary upg-text-secondary--flush">{route.startingPoint[locale]}</p>
                  </div>
                )}
                {route.endingPoint && (
                  <div class="upg-practical-item">
                    <h4 class="upg-practical-label">{t('detail.endingPoint')}</h4>
                    <p class="upg-text-secondary upg-text-secondary--flush">{route.endingPoint[locale]}</p>
                  </div>
                )}
                {route.howToGetThere && (
                  <div class="upg-practical-item">
                    <h4 class="upg-practical-label">{t('detail.howToGetThere')}</h4>
                    <p class="upg-text-secondary upg-text-secondary--flush">{route.howToGetThere[locale]}</p>
                  </div>
                )}
                {route.estimatedBudget && (
                  <div class="upg-practical-item">
                    <h4 class="upg-practical-label">{t('detail.estimatedBudget')}</h4>
                    <p class="upg-text-secondary upg-text-secondary--flush">{route.estimatedBudget[locale]}</p>
                  </div>
                )}
                {route.whoIsItFor && (
                  <div class="upg-practical-item">
                    <h4 class="upg-practical-label">{t('detail.whoIsItFor')}</h4>
                    <p class="upg-text-secondary upg-text-secondary--flush">{route.whoIsItFor[locale]}</p>
                  </div>
                )}
                {route.accessibility && (
                  <div class="upg-practical-item">
                    <h4 class="upg-practical-label">{t('detail.accessibility')}</h4>
                    <p class="upg-text-secondary upg-text-secondary--flush">{route.accessibility[locale]}</p>
                  </div>
                )}
                {route.bestTimeToVisit && (
                  <div class="upg-practical-item">
                    <h4 class="upg-practical-label">{t('detail.bestTimeToVisit')}</h4>
                    <p class="upg-text-secondary upg-text-secondary--flush">{route.bestTimeToVisit[locale]}</p>
                  </div>
                )}
              </div>
            </section>
          )}

          {route.whatToBring && (
            <section class="upg-block" id="what-to-bring" data-reveal>
              <header class="upg-header">
                <span class="upg-num">05</span>
                <div class="upg-line"></div>
                <span class="upg-eyebrow">[ {copy.sections.bringLabel} ]</span>
              </header>
              <h2 class="upg-title">{copy.sections.bringLabel}</h2>
              <ul class="route-bring-list route-bring-list--inline">
                {route.whatToBring[locale].map((item: string) => (
                  <li>
                    <span aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                        <path d="M5 13l4 4L19 7"/>
                      </svg>
                    </span>
                    {item}
                  </li>
                ))}
              </ul>
            </section>
          )}

          {route.tags.length > 0 && (
            <div class="upg-tags" data-reveal>
              <span class="upg-tags-title">{copy.sections.tags}</span>
              <div class="upg-tags-list">
                {route.tags.map((tag: string) => (
                  <span class="upg-tag">#{tag}</span>
                ))}
              </div>
            </div>
          )}
          </article>

        </main>

        <aside class="upg-sidebar" aria-label={isEnglish ? 'Route details sidebar' : 'Barra lateral de detalles de ruta'}>
          <div class="upg-sidebar-sticky">
            <section class="route-side-card route-keyfacts-card" aria-labelledby="route-keyfacts-title" data-reveal>
              <header class="route-side-head">
                <span class="route-side-num">01</span>
                <span class="route-side-line" aria-hidden="true"></span>
                <h2 id="route-keyfacts-title" class="route-side-title">{t('detail.keyFacts')}</h2>
              </header>

              <dl class="route-facts-grid">
                {routeFacts.map((fact) => (
                  <div class="route-fact">
                    <dt>{fact.label}</dt>
                    <dd>{fact.value}</dd>
                  </div>
                ))}
              </dl>
            </section>

            {(route.highlights.length > 0 || route.tips.length > 0 || route.startingPoint || route.endingPoint) && (
              <nav class="route-side-card route-toc-card" data-reveal aria-labelledby="route-toc-title">
                <header class="route-side-head">
                  <span class="route-side-num">02</span>
                  <span class="route-side-line" aria-hidden="true"></span>
                  <h2 id="route-toc-title" class="route-side-title">{t('detail.inThisGuide')}</h2>
                </header>

                <ol class="route-toc-list">
                  {route.highlights.length > 0 && (
                    <li><a href="#itinerary" class="route-toc-link"><span>01</span><strong>{copy.sections.itineraryTitle}</strong></a></li>
                  )}
                  {route.tips.length > 0 && (
                    <li><a href="#tips" class="route-toc-link"><span>02</span><strong>{copy.sections.tipsTitle}</strong></a></li>
                  )}
                  {(route.startingPoint || route.endingPoint || route.howToGetThere || route.estimatedBudget || route.whoIsItFor || route.accessibility || route.bestTimeToVisit) && (
                    <li><a href="#practical-info" class="route-toc-link"><span>03</span><strong>{t('detail.routeInfo')}</strong></a></li>
                  )}
                </ol>
              </nav>
            )}

            <section class="route-side-card route-share-card" data-reveal aria-labelledby="route-share-title">
              <header class="route-side-head">
                <span class="route-side-num">03</span>
                <span class="route-side-line" aria-hidden="true"></span>
                <h2 id="route-share-title" class="route-side-title">{copy.share.label}</h2>
              </header>

              <div class="route-share-actions">
                <ShareButton
                  title={route.title[locale]}
                  url={Astro.url.href}
                  label={copy.share.label}
                  copiedLabel={copy.share.copied}
                  variant="primary"
                  fullWidth
                />

                <div class="upg-tc-channels" aria-label={copy.share.label}>
                  <a
                    class="upg-tc-channel upg-tc-channel--whatsapp"
                    href={`https://wa.me/?text=${encodeURIComponent(`${displayTitle} · GRN URBAN`)}%20${encodeURIComponent(Astro.url.href)}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={copy.share.whatsappAria}
                    title={copy.share.whatsappAria}
                  >
                    <span class="upg-tc-channel-icon" aria-hidden="true">
                      <WhatsAppIcon />
                    </span>
                    <span class="upg-tc-channel-label">{copy.share.whatsappLabel}</span>
                  </a>
                  <button
                    type="button"
                    class="upg-tc-channel upg-tc-channel--instagram"
                    data-share-copy
                    data-share-url={Astro.url.href}
                    data-share-method="instagram"
                    aria-label={copy.share.instagramAria}
                    title={copy.share.instagramAria}
                  >
                    <span class="upg-tc-channel-icon" aria-hidden="true">
                      <InstagramIcon />
                    </span>
                    <span class="upg-tc-channel-label">{copy.share.instagramLabel}</span>
                  </button>
                  <a
                    class="upg-tc-channel upg-tc-channel--facebook"
                    href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={copy.share.facebookAria}
                    title={copy.share.facebookAria}
                  >
                    <span class="upg-tc-channel-icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M22 12.06C22 6.48 17.52 2 11.94 2S2 6.48 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.91h2.54V9.84c0-2.52 1.5-3.91 3.8-3.91 1.1 0 2.25.2 2.25.2v2.47h-1.27c-1.25 0-1.64.78-1.64 1.57v1.89h2.8l-.45 2.91h-2.35V22A10 10 0 0 0 22 12.06Z"/>
                      </svg>
                    </span>
                    <span class="upg-tc-channel-label">{copy.share.facebookLabel}</span>
                  </a>
                </div>
              </div>
            </section>
          </div>
          </aside>
        </div>

        {(prevRoute || nextRoute) && (
          <nav class="upg-block upg-nav-block route-nav-full" data-reveal aria-label={isEnglish ? 'Route navigation' : 'Navegación de rutas'}>
            <div class="upg-block-bg"></div>
            <div class="upg-nav-flex">
              {prevRoute ? (
                <a href={getRouteDetailUrl(prevRoute.slug, locale)} class="upg-nav-link">
                  <span class="upg-nav-arrow" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M15 18l-6-6 6-6"></path>
                    </svg>
                  </span>
                  <span class="upg-nav-copy">
                    <span class="upg-nav-label">{copy.nav.prev}</span>
                    <span class="upg-nav-title">{getRouteDisplayTitle(prevRoute, locale)}</span>
                    <span class="upg-nav-meta">{formatDuration(prevRoute.duration, locale)} · {t(`difficulty.${prevRoute.difficulty}`)}</span>
                  </span>
                </a>
              ) : <span />}
              {nextRoute ? (
                <a href={getRouteDetailUrl(nextRoute.slug, locale)} class="upg-nav-link upg-nav-link--end">
                  <span class="upg-nav-copy">
                    <span class="upg-nav-label">{copy.nav.next}</span>
                    <span class="upg-nav-title">{getRouteDisplayTitle(nextRoute, locale)}</span>
                    <span class="upg-nav-meta">{formatDuration(nextRoute.duration, locale)} · {t(`difficulty.${nextRoute.difficulty}`)}</span>
                  </span>
                  <span class="upg-nav-arrow" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M9 18l6-6-6-6"></path>
                    </svg>
                  </span>
                </a>
              ) : <span />}
            </div>
          </nav>
        )}

        {hasRelatedContent && (
          <section class="upg-block upg-block--loose guide-related-full" id="also-interesting" data-reveal aria-labelledby="route-related-title">
            <header class="upg-header">
              <span class="upg-num">05</span>
              <span class="upg-line" aria-hidden="true"></span>
              <h2 id="route-related-title" class="upg-eyebrow">[ {t('detail.alsoInteresting')} ]</h2>
            </header>
            <div class="upg-related-stack">
              <RelatedGuides type="route" route={route} locale={locale} title={t('detail.relatedGuides')} limit={3} />
              <RelatedEvents type="route" route={route} locale={locale} title={t('detail.relatedEvents')} limit={3} />
              <RelatedRoutes type="route" route={route} locale={locale} title={t('detail.relatedRoutes')} limit={3} />
              <RelatedVenues type="route" route={route} locale={locale} title={t('detail.relatedVenues')} limit={3} />
            </div>
          </section>
        )}
      </div>

      <div class="route-collab-section">
        <CollaborateCTA locale={locale} variant="route" />
      </div>

      <ContinueExploring locale={locale} />

      <div class="det-footer-orn" aria-hidden="true">
        <span></span>
        <i></i>
        <b>
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
            <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17.2l-6.2 4.1 2.4-7.4L2 9.4h7.6z"/>
          </svg>
        </b>
        <i></i>
        <span></span>
      </div>
  </div>

  <Footer slot="footer" locale={locale} />
</BaseLayout>

<script is:inline>
  (function () {
    if (window.__guideShareCopyInitialized) return;
    window.__guideShareCopyInitialized = true;

    document.addEventListener('click', async function (event) {
      const button = event.target.closest('[data-share-copy]');
      if (!button) return;

      const url = button.dataset.shareUrl ?? window.location.href;
      const method = button.dataset.shareMethod ?? 'copy';

      try {
        await navigator.clipboard.writeText(url);
        button.classList.add('is-copied');
        window.setTimeout(function () {
          button.classList.remove('is-copied');
        }, 1600);

        if (typeof window.grnTrackEvent === 'function') {
          window.grnTrackEvent('share', {
            method,
            content_id: window.location.pathname,
          });
        }
      } catch (_) {}
    });
  })();
</script>

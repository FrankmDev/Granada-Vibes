---
import type { Locale } from '@types';
import { useTranslations } from '@i18n/utils';
import OptimizedImage from '@components/ui/OptimizedImage.astro';
import ScreenFrame from '@components/ui/ScreenFrame.astro';

/**
 * CinematicHero — shared full-bleed dark hero for detail pages.
 * Aesthetic inspired by EventDetailHero: editorial lockup, glass dock,
 * bottom bar, scroll hint, decorative layer. Image always full-bleed.
 *
 * Dock content is passed via <div slot="dock">…</div> from the caller.
 * Optional description text via `description` prop.
 * Optional 4-corner ScreenFrame tags via frameTag* props.
 */
interface Props {
  locale: Locale;
  backHref: string;
  backLabel: string;
  refCode: string;       // e.g. "EVT / 001 · 2026"
  title: string;
  imageUrl: string | undefined;
  eyebrowText: string;   // category label, already uppercased
  featuredLabel?: string;
  dockAriaLabel?: string;
  description?: string;  // NEW: optional lead paragraph below title
  frameTagTopRight?: string;
  frameTagBottomLeft?: string;
  frameTagBottomRight?: string;
}

const {
  locale,
  backHref,
  backLabel,
  refCode,
  title,
  imageUrl,
  eyebrowText,
  featuredLabel,
  dockAriaLabel,
  description,
  frameTagTopRight,
  frameTagBottomLeft,
  frameTagBottomRight,
} = Astro.props;
const t = useTranslations(locale);

const hasScreenFrameTags = frameTagTopRight || frameTagBottomLeft || frameTagBottomRight;
---

<section class="cin-hero" aria-label={title}>

  <!-- Deep ambient canvas -->
  <div class="cin-canvas" aria-hidden="true">
    {imageUrl
      ? <OptimizedImage src={imageUrl} alt="" class="cin-bg-img" loading="eager" sizes="100vw" width={1920} height={1080} />
      : <div class="cin-bg-fallback"></div>
    }
    <div class="cin-overlay-base"></div>
    <div class="cin-overlay-vignette"></div>
    <div class="cin-overlay-bottom"></div>
    <div class="cin-overlay-diagonal"></div>
    <div class="cin-grain"></div>
  </div>

  <!-- Decorative architectural layer -->
  <div class="cin-deco" aria-hidden="true">
    <span class="deco-ring r1"></span>
    <span class="deco-ring r2"></span>
    <span class="deco-dot d1"></span>
    <span class="deco-dot d2"></span>
    <span class="deco-dot d3"></span>
    <span class="deco-line v1"></span>
    <span class="deco-ghost">GRANADA</span>
    <svg class="deco-star" viewBox="0 0 60 60" fill="none">
      <path d="M30 4 L34.5 22.5 L52 15 L39 28.5 L56 30 L39 31.5 L52 45 L34.5 37.5 L30 56 L25.5 37.5 L8 45 L21 31.5 L4 30 L21 28.5 L8 15 L25.5 22.5 Z"
        fill="none" stroke="var(--h-gold)" stroke-width="0.8" stroke-opacity="0.35"/>
      <path d="M30 12 L32.5 24.5 L42 20 L36 28.5 L46 30 L36 31.5 L42 40 L32.5 35.5 L30 48 L27.5 35.5 L18 40 L24 31.5 L14 30 L24 28.5 L18 20 L27.5 24.5 Z"
        fill="var(--h-gold)" fill-opacity="0.12" stroke="none"/>
    </svg>
  </div>

  <!-- ScreenFrame (4 tags) or simple frame (2 tags) -->
  {hasScreenFrameTags ? (
    <ScreenFrame
      tagTopLeft={eyebrowText}
      tagTopRight={frameTagTopRight}
      tagBottomLeft={frameTagBottomLeft}
      tagBottomRight={frameTagBottomRight}
    />
  ) : (
    <div class="cin-frame" aria-hidden="true">
      <span class="cin-corner tl"></span>
      <span class="cin-corner tr"></span>
      <span class="cin-corner bl"></span>
      <span class="cin-corner br"></span>
      <span class="cin-frame-tag left">[{refCode}]</span>
      <span class="cin-frame-tag right">GRN INDEX</span>
    </div>
  )}

  <!-- Navbar scrim -->
  <div class="cin-nav-scrim" aria-hidden="true"></div>

  <!-- Back link -->
  <a href={backHref} class="cin-back">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    <span>{backLabel}</span>
  </a>

  <!-- Archive ref badge -->
  <div class="cin-ref" aria-hidden="true">
    <span class="ref-label">REF.</span>
    <span class="ref-num">{refCode.split(' / ').pop()?.split(' · ')[0] ?? refCode}</span>
  </div>

  <!-- Main stage -->
  <div class="cin-stage">
    <!-- LEFT: Editorial lockup -->
    <div class="cin-lockup">
      <!-- Left gold accent rule -->
      <div class="lockup-rule" aria-hidden="true"></div>

      <!-- Eyebrow -->
      <div class="cin-eyebrow">
        <span class="eyebrow-line"></span>
        <span class="eyebrow-text">
          {'GRANADA'}
          <span class="eyebrow-slash">/</span>
          {eyebrowText}
        </span>
        <span class="eyebrow-line"></span>
      </div>

      <!-- Meta badges -->
      <div class="cin-meta">
        <span class="cin-cat">{eyebrowText}</span>
        {featuredLabel && (
          <span class="cin-feat">
            <svg viewBox="0 0 12 12" fill="currentColor">
              <path d="M6 0l1.5 4.5H12L8.5 7l1.5 5L6 9.5 2 12l1.5-5L0 4.5h4.5z" />
            </svg>
            {featuredLabel}
          </span>
        )}
        <slot name="meta-extra" />
      </div>

      <!-- Title -->
      <h1 class="cin-title">
        {
          (() => {
            let delayIndex = 0;
            return title
              .split(' ')
              .map((word) => (
                <span class="cin-word">
                  {word.split('').map((char) => {
                    const d = 0.3 + delayIndex * 0.045;
                    delayIndex++;
                    return (
                      <span class="cin-char" style={`--delay: ${d}s`}>
                        {char}
                      </span>
                    );
                  })}
                </span>
              ))
              .reduce(
                (prev, curr, i) =>
                  i === 0 ? [curr] : [...prev, ' ', curr],
                [] as (JSX.Element | string)[]
              );
          })()
        }
      </h1>

      <!-- Description -->
      {description && (
        <p class="cin-lead">
          <span class="lead-quote">"</span>
          {description.length > 180
            ? description.slice(0, 180).trim() + '…'
            : description}
          <span class="lead-quote">"</span>
        </p>
      )}

      <!-- Dock -->
      <div class="cin-dock-wrap">
        <div class="cin-dock" role="region" aria-label={dockAriaLabel}>
          <slot name="dock" />
          <!-- Corner brackets -->
          <span class="dock-bracket tl"></span>
          <span class="dock-bracket tr"></span>
          <span class="dock-bracket bl"></span>
          <span class="dock-bracket br"></span>
        </div>
        <!-- Glow behind dock -->
        <div class="cin-dock-glow" aria-hidden="true"></div>
      </div>
    </div>
  </div>

  <!-- Bottom editorial bar -->
  <div class="cin-bottom-bar">
    <div class="bar-line"></div>
    <div class="bar-content">
      <span class="bar-item">{eyebrowText}</span>
      <span class="bar-diamond" aria-hidden="true">
        <svg viewBox="0 0 12 12" width="10" height="10">
          <polygon points="6,0 12,6 6,12 0,6" fill="var(--h-muted)" />
        </svg>
      </span>
      <span class="bar-item">VOL. I · 2026</span>
      <span class="bar-diamond" aria-hidden="true">
        <svg viewBox="0 0 12 12" width="10" height="10">
          <polygon points="6,0 12,6 6,12 0,6" fill="var(--h-muted)" />
        </svg>
      </span>
      <span class="bar-item">37°10′N  3°36′W</span>
    </div>
    <div class="bar-line"></div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-hint" aria-hidden="true">
    <div class="scroll-line"></div>
    <span class="scroll-text">{t('routes.explore')}</span>
  </div>

</section>

<style>
  .cin-hero {
    --h-gold:     #c9a84c;
    --h-gold-dim: rgba(201, 162, 39, 0.45);
    --h-gold-bright: #e6c587;
    --h-orange:   #e8622a;
    --h-cream:    #f0ede8;
    --h-muted:    rgba(240, 237, 232, 0.45);
    --ease-expo:  cubic-bezier(0.16, 1, 0.3, 1);
    --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);

    position: relative;
    width: 100%;
    min-height: 100svh;
    background: #000;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    contain: layout;
  }

  /* ---- ScreenFrame overrides ---- */
  .cin-hero :global(.cin-screen-frame) { border-color: rgba(255,255,255,0.08); top: 1.25rem; left: 1.25rem; right: 1.25rem; bottom: 1.25rem; }
  .cin-hero :global(.cin-corner::before),
  .cin-hero :global(.cin-corner::after) { background: var(--h-gold); opacity: 0.25; }
  .cin-hero :global(.cin-frame-tag) { color: rgba(255,255,255,0.35); font-size: 0.55rem; letter-spacing: 0.18em; }

  /* ---- CANVAS ---- */
  .cin-canvas { position: absolute; inset: 0; z-index: 1; pointer-events: none; overflow: hidden; }
  .cin-bg-img {
    position: absolute; inset: 0;
    filter: grayscale(5%) contrast(1.08) brightness(0.92);
    transform: scale(1.06);
    will-change: transform;
    animation: hero-settle 3s var(--ease-expo) forwards;
    image-rendering: -webkit-optimize-contrast;
    image-rendering: crisp-edges;
  }
  @keyframes hero-settle {
    to { transform: scale(1.02); filter: grayscale(2%) contrast(1.05) brightness(0.88); }
  }
  .cin-bg-fallback {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 30% 50%, rgba(201,168,76,0.06) 0%, transparent 60%),
                radial-gradient(ellipse at 70% 20%, rgba(232,98,42,0.04) 0%, transparent 50%),
                #0a0a0a;
  }
  .cin-overlay-base     { position: absolute; inset: 0; background: rgba(0,0,0,0.15); }
  .cin-overlay-vignette { position: absolute; inset: 0; background: radial-gradient(ellipse at center, transparent 40%, rgba(0,0,0,0.5) 100%); }
  .cin-overlay-bottom   { position: absolute; bottom: 0; left: 0; right: 0; height: 65%; background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.5) 40%, transparent 100%); }
  .cin-overlay-diagonal { position: absolute; inset: 0; background: linear-gradient(35deg, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.6) 35%, rgba(0,0,0,0.2) 60%, transparent 100%); pointer-events: none; }
  .cin-grain {
    position: absolute; inset: 0; pointer-events: none;
    mix-blend-mode: soft-light; opacity: 0.04;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  /* ---- NAV SCRIM ---- */
  .cin-nav-scrim { position: absolute; top: 0; left: 0; right: 0; height: 160px; background: linear-gradient(180deg, rgba(0,0,0,0.70) 0%, rgba(0,0,0,0.20) 60%, transparent 100%); pointer-events: none; z-index: 5; }

  /* ---- DECORATIVE LAYER ---- */
  .cin-deco { position: absolute; inset: 0; z-index: 2; pointer-events: none; overflow: hidden; }
  .deco-ring { position: absolute; border-radius: 50%; border: 1px solid var(--h-gold); opacity: 0; animation: deco-ring-in 2s var(--ease-expo) forwards; }
  .deco-ring.r1 { width: 260px; height: 260px; top: 10%; right: 15%; animation-delay: 0.4s; --target-opacity: 0.12; }
  .deco-ring.r2 { width: 420px; height: 420px; top: 5%; right: 5%; animation-delay: 0.7s; --target-opacity: 0.06; border-color: rgba(255,255,255,0.15); }
  @keyframes deco-ring-in { from { opacity: 0; transform: scale(0.8); } to { opacity: var(--target-opacity, 0.1); transform: scale(1); } }
  .deco-dot { position: absolute; border-radius: 50%; animation: ev-float 7s ease-in-out infinite; }
  .deco-dot.d1 { width: 160px; height: 160px; top: 14%; left: 6%; background: radial-gradient(circle, rgba(201,168,76,0.25), transparent 70%); animation-duration: 8s; }
  .deco-dot.d2 { width: 90px; height: 90px; top: 50%; left: 42%; background: radial-gradient(circle, rgba(232,98,42,0.14), transparent 70%); animation-duration: 10s; animation-delay: 1.2s; }
  .deco-dot.d3 { width: 55px; height: 55px; bottom: 18%; right: 10%; background: radial-gradient(circle, rgba(201,168,76,0.22), transparent 70%); animation-duration: 6.5s; animation-delay: 0.5s; }
  .deco-line { position: absolute; background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.08) 20%, rgba(255,255,255,0.08) 80%, transparent); }
  .deco-line.v1 { top: 0; left: 33%; width: 1px; height: 100%; }
  .deco-ghost { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-family: var(--font-body); font-size: clamp(10rem, 30vw, 20rem); font-weight: 300; color: #fff; opacity: 0.018; pointer-events: none; letter-spacing: -0.04em; line-height: 1; user-select: none; }
  .deco-star { position: absolute; top: 18%; right: 22%; width: 44px; height: 44px; animation: star-rotate 30s linear infinite; opacity: 0.6; }
  @keyframes star-rotate { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  @keyframes ev-float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }

  /* ---- BACK LINK ---- */
  .cin-back {
    position: absolute; top: calc(var(--header-height, 64px) + 1.25rem); left: clamp(1.5rem, 4vw, 3rem); z-index: 30;
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-family: var(--font-display); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(240,237,232,0.85); text-decoration: none;
    padding: 0.55rem 1rem; border-radius: 100px;
    background: rgba(0,0,0,0.35); backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.12);
    transition: all 0.3s ease;
    opacity: 0; animation: fadeInUp 0.8s ease 0.2s both;
  }
  .cin-back svg { transition: transform 0.25s ease; }
  .cin-back:hover { background: rgba(201,168,76,0.15); border-color: rgba(201,168,76,0.3); transform: translateY(-1px); }
  .cin-back:hover svg { transform: translateX(-3px); }

  /* ---- ARCHIVE REF ---- */
  .cin-ref {
    position: absolute; top: calc(var(--header-height, 64px) + 1.25rem); right: clamp(1.5rem, 4vw, 3rem); z-index: 30;
    display: flex; align-items: center; gap: 0.35rem;
    font-family: var(--font-display); font-size: 0.6rem; font-weight: 700; letter-spacing: 0.15em;
    color: rgba(240,237,232,0.45);
    opacity: 0; animation: fadeInUp 0.8s ease 0.3s both;
  }
  .ref-label { text-transform: uppercase; }
  .ref-num { color: var(--h-gold); font-weight: 800; }

  /* ---- FRAME (simple fallback) ---- */
  .cin-frame {
    position: absolute; inset: 1.5rem; border: 1px solid rgba(255,255,255,0.08); pointer-events: none; z-index: 20;
  }
  .cin-corner {
    position: absolute; width: 12px; height: 12px;
    border-color: var(--h-gold-dim); border-style: solid; border-width: 0;
  }
  .cin-corner.tl { top: -1px; left: -1px; border-top-width: 1px; border-left-width: 1px; }
  .cin-corner.tr { top: -1px; right: -1px; border-top-width: 1px; border-right-width: 1px; }
  .cin-corner.bl { bottom: -1px; left: -1px; border-bottom-width: 1px; border-left-width: 1px; }
  .cin-corner.br { bottom: -1px; right: -1px; border-bottom-width: 1px; border-right-width: 1px; }
  .cin-frame-tag {
    position: absolute; top: -0.75rem; font-family: var(--font-display); font-size: 0.55rem; font-weight: 700;
    letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.3); padding: 0 0.5rem; background: #000;
  }
  .cin-frame-tag.left  { left: 1.5rem; }
  .cin-frame-tag.right { right: 1.5rem; }

  /* ---- STAGE ---- */
  .cin-stage {
    position: relative; z-index: 10; flex: 1;
    display: flex; align-items: flex-end;
    max-width: 1320px; margin: 0 auto; width: 100%;
    padding: calc(var(--header-height, 64px) + 3.5rem) clamp(1.5rem, 5vw, 3rem) 3rem;
  }

  /* ---- LOCKUP ---- */
  .cin-lockup {
    display: flex; flex-direction: column; align-items: flex-start; gap: 1.1rem; min-width: 0;
    position: relative; max-width: 900px;
  }
  .lockup-rule {
    position: absolute; left: -1.25rem; top: 0.5rem; bottom: 0.5rem; width: 2px;
    background: linear-gradient(to bottom, transparent, var(--h-gold) 20%, var(--h-orange) 80%, transparent);
    opacity: 0.45; border-radius: 2px;
    opacity: 0; animation: fadeInUp 0.8s ease 0.35s both;
  }

  /* Eyebrow */
  .cin-eyebrow { display: flex; align-items: center; gap: 0.85rem; opacity: 0; animation: fadeInUp 0.8s ease 0.4s both; }
  .eyebrow-line { width: 36px; height: 1px; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15) 50%, transparent); }
  .eyebrow-text { font-family: var(--font-display); font-size: 0.6rem; font-weight: 700; letter-spacing: 0.25em; text-transform: uppercase; color: var(--h-muted); white-space: nowrap; }
  .eyebrow-slash { opacity: 0.4; margin: 0 0.3em; }

  /* Meta badges */
  .cin-meta { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; opacity: 0; animation: fadeInUp 0.8s ease 0.5s both; }
  .cin-cat { display: inline-flex; padding: 0.35rem 0.9rem; font-family: var(--font-display); font-size: 0.6rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--h-gold); background: rgba(201,168,76,0.10); border: 1px solid rgba(201,168,76,0.22); border-radius: 100px; }
  .cin-feat { display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.35rem 0.85rem; font-family: var(--font-display); font-size: 0.6rem; font-weight: 700; letter-spacing: 0.12em; background: rgba(201,168,76,0.10); border: 1px solid rgba(201,168,76,0.22); color: var(--h-gold); border-radius: 100px; text-transform: uppercase; }
  .cin-feat svg { width: 10px; height: 10px; }

  /* Title */
  .cin-title {
    font-family: var(--font-body);
    font-size: clamp(2.5rem, 5.5vw, 5rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--h-cream);
    margin: 0;
    max-width: 900px;
    perspective: 1200px;
    text-shadow: 0 2px 20px rgba(0,0,0,0.5), 0 4px 40px rgba(0,0,0,0.4);
  }
  .cin-word { display: inline-block; white-space: nowrap; }
  .cin-char { display: inline-block; opacity: 0; transform: translateY(50px); animation: char-rise 1.4s var(--ease-expo) var(--delay) forwards; }

  /* Lead */
  .cin-lead { font-family: var(--font-display); font-size: clamp(0.92rem, 1.05vw, 1rem); line-height: 1.7; color: rgba(240,237,232,0.55); max-width: 55ch; margin: 0; opacity: 0; animation: fadeInUp 0.8s ease 0.85s both; }
  .lead-quote { color: var(--h-gold); opacity: 0.35; font-family: var(--font-body); font-size: 1.2em; font-weight: 300; }

  /* ================================================================
     PREMIUM DOCK — Bento-card glass panel
     ================================================================ */
  .cin-dock-wrap {
    position: relative;
    width: 100%;
    max-width: 920px;
    margin-top: 0.75rem;
    animation: fadeInUp 1s var(--ease-expo) 0.8s both;
  }

  .cin-dock-glow {
    position: absolute;
    inset: -20px -30px;
    background: radial-gradient(ellipse at 50% 30%, rgba(201,168,76,0.12) 0%, transparent 60%);
    pointer-events: none;
    z-index: -1;
    opacity: 0.6;
  }

  .cin-dock {
    position: relative;
    z-index: 5;
    display: flex;
    align-items: stretch;
    gap: 0;
    background: rgba(255,255,255,0.04);
    backdrop-filter: blur(40px) saturate(180%);
    -webkit-backdrop-filter: blur(40px) saturate(180%);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 24px;
    overflow: hidden;
    box-shadow:
      0 28px 70px rgba(0,0,0,0.45),
      0 0 0 1px rgba(201,168,76,0.12),
      inset 0 1px 0 rgba(255,255,255,0.08);
    transition: transform 0.4s var(--ease-expo), box-shadow 0.4s ease;
  }

  .cin-dock:hover {
    transform: translateY(-2px);
    box-shadow:
      0 36px 90px rgba(0,0,0,0.55),
      0 0 0 1px rgba(201,168,76,0.18),
      inset 0 1px 0 rgba(255,255,255,0.1);
  }

  /* Top gold accent bar */
  .cin-dock::before {
    content: '';
    position: absolute;
    top: 0;
    left: 24px;
    right: 24px;
    height: 2px;
    background: linear-gradient(90deg,
      transparent 0%,
      rgba(201,168,76,0.5) 15%,
      rgba(201,168,76,0.8) 50%,
      rgba(201,168,76,0.5) 85%,
      transparent 100%
    );
    border-radius: 0 0 2px 2px;
    z-index: 2;
  }

  /* Corner brackets on dock */
  .dock-bracket {
    position: absolute;
    width: 18px;
    height: 18px;
    border-color: rgba(201,168,76,0.35);
    border-style: solid;
    border-width: 0;
    transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
    pointer-events: none;
    z-index: 2;
  }
  .cin-dock:hover .dock-bracket {
    width: 28px;
    height: 28px;
    border-color: rgba(201,168,76,0.6);
  }
  .dock-bracket.tl { top: 10px; left: 10px; border-top-width: 1.5px; border-left-width: 1.5px; }
  .dock-bracket.tr { top: 10px; right: 10px; border-top-width: 1.5px; border-right-width: 1.5px; }
  .dock-bracket.bl { bottom: 10px; left: 10px; border-bottom-width: 1.5px; border-left-width: 1.5px; }
  .dock-bracket.br { bottom: 10px; right: 10px; border-bottom-width: 1.5px; border-right-width: 1.5px; }

  /* Dock cells */
  :global(.cin-dock-cell) {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 2rem 1.75rem 2rem 1.5rem;
    flex: 1;
    min-width: 0;
    position: relative;

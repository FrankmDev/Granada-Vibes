---
import ScreenFrame from '@components/ui/ScreenFrame.astro';
import OptimizedImage from '@components/ui/OptimizedImage.astro';
import type { Locale } from '@types';

interface Props {
  locale: Locale;
  title: string;
  subtitle?: string;
  eyebrow?: string;
  eyebrowRight?: string;
  description?: string;
  ctaText?: string;
  ctaLink?: string;
  secondaryCtaText?: string;
  secondaryCtaLink?: string;
  backgroundImage?: string;
  pageNumber?: string;
  coordinates?: string;
  metadata?: { label: string; value: string; icon?: string }[];
  variant?: 'default' | 'compact';
}

const {
  locale,
  title,
  subtitle,
  eyebrow,
  eyebrowRight,
  description,
  ctaText,
  ctaLink = '#',
  secondaryCtaText,
  secondaryCtaLink = '#',
  backgroundImage = '/images/hero-fallback.jpg',
  pageNumber = '01',
  coordinates = '37\u00b0N \u00b7 3\u00b0W',
  metadata = [],
  variant = 'default',
} = Astro.props;

const iconSvg: Record<string, string> = {
  calendar: '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>',
  layers: '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline></svg>',
  'map-pin': '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>',
  clock: '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>',
  compass: '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon></svg>',
  default: '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>',
};
---

<section
  class="radiant-hero"
  aria-label={title}
  data-hero-variant={variant}
  data-radiant-hero
>
  <!-- FULL-BLEED IMAGE LAYER -->
  <div class="rh-bg">
    <div class="rh-img-wrap">
      <OptimizedImage
        src={backgroundImage}
        alt=""
        class="rh-img"
        loading="eager"
        sizes="100vw"
      />
    </div>
    <!-- WARM OVERLAY: much less dark, preserves image vibrancy -->
    <div class="rh-overlay" aria-hidden="true"></div>
    <div class="rh-warm-wash" aria-hidden="true"></div>
    <div class="rh-vignette" aria-hidden="true"></div>
    <div class="rh-noise" aria-hidden="true"></div>
  </div>

  <!-- FLOATING PARTICLES -->
  <div class="rh-particles" aria-hidden="true">
    {Array.from({ length: 8 }).map((_, i) => (
      <span class={`particle p-${i + 1}`}></span>
    ))}
  </div>

  <!-- DECORATIVE BLOBS -->
  <div class="rh-blob blob-a" aria-hidden="true"></div>
  <div class="rh-blob blob-b" aria-hidden="true"></div>
  <div class="rh-blob blob-c" aria-hidden="true"></div>
  <div class="rh-blob blob-d" aria-hidden="true"></div>

  <!-- FLOATING RING -->
  <div class="rh-ring" aria-hidden="true">
    <svg viewBox="0 0 300 300" fill="none">
      <circle cx="150" cy="150" r="148" stroke="rgba(232,98,42,0.15)" stroke-width="0.8" stroke-dasharray="6 10"/>
      <circle cx="150" cy="150" r="135" stroke="rgba(201,168,76,0.1)" stroke-width="0.6"/>
    </svg>
  </div>

  <!-- ACCENT LINES -->
  <div class="rh-accent-line al-1" aria-hidden="true"></div>
  <div class="rh-accent-line al-2" aria-hidden="true"></div>
  <div class="rh-accent-line al-3" aria-hidden="true"></div>

  <!-- SWEEP LINE -->
  <div class="rh-sweep" aria-hidden="true">
    <span class="sweep-bar"></span>
  </div>

  <!-- TIMECODE FLOAT -->
  <div class="rh-timecode" aria-hidden="true">
    <span class="tc-digits">00:{pageNumber}:00</span>
  </div>

  <!-- Screen Frame -->
  <ScreenFrame
    tagTopLeft={eyebrow || 'GRN INDEX'}
    tagTopRight={eyebrowRight || coordinates}
    tagBottomLeft={`PG. ${pageNumber}`}
    tagBottomRight={locale === 'es' ? 'ED. 2025' : 'ED. 2025'}
  />

  <!-- MAIN CONTENT -->
  <div class="rh-content">
    <div class="rh-inner">
      <!-- LEFT: Typography -->
      <div class="rh-main">
        <!-- Floating badge -->
        <div class="rh-badge" aria-hidden="true">
          <span class="rhb-pip"></span>
          <span class="rhb-text">REF. {pageNumber}</span>
        </div>

        {(subtitle || eyebrow) && (
          <div class="rh-eyebrow">
            <span class="rhe-line" aria-hidden="true"></span>
            <span class="rhe-text">{subtitle || eyebrow}</span>
            <span class="rhe-line" aria-hidden="true"></span>
          </div>
        )}

        <!-- Title with warm glow -->
        <h1 class="rh-title">
          {title.split('').map((char, i) => (
            <span class="rh-char" style={`--delay: ${0.2 + i * 0.025}s`}>
              {char === ' ' ? '\u00A0' : char}
            </span>
          ))}
        </h1>

        <!-- Gold underline track -->
        <div class="rh-track" aria-hidden="true">
          <span class="rht-fill"></span>
          <span class="rht-orb"></span>
          <span class="rht-glow"></span>
        </div>

        {description && (
          <p class="rh-desc">{description}</p>
        )}

        <div class="rh-ctas">
          {ctaText && (
            <a href={ctaLink} class="rh-cta rh-cta-p">
              <span class="cta-gleam" aria-hidden="true"></span>
              <span class="cta-txt">{ctaText}</span>
              <svg class="cta-arrow" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          )}

          {secondaryCtaText && (
            <a href={secondaryCtaLink} class="rh-cta rh-cta-s">
              <span class="cta-txt">{secondaryCtaText}</span>
            </a>
          )}
        </div>
      </div>

      <!-- RIGHT: Floating Metadata Pills -->
      {metadata.length > 0 && (
        <div class="rh-meta">
          <div class="rh-meta-header">
            <span class="rhm-pip" aria-hidden="true"></span>
            <span class="rhm-label">
              {locale === 'es' ? 'REGISTRO' : 'LOG'}
            </span>
          </div>
          <div class="rh-pills">
            {metadata.map((item, idx) => (
              <div class="rh-pill" style={`--delay: ${0.45 + idx * 0.1}s`}>
                <div class="pill-icon" set:html={iconSvg[item.icon ?? ''] ?? iconSvg.default} />
                <div class="pill-body">
                  <span class="pill-val">{item.value}</span>
                  <span class="pill-lbl">{item.label}</span>
                </div>
                <span class="pill-idx" aria-hidden="true">{String(idx + 1).padStart(2, '0')}</span>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>

  <!-- BOTTOM STRIP -->
  <div class="rh-strip" aria-hidden="true">
    <div class="rh-strip-inner">
      <div class="rs-left">
        <span class="rs-pip"></span>
        <span class="rs-text">{coordinates}</span>
      </div>
      <div class="rs-center">
        <span class="rs-diamond">
          <svg width="8" height="8" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2L22 12L12 22L2 12Z"/>
          </svg>
        </span>
      </div>
      <div class="rs-right">
        <span class="rs-text">GRANADA</span>
        <span class="rs-pip"></span>
      </div>
    </div>
  </div>
</section>

<style>
  /* ========== RADIANT HERO ========== */
  .radiant-hero {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    overflow: hidden;
    isolation: isolate;
  }

  [data-hero-variant="default"] {
    min-height: 72vh;
    min-height: 72dvh;
  }

  [data-hero-variant="compact"] {
    min-height: auto;
  }

  /* ========== BACKGROUND ========== */
  .rh-bg {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .rh-img-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  /* MUCH more vibrant image */
  .rh-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.72) saturate(1.45) contrast(1.05);
    transform: scale(1.06);
    will-change: transform;
    animation: imgSettle 2.5s var(--ease-out-expo) forwards;
  }

  @keyframes imgSettle {
    from { transform: scale(1.14); filter: brightness(0.5) saturate(1.1) contrast(1.05); }
    to   { transform: scale(1.06); filter: brightness(0.72) saturate(1.45) contrast(1.05); }
  }

  /* Directional overlay: ONLY darkens left side where text is */
  .rh-overlay {
    position: absolute;
    inset: 0;
    background:
      /* Very subtle left-side darkening for text */
      radial-gradient(ellipse 75% 100% at 0% 55%, rgba(0,0,0,0.35) 0%, transparent 55%),
      /* Bottom fade for continuity */
      linear-gradient(180deg, transparent 60%, rgba(0,0,0,0.3) 100%);
    z-index: 2;
  }

  /* Warm golden wash over entire image for cohesion */
  .rh-warm-wash {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 80% 20%, rgba(201, 168, 76, 0.1) 0%, transparent 50%),
      radial-gradient(ellipse 50% 40% at 20% 80%, rgba(232, 98, 42, 0.08) 0%, transparent 50%);
    mix-blend-mode: soft-light;
    z-index: 3;
    pointer-events: none;
  }

  .rh-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 65% 35%, transparent 30%, rgba(0,0,0,0.35) 100%);
    z-index: 3;
    pointer-events: none;
  }

  .rh-noise {
    position: absolute;
    inset: 0;
    z-index: 4;
    opacity: 0.02;
    mix-blend-mode: overlay;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 128px 128px;
  }

  /* ========== FLOATING PARTICLES ========== */
  .rh-particles {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }

  .particle {
    position: absolute;
    border-radius: 50%;
    background: var(--color-gold-text);
    box-shadow: 0 0 10px var(--color-gold-dim);
    opacity: 0;
    animation: particleFloat 8s ease-in-out infinite;
  }

  .p-1 { width: 3px; height: 3px; top: 15%; left: 12%; animation-delay: 0s; }
  .p-2 { width: 2px; height: 2px; top: 25%; right: 18%; animation-delay: 1.5s; background: var(--color-accent); box-shadow: 0 0 8px rgba(232,98,42,0.4); }
  .p-3 { width: 4px; height: 4px; top: 60%; left: 8%; animation-delay: 3s; }
  .p-4 { width: 2px; height: 2px; bottom: 30%; right: 25%; animation-delay: 4.5s; background: #fff; box-shadow: 0 0 6px rgba(255,255,255,0.4); }
  .p-5 { width: 3px; height: 3px; top: 40%; right: 10%; animation-delay: 2s; }
  .p-6 { width: 2px; height: 2px; bottom: 20%; left: 20%; animation-delay: 5.5s; background: var(--color-accent); box-shadow: 0 0 8px rgba(232,98,42,0.4); }
  .p-7 { width: 3px; height: 3px; top: 10%; right: 35%; animation-delay: 1s; }
  .p-8 { width: 2px; height: 2px; bottom: 40%; left: 30%; animation-delay: 6s; background: #fff; box-shadow: 0 0 6px rgba(255,255,255,0.4); }

  @keyframes particleFloat {
    0% { opacity: 0; transform: translateY(0) scale(0); }
    15% { opacity: 0.7; transform: translateY(-10px) scale(1); }
    50% { opacity: 0.4; transform: translateY(-30px) scale(0.8); }
    85% { opacity: 0.7; transform: translateY(-50px) scale(1); }
    100% { opacity: 0; transform: translateY(-70px) scale(0); }
  }

  /* ========== DECORATIVE BLOBS ========== */
  .rh-blob {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: 2;
    opacity: 0;
    animation: blobFade 2.5s ease forwards;
    mix-blend-mode: screen;
  }

  .blob-a {
    width: 400px; height: 400px;
    top: -15%; right: -8%;
    background: radial-gradient(circle, rgba(232,98,42,0.22) 0%, transparent 65%);
    filter: blur(50px);
    animation-delay: 0.6s;
  }

  .blob-b {
    width: 320px; height: 320px;
    bottom: 0%; left: -10%;
    background: radial-gradient(circle, rgba(201,168,76,0.18) 0%, transparent 65%);
    filter: blur(45px);
    animation-delay: 1s;
  }

  .blob-c {
    width: 220px; height: 220px;
    top: 30%; right: 15%;
    background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 60%);
    filter: blur(35px);
    animation-delay: 1.4s;
  }

  .blob-d {
    width: 180px; height: 180px;
    bottom: 25%; right: 30%;
    background: radial-gradient(circle, rgba(232,98,42,0.12) 0%, transparent 60%);
    filter: blur(40px);
    animation-delay: 1.8s;
  }

  @keyframes blobFade {
    from { opacity: 0; transform: scale(0.8); }
    to   { opacity: 1; transform: scale(1); }
  }

  /* ========== FLOATING RING ========== */
  .rh-ring {
    position: absolute;
    top: 50%;
    right: -5%;
    width: 420px;
    height: 420px;
    transform: translateY(-50%);
    z-index: 2;
    pointer-events: none;
    opacity: 0;
    animation: blobFade 3s ease 1s forwards;
  }

  .rh-ring svg {
    width: 100%;
    height: 100%;
    animation: ringSpin 30s linear infinite;
  }

  @keyframes ringSpin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* ========== ACCENT LINES ========== */
  .rh-accent-line {
    position: absolute;
    z-index: 2;
    pointer-events: none;
  }

  .al-1 {
    top: 18%;
    left: 6%;
    width: 1px;
    height: 100px;
    background: linear-gradient(to bottom, var(--color-gold-dim), transparent);
    opacity: 0;
    animation: lineGrow 1.2s var(--ease-out-expo) 0.6s forwards;
  }

  .al-2 {
    bottom: 22%;
    right: 10%;
    width: 100px;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(232,98,42,0.35));
    opacity: 0;
    animation: lineGrowH 1.2s var(--ease-out-expo) 0.8s forwards;
  }

  .al-3 {
    top: 8%;
    right: 25%;
    width: 60px;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--color-gold-dim));
    opacity: 0;
    animation: lineGrowH 1s var(--ease-out-expo) 1s forwards;
  }

  @keyframes lineGrow {
    from { opacity: 0; transform: scaleY(0); }
    to   { opacity: 0.7; transform: scaleY(1); }
  }

  @keyframes lineGrowH {
    from { opacity: 0; transform: scaleX(0); }
    to   { opacity: 0.7; transform: scaleX(1); }
  }

  /* ========== SWEEP LINE ========== */
  .rh-sweep {
    position: absolute;
    top: 35%;
    left: 0;
    right: 0;
    height: 1px;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }

  .sweep-bar {
    display: block;
    width: 30%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(201,168,76,0.2), transparent);
    animation: sweepMove 5s ease-in-out infinite;
  }

  @keyframes sweepMove {
    0% { transform: translateX(-100%); opacity: 0; }
    20% { opacity: 1; }
    80% { opacity: 1; }
    100% { transform: translateX(400%); opacity: 0; }
  }

  /* ========== TIMECODE FLOAT ========== */
  .rh-timecode {
    position: absolute;
    top: 12%;
    right: 8%;
    z-index: 2;
    pointer-events: none;
    opacity: 0;
    animation: fadeUp 1s ease 1.2s forwards;
  }

  .tc-digits {
    font-family: var(--font-display);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.18);
    font-variant-numeric: tabular-nums;
  }

  /* ========== SCREEN FRAME OVERRIDES ========== */
  .radiant-hero :global(.cin-screen-frame) { z-index: 10; }
  .radiant-hero :global(.cin-corner::before),
  .radiant-hero :global(.cin-corner::after) { background: rgba(255, 255, 255, 0.12); }
  .radiant-hero :global(.cin-frame-tag) {
    color: rgba(255, 255, 255, 0.28);
    font-size: 0.5rem;
    letter-spacing: 0.28em;
    font-weight: 600;
  }

  /* ========== MAIN CONTENT ========== */
  .rh-content {
    position: relative;
    z-index: 6;
    flex: 1;
    display: flex;
    align-items: flex-end;
    padding: calc(var(--header-height) + 5rem) clamp(1.5rem, 6vw, 5rem) 2.5rem;
    max-width: 1440px;
    margin: 0 auto;
    width: 100%;
  }

  [data-hero-variant="compact"] .rh-content {
    padding: calc(var(--header-height) + 3.5rem) clamp(1.5rem, 6vw, 5rem) 2rem;
  }

  .rh-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    width: 100%;
    gap: 3rem;
  }

  /* ========== LEFT COLUMN ========== */
  .rh-main {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 680px;
    position: relative;
  }

  /* Floating badge */
  .rh-badge {
    position: absolute;
    top: -2.25rem;
    right: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    animation: fadeSlideRight 0.8s var(--ease-out-expo) 0.3s forwards;
  }

  .rhb-pip {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 8px var(--color-accent);
    animation: pulse 2.5s ease-in-out infinite;
  }

  .rhb-text {
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--color-gold-text);
    text-transform: uppercase;
  }

  /* Eyebrow */
  .rh-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    opacity: 0;
    animation: fadeSlideRight 0.8s var(--ease-out-expo) 0.15s forwards;
  }

  .rhe-line {
    width: 36px;
    height: 1px;
    background: linear-gradient(to right, var(--color-gold-dim), transparent);
    flex-shrink: 0;
  }

  .rhe-text {
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-gold-text);
    white-space: nowrap;
  }

  @keyframes fadeSlideRight {
    from { opacity: 0; transform: translateX(-24px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  /* Title with warm glow and gradient tint */
  .rh-title {
    font-family: var(--font-body);
    font-size: clamp(2.8rem, 5.5vw, 5.8rem);
    font-weight: 300;
    line-height: 1.02;
    margin: 0;
    letter-spacing: -0.02em;
    white-space: nowrap;
    display: block;
    position: relative;
    z-index: 1;
    color: var(--color-text-primary);
    text-shadow:
      0 2px 20px rgba(0,0,0,0.5),
      0 4px 40px rgba(0,0,0,0.3),
      0 0 80px rgba(201,168,76,0.08);
  }

  .rh-char {
    display: inline-block;
    opacity: 0;
    transform: translateY(110%) rotateX(45deg);
    transform-origin: bottom center;
    animation: charPop 0.9s var(--ease-out-expo) forwards;
  }

  @keyframes charPop {
    from { opacity: 0; transform: translateY(110%) rotateX(45deg); }
    to   { opacity: 1; transform: translateY(0) rotateX(0deg); }
  }

  /* Gold track under title */
  .rh-track {
    display: block;
    position: relative;
    height: 2px;
    margin-top: 1rem;
    width: 0;
    animation: trackGrow 1.4s var(--ease-out-expo) 0.7s forwards;
  }

  .rht-fill {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, var(--color-gold-dim), rgba(232,98,42,0.5), transparent);
    border-radius: 1px;
  }

  .rht-orb {
    position: absolute;
    top: -3px;
    left: 0;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-gold-text);
    box-shadow: 0 0 12px var(--color-gold-dim), 0 0 24px rgba(232,98,42,0.25);
    animation: orbDash 3s ease-in-out infinite;
  }

  .rht-glow {
    position: absolute;
    top: -4px;
    left: 0;
    width: 60px;
    height: 10px;

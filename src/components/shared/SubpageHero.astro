---
import ScreenFrame from '@components/ui/ScreenFrame.astro';
import OptimizedImage from '@components/ui/OptimizedImage.astro';
import type { Locale } from '@types';
import { useTranslations } from '@i18n/utils';

interface Props {
  locale: Locale;
  title: string;
  subtitle?: string;
  eyebrow?: string;
  eyebrowRight?: string;
  description?: string;
  ctaText?: string;
  ctaLink?: string;
  secondaryCtaText?: string;
  secondaryCtaLink?: string;
  backgroundImage?: string;
  pageNumber?: string;
  coordinates?: string;
  metadata?: { label: string; value: string; icon?: string }[];
  variant?: 'default' | 'compact';
}

const {
  locale,
  title,
  subtitle,
  eyebrow,
  eyebrowRight,
  description,
  ctaText,
  ctaLink = '#',
  secondaryCtaText,
  secondaryCtaLink = '#',
  backgroundImage = undefined,
  pageNumber = '01',
  coordinates = '37\u00b0N \u00b7 3\u00b0W',
  metadata = [],
  variant = 'default',
} = Astro.props;
const t = useTranslations(locale);

const iconSvg: Record<string, string> = {
  calendar: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>',
  layers: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>',
  'map-pin': '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>',
  clock: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
  compass: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>',
  default: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>',
};
---

<section
  class="sp-hero"
  aria-label={title}
  data-hero-variant={variant}
  data-sp-hero
>
  <!-- BACKGROUND -->
  <div class="sp-bg">
    {backgroundImage && (
      <div class="sp-img-wrap">
        <OptimizedImage
          src={backgroundImage}
          alt=""
          class="sp-img"
          loading="eager"
          sizes="100vw"
        />
      </div>
    )}
    <div class="sp-overlay" aria-hidden="true"></div>
    <div class="sp-vignette" aria-hidden="true"></div>
    <div class="sp-grain" aria-hidden="true"></div>
    <div class="sp-mouse-glow" aria-hidden="true"></div>
  </div>

  <!-- CINEMATIC PARTICLE FIELD -->
  <div class="sp-particles" aria-hidden="true">
    {Array.from({ length: 12 }).map((_, i) => (
      <span class={`sp-particle sp-p-${i + 1}`}></span>
    ))}
  </div>

  <!-- SCAN LINE -->
  <div class="sp-scan" aria-hidden="true">
    <span class="sp-scan-bar"></span>
  </div>

  <!-- GRID OVERLAY -->
  <div class="sp-grid" aria-hidden="true"></div>

  <!-- COMPASS RING -->
  <div class="sp-compass" aria-hidden="true">
    <svg viewBox="0 0 200 200" fill="none">
      <circle cx="100" cy="100" r="98" stroke="rgba(201,168,76,0.08)" stroke-width="0.5" stroke-dasharray="4 8"/>
      <circle cx="100" cy="100" r="84" stroke="rgba(232,98,42,0.05)" stroke-width="0.5"/>
      <circle cx="100" cy="100" r="72" stroke="rgba(201,168,76,0.04)" stroke-width="0.5" stroke-dasharray="2 6"/>
    </svg>
  </div>

  <!-- CROSSHAIR DECORATION -->
  <div class="sp-crosshair" aria-hidden="true">
    <span class="sp-ch-h"></span>
    <span class="sp-ch-v"></span>
    <span class="sp-ch-dot"></span>
  </div>

  <!-- VERTICAL ACCENTS -->
  <div class="sp-accent-v" aria-hidden="true"></div>
  <div class="sp-accent-v2" aria-hidden="true"></div>

  <!-- PAGE INDICATOR -->
  <div class="sp-page-indicator" aria-hidden="true">
    <span class="sp-pi-line"></span>
    <span class="sp-pi-num">{pageNumber}</span>
    <span class="sp-pi-line"></span>
  </div>

  <!-- Screen Frame -->
  <ScreenFrame
    tagTopLeft={eyebrow || 'GRN URBAN'}
    tagTopRight={eyebrowRight || coordinates}
    tagBottomLeft={`PG. ${pageNumber}`}
    tagBottomRight={'ED. 2025'}
  />

  <!-- MAIN CONTENT -->
  <div class="sp-content">
    <div class="sp-inner">
      <!-- LEFT: Typography -->
      <div class="sp-main">
        {(subtitle || eyebrow) && (
          <div class="sp-eyebrow">
            <span class="sp-eyebrow-line" aria-hidden="true"></span>
            <span class="sp-status-dot" aria-hidden="true"></span>
            <span class="sp-eyebrow-text">{subtitle || eyebrow}</span>
          </div>
        )}

        <h1 class="sp-title">
          {title.split('').map((char, i) => (
            <span class="sp-char" style={`--delay: ${0.15 + i * 0.03}s`}>
              {char === ' ' ? '\u00A0' : char}
            </span>
          ))}
        </h1>

        <div class="sp-divider" aria-hidden="true">
          <span class="sp-divider-track"></span>
          <span class="sp-divider-orb"></span>
          <span class="sp-divider-glow"></span>
        </div>

        {description && (
          <p class="sp-desc">{description}</p>
        )}

        <div class="sp-ctas">
          {ctaText && (
            <a href={ctaLink} class="sp-cta sp-cta-p">
              <span class="sp-cta-gleam" aria-hidden="true"></span>
              <span class="sp-cta-txt">{ctaText}</span>
              <svg class="sp-cta-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          )}

          {secondaryCtaText && (
            <a href={secondaryCtaLink} class="sp-cta sp-cta-s">
              <span class="sp-cta-txt">{secondaryCtaText}</span>
            </a>
          )}
        </div>
      </div>

      <!-- RIGHT: Premium Metadata Panel -->
      {metadata.length > 0 && (
        <div class="sp-meta">
          <!-- Ambient glow behind panel -->
          <div class="sp-meta-ambient" aria-hidden="true"></div>

          <div class="sp-meta-card" data-meta-card>
            <!-- Animated rotating border -->
            <div class="sp-meta-border" aria-hidden="true"></div>

            <div class="sp-meta-inner">
              <!-- Top accent bar -->
              <div class="sp-meta-topbar" aria-hidden="true">
                <span class="sp-meta-topbar-glow"></span>
              </div>

              <!-- Panel Header -->
              <div class="sp-meta-header">
                <div class="sp-meta-header-left">
                  <span class="sp-meta-header-pip" aria-hidden="true"></span>
                  <span class="sp-meta-header-text">{locale === 'es' ? 'Datos clave' : 'Key data'}</span>
                </div>
                <span class="sp-meta-header-count" aria-hidden="true">{String(metadata.length).padStart(2, '0')}</span>
              </div>

              <!-- Panel Items -->
              <div class="sp-meta-body">
                {metadata.map((item, idx) => (
                  <div class="sp-meta-row" style={`--delay: ${0.5 + idx * 0.14}s; --row-idx: ${idx}`}>
                    <!-- Background index number -->
                    <span class="sp-meta-bg-idx" aria-hidden="true">{String(idx + 1).padStart(2, '0')}</span>

                    <div class="sp-meta-ring" aria-hidden="true">
                      <div class="sp-meta-ring-inner">
                        <div class="sp-meta-icon" set:html={iconSvg[item.icon ?? ''] ?? iconSvg.default} />
                      </div>
                      <svg class="sp-meta-ring-svg" viewBox="0 0 38 38" fill="none">
                        <circle cx="19" cy="19" r="17" stroke="rgba(201,168,76,0.15)" stroke-width="1" stroke-dasharray="50 35" style={`animation-delay: ${idx * 0.5}s`} />
                      </svg>
                    </div>

                    <div class="sp-meta-content">
                      <span class="sp-meta-val">{item.value}</span>
                      <span class="sp-meta-lbl">{item.label}</span>
                      <div class="sp-meta-mini-divider" aria-hidden="true">
                        <span class="sp-meta-mini-track"></span>
                        <span class="sp-meta-mini-orb"></span>
                      </div>
                    </div>

                    <div class="sp-meta-row-accent" aria-hidden="true"></div>
                  </div>
                ))}
              </div>

              <!-- Footer dots -->
              <div class="sp-meta-footer" aria-hidden="true">
                {metadata.map((_, idx) => (
                  <span class={`sp-meta-dot ${idx === 0 ? 'is-active' : ''}`} style={`--dot-delay: ${idx * 0.2}s`}></span>
                ))}
              </div>

              <!-- Corner Brackets -->
              <span class="sp-meta-corner sp-meta-corner-tl" aria-hidden="true"></span>
              <span class="sp-meta-corner sp-meta-corner-tr" aria-hidden="true"></span>
              <span class="sp-meta-corner sp-meta-corner-bl" aria-hidden="true"></span>
              <span class="sp-meta-corner sp-meta-corner-br" aria-hidden="true"></span>
            </div>
          </div>
        </div>
      )}
    </div>
  </div>

  <!-- BOTTOM STRIP -->
  <div class="sp-strip" aria-hidden="true">
    <div class="sp-strip-inner">
      <div class="sp-strip-left">
        <span class="sp-live-dot" aria-hidden="true"></span>
        <span class="sp-strip-text">{locale === 'es' ? 'En directo' : 'Live'}</span>
      </div>
      <div class="sp-strip-center">
        <span class="sp-strip-coords">{coordinates}</span>
        <span class="sp-strip-sep" aria-hidden="true"></span>
        <span class="sp-strip-city">Granada</span>
      </div>
      <div class="sp-strip-right">
        <span class="sp-strip-time" data-live-time aria-hidden="true">--:--</span>
        <span class="sp-strip-temp" aria-hidden="true">19\u00b0C</span>
      </div>
    </div>
  </div>
</section>

<style>
  /* ========== SUBPAGE HERO ========== */
  .sp-hero {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    overflow: hidden;
    isolation: isolate;
  }

  [data-hero-variant="default"] {
    min-height: 72vh;
    min-height: 72dvh;
  }

  [data-hero-variant="compact"] {
    min-height: auto;
  }

  /* ========== BACKGROUND ========== */
  .sp-bg {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .sp-img-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .sp-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.65) saturate(1.4) contrast(1.08);
    transform: scale(1.1);
    will-change: transform;
    animation: spImgSettle 2.4s var(--ease-out-expo) forwards;
  }

  @keyframes spImgSettle {
    from {
      transform: scale(1.2);
      filter: brightness(0.4) saturate(1.05) contrast(1.05);
    }
    to {
      transform: scale(1.1);
      filter: brightness(0.65) saturate(1.4) contrast(1.08);
    }
  }

  .sp-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 100% at 0% 50%, rgba(0,0,0,0.48) 0%, transparent 65%),
      linear-gradient(180deg, rgba(0,0,0,0.15) 0%, transparent 35%, rgba(0,0,0,0.4) 100%);
    z-index: 2;
  }

  .sp-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 55% 30%, transparent 25%, rgba(0,0,0,0.4) 100%);
    z-index: 3;
    pointer-events: none;
  }

  .sp-grain {
    position: absolute;
    inset: 0;
    z-index: 4;
    opacity: 0.03;
    mix-blend-mode: overlay;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 128px 128px;
  }

  .sp-mouse-glow {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  .sp-hero:hover .sp-mouse-glow {
    opacity: 1;
  }

  .sp-mouse-glow::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(500px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(232,98,42,0.07), transparent 55%);
  }

  .sp-mouse-glow::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(300px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(201,168,76,0.04), transparent 50%);
  }

  /* ========== PARTICLE FIELD ========== */
  .sp-particles {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }

  .sp-particle {
    position: absolute;
    border-radius: 50%;
    opacity: 0;
  }

  .sp-p-1 { width: 2px; height: 2px; top: 12%; left: 10%; background: var(--color-gold-text); box-shadow: 0 0 8px rgba(201,168,76,0.3); animation: spParticleFloat 12s ease-in-out infinite; }
  .sp-p-2 { width: 3px; height: 3px; top: 22%; right: 15%; background: var(--color-accent); box-shadow: 0 0 10px rgba(232,98,42,0.25); animation: spParticleFloat 14s ease-in-out 1.5s infinite; }
  .sp-p-3 { width: 2px; height: 2px; top: 55%; left: 6%; background: var(--color-gold-text); box-shadow: 0 0 6px rgba(201,168,76,0.2); animation: spParticleFloat 11s ease-in-out 3s infinite; }
  .sp-p-4 { width: 2px; height: 2px; bottom: 32%; right: 22%; background: rgba(255,255,255,0.6); box-shadow: 0 0 8px rgba(255,255,255,0.15); animation: spParticleFloat 13s ease-in-out 2s infinite; }
  .sp-p-5 { width: 2px; height: 2px; top: 38%; right: 8%; background: var(--color-gold-text); box-shadow: 0 0 7px rgba(201,168,76,0.2); animation: spParticleFloat 15s ease-in-out 4s infinite; }
  .sp-p-6 { width: 3px; height: 3px; bottom: 18%; left: 18%; background: var(--color-accent); box-shadow: 0 0 9px rgba(232,98,42,0.2); animation: spParticleFloat 12s ease-in-out 0.5s infinite; }
  .sp-p-7 { width: 2px; height: 2px; top: 8%; right: 32%; background: rgba(255,255,255,0.5); box-shadow: 0 0 6px rgba(255,255,255,0.12); animation: spParticleFloat 16s ease-in-out 5s infinite; }
  .sp-p-8 { width: 2px; height: 2px; bottom: 42%; left: 28%; background: var(--color-gold-text); box-shadow: 0 0 7px rgba(201,168,76,0.18); animation: spParticleFloat 10s ease-in-out 2.5s infinite; }
  .sp-p-9 { width: 2px; height: 2px; top: 65%; right: 12%; background: var(--color-accent); box-shadow: 0 0 8px rgba(232,98,42,0.15); animation: spParticleFloat 14s ease-in-out 6s infinite; }
  .sp-p-10 { width: 2px; height: 2px; top: 45%; left: 15%; background: rgba(255,255,255,0.4); box-shadow: 0 0 5px rgba(255,255,255,0.1); animation: spParticleFloat 11s ease-in-out 3.5s infinite; }
  .sp-p-11 { width: 3px; height: 3px; bottom: 28%; right: 38%; background: var(--color-gold-text); box-shadow: 0 0 9px rgba(201,168,76,0.2); animation: spParticleFloat 13s ease-in-out 1s infinite; }
  .sp-p-12 { width: 2px; height: 2px; top: 18%; left: 42%; background: var(--color-accent); box-shadow: 0 0 7px rgba(232,98,42,0.18); animation: spParticleFloat 15s ease-in-out 4.5s infinite; }

  @keyframes spParticleFloat {
    0% { opacity: 0; transform: translateY(0) scale(0); }
    8% { opacity: 0.6; transform: translateY(-6px) scale(1); }
    45% { opacity: 0.3; transform: translateY(-22px) scale(0.9); }
    88% { opacity: 0.5; transform: translateY(-40px) scale(1); }
    100% { opacity: 0; transform: translateY(-56px) scale(0); }
  }

  /* ========== SCAN LINE ========== */
  .sp-scan {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    z-index: 5;
    pointer-events: none;
    overflow: hidden;
  }

  .sp-scan-bar {
    display: block;
    width: 35%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(232,98,42,0.18), rgba(201,168,76,0.12), rgba(232,98,42,0.18), transparent);
    filter: blur(1px);
    animation: spScanMove 8s ease-in-out infinite;
  }

  .sp-scan-bar::after {
    content: '';
    position: absolute;
    inset: 0;
    display: block;
    width: 20%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(232,98,42,0.08), transparent);
    animation: spScanEcho 8s ease-in-out 0.4s infinite;
  }

  @keyframes spScanEcho {
    0% { transform: translateX(-120%); opacity: 0; }
    15% { opacity: 0.6; }
    85% { opacity: 0.6; }
    100% { transform: translateX(520%); opacity: 0; }
  }

  @keyframes spScanMove {
    0% { transform: translateX(-120%); opacity: 0; }
    15% { opacity: 0.8; }
    85% { opacity: 0.8; }
    100% { transform: translateX(420%); opacity: 0; }
  }

  /* ========== GRID OVERLAY ========== */
  .sp-grid {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    opacity: 0;
    animation: spFadeIn 2.5s ease 1s forwards;
    background-image:
      linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse at 50% 50%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at 50% 50%, black 20%, transparent 70%);
  }

  /* ========== COMPASS RING ========== */
  .sp-compass {
    position: absolute;
    top: 50%;
    right: -4%;
    width: 340px;
    height: 340px;
    transform: translateY(-50%);
    z-index: 2;
    pointer-events: none;
    opacity: 0;
    animation: spFadeIn 2s ease 0.8s forwards;
  }

  .sp-compass svg {
    width: 100%;
    height: 100%;
    animation: spRingSpin 60s linear infinite;
  }

  @keyframes spRingSpin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* ========== CROSSHAIR ========== */
  .sp-crosshair {
    position: absolute;
    top: 14%;
    right: 12%;
    width: 24px;
    height: 24px;
    z-index: 2;
    pointer-events: none;
    opacity: 0;
    animation: spFadeIn 1.5s ease 1.2s forwards;
  }

  .sp-ch-h, .sp-ch-v {
    position: absolute;
    background: rgba(201, 168, 76, 0.15);
  }

  .sp-ch-h {
    top: 50%;
    left: 0;
    width: 100%;
    height: 1px;
    transform: translateY(-50%);
  }

  .sp-ch-v {
    left: 50%;
    top: 0;
    width: 1px;
    height: 100%;
    transform: translateX(-50%);
  }

  .sp-ch-dot {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: rgba(232, 98, 42, 0.4);
    transform: translate(-50%, -50%);
    animation: spChPulse 3s ease-in-out infinite;
  }

  @keyframes spChPulse {
    0%, 100% { opacity: 0.4; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 0.8; transform: translate(-50%, -50%) scale(1.3); }
  }

  /* ========== VERTICAL ACCENTS ========== */
  .sp-accent-v {
    position: absolute;
    top: 20%;
    left: 5.5%;
    width: 1px;
    height: 72px;
    background: linear-gradient(to bottom, var(--color-gold-dim), transparent);
    z-index: 2;
    pointer-events: none;
    opacity: 0;
    animation: spLineGrow 1s var(--ease-out-expo) 0.6s forwards;
  }

  .sp-accent-v2 {
    position: absolute;
    bottom: 18%;
    right: 6%;
    width: 48px;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(232,98,42,0.2));
    z-index: 2;
    pointer-events: none;
    opacity: 0;
    animation: spLineGrowH 1s var(--ease-out-expo) 0.9s forwards;
  }

  @keyframes spLineGrow {
    from { opacity: 0; transform: scaleY(0); }
    to   { opacity: 0.5; transform: scaleY(1); }
  }

  @keyframes spLineGrowH {
    from { opacity: 0; transform: scaleX(0); }
    to   { opacity: 0.5; transform: scaleX(1); }
  }

  @keyframes spFadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* ========== PAGE INDICATOR ========== */
  .sp-page-indicator {
    position: absolute;
    top: 50%;
    left: 1.75rem;
    transform: translateY(-50%);
    z-index: 6;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    opacity: 0;
    animation: spFadeIn 1s ease 1.5s forwards;
  }

  .sp-pi-line {
    width: 1px;
    height: 24px;
    background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.12), transparent);
  }

  .sp-pi-num {
    font-family: var(--font-display);
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.2);
    writing-mode: vertical-rl;
    text-orientation: mixed;
  }

  /* ========== SCREEN FRAME OVERRIDES ========== */
  .sp-hero :global(.cin-screen-frame) { z-index: 10; }
  .sp-hero :global(.cin-corner::before),
  .sp-hero :global(.cin-corner::after) { background: rgba(255, 255, 255, 0.12); }
  .sp-hero :global(.cin-frame-tag) {
    color: rgba(255, 255, 255, 0.28);
    font-size: 0.5rem;
    letter-spacing: 0.28em;
    font-weight: 600;
  }

  /* ========== MAIN CONTENT ========== */
  .sp-content {
    position: relative;
    z-index: 6;
    flex: 1;
    display: flex;
    align-items: flex-end;
    padding: calc(var(--header-height) + 5.5rem) clamp(2rem, 6.5vw, 5.5rem) 3rem;
    max-width: 1440px;
    margin: 0 auto;
    width: 100%;
  }

  [data-hero-variant="compact"] .sp-content {
    padding: calc(var(--header-height) + 4rem) clamp(2rem, 6.5vw, 5.5rem) 2.5rem;
  }

  .sp-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    width: 100%;
    gap: 4rem;
  }

  /* ========== LEFT COLUMN ========== */
  .sp-main {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 680px;
    position: relative;
  }

  /* Eyebrow */
  .sp-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    opacity: 0;
    animation: spFadeSlideRight 0.8s var(--ease-out-expo) 0.15s forwards;
  }

  .sp-eyebrow-line {
    width: 32px;
    height: 1px;
    background: linear-gradient(to right, var(--color-gold-dim), transparent);
    flex-shrink: 0;
  }

  .sp-status-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 8px var(--color-accent), 0 0 16px rgba(232,98,42,0.3);
    animation: spStatusPulse 2.2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes spStatusPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.7); }
  }

  .sp-eyebrow-text {
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-gold-text);
    white-space: nowrap;
  }

  @keyframes spFadeSlideRight {
    from { opacity: 0; transform: translateX(-16px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  /* Title */
  .sp-title {
    font-family: var(--font-body);
    font-size: clamp(2.6rem, 5vw, 5rem);
    font-weight: 300;
    line-height: 1.04;
    margin: 0;
    letter-spacing: -0.02em;
    white-space: nowrap;
    display: block;
    color: var(--color-text-primary);
    text-shadow:
      0 2px 24px rgba(0,0,0,0.55),
      0 4px 48px rgba(0,0,0,0.3),
      0 0 80px rgba(201,168,76,0.04);
  }

  .sp-char {
    display: inline-block;
    opacity: 0;
    transform: translateY(100%) rotateX(40deg);
    transform-origin: bottom center;
    animation: spCharRise 0.9s var(--ease-out-expo) forwards;
  }

  @keyframes spCharRise {
    from { opacity: 0; transform: translateY(100%) rotateX(40deg); }
    to   { opacity: 1; transform: translateY(0) rotateX(0deg); }
  }

  /* Divider with orb and glow */
  .sp-divider {
    display: block;
    position: relative;
    height: 1px;
    margin-top: 0.75rem;
    width: 0;
    animation: spDividerGrow 1.6s var(--ease-out-expo) 0.6s forwards;
  }

  .sp-divider-track {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, var(--color-gold-dim), rgba(232,98,42,0.35), transparent 80%);
    border-radius: 1px;
  }

  .sp-divider-orb {
    position: absolute;
    top: -2px;
    left: 0;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-gold-text);
    box-shadow: 0 0 10px var(--color-gold-dim), 0 0 20px rgba(232,98,42,0.15);
    animation: spOrbDrift 5s ease-in-out infinite;
  }

  .sp-divider-glow {
    position: absolute;
    top: -4px;
    left: 0;
    width: 60px;
    height: 10px;
    background: radial-gradient(ellipse, rgba(201,168,76,0.12), transparent 70%);
    filter: blur(6px);
    animation: spGlowDrift 5s ease-in-out infinite;
  }

  @keyframes spDividerGrow {
    to { width: 60%; }
  }

  @keyframes spOrbDrift {
    0% { left: 0; opacity: 0.5; }
    50% { opacity: 1; }
    100% { left: calc(100% - 5px); opacity: 0.5; }
  }

  @keyframes spGlowDrift {
    0%, 100% { transform: translateX(0); opacity: 0.3; }
    50% { transform: translateX(30px); opacity: 0.7; }
  }

  /* Description */
  .sp-desc {
    font-family: var(--font-display);
    font-size: clamp(0.9rem, 1.05vw, 1.05rem);
    line-height: 1.7;
    color: rgba(240, 237, 232, 0.5);
    max-width: 440px;
    margin: 0;
    opacity: 0;
    animation: spFadeUp 0.7s ease 0.55s forwards;
  }

  @keyframes spFadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* CTAs */
  .sp-ctas {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
    opacity: 0;
    animation: spFadeUp 0.7s ease 0.75s forwards;
  }

  .sp-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    white-space: nowrap;
    cursor: pointer;
    transition: all 0.45s var(--ease-out-expo);
  }

  .sp-cta-p {
    padding: 0.85rem 1.875rem;
    min-width: 170px;
    max-width: 240px;
    justify-content: center;
    background: var(--color-accent);
    color: #fff;
    border-radius: 100px;
    box-shadow:
      0 4px 18px rgba(232, 98, 42, 0.3),
      0 0 0 1px rgba(232, 98, 42, 0.12),
      inset 0 1px 0 rgba(255,255,255,0.12);
  }

  .sp-cta-gleam {
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 38%, rgba(255,255,255,0.14) 50%, transparent 62%);
    transform: translateX(-100%);
  }

  .sp-cta-p:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
    box-shadow:
      0 10px 32px rgba(232, 98, 42, 0.5),
      0 0 0 1px rgba(232, 98, 42, 0.25),
      inset 0 1px 0 rgba(255,255,255,0.18);
  }

  .sp-cta-p:hover .sp-cta-gleam {
    animation: spGleamSweep 0.9s ease forwards;
  }

  @keyframes spGleamSweep {
    to { transform: translateX(100%); }
  }

  .sp-cta-p .sp-cta-arrow {
    transition: transform 0.35s var(--ease-out-expo);
  }

  .sp-cta-p:hover .sp-cta-arrow {
    transform: translateX(3px);
  }

  .sp-cta-s {
    padding: 0.85rem 0.25rem;
    min-width: 140px;
    justify-content: center;
    color: rgba(255, 255, 255, 0.5);
    background: none;
    border: none;
  }

  .sp-cta-s::after {
    content: '';
    position: absolute;
    bottom: 0.5rem;
    left: 0.25rem;
    right: 0.25rem;
    height: 1px;
    background: linear-gradient(90deg, var(--color-gold-dim), transparent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s var(--ease-out-expo);
  }

  .sp-cta-s:hover {
    color: rgba(255, 255, 255, 0.9);
  }

  .sp-cta-s:hover::after {
    transform: scaleX(1);
  }

  /* ========== RIGHT: PREMIUM METADATA PANEL ========== */
  .sp-meta {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
    min-width: 300px;
    max-width: 340px;
    flex-shrink: 0;
    opacity: 0;
    animation: spFadeUp 0.8s ease 0.4s forwards;
    margin-bottom: 0.25rem;
    perspective: 1000px;
  }

  /* Ambient glow behind card */
  .sp-meta-ambient {
    position: absolute;
    inset: -12px;
    border-radius: 28px;
    background: radial-gradient(ellipse at 50% 50%, rgba(232,98,42,0.08) 0%, rgba(201,168,76,0.04) 40%, transparent 70%);
    pointer-events: none;
    z-index: -1;
    animation: spAmbientBreathe 4s ease-in-out infinite;
  }

  @keyframes spAmbientBreathe {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.03); }
  }

  /* Card with animated border */
  .sp-meta-card {
    position: relative;
    border-radius: 24px;
    padding: 2px;
    overflow: hidden;
    background: linear-gradient(160deg, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0.02) 100%);
    transition: transform 0.6s var(--ease-out-expo);
    transform: perspective(1000px) rotateY(-2deg) rotateX(1deg);
  }

  .sp-meta-card:hover {
    transform: perspective(1000px) rotateY(0deg) rotateX(0deg) translateY(-4px);
  }

  /* Rotating gradient border */
  .sp-meta-border {
    position: absolute;
    inset: 0;
    border-radius: 24px;
    padding: 1.5px;
    background: conic-gradient(from 0deg, transparent 0%, rgba(201,168,76,0.4) 15%, rgba(232,98,42,0.3) 30%, transparent 45%, transparent 55%, rgba(232,98,42,0.3) 70%, rgba(201,168,76,0.4) 85%, transparent 100%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    animation: spBorderSpin 8s linear infinite;
    pointer-events: none;
    z-index: 1;
  }

  @keyframes spBorderSpin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* Inner content */
  .sp-meta-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    background: linear-gradient(165deg, rgba(17,17,17,0.85) 0%, rgba(8,8,8,0.92) 100%);
    border-radius: 22px;
    padding: 1rem 1.25rem;
    backdrop-filter: blur(32px) saturate(180%);
    -webkit-backdrop-filter: blur(32px) saturate(180%);
    overflow: hidden;
    z-index: 2;
  }

  /* Top accent bar */
  .sp-meta-topbar {
    position: absolute;
    top: 0;
    left: 2rem;
    right: 2rem;
    height: 2px;
    overflow: hidden;
  }

  .sp-meta-topbar-glow {
    display: block;
    width: 40%;
    height: 100%;
    margin: 0 auto;
    background: linear-gradient(90deg, transparent, var(--color-gold-dim), rgba(232,98,42,0.4), var(--color-gold-dim), transparent);
    animation: spTopbarShift 4s ease-in-out infinite;
  }

  @keyframes spTopbarShift {
    0%, 100% { transform: translateX(-120%); opacity: 0; }
    30% { opacity: 1; }
    70% { opacity: 1; }
    100% { transform: translateX(220%); opacity: 0; }
  }

  /* Panel Header */
  .sp-meta-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.625rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .sp-meta-header-left {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .sp-meta-header-pip {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 10px var(--color-accent), 0 0 20px rgba(232,98,42,0.25);
    animation: spStatusPulse 2.2s ease-in-out infinite;
  }

  .sp-meta-header-text {
    font-family: var(--font-display);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
  }

  .sp-meta-header-count {
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: rgba(201, 168, 76, 0.35);
    font-variant-numeric: tabular-nums;
  }

  /* Panel Body */
  .sp-meta-body {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .sp-meta-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.5rem;
    position: relative;
    opacity: 0;
    animation: spPanelItem 0.7s var(--ease-out-expo) var(--delay) forwards;
    transition: all 0.5s var(--ease-out-expo);
    overflow: hidden;
  }

  .sp-meta-row:not(:last-child) {
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  @keyframes spPanelItem {
    from { opacity: 0; transform: translateX(20px) scale(0.98); }
    to   { opacity: 1; transform: translateX(0) scale(1); }
  }

  .sp-meta-row:hover {
    background: linear-gradient(90deg, rgba(255,255,255,0.02) 0%, rgba(255,255,255,0.05) 50%, rgba(255,255,255,0.02) 100%);
    border-radius: 12px;
    margin: 0 -0.5rem;
    padding-left: 1rem;
    padding-right: 1rem;
  }

  .sp-meta-row:hover .sp-meta-row-accent {
    transform: scaleY(1);
    opacity: 1;
  }

  .sp-meta-row:hover .sp-meta-bg-idx {
    opacity: 0.08;
    transform: translateY(-50%) scale(1.1);
  }

  .sp-meta-row:hover .sp-meta-ring-svg circle {
    stroke: rgba(201,168,76,0.35);
  }

  /* Background index number */
  .sp-meta-bg-idx {
    position: absolute;
    top: 50%;
    right: 0.25rem;
    transform: translateY(-50%);
    font-family: var(--font-body);
    font-size: 2.2rem;
    font-weight: 300;
    color: var(--color-gold-text);
    opacity: 0.03;
    line-height: 1;
    pointer-events: none;
    transition: all 0.5s var(--ease-out-expo);
    letter-spacing: -0.04em;
  }

  /* Icon ring */
  .sp-meta-ring {
    position: relative;
    width: 38px;
    height: 38px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sp-meta-ring-inner {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 8px;
    background: linear-gradient(135deg, rgba(201,168,76,0.1) 0%, rgba(232,98,42,0.05) 100%);
    border: 1px solid rgba(201, 168, 76, 0.15);
    color: var(--color-gold-text);
    transition: all 0.4s var(--ease-out-expo);
  }

  .sp-meta-row:hover .sp-meta-ring-inner {
    background: linear-gradient(135deg, rgba(201,168,76,0.18) 0%, rgba(232,98,42,0.1) 100%);
    border-color: rgba(201, 168, 76, 0.28);
    transform: scale(1.08);
    box-shadow: 0 0 16px rgba(201,168,76,0.1);
  }

  .sp-meta-ring-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    animation: spRingDash 12s linear infinite;
  }

  .sp-meta-ring-svg circle {
    transition: stroke 0.4s ease;
  }

  @keyframes spRingDash {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* Content */
  .sp-meta-content {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
    position: relative;
    z-index: 2;
  }

  .sp-meta-val {
    font-family: var(--font-body);
    font-size: clamp(1.1rem, 1.5vw, 1.35rem);
    font-weight: 300;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1.15;
    text-shadow: 0 2px 12px rgba(0,0,0,0.3);
    position: relative;
    overflow: hidden;
  }

  .sp-meta-row .sp-meta-val::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent);
    animation: spValShine 2s ease-in-out var(--delay) forwards;
  }

  @keyframes spValShine {
    0% { left: -100%; }
    40% { left: 120%; }
    100% { left: 120%; }
  }

  .sp-meta-lbl {
    font-family: var(--font-display);
    font-size: 0.52rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
  }

  /* Mini divider per row */
  .sp-meta-mini-divider {
    position: relative;
    height: 1px;
    margin-top: 0.25rem;
    width: 40%;
    opacity: 0;
    transition: opacity 0.5s ease 0.1s;
  }

  .sp-meta-row:hover .sp-meta-mini-divider {
    opacity: 1;
  }

  .sp-meta-mini-track {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, var(--color-gold-dim), transparent);
    border-radius: 1px;
  }

  .sp-meta-mini-orb {
    position: absolute;
    top: -1.5px;
    left: 0;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-gold-text);
    box-shadow: 0 0 6px var(--color-gold-dim);
    animation: spMiniOrbDrift 3s ease-in-out infinite;
  }

  @keyframes spMiniOrbDrift {
    0% { left: 0; opacity: 0.6; }
    50% { opacity: 1; }
    100% { left: calc(100% - 4px); opacity: 0.6; }
  }

  /* Row accent bar */
  .sp-meta-row-accent {
    position: absolute;
    left: 0;
    top: 0.4rem;
    bottom: 0.4rem;
    width: 2px;
    background: linear-gradient(to bottom, var(--color-accent), rgba(232,98,42,0.2));
    border-radius: 2px;
    transform: scaleY(0);
    opacity: 0;
    transition: all 0.4s var(--ease-out-expo);
  }

  /* Footer dots */
  .sp-meta-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    margin-top: 0.625rem;
    padding-top: 0.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }

  .sp-meta-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    transition: all 0.4s var(--ease-out-expo);
    animation: spDotPulse 3s ease-in-out var(--dot-delay) infinite;
  }

  .sp-meta-dot.is-active {
    background: var(--color-accent);
    box-shadow: 0 0 6px rgba(232,98,42,0.4);
    animation: spDotActivePulse 2s ease-in-out infinite;
  }

  @keyframes spDotPulse {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.2); opacity: 0.8; }
  }

  @keyframes spDotActivePulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.3); opacity: 0.7; }
  }

  /* Corner Brackets */
  .sp-meta-corner {
    position: absolute;
    width: 14px;
    height: 14px;
    border-color: rgba(201, 168, 76, 0.2);
    border-style: solid;
    border-width: 0;
    opacity: 1;
    transition: all 0.5s var(--ease-out-expo);
    z-index: 3;
  }

  .sp-meta-card:hover .sp-meta-corner {
    border-color: rgba(201, 168, 76, 0.4);
    width: 18px;
    height: 18px;
  }

  .sp-meta-corner-tl {
    top: 10px;
    left: 10px;
    border-top-width: 1.5px;
    border-left-width: 1.5px;
  }

  .sp-meta-corner-tr {
    top: 10px;
    right: 10px;
    border-top-width: 1.5px;
    border-right-width: 1.5px;
  }

  .sp-meta-corner-bl {
    bottom: 10px;
    left: 10px;
    border-bottom-width: 1.5px;
    border-left-width: 1.5px;
  }

  .sp-meta-corner-br {
    bottom: 10px;
    right: 10px;
    border-bottom-width: 1.5px;
    border-right-width: 1.5px;
  }

  /* ========== BOTTOM STRIP ========== */
  .sp-strip {
    position: relative;
    z-index: 6;
    padding: 0 clamp(2rem, 6.5vw, 5.5rem) 2.5rem;
  }

  [data-hero-variant="compact"] .sp-strip {
    padding-bottom: 1.75rem;
  }

  .sp-strip-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0.7rem 1.75rem;
    background: linear-gradient(135deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.01) 100%);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 100px;
    backdrop-filter: blur(24px) saturate(150%);
    -webkit-backdrop-filter: blur(24px) saturate(150%);
    box-shadow:
      0 4px 20px rgba(0,0,0,0.15),
      inset 0 1px 0 rgba(255,255,255,0.04);
    opacity: 0;
    animation: spFadeUp 0.8s ease 1.1s forwards;
    transition: border-color 0.4s ease;
  }

  .sp-hero:hover .sp-strip-inner {
    border-color: rgba(255, 255, 255, 0.11);
  }

  .sp-strip-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .sp-live-dot {
    width: 5px;

---
/**
 * DetailContent — shared cream editorial CSS for event and route detail pages.
 * Defines all .det-* shared classes via is:global. Wraps slot content.
 * Specific component CSS (evt-*, rut-*) lives in the respective slug pages.
 */
---
<slot />

<style is:global>
  /* ============================================
     DETAIL — SHARED CREAM EDITORIAL STYLES
     Used by both event and route detail pages
     ============================================ */
  .det-page {
    --s-bg:       #f5f0ea;
    --s-bg-hi:    #faf8f5;
    --s-ink:      #1a1619;
    --s-ink-2:    #5a4f47;
    --s-ink-3:    #8a7f77;
    --s-orange:   #e8622a;
    --s-gold:     #c9a84c;
    --s-gold-dim: rgba(201,168,76,0.35);
    --s-border:   rgba(26,22,25,0.10);
    --s-border-s: rgba(26,22,25,0.06);
    --ease-expo:  cubic-bezier(0.16, 1, 0.3, 1);

    background: var(--s-bg);
    position: relative;
    overflow: hidden;
  }

  .det-page::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    mix-blend-mode: multiply;
    opacity: 0.025;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  .det-content-wrap {
    max-width: 1440px;
    margin: 0 auto;
    padding: 4rem clamp(1.5rem, 5vw, 4rem) 2rem;
    position: relative;
    z-index: 2;
  }

  .det-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 4rem;
    align-items: start;
  }

  .det-main {
    display: flex;
    flex-direction: column;
    gap: 2px;
    background: var(--s-border);
  }

  /* Editorial blocks */
  .det-block {
    position: relative;
    padding: 2.5rem;
    background: var(--s-bg);
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.9s var(--ease-expo), transform 0.9s var(--ease-expo);
  }

  .det-block.is-visible { opacity: 1; transform: translateY(0); }

  .det-block-head {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .det-block-num {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 300;
    color: var(--s-gold);
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .det-block-divider {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--s-border), transparent);
    max-width: 60px;
  }

  .det-block-eyebrow {
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--s-ink-3);
  }

  .det-block-title {
    font-family: var(--font-body);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--s-ink);
    margin-bottom: 1.25rem;
  }

  .det-lead {
    font-family: var(--font-display);
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--s-ink-2);
    max-width: 65ch;
  }

  /* Hover corner brackets */
  .det-hover-corners { position: absolute; inset: 0; pointer-events: none; }

  .hc {
    position: absolute;
    width: 14px;
    height: 14px;
    border-color: var(--s-orange);
    border-style: solid;
    border-width: 0;
    opacity: 0;
    transition: opacity 0.35s ease, width 0.35s ease, height 0.35s ease;
  }

  .det-block:hover .hc { opacity: 0.5; width: 18px; height: 18px; }
  .hc.tl { top: 1rem; left: 1rem; border-top-width: 1px; border-left-width: 1px; }
  .hc.tr { top: 1rem; right: 1rem; border-top-width: 1px; border-right-width: 1px; }
  .hc.bl { bottom: 1rem; left: 1rem; border-bottom-width: 1px; border-left-width: 1px; }
  .hc.br { bottom: 1rem; right: 1rem; border-bottom-width: 1px; border-right-width: 1px; }

  /* Tags section */
  .det-tags {
    padding: 2.5rem;
    background: var(--s-bg);
    opacity: 0;
    transform: translateY(24px);
    transition: all 0.7s var(--ease-expo);
  }

  .det-tags.is-visible { opacity: 1; transform: translateY(0); }

  .det-tags-eyebrow {
    display: block;
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--s-ink-3);
    margin-bottom: 1rem;
  }

  .det-tags-flow { display: flex; flex-wrap: wrap; gap: 0.5rem; }

  .det-tag-pill {
    display: inline-flex;
    padding: 0.4rem 1rem;
    font-family: var(--font-display);
    font-size: 0.75rem;
    color: var(--s-ink-2);
    background: var(--s-bg-hi);
    border: 1px solid var(--s-border);
    border-radius: 100px;
    opacity: 0;
    transform: scale(0.9);
    transition: all 0.4s ease calc(var(--ti, 0) * 0.05s);
  }

  .det-tags.is-visible .det-tag-pill { opacity: 1; transform: scale(1); }

  /* Sidebar */
  .det-sidebar-sticky {
    position: sticky;
    top: calc(var(--header-height, 64px) + 2rem);
    display: flex;
    flex-direction: column;
    gap: 2px;
    background: var(--s-border);
  }

  .det-sidebar-card {
    background: var(--s-bg);
    padding: 2rem;
    opacity: 0;
    transform: translateX(30px);
    transition: all 0.8s var(--ease-expo);
  }

  .det-sidebar-card.is-visible { opacity: 1; transform: translateX(0); }

  .det-sc-head {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .det-sc-eyebrow {
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--s-ink-3);
    flex-shrink: 0;
  }

  .det-sc-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--s-border), transparent);
  }

  .det-info-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    padding: 0.75rem 0;
  }

  .det-info-label {
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--s-ink-3);
    flex-shrink: 0;
  }

  .det-info-val {
    font-family: var(--font-display);
    font-size: 0.88rem;
    color: var(--s-ink);
    text-align: right;
  }

  .det-info-sep { height: 1px; background: var(--s-border-s); }

  /* Related items */
  .det-related-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    background: var(--s-border-s);
    margin-bottom: 1rem;
  }

  .det-related-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.875rem;
    background: var(--s-bg);
    text-decoration: none;
    position: relative;
    opacity: 0;
    transform: translateX(16px);
    transition: opacity 0.5s var(--ease-expo) calc(var(--ri, 0) * 0.1s),
                transform 0.5s var(--ease-expo) calc(var(--ri, 0) * 0.1s),
                background 0.2s ease;
  }

  .det-sidebar-card.is-visible .det-related-item { opacity: 1; transform: translateX(0); }
  .det-related-item:hover { background: var(--s-bg-hi); }

  .det-rel-thumb {
    width: 56px;
    height: 56px;
    flex-shrink: 0;
    overflow: hidden;
    position: relative;
    background: rgba(26,22,25,0.06);
  }

  .det-rel-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(30%);
    transition: filter 0.4s ease;
  }

  .det-related-item:hover .det-rel-thumb img { filter: grayscale(0%); }

  .det-rel-thumb-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    color: var(--s-ink-3);
  }

  .det-rel-thumb-fallback svg { width: 20px; height: 20px; }

  .det-rel-thumb-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 60%, rgba(232,98,42,0.12) 100%);
  }

  .det-rel-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 0.25rem; }

  .det-rel-title {
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--s-ink);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.4;
  }

  .det-rel-meta { font-family: var(--font-display); font-size: 0.68rem; color: var(--s-ink-3); }

  .det-rel-arrow {
    width: 14px;
    height: 14px;
    color: var(--s-ink-3);
    flex-shrink: 0;
    transition: transform 0.25s ease, color 0.25s ease;
  }

  .det-related-item:hover .det-rel-arrow { transform: translateX(3px); color: var(--s-orange); }

  .det-all-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem;
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--s-ink-3);
    text-decoration: none;
    transition: color 0.25s ease;
  }

  .det-all-link:hover { color: var(--s-orange); }
  .det-all-link svg { width: 14px; height: 14px; }

  /* Footer ornament */
  .det-footer-orn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 3rem clamp(1.5rem, 5vw, 4rem) 4rem;
    opacity: 0.3;
  }

  .det-orn-line    { flex: 1; max-width: 120px; height: 1px; background: var(--s-border); }
  .det-orn-diamond { width: 8px; height: 8px; background: var(--s-gold); transform: rotate(45deg); }
  .det-orn-star    { color: var(--s-gold); }
  .det-orn-star svg { width: 16px; height: 16px; }

  /* Responsive */
  @media (max-width: 1024px) {
    .det-layout { grid-template-columns: 1fr; }
    .det-sidebar-sticky { position: static; }
    .det-sidebar-card { transform: translateY(20px); }
    .det-sidebar-card.is-visible { transform: translateY(0); }
    .det-related-item { opacity: 1; transform: none; }
  }

  @media (max-width: 640px) {
    .det-block { padding: 1.75rem 1.25rem; }
    .det-sidebar-card { padding: 1.5rem 1.25rem; }
    .det-content-wrap { padding: 2rem 1rem 1rem; }
  }
</style>

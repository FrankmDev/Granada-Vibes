---
/**
 * PlanHero — Time-based mixed route hero
 *
 * Editorial magazine-cover spread for time-based mixed route pages
 * (rutas por tiempo). Mirrors the v14 ALHAMBRA SPREAD architecture
 * used by BlogDetailHero and RouteDetailHero:
 *  - Cover image on the LEFT with cinematic treatment
 *    (corner brackets, vignette, glare, stamp, glow, shadow)
 *  - Editorial lockup on the RIGHT
 *    (eyebrow + meta pills + title + lead)
 *  - Compact bottom bar (category · coords)
 *
 * If `image` is undefined, falls back to a nazarí SVG placeholder.
 *
 * Geometry: hero is exactly 100svh - 72px (NavBar). Content must fit.
 * Aligned with GRN URBAN "Alhambra Noir" — global tokens only.
 * Title uses Fraunces Thin (100) for editorial drama.
 * `text-wrap: pretty` prevents mid-word breaks.
 * Reduced-motion safe.
 */
import type { Locale } from '@types';
import { useTranslations } from '@i18n/utils';
import ScreenFrame from '@components/ui/ScreenFrame.astro';
import OptimizedImage from '@components/ui/OptimizedImage.astro';

interface Props {
  locale: Locale;
  backHref: string;
  backLabel: string;
  refCode: string;
  title: string;
  eyebrowText: string;
  description?: string;
  duration: string;
  totalStops: number;
  neighborhoods: string[];
  bestFor?: string;
  image?: string;
}

const {
  locale,
  backHref,
  backLabel,
  refCode,
  title,
  eyebrowText,
  description,
  duration,
  totalStops,
  neighborhoods,
  bestFor,
  image,
} = Astro.props;
const t = useTranslations(locale);

const refNum = refCode.split(' / ').pop()?.split(' · ')[0] ?? refCode;

const hasImage = !!image;
const imageAlt = `${title} — ${eyebrowText}`;

// Scroll hint translation
const scrollLabel = locale === 'en' ? 'Scroll to explore' : 'Desplázate para explorar';
---

<section class="ph" aria-label={title} data-ph>
  <!-- ScreenFrame -->
  <ScreenFrame
    tagTopLeft={`${t('detail.archiveTag')} · ${refNum}`}
    tagTopRight={eyebrowText}
    tagBottomLeft="GRN URBAN"
    tagBottomRight={t('detail.coordinates')}
  />

  <!-- Ambient canvas -->
  <div class="ph-canvas" aria-hidden="true">
    <div class="ph-bg"></div>
    <div class="ph-radial"></div>
    <div class="ph-shaft"></div>
    <div class="ph-grid"></div>
    <div class="ph-vignette"></div>
    <div class="ph-grain"></div>
  </div>

  <!-- Decorative layer (subtle rings + dot) -->
  <div class="ph-deco" aria-hidden="true">
    <span class="deco-ring r1"></span>
    <span class="deco-dot d1"></span>
  </div>

  <!-- Nav scrim -->
  <div class="ph-nav-scrim" aria-hidden="true"></div>

  <!-- Back link -->
  <a href={backHref} class="ph-back">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    <span>{backLabel}</span>
  </a>

  <!-- Archive ref -->
  <div class="ph-ref" aria-hidden="true">
    <span class="ph-ref-label">REF.</span>
    <span class="ph-ref-num">{refNum}</span>
  </div>

  <!-- Main spread: image left, editorial lockup right -->
  <div class="ph-stage">
    <div class="ph-spread">

      <!-- LEFT: Cover image -->
      <figure class="ph-figure">
        <div class="ph-figure-wrap">
          {hasImage && (
            <OptimizedImage
              src={image as string}
              alt={imageAlt}
              class="ph-img"
              loading="eager"
              decoding="async"
              fetchpriority="high"
              sizes="(max-width: 768px) 100vw, 38vw"
              width={900}
              height={1200}
            />
          )}
          {!hasImage && (
            <div class="ph-img-fallback" aria-hidden="true">
              <svg viewBox="0 0 60 60" fill="none">
                <path d="M30 4 L34.5 22.5 L52 15 L39 28.5 L56 30 L39 31.5 L52 45 L34.5 37.5 L30 56 L25.5 37.5 L8 45 L21 31.5 L4 30 L21 28.5 L8 15 L25.5 22.5 Z"
                  stroke="var(--h-gold)" stroke-width="0.6" stroke-opacity="0.45" fill="none"/>
                <path d="M30 12 L32.5 24.5 L42 20 L36 28.5 L46 30 L36 31.5 L42 40 L32.5 35.5 L30 48 L27.5 35.5 L18 40 L24 31.5 L14 30 L24 28.5 L18 20 L27.5 24.5 Z"
                  fill="var(--h-gold)" fill-opacity="0.10" stroke="none"/>
              </svg>
            </div>
          )}
          <div class="ph-figure-vignette" aria-hidden="true"></div>
          <div class="ph-figure-glare" aria-hidden="true"></div>

          <!-- Corner brackets -->
          <span class="bracket tl" aria-hidden="true"></span>
          <span class="bracket tr" aria-hidden="true"></span>
          <span class="bracket bl" aria-hidden="true"></span>
          <span class="bracket br" aria-hidden="true"></span>

          <!-- Expedition stamp -->
          <div class="ph-stamp" aria-hidden="true">
            <span class="stamp-prefix">{eyebrowText}</span>
            <span class="stamp-num">Nº {refNum}</span>
          </div>
        </div>

        <!-- Glow + shadow behind the figure -->
        <div class="ph-figure-glow" aria-hidden="true"></div>
        <div class="ph-figure-shadow" aria-hidden="true"></div>

        <figcaption class="ph-caption">
          <span class="caption-line"></span>
          <span class="caption-text">{t('detail.archiveTag')} · {refNum} · {refCode}</span>
        </figcaption>
      </figure>

      <!-- RIGHT: Editorial lockup -->
      <div class="ph-text">
        <div class="lockup-rule" aria-hidden="true"></div>

        <div class="ph-eyebrow">
          <span class="eyebrow-line"></span>
          <span class="eyebrow-text">
            GRANADA
            <span class="eyebrow-slash">/</span>
            {eyebrowText}
          </span>
          <span class="eyebrow-line"></span>
        </div>

        <h1 class="ph-title" style="text-wrap: pretty; word-break: normal; overflow-wrap: normal; hyphens: none;">
          {
            (() => {
              let delayIndex = 0;
              return title
                .split(' ')
                .map((word) => (
                  <span class="ph-word">
                    {word.split('').map((char) => {
                      const d = 0.3 + delayIndex * 0.045;
                      delayIndex++;
                      return (
                        <span class="ph-char" style={`--delay: ${d}s`}>
                          {char}
                        </span>
                      );
                    })}
                  </span>
                ))
                .reduce(
                  (prev, curr, i) =>
                    i === 0 ? [curr] : [...prev, ' ', curr],
                  [] as unknown[]
                );
            })()
          }
        </h1>

        {description && (
          <p class="ph-lead">
            <span class="lead-quote">“</span>
            {description}
            <span class="lead-quote">”</span>
          </p>
        )}

        <!-- Metadata pills bar -->
        <div class="ph-meta-bar">
          <div class="ph-meta-pill">
            <span class="ph-meta-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <span class="ph-meta-label">{t('mixedRoutes.dockDuration')}</span>
            <span class="ph-meta-value">{eyebrowText}</span>
          </div>
          <div class="ph-meta-divider" aria-hidden="true"></div>
          <div class="ph-meta-pill">
            <span class="ph-meta-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="10" r="3"/></svg>
            </span>
            <span class="ph-meta-label">{t('mixedRoutes.dockStops')}</span>
            <span class="ph-meta-value">{totalStops}</span>
          </div>
          <div class="ph-meta-divider" aria-hidden="true"></div>
          <div class="ph-meta-pill">
            <span class="ph-meta-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" stroke-linecap="round" stroke-linejoin="round"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <span class="ph-meta-label">{t('mixedRoutes.dockZones')}</span>
            <span class="ph-meta-value">{neighborhoods.length}</span>
          </div>
          {bestFor && (
            <>
              <div class="ph-meta-divider" aria-hidden="true"></div>
              <div class="ph-meta-pill">
                <span class="ph-meta-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                <span class="ph-meta-label">{t('mixedRoutes.idealFor')}</span>
                <span class="ph-meta-value">{bestFor}</span>
              </div>
            </>
          )}
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="ph-bottom-bar">
    <div class="bar-content">
      <span class="bar-item">{eyebrowText}</span>
      <span class="bar-dot" aria-hidden="true"></span>
      <span class="bar-item">{t('detail.coordinates')}</span>
    </div>
  </div>

  <!-- Scroll hint (mobile only) -->
  <div class="scroll-hint" aria-hidden="true">
    <div class="scroll-line"></div>
    <span class="scroll-text">{scrollLabel}</span>
  </div>
</section>

<style>
  .ph {
    --h-gold:     #c9a84c;
    --h-gold-dim: rgba(201, 162, 39, 0.45);
    --h-orange:   #e8622a;
    --h-cream:    #f0ede8;
    --h-muted:    rgba(240, 237, 232, 0.45);
    --ease-expo:  cubic-bezier(0.16, 1, 0.3, 1);

    position: relative;
    width: 100%;
    height: calc(100svh - 72px);
    min-height: 560px;
    margin-top: 72px;
    background: #050505;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    contain: layout;
  }

  /* ---- ScreenFrame overrides ---- */
  .ph :global(.cin-screen-frame) {
    top: 1.5rem; left: 1.5rem; right: 1.5rem; bottom: 1.5rem;
    border-color: rgba(255, 255, 255, 0.07);
  }
  .ph :global(.cin-corner::before),
  .ph :global(.cin-corner::after) { background: var(--h-gold); opacity: 0.3; }
  .ph :global(.cin-frame-tag) {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.55rem;
    letter-spacing: 0.2em;
  }

  /* ---- CANVAS ---- */
  .ph-canvas { position: absolute; inset: 0; z-index: 1; pointer-events: none; overflow: hidden; }
  .ph-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse at 20% 0%, rgba(201,168,76,0.04) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 60%, rgba(232,98,42,0.025) 0%, transparent 45%),
      radial-gradient(ellipse at 50% 100%, rgba(201,168,76,0.02) 0%, transparent 40%),
      #050505;
  }
  .ph-radial {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 35% 30% at 22% 45%, rgba(201, 168, 76, 0.10) 0%, transparent 60%),
      radial-gradient(ellipse 26% 22% at 80% 60%, rgba(232, 98, 42, 0.05) 0%, transparent 55%);
  }
  .ph-shaft {
    position: absolute; inset: 0;
    background:
      linear-gradient(118deg, transparent 32%, rgba(201, 168, 76, 0.05) 42%, rgba(232, 98, 42, 0.025) 50%, transparent 62%),
      linear-gradient(118deg, transparent 60%, rgba(255, 255, 255, 0.018) 75%, transparent 92%);
    mix-blend-mode: screen;
    opacity: 0.85;
  }
  .ph-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.022) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.022) 1px, transparent 1px);
    background-size: 80px 80px;
    background-position: center;
    -webkit-mask-image: radial-gradient(ellipse 80% 75% at center, black 25%, transparent 85%);
    mask-image: radial-gradient(ellipse 80% 75% at center, black 25%, transparent 85%);
    opacity: 0.9;
  }
  .ph-vignette { position: absolute; inset: 0; background: radial-gradient(ellipse 110% 90% at center, transparent 55%, rgba(0,0,0,0.55) 100%); }
  .ph-grain {
    position: absolute; inset: 0; pointer-events: none;
    mix-blend-mode: soft-light; opacity: 0.06;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  /* ---- DECORATIVE LAYER ---- */
  .ph-deco { position: absolute; inset: 0; z-index: 2; pointer-events: none; overflow: hidden; }
  .deco-ring { position: absolute; border-radius: 50%; border: 1px solid var(--h-gold); opacity: 0; animation: deco-ring-in 2s var(--ease-expo) forwards; }
  .deco-ring.r1 { width: 280px; height: 280px; top: 18%; left: 5%; animation-delay: 0.4s; --target-opacity: 0.07; }
  @keyframes deco-ring-in { from { opacity: 0; transform: scale(0.8); } to { opacity: var(--target-opacity, 0.07); transform: scale(1); } }
  .deco-dot { position: absolute; border-radius: 50%; animation: ev-float 7s ease-in-out infinite; }
  .deco-dot.d1 { width: 110px; height: 110px; top: 68%; right: 5%; background: radial-gradient(circle, rgba(201, 168, 76, 0.15), transparent 70%); animation-duration: 9s; }
  @keyframes ev-float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }

  /* ---- NAV SCRIM ---- */
  .ph-nav-scrim { position: absolute; top: 0; left: 0; right: 0; height: 160px; background: linear-gradient(180deg, rgba(0, 0, 0, 0.70) 0%, rgba(0, 0, 0, 0.20) 60%, transparent 100%); pointer-events: none; z-index: 5; }

  /* ---- BACK LINK ---- */
  .ph-back {
    position: absolute; top: 2.25rem; left: 2.25rem; z-index: 30;
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-family: var(--font-display); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(240, 237, 232, 0.85); text-decoration: none;
    padding: 0.55rem 1rem; border-radius: 100px;
    background: rgba(0, 0, 0, 0.45); backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.14);
    transition: all 0.3s ease;
    opacity: 0; animation: fadeInUp 0.8s ease 0.2s both;
  }
  .ph-back svg { transition: transform 0.25s ease; }
  .ph-back:hover { background: rgba(201, 168, 76, 0.15); border-color: rgba(201, 168, 76, 0.3); transform: translateY(-1px); }
  .ph-back:hover svg { transform: translateX(-3px); }

  /* ---- ARCHIVE REF ---- */
  .ph-ref {
    position: absolute; top: 2.25rem; right: 2.25rem; z-index: 30;
    display: flex; align-items: center; gap: 0.35rem;
    font-family: var(--font-display); font-size: 0.6rem; font-weight: 700; letter-spacing: 0.15em;
    color: rgba(240, 237, 232, 0.5);
    opacity: 0; animation: fadeInUp 0.8s ease 0.3s both;
  }
  .ph-ref-label { text-transform: uppercase; }
  .ph-ref-num { color: var(--h-gold); font-weight: 800; }

  /* ---- STAGE ---- */
  .ph-stage {
    position: relative; z-index: 10;
    flex: 1 1 auto;
    min-height: 0;
    display: flex; align-items: center;
    max-width: 1480px; margin: 0 auto; width: 100%;
    padding: 4.5rem clamp(2.25rem, 5vw, 3.5rem) 1.5rem;
  }

  /* ---- SPREAD 38/62 ---- */
  .ph-spread {
    display: grid;
    grid-template-columns: 38fr 62fr;
    gap: clamp(2rem, 4.5vw, 4rem);
    align-items: center;
    width: 100%;
    height: 100%;
    min-height: 0;
  }

  /* ============================
     LEFT — COVER IMAGE
     ============================ */
  .ph-figure {
    position: relative;
    margin: 0;
    display: flex; flex-direction: column; align-items: stretch; gap: 0.85rem;
    min-height: 0;
    opacity: 0; transform: translateX(-30px) rotate(-1deg);
    animation: figure-enter 1.4s var(--ease-expo) 0.4s forwards;
  }
  @keyframes figure-enter {
    to { opacity: 1; transform: translateX(0) rotate(0deg); }
  }

  .ph-figure-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    max-height: calc(100svh - 220px);
    align-self: center;
    overflow: hidden;
    border-radius: 14px;
    background: #14110d;
    box-shadow:
      0 40px 80px rgba(0, 0, 0, 0.55),
      0 16px 32px rgba(0, 0, 0, 0.35),
      0 0 0 1px rgba(255, 255, 255, 0.05);
    transition: transform 0.5s var(--ease-expo);
  }

  :global(.ph-img) { display: block; width: 100%; height: 100%; object-fit: cover; object-position: center; filter: saturate(1.05) contrast(1.08) brightness(0.92); }
  .ph-img-fallback {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, #1a1410 0%, #2a1f15 100%);
  }
  .ph-img-fallback svg { width: 38%; height: 38%; }

  .ph-figure-vignette {
    position: absolute; inset: 0; z-index: 2; pointer-events: none;
    background: radial-gradient(ellipse at center, transparent 50%, rgba(0, 0, 0, 0.35) 100%);
    mix-blend-mode: multiply;
  }
  .ph-figure-glare {
    position: absolute; inset: 0; z-index: 3; pointer-events: none;
    background: linear-gradient(105deg, transparent 40%, rgba(255, 255, 255, 0.10) 48%, rgba(255, 255, 255, 0.20) 50%, rgba(255, 255, 255, 0.10) 52%, transparent 60%);
    opacity: 0; transition: opacity 0.6s ease;
  }
  .ph-figure-wrap:hover .ph-figure-glare { opacity: 1; animation: glare-sweep 1.2s ease forwards; }
  @keyframes glare-sweep { 0% { transform: translateX(-100%); opacity: 0; } 30% { opacity: 1; } 100% { transform: translateX(100%); opacity: 0; } }

  /* Corner brackets */
  .bracket {
    position: absolute; width: 22px; height: 22px; z-index: 4;
    border-color: rgba(255, 255, 255, 0.6); border-style: solid; border-width: 0;
    opacity: 0.75; pointer-events: none;
    transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
  }
  .ph-figure-wrap:hover .bracket { width: 36px; height: 36px; border-color: var(--h-gold); opacity: 1; }
  .bracket.tl { top: 1rem; left: 1rem; border-top-width: 2px; border-left-width: 2px; }
  .bracket.tr { top: 1rem; right: 1rem; border-top-width: 2px; border-right-width: 2px; }
  .bracket.bl { bottom: 1rem; left: 1rem; border-bottom-width: 2px; border-left-width: 2px; }
  .bracket.br { bottom: 1rem; right: 1rem; border-bottom-width: 2px; border-right-width: 2px; }

  /* Stamp */
  .ph-stamp {
    position: absolute; top: 1.1rem; right: 1.1rem; z-index: 5;
    display: flex; flex-direction: column; align-items: flex-end;
    padding: 0.5rem 0.875rem;
    background: rgba(8, 8, 8, 0.82);
    border: 1.5px solid var(--h-gold); border-radius: 6px;
    transform: rotate(-1.5deg);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.35);
    opacity: 0;
    animation: stamp-in 0.6s var(--ease-expo) 1.0s both;
    backdrop-filter: blur(6px);
  }
  .ph-figure-wrap:hover .ph-stamp { transform: rotate(0deg) scale(1.03); }
  @keyframes stamp-in { from { opacity: 0; transform: rotate(-3deg) scale(0.9); } to { opacity: 1; transform: rotate(-1.5deg) scale(1); } }
  .stamp-prefix { font-family: var(--font-display); font-size: 0.55rem; font-weight: 700; letter-spacing: 0.18em; color: var(--h-gold); }
  .stamp-num { font-family: var(--font-display); font-size: 0.85rem; font-weight: 800; letter-spacing: 0.06em; color: var(--h-cream); line-height: 1.1; }

  /* Glow + shadow behind figure */
  .ph-figure-glow { position: absolute; inset: -15%; z-index: -1; pointer-events: none; background: radial-gradient(circle at 50% 45%, rgba(201, 168, 76, 0.10) 0%, transparent 60%); animation: glow-breathe 6s ease-in-out infinite; }
  @keyframes glow-breathe { 0%, 100% { opacity: 0.55; transform: scale(1); } 50% { opacity: 1; transform: scale(1.06); } }
  .ph-figure-shadow { position: absolute; bottom: -14px; left: 10%; right: 10%; height: 28px; z-index: -1; pointer-events: none; background: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.55) 0%, transparent 70%); filter: blur(16px); }

  /* Caption */
  .ph-caption {
    display: flex; align-items: center; gap: 0.75rem;
    font-family: var(--font-display); font-size: 0.55rem; font-weight: 700;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: rgba(240, 237, 232, 0.4);
    flex: 0 0 auto;
    opacity: 0; animation: fadeInUp 0.8s ease 1.3s both;
  }
  .caption-line { flex: 1; height: 1px; background: linear-gradient(90deg, rgba(255, 255, 255, 0.12), transparent); }
  .caption-text { white-space: nowrap; }

  /* ============================
     RIGHT — EDITORIAL LOCKUP
     ============================ */
  .ph-text {
    position: relative;
    display: flex; flex-direction: column; align-items: flex-start;
    justify-content: center;
    gap: 0.85rem;
    min-height: 0;
    min-width: 0;
  }
  .lockup-rule {
    position: absolute; left: -1.1rem; top: 0.4rem; bottom: 0.4rem; width: 2px;
    background: linear-gradient(to bottom, transparent, var(--h-gold) 20%, var(--h-orange) 80%, transparent);
    opacity: 0.5; border-radius: 2px;
    animation: fadeInUp 0.8s ease 0.35s both;
  }

  /* Eyebrow */
  .ph-eyebrow { display: flex; align-items: center; gap: 0.85rem; opacity: 0; animation: fadeInUp 0.8s ease 0.45s both; }
  .eyebrow-line { width: 36px; height: 1px; background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.15) 50%, transparent); }

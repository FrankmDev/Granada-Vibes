---
/**
 * CofradiaDetailContent — wraps DetailContent with ss-* global CSS classes
 * for Semana Santa cofradía detail pages.
 */
import DetailContent from '@components/shared/DetailContent.astro';
---

<DetailContent>
  <slot />
</DetailContent>

<style is:global>
  /* ============================================
     SEMANA SANTA — cofradía detail page styles
     ss-* prefix, cream editorial palette
     Enhanced with more animations and spacing
     ============================================ */

  /* Block spacing — add gap between blocks */
  .det-main {
    gap: 3rem;
  }

  /* Enhanced paso cards with staggered animations */
  .ss-pasos-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ss-paso-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.5rem 2rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--s-border-s);
    align-items: start;
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .ss-paso-card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .ss-paso-card:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .ss-paso-card:first-child {
    padding-top: 0.5rem;
  }

  .ss-paso-tipo {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 1rem;
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border-radius: 2px;
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 0.15rem;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .ss-paso-tipo.is-misterio,
  .ss-paso-tipo.is-palio {
    background: rgba(201, 168, 76, 0.12);
    color: var(--s-gold);
    border: 1px solid rgba(201, 168, 76, 0.3);
  }

  .ss-paso-tipo.is-misterio:hover,
  .ss-paso-tipo.is-palio:hover {
    background: rgba(201, 168, 76, 0.2);
    border-color: rgba(201, 168, 76, 0.5);
    transform: translateX(3px);
  }

  .ss-paso-tipo.is-cristo {
    background: rgba(232, 98, 42, 0.10);
    color: var(--s-orange);
    border: 1px solid rgba(232, 98, 42, 0.25);
  }

  .ss-paso-tipo.is-cristo:hover {
    background: rgba(232, 98, 42, 0.18);
    border-color: rgba(232, 98, 42, 0.45);
    transform: translateX(3px);
  }

  .ss-paso-nombre {
    font-family: var(--font-body);
    font-size: 1.15rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    color: var(--s-ink);
    line-height: 1.3;
    margin-bottom: 0.5rem;
    transition: color 0.3s ease;
  }

  .ss-paso-card:hover .ss-paso-nombre {
    color: var(--s-gold);
  }

  .ss-paso-desc {
    font-family: var(--font-display);
    font-size: 0.92rem;
    line-height: 1.8;
    color: var(--s-ink-2);
  }

  /* Enhanced horario table with row animations */
  .ss-horario-table {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--s-border-s);
    border-radius: 8px;
    overflow: hidden;
  }

  .ss-horario-row {
    display: contents;
  }

  .ss-horario-row > * {
    padding: 1rem 1.5rem;
    background: var(--s-bg);
    transition: all 0.3s ease;
  }

  .ss-horario-row:hover > * {
    background: var(--s-bg-hi);
  }

  .ss-horario-key {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--s-ink-2);
  }

  .ss-horario-val {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 400;
    color: var(--s-ink);
    letter-spacing: 0.02em;
    text-align: right;
  }

  /* Highlighted rows (salida, tribunaOficial, encierro) */
  .ss-horario-row.is-highlight > * {
    background: var(--s-bg-hi);
  }

  .ss-horario-row.is-highlight .ss-horario-key {
    font-weight: 700;
    color: var(--s-ink);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .ss-horario-row.is-highlight .ss-horario-val {
    font-family: var(--font-body);
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--s-gold);
    position: relative;
  }

  .ss-horario-row.is-highlight .ss-horario-val::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 60%;
    background: var(--s-gold);
    border-radius: 2px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ss-horario-row.is-highlight:hover .ss-horario-val::before {
    opacity: 1;
  }

  /* Itinerario enhanced */
  .ss-itinerario-text {
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 2;
    color: var(--s-ink-2);
    max-width: 70ch;
    position: relative;
    padding-left: 1.5rem;
  }

  .ss-itinerario-text::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, var(--s-gold), var(--s-orange));
    border-radius: 2px;
  }

  /* Música enhanced with hover effects */
  .ss-musica-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--s-border-s);
    border-radius: 8px;
    overflow: hidden;
  }

  .ss-musica-item {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 1.5rem;
    padding: 1.25rem 1.5rem;
    background: var(--s-bg);
    align-items: start;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
  }

  .ss-musica-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 0;
    background: linear-gradient(90deg, rgba(201, 168, 76, 0.08), transparent);
    transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .ss-musica-item:hover::before {
    width: 100%;
  }

  .ss-musica-item:hover {
    transform: translateX(4px);
  }

  .ss-musica-role {
    font-family: var(--font-display);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--s-ink-3);
    padding-top: 0.2rem;
    transition: color 0.3s ease;
  }

  .ss-musica-item:hover .ss-musica-role {
    color: var(--s-gold);
  }

  .ss-musica-banda {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    color: var(--s-ink);
    line-height: 1.5;
  }

  /* Curiosidades callout enhanced */
  .ss-curiosidades-block {
    margin-top: 2rem;
    padding: 1.5rem 2rem;
    background: linear-gradient(135deg, rgba(232, 98, 42, 0.05), rgba(232, 98, 42, 0.02));
    border-left: 4px solid var(--s-orange);
    border-radius: 0 8px 8px 0;
    position: relative;
    overflow: hidden;
    animation: ss-fadeSlideIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .ss-curiosidades-block::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 150px;
    height: 100%;
    background: radial-gradient(ellipse at top right, rgba(232, 98, 42, 0.08), transparent);
    pointer-events: none;
  }

  .ss-curiosidades-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--s-orange);
    margin-bottom: 0.75rem;
    padding: 0.3rem 0.8rem;
    background: rgba(232, 98, 42, 0.1);
    border-radius: 20px;
  }

  .ss-curiosidades-text {
    font-family: var(--font-display);
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--s-ink-2);
  }

  @keyframes ss-fadeSlideIn {
    from {
      opacity: 0;
      transform: translateX(-20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Animated background pattern for blocks */
  .det-block::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, rgba(201, 168, 76, 0.03), transparent 70%);
    opacity: 0;
    transition: opacity 0.6s ease;
    pointer-events: none;
    z-index: 0;
  }

  .det-block:hover::after {
    opacity: 1;
  }

  .det-block > * {
    position: relative;
    z-index: 1;
  }

  /* Enhanced hover corners */
  .hc {
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .det-block:hover .hc {
    border-color: rgba(201, 168, 76, 0.6);
  }

  .det-block:hover .hc.tl,
  .det-block:hover .hc.tr {
    top: 0.75rem;
  }

  .det-block:hover .hc.bl,
  .det-block:hover .hc.br {
    bottom: 0.75rem;
  }

  .det-block:hover .hc.tl,
  .det-block:hover .hc.bl {
    left: 0.75rem;
  }

  .det-block:hover .hc.tr,
  .det-block:hover .hc.br {
    right: 0.75rem;
  }

  /* Block number animation */
  .det-block-num {
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .det-block:hover .det-block-num {
    color: var(--s-gold);
    transform: scale(1.1);
  }

  /* Staggered animation for paso cards */
  .ss-paso-card:nth-child(1) { transition-delay: 0s; }
  .ss-paso-card:nth-child(2) { transition-delay: 0.1s; }
  .ss-paso-card:nth-child(3) { transition-delay: 0.2s; }

  /* Animated underline for block titles */
  .det-block-title {
    position: relative;
    display: inline-block;
  }

  .det-block-title::after {
    content: '';
    position: absolute;
    bottom: -0.5rem;
    left: 0;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--s-gold), var(--s-orange));
    transition: width 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .det-block:hover .det-block-title::after {
    width: 60px;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .ss-horario-table {
      grid-template-columns: 1fr;
    }

    .ss-horario-key {
      padding-bottom: 0.25rem;
    }

    .ss-horario-val {
      text-align: left;
      padding-top: 0.25rem;
      padding-bottom: 1rem;
    }

    .ss-paso-card {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .ss-musica-item {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }

    .det-main {
      gap: 2rem;
    }
  }

  @media (max-width: 480px) {
    .ss-curiosidades-block {
      padding: 1.25rem 1.5rem;
    }
  }
</style>

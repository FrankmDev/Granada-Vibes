---
/**
 * CofradiaMainBlocks — main column content blocks for cofradía detail page.
 * Blocks 01–05: descripción, pasos, horario, itinerario, música.
 */
import type { CofradiaWithDia } from '@data/semana-santa/index.js';

interface Props {
  cofradia: CofradiaWithDia;
}

const { cofradia } = Astro.props;

// Horario key → Spanish label mapping
const HORARIO_LABELS: Record<string, string> = {
  salida: 'Salida',
  salidaCasaHermandad: 'Salida (Casa Hermandad)',
  plazaIsabelCatolica: 'Plaza Isabel la Católica',
  plazaSJuanCruz: 'Plaza S. Juan de la Cruz',
  inicioCarreraOficial: 'Inicio Carrera Oficial',
  tribunaOficial: 'Tribuna Oficial',
  puertaCatedral: 'Puerta Catedral',
  salidaCatedral: 'Salida Catedral',
  salidaEncarnacion: 'Salida Encarnación',
  encierro: 'Encierro',
  mulhacen: 'Mulhacén',
  elvira: 'Elvira',
  jesusYMaria: 'Jesús y María',
  sanJoseBaja: 'San José Baja',
  puenteRomano: 'Puente Romano',
  plazaHumilladero: 'Plaza del Humilladero',
  plazaTrinidad: 'Plaza de la Trinidad',
  plazaNueva: 'Plaza Nueva',
  plazaUniversidad: 'Plaza Universidad',
  plazaMariana: 'Plaza Mariana Pineda',
  plazaFortuny: 'Plaza Fortuny',
  plazaSantaAna: 'Plaza Santa Ana',
  plazaCampos: 'Plaza de los Campos',
  cuestaAixa: 'Cuesta de Aixa',
  sanAnton: 'San Antón',
  sanAnton2: 'San Antón',
  recogidas: 'Recogidas',
  aceraDarro: 'Acera del Darro',
  corralCarbon: 'Corral del Carbón',
  enriquetaLozano: 'Enriqueta Lozano',
  anchaVirgen: 'Ancha de la Virgen',
  pavaneras: 'Pavaneras',
  varela: 'Varela',
  santiago: 'Santiago',
  campoPrincipe: 'Campo del Príncipe',
  molinos: 'Molinos',
  pManuelGongora: 'P. Manuel de Góngora',
  profTiernoGalvan: 'Prof. Tierno Galván',
  pesoHarina: 'Peso de la Harina',
  sanJeronimo: 'San Jerónimo',
  santaEscolastica: 'Santa Escolástica',
  granVia: 'Gran Vía',
  grifosSanJose: 'Grifos San José',
  grifosSanJoseVuelta: 'Grifos San José (vuelta)',
  arcoElvira: 'Arco de Elvira',
  plazaCristóbal: 'Plaza San Cristóbal',
  puertaJusticia: 'Puerta de la Justicia',
  puenteRomanoVuelta: 'Puente Romano (vuelta)',
  sanMatias: 'San Matías',
  salidaCasaHermandad2: 'Salida (Casa Hermandad)',
  basilicaSJuanDios: 'Basílica San Juan de Dios',
  malaga: 'Málaga',
  colcha: 'Colcha',
  alhondiga: 'Alhóndiga',
};

const HIGHLIGHT_KEYS = new Set(['salida', 'salidaCasaHermandad', 'tribunaOficial', 'encierro']);

const horarioEntries = Object.entries(cofradia.horario as Record<string, string>);

const tipoClass = (tipo: string) => {
  if (tipo === 'misterio') return 'is-misterio';
  if (tipo === 'palio') return 'is-palio';
  if (tipo === 'cristo') return 'is-cristo';
  return 'is-misterio';
};

const tipoLabel = (tipo: string) => {
  if (tipo === 'misterio') return 'Misterio';
  if (tipo === 'palio') return 'Palio';
  if (tipo === 'cristo') return 'Cristo';
  return tipo;
};

const horarioLabel = (key: string) =>
  HORARIO_LABELS[key] ??
  key.replace(/([A-Z])/g, ' $1').replace(/^./, (s) => s.toUpperCase());

const mainDesc =
  cofradia.curiosidades ??
  cofradia.pasos.map((p: { descripcion?: string }) => p.descripcion ?? '').join(' ');

const musica = cofradia.musica as { cristo?: string | null; virgen?: string | null } | undefined;
const hasCristo = musica?.cristo && musica.cristo !== 'Silente';
const hasVirgen = musica?.virgen;
const hasMusica = hasCristo || hasVirgen || (musica?.cristo === 'Silente');
---

<!-- Block 01 — Sobre la cofradía -->
<article class="det-block det-block-premium ss-block-01" data-reveal style="--block-delay: 0.1s">
  <header class="det-block-head">
    <span class="det-block-num">01</span>
    <div class="det-block-divider"></div>
    <span class="det-block-eyebrow">[ Sobre la cofradía ]</span>
  </header>
  <h2 class="det-block-title">{cofradia.nombreOficial}</h2>
  <p class="det-lead">{mainDesc}</p>
  {cofradia.curiosidades && (
    <div class="ss-curiosidades-block">
      <span class="ss-curiosidades-label">
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        Curiosidad
      </span>
      <p class="ss-curiosidades-text">{cofradia.curiosidades}</p>
    </div>
  )}
  <div class="det-block-footer">
    <span class="det-block-accent-line"></span>
  </div>
  <div class="det-hover-corners" aria-hidden="true">
    <span class="hc tl"></span><span class="hc tr"></span>
    <span class="hc bl"></span><span class="hc br"></span>
  </div>
</article>

<!-- Block 02 — Los pasos -->
<article class="det-block det-block-premium ss-block-02" data-reveal style="--block-delay: 0.2s">
  <header class="det-block-head">
    <span class="det-block-num">02</span>
    <div class="det-block-divider"></div>
    <span class="det-block-eyebrow">[ Los pasos ]</span>
  </header>
  <h2 class="det-block-title">Imágenes procesionales</h2>
  <div class="ss-pasos-list">
    {cofradia.pasos.map((paso: { nombre: string; tipo: string; descripcion?: string }) => (
      <div class="ss-paso-card" data-reveal-inner>
        <span class:list={['ss-paso-tipo', tipoClass(paso.tipo)]}>
          {tipoLabel(paso.tipo)}
        </span>
        <div>
          <p class="ss-paso-nombre">{paso.nombre}</p>
          {paso.descripcion && <p class="ss-paso-desc">{paso.descripcion}</p>}
        </div>
      </div>
    ))}
  </div>
  <div class="det-block-footer">
    <span class="det-block-accent-line"></span>
  </div>
  <div class="det-hover-corners" aria-hidden="true">
    <span class="hc tl"></span><span class="hc tr"></span>
    <span class="hc bl"></span><span class="hc br"></span>
  </div>
</article>

<!-- Block 03 — Horario -->
<article class="det-block det-block-premium ss-block-03" data-reveal style="--block-delay: 0.3s">
  <header class="det-block-head">
    <span class="det-block-num">03</span>
    <div class="det-block-divider"></div>
    <span class="det-block-eyebrow">[ Horario ]</span>
  </header>
  <h2 class="det-block-title">Tiempos de paso</h2>
  <div class="ss-horario-table" role="table" aria-label="Horario de la cofradía">
    {horarioEntries.map(([key, val]) => (
      <div class:list={['ss-horario-row', HIGHLIGHT_KEYS.has(key) && 'is-highlight']} role="row">
        <span class="ss-horario-key" role="rowheader">{horarioLabel(key)}</span>
        <span class="ss-horario-val" role="cell">{val}</span>
      </div>
    ))}
  </div>
  <div class="det-block-footer">
    <span class="det-block-accent-line"></span>
  </div>
  <div class="det-hover-corners" aria-hidden="true">
    <span class="hc tl"></span><span class="hc tr"></span>
    <span class="hc bl"></span><span class="hc br"></span>
  </div>
</article>

<!-- Block 04 — Itinerario -->
<article class="det-block det-block-premium ss-block-04" data-reveal style="--block-delay: 0.4s">
  <header class="det-block-head">
    <span class="det-block-num">04</span>
    <div class="det-block-divider"></div>
    <span class="det-block-eyebrow">[ Itinerario ]</span>
  </header>
  <h2 class="det-block-title">Recorrido procesional</h2>
  <p class="ss-itinerario-text">{cofradia.itinerario}</p>
  <div class="det-block-footer">
    <span class="det-block-accent-line"></span>
  </div>
  <div class="det-hover-corners" aria-hidden="true">
    <span class="hc tl"></span><span class="hc tr"></span>
    <span class="hc bl"></span><span class="hc br"></span>
  </div>
</article>

<!-- Block 05 — Música (conditional) -->
{hasMusica && (
  <article class="det-block det-block-premium ss-block-05" data-reveal style="--block-delay: 0.5s">
    <header class="det-block-head">
      <span class="det-block-num">05</span>
      <div class="det-block-divider"></div>
      <span class="det-block-eyebrow">[ Música ]</span>
    </header>
    <h2 class="det-block-title">Agrupaciones musicales</h2>
    <div class="ss-musica-list">
      {musica?.cristo && (
        <div class="ss-musica-item" data-reveal-inner>
          <span class="ss-musica-role">Cristo</span>
          <span class="ss-musica-banda">{musica.cristo}</span>
        </div>
      )}
      {musica?.virgen && (
        <div class="ss-musica-item" data-reveal-inner>
          <span class="ss-musica-role">Virgen</span>
          <span class="ss-musica-banda">{musica.virgen}</span>
        </div>
      )}
    </div>
    <div class="det-block-footer">
      <span class="det-block-accent-line"></span>
    </div>
    <div class="det-hover-corners" aria-hidden="true">
      <span class="hc tl"></span><span class="hc tr"></span>
      <span class="hc bl"></span><span class="hc br"></span>
    </div>
  </article>
)}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const io = new IntersectionObserver(
      (entries) => entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          
          // Trigger inner animations for paso cards
          if (e.target.classList.contains('ss-block-02')) {
            e.target.querySelectorAll('.ss-paso-card').forEach((card, i) => {
              setTimeout(() => card.classList.add('is-visible'), 200 + (i * 150));
            });
          }
          
          // Trigger inner animations for musica items
          if (e.target.classList.contains('ss-block-05')) {
            e.target.querySelectorAll('.ss-musica-item').forEach((item, i) => {
              setTimeout(() => item.classList.add('is-visible'), 200 + (i * 150));
            });
          }
          
          io.unobserve(e.target);
        }
      }),
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );
    document.querySelectorAll('[data-reveal]').forEach(el => io.observe(el));
  });
</script>

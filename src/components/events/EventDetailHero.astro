  .ev-ghost-label { position: absolute; bottom: -1.2rem; right: -1.5rem; z-index: -2; pointer-events: none; font-family: var(--font-body); font-size: clamp(4rem, 10vw, 7rem); font-weight: 300; color: var(--s-ink); opacity: 0.025; letter-spacing: -0.03em; line-height: 1; user-select: none; white-space: nowrap; }

  /* Neighborhood floating tag */
  .ev-nb-tag {
    position: absolute; bottom: -0.8rem; left: -0.5rem; z-index: 8;
    display: inline-flex; align-items: center; gap: 0.45rem;
    padding: 0.45rem 1rem;
    font-family: var(--font-display); font-size: 0.6rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--s-ink-2);
    background: rgba(255,255,255,0.75); backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.8); border-radius: 100px;
    box-shadow: 0 4px 14px rgba(26,22,25,0.08);

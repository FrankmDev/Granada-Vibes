</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const hero = document.querySelector('[data-ev-hero]') as HTMLElement;
    const imgWrap = hero?.querySelector('[data-ev-img]') as HTMLElement;
    const stage = hero?.querySelector('[data-ev-stage]') as HTMLElement;
    if (!hero) return;

    // 3D tilt on mouse move (desktop)
    if (window.matchMedia('(pointer: fine)').matches) {
      hero.addEventListener('mousemove', (e) => {
        const { clientX, clientY } = e;
        const { innerWidth, innerHeight } = window;
        const x = (clientX / innerWidth - 0.5);
        const y = (clientY / innerHeight - 0.5);

        requestAnimationFrame(() => {
          if (imgWrap) {
            imgWrap.style.transform = `translate(${x * -12}px, ${y * -10}px) rotateY(${x * 5}deg) rotateX(${-y * 4}deg)`;
          }
          if (stage) {
            stage.style.setProperty('--parallax-x', `${x * 8}px`);
            stage.style.setProperty('--parallax-y', `${y * 6}px`);
          }
        });
      });

      hero.addEventListener('mouseleave', () => {
        requestAnimationFrame(() => {
          if (imgWrap) {
            imgWrap.style.transform = 'translate(0, 0) rotateY(0deg) rotateX(0deg)';
          }
        });
      });
    }

    // Mouse glow on CTA
    document.querySelectorAll('.ev-cta').forEach((btn) => {
      btn.addEventListener('mousemove', (e) => {
        const rect = (btn as HTMLElement).getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        (btn as HTMLElement).style.setProperty('--mouse-x', `${x}%`);
        (btn as HTMLElement).style.setProperty('--mouse-y', `${y}%`);
      });
    });
  });
</script>

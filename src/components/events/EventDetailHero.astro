  }
  .nb-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--s-gold); box-shadow: 0 0 6px rgba(201,168,76,0.5); }

  /* ---- BOTTOM BAR ---- */
  .ev-bottom-bar { position: relative; z-index: 10; display: flex; align-items: center; gap: 1.25rem; width: 100%; max-width: 600px; margin: 0 auto; padding: 0 clamp(1.5rem, 5vw, 3rem) 2rem; opacity: 0; animation: fadeInUp 0.8s ease 1.4s both; }
  .bar-line { flex: 1; height: 1px; background: linear-gradient(90deg, transparent, var(--s-border), transparent); }
  .bar-content { display: flex; align-items: center; gap: 0.75rem; white-space: nowrap; }
  .bar-item { font-family: var(--font-display); font-size: 0.58rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--s-ink-3); }
  .bar-diamond { opacity: 0.5; display: flex; align-items: center; }

  /* ---- SCROLL HINT ---- */
  .scroll-hint { position: absolute; bottom: 1.25rem; left: 50%; transform: translateX(-50%); z-index: 10; display: flex; flex-direction: column; align-items: center; gap: 0.4rem; opacity: 0; animation: fadeInUp 0.8s ease 1.6s both; }
  .scroll-line { width: 1px; height: 28px; background: linear-gradient(to bottom, var(--s-border), transparent); animation: scroll-pulse 2s ease-in-out infinite; }
  .scroll-text { font-family: var(--font-display); font-size: 0.5rem; font-weight: 700; letter-spacing: 0.25em; text-transform: uppercase; color: var(--s-ink-3); }
  @keyframes scroll-pulse { 0%,100% { opacity: 0.4; transform: scaleY(1); } 50% { opacity: 0.8; transform: scaleY(1.15); } }

  /* ---- RESPONSIVE ---- */
  @media (max-width: 1024px) {

  /* Header */
  .data-sheet-header { display: flex; align-items: center; gap: 0.7rem; margin-bottom: 0.85rem; }
  .dsh-line { flex: 1; height: 1px; background: linear-gradient(90deg, transparent, var(--s-border) 40%, var(--s-border) 60%, transparent); }
  .dsh-label { font-family: var(--font-display); font-size: 0.52rem; font-weight: 800; letter-spacing: 0.28em; text-transform: uppercase; color: var(--s-ink-3); white-space: nowrap; }

  /* Body */
  .data-sheet-body { display: flex; align-items: stretch; gap: 0; }
  .data-cell {
    flex: 1; display: flex; flex-direction: column; align-items: center; gap: 0.3rem;
    padding: 0 0.6rem; min-width: 0; text-align: center;
  }
  .data-cell:first-child { padding-left: 0; }
  .data-cell:last-child { padding-right: 0; }
  .data-icon { width: 20px; height: 20px; color: var(--s-gold); flex-shrink: 0; opacity: 0.85; }
  .data-caption { font-family: var(--font-display); font-size: 0.52rem; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--s-ink-3); }
  .data-value { font-family: var(--font-display); font-size: clamp(0.8rem, 1vw, 0.92rem); font-weight: 700; color: var(--s-ink-2); line-height: 1.35; overflow-wrap: break-word; word-break: break-word; hyphens: auto; }
  .data-sep {
    width: 1px; align-self: stretch; min-height: 44px;
    background: linear-gradient(to bottom, transparent, var(--s-border) 25%, var(--s-border) 75%, transparent);
    flex-shrink: 0;
  }

  /* Panel corner brackets */
  .panel-bracket {
    position: absolute; width: 14px; height: 14px;
    border-color: rgba(201,168,76,0.35); border-style: solid; border-width: 0;
    transition: all 0.4s cubic-bezier(0.19, 1, 0.22, 1); pointer-events: none;
  }
  .data-sheet:hover .panel-bracket { width: 20px; height: 20px; border-color: rgba(201,168,76,0.6); }
  .panel-bracket.tl { top: 8px; left: 8px; border-top-width: 1.5px; border-left-width: 1.5px; }
  .panel-bracket.tr { top: 8px; right: 8px; border-top-width: 1.5px; border-right-width: 1.5px; }
  .panel-bracket.bl { bottom: 8px; left: 8px; border-bottom-width: 1.5px; border-left-width: 1.5px; }
  .panel-bracket.br { bottom: 8px; right: 8px; border-bottom-width: 1.5px; border-right-width: 1.5px; }

  /* Actions row */
  .ev-actions { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; opacity: 0; animation: fadeInUp 0.8s ease 1.15s both; margin-top: 0.25rem; }

  /* Ticket-style price badge */
  .ev-price-ticket {
    position: relative; display: inline-flex; align-items: center; gap: 0;

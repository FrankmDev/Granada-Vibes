  .ev-img-glow { position: absolute; inset: -18%; z-index: -1; pointer-events: none; background: radial-gradient(circle at 50% 40%, rgba(232,98,42,0.14) 0%, transparent 55%); animation: glow-breathe 5s ease-in-out infinite; }

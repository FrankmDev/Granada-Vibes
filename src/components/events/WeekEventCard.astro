---
import type { Event, Locale } from '@types';
import Badge from '@components/ui/Badge.astro';
import { formatDateShort, getTemporalProximity } from '@utils/dates';
import { icons } from '@config/ui';

interface Props {
  event: Event;
  locale: Locale;
  index: number;
}

const { event, locale, index } = Astro.props;
const proximity = getTemporalProximity(event.date);
const dateParts = formatDateShort(event.date, locale).split(' ');
const dayNumber = dateParts[0];
const monthLabel = dateParts.slice(1).join(' ');
const isFree = event.price === null;
const priceLabel = isFree ? (locale === 'es' ? 'Gratis' : 'Free') : `${event.price}€`;
const viewMoreLabel = locale === 'es' ? 'Ver más' : 'See more';
---

<a
  href={`${locale === 'en' ? '/en' : ''}/eventos/${event.slug}`}
  class="group flex-shrink-0 w-[320px] lg:w-auto snap-start scroll-animate"
>
  <div class="card-base h-full p-6">
    <div class="accent-bar"></div>

    <!-- Background number -->
    <span class="absolute top-4 right-4 font-display text-5xl font-bold text-white/[0.03]">
      {String(index + 1).padStart(2, '0')}
    </span>

    <!-- Date -->
    <div class="flex items-center gap-3 mb-5 relative">
      <span class="font-display text-3xl font-bold text-white">{dayNumber}</span>
      <div class="flex flex-col">
        <span class="text-xs font-semibold uppercase tracking-wider text-white/40">{monthLabel}</span>
      </div>
      {proximity === 'today' && (
        <Badge variant="live" size="sm" class="ml-auto">
          {locale === 'es' ? 'Hoy' : 'Today'}
        </Badge>
      )}
      {proximity === 'tomorrow' && (
        <Badge variant="primary" size="sm" class="ml-auto">
          {locale === 'es' ? 'Mañana' : 'Tomorrow'}
        </Badge>
      )}
    </div>

    <div class="accent-line-animated mb-5"></div>

    <h3 class="font-display text-lg font-semibold text-white mb-3 group-hover:text-accent transition-colors duration-300 line-clamp-2 leading-tight">
      {event.title[locale]}
    </h3>

    <p class="text-sm text-white/40 flex items-center gap-1.5 mb-4">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icons.location} />
      </svg>
      <span class="truncate">{event.venue}</span>
    </p>

    <div class="flex items-center justify-between pt-4 border-t border-white/[0.05]">
      <span class:list={['font-display font-semibold', isFree ? 'text-success' : 'text-white']}>
        {priceLabel}
      </span>
      <span class="flex items-center gap-1 text-xs font-semibold uppercase tracking-wider text-accent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
        {viewMoreLabel}
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icons.chevronRight} />
        </svg>
      </span>
    </div>

    <div class="hover-glow-overlay"></div>
  </div>
</a>

---
import type { Event, Locale } from '@types';
import Badge from '@components/ui/Badge.astro';
import { formatDateShort, getTemporalProximity } from '@utils/dates';

interface Props {
  event: Event;
  locale: Locale;
  index: number;
}

const { event, locale, index } = Astro.props;
const proximity = getTemporalProximity(event.date);
const dateParts = formatDateShort(event.date, locale).split(' ');
const dayNumber = dateParts[0];
const monthLabel = dateParts.slice(1).join(' ');
const isFree = event.price === null;
const priceLabel = isFree
  ? (locale === 'es' ? 'Gratis' : 'Free')
  : `${event.price}€`;
const viewMoreLabel = locale === 'es' ? 'Ver más' : 'See more';
---

<a
  href={`${locale === 'en' ? '/en' : ''}/eventos/${event.slug}`}
  class="group flex-shrink-0 w-[320px] lg:w-auto snap-start reveal"
>
  <div class="relative h-full bg-white border border-border/60 rounded-2xl p-6 transition-all duration-500 hover:border-accent/30 hover:-translate-y-2 hover:shadow-soft-xl overflow-hidden">
    <!-- Background number -->
    <span class="absolute top-4 right-4 font-display text-5xl font-bold text-text-primary/[0.03]">
      {String(index + 1).padStart(2, '0')}
    </span>

    <!-- Date -->
    <div class="flex items-center gap-3 mb-5 relative">
      <span class="font-display text-3xl font-bold text-text-primary">{dayNumber}</span>
      <div class="flex flex-col">
        <span class="text-xs font-semibold uppercase tracking-wider text-text-muted">
          {monthLabel}
        </span>
      </div>
      {proximity === 'today' && (
        <Badge variant="live" size="sm" class="ml-auto">
          {locale === 'es' ? 'Hoy' : 'Today'}
        </Badge>
      )}
      {proximity === 'tomorrow' && (
        <Badge variant="accent" size="sm" class="ml-auto">
          {locale === 'es' ? 'Mañana' : 'Tomorrow'}
        </Badge>
      )}
    </div>

    <!-- Animated divider -->
    <div class="w-12 h-[2px] bg-gradient-to-r from-accent to-coral mb-5 transition-all duration-300 group-hover:w-20"></div>

    <!-- Title -->
    <h3 class="font-display text-lg font-semibold text-text-primary mb-3 group-hover:text-accent transition-colors duration-300 line-clamp-2 leading-tight">
      {event.title[locale]}
    </h3>

    <!-- Venue -->
    <p class="text-sm text-text-muted flex items-center gap-1.5 mb-4">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
      </svg>
      <span class="truncate">{event.venue}</span>
    </p>

    <!-- Price + CTA -->
    <div class="flex items-center justify-between pt-4 border-t border-border/40">
      <span class:list={['font-display font-semibold', isFree ? 'text-sage' : 'text-text-primary']}>
        {priceLabel}
      </span>
      <span class="flex items-center gap-1 text-xs font-semibold uppercase tracking-wider text-accent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
        {viewMoreLabel}
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </span>
    </div>
  </div>
</a>

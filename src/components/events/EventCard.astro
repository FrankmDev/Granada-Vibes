---
import type { Event, Locale } from '@types';
import { formatDateShort, formatTime, getTemporalProximity } from '@utils/dates';
import { truncateTitle } from '@utils/strings';
import { eventCategoryStyles, icons } from '@config/ui';
import { getEventDetailUrl } from '@utils/routes';
import OptimizedImage from '@components/ui/OptimizedImage.astro';

interface Props {
  event: Event;
  locale: Locale;
  t: (key: string, vars?: Record<string, string | number>) => string;
  featured?: boolean;
}

const { event, locale, t, featured = false } = Astro.props;
const href = getEventDetailUrl(event.slug, locale);
const temporalProximity = getTemporalProximity(event.date);
const catStyle = eventCategoryStyles[event.category] ?? eventCategoryStyles.other;
const eventImage = event.imageUrl ?? event.image;
const catColor = catStyle.colorVar;
---

<article class:list={['group relative', { 'lg:col-span-2': featured }]}>
  <a href={href} class="block h-full">
    <div class:list={['card-base', event.featured && 'is-featured']}>
      <div class="accent-bar"></div>

      <!-- Image -->
      <div class:list={['relative overflow-hidden', featured ? 'aspect-[21/10]' : 'aspect-[16/10]']}>
        <div class="event-card__fallback" style={`--cat-color: ${catColor}`}></div>
        {eventImage && (
          <OptimizedImage
            src={eventImage}
            alt={event.title[locale]}
            class="absolute inset-0 transition-transform duration-700 group-hover:scale-110"
            loading="lazy"
            decoding="async"
          />
        )}

        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>

        {event.featured && (
          <div class="absolute top-4 left-4 z-10">
            <span class="badge badge-accent">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                <path d={icons.star} />
              </svg>
              {t('events.featured')}
            </span>
          </div>
        )}

        {temporalProximity === 'today' && (
          <div class="absolute top-4 right-4 z-10">
            <span class="badge badge-accent animate-pulse">
              <span class="event-card__live-dot"></span>
              HOY
            </span>
          </div>
        )}
        {temporalProximity === 'tomorrow' && (
          <div class="absolute top-4 right-4 z-10">
            <span class="badge badge-secondary">
              {t('events.tomorrow')}
            </span>
          </div>
        )}

        <div class="absolute bottom-4 left-4 z-10">
          <span class="badge badge-glass event-card__cat-badge" style={`--cat-color: ${catColor}`}>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={catStyle.icon} />
            </svg>
            {t(`categories.${event.category}`)}
          </span>
        </div>

        <div class="absolute bottom-4 right-4 z-10">
          <span class:list={['badge', event.price === null ? 'badge-success' : 'badge-glass']}>
            {event.price === null ? t('detail.free').toUpperCase() : `${event.price}€`}
          </span>
        </div>
      </div>

      <!-- Content -->
      <div class="p-6">
        <div class="flex items-center gap-4 mb-4">
          <div class="event-card__date-icon" style={`--cat-color: ${catColor}`}>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icons.calendar} />
            </svg>
          </div>
          <span class="font-semibold text-sm" style={`color: ${catColor}`}>
            {formatDateShort(event.date, locale)}
          </span>
          <span class="w-1.5 h-1.5 rounded-full bg-white/30"></span>
          <div class="flex items-center gap-2 text-white/50">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icons.clock} />
            </svg>
            <span class="text-sm">{formatTime(event.time, locale)}</span>
          </div>
        </div>

        <div class="accent-line-animated mb-5"></div>

        <h3 class:list={[
          'font-bold text-white mb-3 transition-colors duration-300 line-clamp-2 group-hover:text-accent',
          featured ? 'text-xl lg:text-2xl' : 'text-lg'
        ]}>
          {truncateTitle(event.title[locale])}
        </h3>

        <p class="text-sm text-white/50 line-clamp-2 mb-6 leading-relaxed">
          {event.description[locale]}
        </p>

        <div class="flex items-center gap-4 pt-5 border-t border-white/[0.05]">
          <div class="event-card__location-icon" style={`--cat-color: ${catColor}`}>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icons.location} />
            </svg>
          </div>
          <div class="min-w-0 flex-1">
            <span class="text-sm text-white font-medium truncate block group-hover:text-accent transition-colors">
              {event.venue}
            </span>
            <span class="text-xs text-white/40">{t(`neighborhoods.${event.neighborhood}`)}</span>
          </div>
          <div class="arrow-btn">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icons.chevronRight} />
            </svg>
          </div>
        </div>
      </div>

      <div class="hover-glow-overlay"></div>
    </div>
  </a>
</article>

<style>
  .event-card__fallback {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 1px 1px, white 1px, transparent 0),
      linear-gradient(135deg, color-mix(in srgb, var(--cat-color) 20%, transparent), var(--color-bg));
    background-size: 20px 20px, 100% 100%;
    opacity: 0.6;
  }

  .event-card__cat-badge {
    background: color-mix(in srgb, var(--cat-color) 15%, transparent);
    color: var(--cat-color);
    border-color: color-mix(in srgb, var(--cat-color) 30%, transparent);
  }

  .event-card__live-dot {
    width: 0.5rem;
    height: 0.5rem;
    background: white;
    border-radius: 50%;
    box-shadow: 0 0 10px rgba(255, 255, 255, 0.8);
  }

  .event-card__date-icon {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--cat-color) 10%, transparent);
    color: var(--cat-color);
  }

  .event-card__location-icon {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: color-mix(in srgb, var(--cat-color) 10%, transparent);
    color: var(--cat-color);
    transition: background var(--duration-normal);
  }

  .group:hover .event-card__location-icon {
    background: color-mix(in srgb, var(--cat-color) 20%, transparent);
  }

  .card-base.is-featured {
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-accent) 20%, transparent);
  }

  .group:hover .card-base.is-featured {
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-accent) 40%, transparent);
  }

  .badge-success {
    background: var(--color-success);
    color: white;
  }
</style>

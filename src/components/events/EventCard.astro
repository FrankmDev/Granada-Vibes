---
import type { Event } from '@types';
import { formatDateShort, formatTime, getTemporalProximity } from '@utils/dates';
import Badge from '@components/ui/Badge.astro';

interface Props {
  event: Event;
  locale: 'es' | 'en';
  t: (key: string, vars?: Record<string, string | number>) => string;
  featured?: boolean;
}

const { event, locale, t, featured = false } = Astro.props;
const href = locale === 'es' ? `/eventos/${event.slug}` : `/en/events/${event.slug}`;

const temporalProximity = getTemporalProximity(event.date);
---

<article class:list={['group', { 'lg:col-span-2': featured }]}>
  <a href={href} class="block h-full">
    <div class:list={[
      'relative h-full bg-base-card/80 backdrop-blur-sm border border-edge rounded-2xl overflow-hidden transition-all duration-400 hover:-translate-y-1.5',
      event.featured 
        ? 'hover:border-amber/30 hover:shadow-[0_12px_40px_rgba(232,157,58,0.08)]' 
        : 'hover:border-terra/25 hover:shadow-[0_12px_40px_rgba(232,90,60,0.08)]'
    ]}>
      
      {/* Image Area - Softer gradient */}
      <div class:list={['relative overflow-hidden', featured ? 'aspect-[21/9]' : 'aspect-[16/10]']}>
        {/* Gradient background */}
        <div class="absolute inset-0 bg-gradient-to-br from-base-elevated to-base-card"></div>
        
        {/* Subtle gradient overlays */}
        <div class="absolute inset-0 bg-gradient-to-t from-base-card via-base-card/30 to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/[0.02] to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1200"></div>
        
        {/* Geometric shapes */}
        <div class="absolute top-4 right-4 w-16 h-16 border border-white/[0.05] rounded-xl rotate-6" aria-hidden="true"></div>
        <div class="absolute bottom-8 left-4 w-8 h-8 bg-white/[0.02] rounded-full" aria-hidden="true"></div>
        
        {/* Featured badge */}
        {event.featured && (
          <div class="absolute top-4 left-4">
            <span class="inline-flex items-center px-3 py-1.5 bg-amber/90 backdrop-blur-sm text-base text-[10px] font-bold uppercase tracking-[0.12em] rounded-full">
              {t('events.featured')}
            </span>
          </div>
        )}
        
        {/* Temporal proximity badge */}
        {temporalProximity === 'today' && (
          <div class="absolute top-4 right-4">
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-terra text-surface text-[10px] font-bold uppercase tracking-[0.12em] rounded-full animate-pulse">
              <span class="w-1.5 h-1.5 bg-surface rounded-full"></span>
              HOY
            </span>
          </div>
        )}
        {temporalProximity === 'tomorrow' && (
          <div class="absolute top-4 right-4">
            <span class="inline-flex items-center px-3 py-1.5 bg-amber/90 backdrop-blur-sm text-base text-[10px] font-bold uppercase tracking-[0.12em] rounded-full">
              MAÑANA
            </span>
          </div>
        )}
        
        {/* Category badge */}
        <div class="absolute bottom-4 left-4">
          <span class="px-3 py-1.5 text-[9px] font-bold uppercase tracking-[0.15em] bg-base/70 backdrop-blur-sm border border-white/[0.08] text-surface-secondary rounded-full">
            {t(`categories.${event.category}`)}
          </span>
        </div>
        
        {/* Price badge */}
        <div class="absolute bottom-4 right-4">
          <span class:list={[
            'px-3 py-1.5 font-display font-semibold text-xs rounded-full backdrop-blur-sm border',
            event.price === null 
              ? 'bg-mint/20 text-mint border-mint/20' 
              : 'bg-base/70 text-surface-secondary border-white/[0.08]'
          ]}>
            {event.price === null ? t('events.free') : `${event.price}€`}
          </span>
        </div>
      </div>
      
      {/* Content */}
      <div class="p-5 lg:p-6">
        {/* Date and time row */}
        <div class="flex items-center gap-3 mb-3">
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-lg bg-terra/10 flex items-center justify-center">
              <svg class="w-3.5 h-3.5 text-terra" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <span class="font-display text-sm font-medium text-surface">{formatDateShort(event.date, locale)}</span>
          </div>
          <span class="w-0.5 h-0.5 rounded-full bg-surface-muted"></span>
          <div class="flex items-center gap-1 text-surface-muted text-xs">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>{formatTime(event.time, locale)}</span>
          </div>
        </div>
        
        {/* Accent line */}
        <div class="w-8 h-[1.5px] bg-gradient-to-r from-terra/60 to-amber/40 mb-3 transition-all duration-300 group-hover:w-12"></div>
        
        {/* Title */}
        <h3 class:list={[
          'font-display font-medium text-surface mb-2 group-hover:text-terra transition-colors duration-300 line-clamp-2',
          featured ? 'text-lg lg:text-xl' : 'text-base'
        ]}>
          {event.title[locale]}
        </h3>
        
        {/* Description */}
        <p class="text-xs text-surface-muted line-clamp-2 mb-3 leading-relaxed">
          {event.description[locale]}
        </p>
        
        {/* Location */}
        <div class="flex items-center gap-2.5 pt-3 border-t border-edge/50">
          <div class="w-7 h-7 rounded-lg bg-base-elevated flex items-center justify-center flex-shrink-0">
            <svg class="w-3.5 h-3.5 text-terra/70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            </svg>
          </div>
          <div class="min-w-0">
            <span class="text-xs text-surface-secondary truncate block">{event.venue}</span>
            <span class="text-[10px] text-surface-muted">{t(`neighborhoods.${event.neighborhood}`)}</span>
          </div>
        </div>
      </div>
    </div>
  </a>
</article>

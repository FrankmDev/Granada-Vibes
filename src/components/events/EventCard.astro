---
import type { Event } from '@types';
import { formatDateShort, formatTime, getTemporalProximity } from '@utils/dates';
import Badge from '@components/ui/Badge.astro';

interface Props {
  event: Event;
  locale: 'es' | 'en';
  t: (key: string, vars?: Record<string, string | number>) => string;
  featured?: boolean;
}

const { event, locale, t, featured = false } = Astro.props;
const href = locale === 'es' ? `/eventos/${event.slug}` : `/en/events/${event.slug}`;

const temporalProximity = getTemporalProximity(event.date);
---

<article class:list={['group reveal', { 'lg:col-span-2': featured }]}>
  <a href={href} class="block h-full">
    <div class:list={[
      'relative h-full bg-base-card border rounded-3xl overflow-hidden transition-all duration-500 hover:-translate-y-2',
      event.featured 
        ? 'border-amber/20 hover:border-amber/40 hover:shadow-lg hover:shadow-amber/10' 
        : 'border-edge hover:border-terra/30 hover:shadow-lg hover:shadow-terra/10'
    ]}>
      
      {/* Image Area - Dark themed */}
      <div class:list={['bg-base-elevated relative overflow-hidden', featured ? 'aspect-[21/9]' : 'aspect-[16/10]']}>
        {/* Gradient overlays */}
        <div class="absolute inset-0 bg-gradient-to-br from-terra/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700" />
        <div class="absolute inset-0 bg-gradient-to-t from-base-card via-base-card/40 to-transparent" />
        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-terra/5 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000"></div>
        
        {/* Placeholder icon */}
        <div class="absolute inset-0 flex items-center justify-center">
          <div class:list={['rounded-2xl bg-base border border-edge flex items-center justify-center group-hover:scale-110 transition-transform duration-500', featured ? 'w-24 h-24' : 'w-20 h-20']}>
            <svg class="w-10 h-10 text-surface-muted/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
        </div>
        
        {/* Featured badge */}
        {event.featured && (
          <div class="absolute top-5 left-5">
            <Badge variant="amber" size="sm">{t('events.featured')}</Badge>
          </div>
        )}
        
        {/* Temporal proximity badge */}
        {temporalProximity === 'today' && (
          <div class="absolute top-5 right-5">
            <Badge variant="live" size="md">HOY</Badge>
          </div>
        )}
        {temporalProximity === 'tomorrow' && (
          <div class="absolute top-5 right-5">
            <Badge variant="terra" size="sm">MAÑANA</Badge>
          </div>
        )}
        {temporalProximity === 'this-week' && !event.featured && (
          <div class="absolute top-5 right-5">
            <Badge variant="default" size="sm">ESTA SEMANA</Badge>
          </div>
        )}
        
        {/* Category badge */}
        <div class="absolute bottom-5 left-5">
          <span class="px-4 py-2 text-[10px] font-bold uppercase tracking-[0.12em] bg-base border border-edge text-surface rounded-full">
            {t(`categories.${event.category}`)}
          </span>
        </div>
        
        {/* Price badge */}
        <div class="absolute bottom-5 right-5">
          <span class:list={[
            'px-4 py-2 font-display font-semibold rounded-full border',
            event.price === null 
              ? 'bg-mint/10 text-mint border-mint/30' 
              : 'bg-base text-surface border-edge'
          ]}>
            {event.price === null ? t('events.free') : `${event.price}€`}
          </span>
        </div>
      </div>
      
      {/* Content */}
      <div class="p-6 lg:p-7">
        {/* Date and time row */}
        <div class="flex items-center gap-3 mb-4">
          <div class="flex items-center gap-2">
            <div class="w-9 h-9 rounded-xl bg-terra/10 flex items-center justify-center">
              <svg class="w-4 h-4 text-terra" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <span class="font-display text-sm font-semibold text-surface">{formatDateShort(event.date, locale)}</span>
          </div>
          <span class="w-1 h-1 rounded-full bg-surface-disabled"></span>
          <div class="flex items-center gap-1.5 text-surface-muted">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-sm">{formatTime(event.time, locale)}</span>
          </div>
        </div>
        
        {/* Accent line */}
        <div class="w-10 h-[2px] bg-gradient-to-r from-terra to-amber mb-4 transition-all duration-300 group-hover:w-16"></div>
        
        {/* Title */}
        <h3 class:list={[
          'font-display font-semibold text-surface mb-3 group-hover:text-terra transition-colors duration-300 line-clamp-2 leading-tight',
          featured ? 'text-xl lg:text-2xl' : 'text-lg'
        ]}>
          {event.title[locale]}
        </h3>
        
        {/* Description */}
        <p class="text-sm text-surface-secondary line-clamp-2 mb-4 leading-relaxed">
          {event.description[locale]}
        </p>
        
        {/* Location */}
        <div class="flex items-center gap-3 text-sm pt-4 border-t border-edge">
          <div class="w-9 h-9 rounded-xl bg-base-elevated flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-terra/70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div class="min-w-0">
            <span class="text-surface-secondary truncate block">{event.venue}</span>
            <span class="text-surface-muted text-xs">{t(`neighborhoods.${event.neighborhood}`)}</span>
          </div>
        </div>
      </div>
      
      {/* Hover effects */}
      <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none">
        <div class="absolute inset-0 bg-gradient-to-t from-terra/5 via-transparent to-transparent"></div>
      </div>
      
      {/* Corner accent on hover */}
      <div class="absolute top-0 right-0 w-16 h-16 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
        <div class="absolute top-4 right-4 w-2 h-2 border-t-2 border-r-2 border-terra/30 rounded-tr"></div>
      </div>
    </div>
  </a>
</article>

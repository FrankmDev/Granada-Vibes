---
/**
 * EventCard — Modern Gradient Event Cards
 * Bold colors, smooth animations, unique layout
 */
import type { Event } from '@types';
import { formatDateShort, formatTime, getTemporalProximity } from '@utils/dates';

interface Props {
  event: Event;
  locale: 'es' | 'en';
  t: (key: string, vars?: Record<string, string | number>) => string;
  featured?: boolean;
}

const { event, locale, t, featured = false } = Astro.props;
const href = locale === 'es' ? `/eventos/${event.slug}` : `/en/events/${event.slug}`;

const temporalProximity = getTemporalProximity(event.date);

const categoryColors: Record<string, { bg: string; text: string; gradient: string }> = {
  concert: { bg: 'bg-primary-light', text: 'text-primary-dark', gradient: 'from-primary to-primary-hover' },
  exhibition: { bg: 'bg-secondary-light', text: 'text-secondary', gradient: 'from-secondary to-secondary-hover' },
  festival: { bg: 'bg-purple-light', text: 'text-purple', gradient: 'from-purple to-purple-hover' },
  market: { bg: 'bg-accent-light', text: 'text-accent', gradient: 'from-accent to-accent-hover' },
  theater: { bg: 'bg-rose-light', text: 'text-rose', gradient: 'from-rose to-rose-hover' },
  workshop: { bg: 'bg-primary-light', text: 'text-primary-dark', gradient: 'from-primary to-secondary' },
  'guided-tour': { bg: 'bg-accent-light', text: 'text-accent', gradient: 'from-accent to-secondary' },
  cinema: { bg: 'bg-purple-light', text: 'text-purple', gradient: 'from-purple to-primary' },
  other: { bg: 'bg-secondary-light', text: 'text-secondary', gradient: 'from-secondary to-accent' },
};

const catConfig = categoryColors[event.category] || categoryColors.festival;
---

<article class:list={['group', { 'lg:col-span-2': featured }]}>
  <a href={href} class="block h-full">
    <div class:list={[
      'relative h-full bg-white rounded-2xl overflow-hidden transition-all duration-300 ease-out',
      'border border-edge hover:border-edge-hover',
      'hover:shadow-soft-xl hover:-translate-y-2',
      event.featured ? 'ring-2 ring-primary/20' : ''
    ]}>
      
      <!-- Image Area with gradient -->
      <div class:list={['relative overflow-hidden', featured ? 'aspect-[21/10]' : 'aspect-[16/10]']}>
        <!-- Base gradient background -->
        <div class="absolute inset-0 bg-gradient-to-br from-base-100 via-base-50 to-base"></div>
        
        <!-- Dynamic gradient overlay based on category -->
        <div class="absolute inset-0 bg-gradient-to-br opacity-60" style={`background: linear-gradient(135deg, var(--color-${event.category === 'concert' ? 'primary' : event.category === 'exhibition' ? 'secondary' : event.category === 'festival' ? 'purple' : event.category === 'market' ? 'accent' : 'primary'}-light 0%, transparent 60%)`}></div>
        
        <!-- Subtle pattern -->
        <div class="absolute inset-0 pattern-dots opacity-30"></div>
        
        <!-- Gradient overlays -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-black/10 to-transparent"></div>
        
        <!-- Decorative shapes -->
        <div class="absolute top-4 right-4 w-20 h-20 border-2 border-white/20 rounded-2xl rotate-6 transition-transform duration-500 group-hover:rotate-12 group-hover:scale-110" aria-hidden="true"></div>
        <div class="absolute bottom-6 left-4 w-8 h-8 bg-white/10 rounded-full transition-all duration-500 group-hover:scale-125" aria-hidden="true"></div>
        
        <!-- Featured badge -->
        {event.featured && (
          <div class="absolute top-4 left-4 z-10">
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white/95 backdrop-blur-sm text-primary text-[10px] font-bold uppercase tracking-wider rounded-full shadow-soft-sm">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
              {t('events.featured')}
            </span>
          </div>
        )}
        
        <!-- Temporal badge -->
        {temporalProximity === 'today' && (
          <div class="absolute top-4 right-4 z-10">
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-primary text-white text-[10px] font-bold uppercase tracking-wider rounded-full shadow-soft-sm animate-pulse">
              <span class="w-1.5 h-1.5 bg-white rounded-full"></span>
              HOY
            </span>
          </div>
        )}
        {temporalProximity === 'tomorrow' && (
          <div class="absolute top-4 right-4 z-10">
            <span class="inline-flex items-center px-3 py-1.5 bg-secondary/95 backdrop-blur-sm text-white text-[10px] font-bold uppercase tracking-wider rounded-full shadow-soft-sm">
              MAÑANA
            </span>
          </div>
        )}
        
        <!-- Category badge -->
        <div class="absolute bottom-4 left-4 z-10">
          <span class:list={[
            'px-3 py-1.5 text-[9px] font-semibold uppercase tracking-wider rounded-full backdrop-blur-sm',
            catConfig.bg,
            catConfig.text
          ]}>
            {t(`categories.${event.category}`)}
          </span>
        </div>
        
        <!-- Price badge -->
        <div class="absolute bottom-4 right-4 z-10">
          <span class:list={[
            'px-3 py-1.5 font-display font-semibold text-xs rounded-full backdrop-blur-sm',
            event.price === null 
              ? 'bg-accent/95 text-white' 
              : 'bg-white/95 text-surface'
          ]}>
            {event.price === null ? 'GRATIS' : `${event.price}€`}
          </span>
        </div>
      </div>
      
      <!-- Content -->
      <div class="p-5 lg:p-6">
        <!-- Date and time -->
        <div class="flex items-center gap-3 mb-4">
          <div class:list={['flex items-center gap-2', catConfig.text]}>
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-current/10 to-current/5 flex items-center justify-center">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <span class="font-display text-sm font-medium">{formatDateShort(event.date, locale)}</span>
          </div>
          <span class="w-1 h-1 rounded-full bg-surface-muted"></span>
          <div class="flex items-center gap-1.5 text-surface-muted text-xs">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>{formatTime(event.time, locale)}</span>
          </div>
        </div>
        
        <!-- Accent bar with animation -->
        <div class="h-1 w-12 bg-gradient-to-r from-primary to-secondary rounded-full mb-4 transition-all duration-300 group-hover:w-20"></div>
        
        <!-- Title -->
        <h3 class:list={[
          'font-display font-semibold text-surface mb-2 transition-colors duration-200 group-hover:text-primary line-clamp-2',
          featured ? 'text-xl lg:text-2xl' : 'text-base lg:text-lg'
        ]}>
          {event.title[locale]}
        </h3>
        
        <!-- Description -->
        <p class="text-sm text-surface-muted line-clamp-2 mb-4 leading-relaxed">
          {event.description[locale]}
        </p>
        
        <!-- Location -->
        <div class="flex items-center gap-3 pt-4 border-t border-edge/50">
          <div class="w-8 h-8 rounded-lg bg-base-100 flex items-center justify-center flex-shrink-0 group-hover:bg-primary/10 transition-colors duration-200">
            <svg class="w-4 h-4 text-surface-muted group-hover:text-primary transition-colors duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            </svg>
          </div>
          <div class="min-w-0 flex-1">
            <span class="text-sm text-surface-secondary truncate block font-medium">{event.venue}</span>
            <span class="text-xs text-surface-muted">{t(`neighborhoods.${event.neighborhood}`)}</span>
          </div>
          
          <!-- Arrow -->
          <div class="w-8 h-8 rounded-full bg-base-100 flex items-center justify-center flex-shrink-0 group-hover:bg-primary group-hover:shadow-glow-primary transition-all duration-200">
            <svg class="w-4 h-4 text-surface-muted group-hover:text-white group-hover:translate-x-0.5 transition-all duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </div>
      </div>
    </div>
  </a>
</article>

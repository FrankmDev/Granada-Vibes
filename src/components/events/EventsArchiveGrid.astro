---
import EventArchiveCard from '@components/events/EventArchiveCard.astro';
import type { Event, EventCategory, Locale } from '@types';
import { useTranslations } from '@i18n/utils';
import { getEventDetailUrl } from '@utils/routes';
import { getPriceStatus } from '@utils/index.js';

interface Props {
  locale: Locale;
  columns: Event[][];
  colHeights: number[][];
  categoryLabels: Record<EventCategory, string>;
}

const { locale, columns, colHeights, categoryLabels } = Astro.props;
const t = useTranslations(locale);

function eventHref(slug: string): string {
  return getEventDetailUrl(slug, locale);
}
---

<div class="masonry-wrapper" id="events-grid">
  {columns.map((colEvents, colIndex) => (
    <div class={`masonry-col col-${['left','center','right'][colIndex]}`}>
      {colEvents.map((evt, idx) => {
        const heightVh = colHeights[colIndex]![idx] ?? 65;
        const category = categoryLabels[evt.category] ?? evt.category.toUpperCase();
        const href = eventHref(evt.slug);

        return (
          <EventArchiveCard
            event={evt}
            locale={locale}
            href={href}
            categoryLabel={category}
            cardIndex={colIndex * 6 + idx}
            heightVh={heightVh}
            dataCategory={evt.category}
            dataNeighborhood={evt.neighborhood}
            dataPrice={getPriceStatus(evt) === 'free' ? 'free' : getPriceStatus(evt) === 'paid' ? 'paid' : 'tickets'}
            dataDate={evt.date}
            dataSearch={`${evt.title[locale]} ${evt.description[locale]} ${evt.venue} ${categoryLabels[evt.category] ?? evt.category}`.toLowerCase()}
            loading={idx === 0 ? 'eager' : 'lazy'}
            fetchpriority={idx === 0 ? 'high' : undefined}
            sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw"
          />
        );
      })}
    </div>
  ))}
</div>

<!-- Empty State -->
<div id="empty-state" class="empty-state hidden">
  <div class="empty-content">
    <div class="empty-icon">
      <div class="empty-icon-inner">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
    </div>
    <h3 class="empty-title">{t('filters.noResults')}</h3>
    <p class="empty-text">{t('filters.noResultsDesc')}</p>
    <button id="empty-clear-filters" class="empty-btn">
      {t('filters.clearFilters')}
    </button>
  </div>
</div>

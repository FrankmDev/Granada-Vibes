---
import type { ImageMetadata } from 'astro';
import type { BlogPost, Event, Locale, MixedRoute, Route } from '@types';
import type { VenueDirectoryEntry } from '@data/directories';
import { useTranslations } from '@i18n/utils';
import { getEventDetailUrl, getRoute } from '@utils/routes';
import { formatFullDate } from '@utils/dates';
import { getEventDisplayTitle } from '@utils/event-seo';
import {
  getRelatedEventsForPost,
  getRelatedEventsForRoute,
  getRelatedEventsForMixedRoute,
  getRelatedEventsForEvent,
  getRelatedEventsForVenue,
} from '@utils/related-content';
import CrossLinksSection from '@components/ui/CrossLinksSection.astro';

const allEventImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/events/*.{webp,jpg,jpeg,png,avif}',
  { eager: true }
);

function resolveEventImage(event: Event): string | null {
  const filename = event.imageUrl ?? event.image;
  if (!filename) return null;
  const imageName = filename.split('/').pop();
  if (!imageName) return null;
  const imageModule = allEventImages[`/src/assets/images/events/${imageName}`];
  return imageModule?.default?.src ?? null;
}

interface BaseProps {
  locale: Locale;
  title?: string;
  limit?: number;
}

interface PostContext extends BaseProps {
  type: 'post';
  post: BlogPost;
}

interface RouteContext extends BaseProps {
  type: 'route';
  route: Route;
}

interface MixedRouteContext extends BaseProps {
  type: 'mixedRoute';
  plan: MixedRoute;
}

interface EventContext extends BaseProps {
  type: 'event';
  event: Event;
}

interface VenueContext extends BaseProps {
  type: 'venue';
  venue: VenueDirectoryEntry;
  excludeEventId?: string;
}

type Props = PostContext | RouteContext | MixedRouteContext | EventContext | VenueContext;

const props = Astro.props;
const { locale, type, title: customTitle, limit = 3 } = props;
const t = useTranslations(locale);

let events: Event[] = [];

if (type === 'post') {
  events = getRelatedEventsForPost(props.post, limit);
} else if (type === 'route') {
  events = getRelatedEventsForRoute(props.route, limit);
} else if (type === 'mixedRoute') {
  events = getRelatedEventsForMixedRoute(props.plan, limit);
} else if (type === 'event') {
  events = getRelatedEventsForEvent(props.event, limit);
} else if (type === 'venue') {
  events = getRelatedEventsForVenue(props.venue, limit, props.excludeEventId);
}

const title = customTitle ?? t('detail.relatedEvents');

const links = events.map((event) => ({
  url: getEventDetailUrl(event.slug, locale),
  title: getEventDisplayTitle(event, locale),
  meta: `${formatFullDate(event.date, locale)} · ${event.venue}`,
  image: resolveEventImage(event),
}));
---

{links.length > 0 && (
  <CrossLinksSection
    title={title}
    links={links}
    viewAllHref={getRoute('events', locale)}
    viewAllLabel={t('actions.viewAll')}
  />
)}

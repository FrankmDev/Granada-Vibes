---
/**
 * TimePlanCard — Card for mixed route time plans
 */
import type { MixedRoute, Locale } from '@types';

interface Props {
  plan: MixedRoute;
  locale: Locale;
  t: (key: string, vars?: Record<string, string | number>) => string;
  index?: number;
}

const { plan, locale, t, index = 0 } = Astro.props;
const href = locale === 'es' ? `/rutas/por-tiempo/${plan.slug}` : `/en/routes/by-time/${plan.slug}`;

const totalStops = plan.days.reduce(
  (acc, day) => acc + day.blocks.reduce((bAcc, block) => bAcc + block.stops.length, 0),
  0
);

const durationConfig: Record<string, { icon: string; gradient: string; accent: string; accentBg: string; border: string }> = {
  '2h': {
    icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
    gradient: 'from-[#00CC99]/20 to-[#00CC99]/5',
    accent: 'text-[#00CC99]',
    accentBg: 'bg-[#00CC99]',
    border: 'border-[#00CC99]/30',
  },
  '6h': {
    icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
    gradient: 'from-[#FF9933]/20 to-[#FF9933]/5',
    accent: 'text-[#FF9933]',
    accentBg: 'bg-[#FF9933]',
    border: 'border-[#FF9933]/30',
  },
  '12h': {
    icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
    gradient: 'from-[#FF3366]/20 to-[#FF3366]/5',
    accent: 'text-[#FF3366]',
    accentBg: 'bg-[#FF3366]',
    border: 'border-[#FF3366]/30',
  },
  '1day': {
    icon: 'M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z',
    gradient: 'from-[#FF3366]/20 via-[#FF9933]/10 to-[#FF3366]/5',
    accent: 'text-[#FF3366]',
    accentBg: 'bg-[#FF3366]',
    border: 'border-[#FF3366]/30',
  },
  '2days': {
    icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
    gradient: 'from-[#FF9933]/20 via-[#FF3366]/10 to-[#FF9933]/5',
    accent: 'text-[#FF9933]',
    accentBg: 'bg-[#FF9933]',
    border: 'border-[#FF9933]/30',
  },
  '3days': {
    icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
    gradient: 'from-[#FF3366]/20 via-[#00CC99]/10 to-[#FF9933]/5',
    accent: 'text-[#FF3366]',
    accentBg: 'bg-[#FF3366]',
    border: 'border-[#FF3366]/30',
  },
};

const config = durationConfig[plan.duration] || durationConfig['2h'];

const stopCategoryIcons: Record<string, string> = {
  mirador: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z',
  tapas: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z',
  monumento: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
  cultura: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
  paseo: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
  compras: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z',
  naturaleza: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z',
  flamenco: 'M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3',
};

const uniqueCategories = [...new Set(
  plan.days.flatMap(d => d.blocks.flatMap(b => b.stops.map(s => s.category)))
)].slice(0, 5);
---

<article class="group h-full">
  <a href={href} class="block h-full">
    <div class:list={[
      'relative h-full bg-[#0a0a0a] rounded-[2rem] overflow-hidden',
      'border border-white/10 hover:border-[#FF3366]/30',
      'transition-all duration-500',
      'hover:shadow-2xl hover:shadow-[#FF3366]/5 hover:-translate-y-2'
    ]}>
      <!-- Header with duration badge -->
      <div class="relative h-44 bg-gradient-to-br from-[#0f0f0f] via-[#0a0a0a] to-[#050505] overflow-hidden">
        <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 20px 20px;"></div>
        <div class:list={['absolute inset-0 bg-gradient-to-br', config.gradient]}></div>

        <!-- Large duration display -->
        <div class="absolute inset-0 flex items-center justify-center">
          <span class:list={['font-display text-6xl lg:text-7xl font-bold opacity-20', config.accent]}>
            {t(`mixedRoutes.durations.${plan.duration}`)}
          </span>
        </div>

        <!-- Duration badge -->
        <div class="absolute top-4 left-4 z-10">
          <span class:list={['inline-flex items-center gap-2 px-4 py-2 text-[11px] font-bold uppercase tracking-wider rounded-full border backdrop-blur-md', `${config.accent} bg-white/5`, config.border]}>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={config.icon} />
            </svg>
            {t(`mixedRoutes.durations.${plan.duration}`)}
          </span>
        </div>

        <!-- Stats -->
        <div class="absolute bottom-4 right-4 z-10 flex items-center gap-3">
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium bg-white/10 backdrop-blur-md rounded-lg border border-white/10 text-white/80">
            {totalStops} {t('mixedRoutes.stops')}
          </span>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium bg-white/10 backdrop-blur-md rounded-lg border border-white/10 text-white/80">
            {plan.neighborhoods.length} {t('mixedRoutes.neighborhoods')}
          </span>
        </div>
      </div>

      <!-- Content -->
      <div class="p-6">
        <!-- Category icons row -->
        <div class="flex items-center gap-2 mb-4">
          {uniqueCategories.map((cat) => (
            <span class="w-8 h-8 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center" title={t(`mixedRoutes.stopCategories.${cat}`)}>
              <svg class="w-4 h-4 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={stopCategoryIcons[cat] || stopCategoryIcons.paseo} />
              </svg>
            </span>
          ))}
        </div>

        <!-- Decorative line -->
        <div class:list={['h-0.5 w-16 rounded-full mb-5 transition-all duration-500 group-hover:w-24', config.accentBg]}></div>

        <!-- Title -->
        <h3 class="font-bold text-xl text-white mb-3 group-hover:text-[#FF3366] transition-colors duration-300 line-clamp-2">
          {plan.title[locale]}
        </h3>

        <!-- Description -->
        <p class="text-sm text-white/60 line-clamp-3 mb-6 leading-relaxed">
          {plan.description[locale]}
        </p>

        <!-- Footer -->
        <div class="flex items-center justify-between pt-5 border-t border-white/10">
          <div class="flex flex-wrap gap-2">
            {plan.neighborhoods.slice(0, 3).map((n) => (
              <span class="text-xs text-white/60 bg-white/5 px-3 py-1.5 rounded-lg font-medium border border-white/10">
                {t(`neighborhoods.${n}`)}
              </span>
            ))}
            {plan.neighborhoods.length > 3 && (
              <span class="text-xs text-white/40 px-2 py-1.5">
                +{plan.neighborhoods.length - 3}
              </span>
            )}
          </div>

          <div class="w-11 h-11 rounded-xl bg-[#FF3366]/10 border border-[#FF3366]/20 flex items-center justify-center group-hover:bg-[#FF3366] group-hover:border-transparent transition-all duration-300 shrink-0">
            <svg class="w-5 h-5 text-[#FF3366] group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </div>
      </div>

      <!-- Hover glow -->
      <div class="absolute inset-0 rounded-[2rem] opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" style="background: radial-gradient(circle at 50% 0%, rgba(255, 51, 102, 0.1) 0%, transparent 50%);"></div>
    </div>
  </a>
</article>
